                    <comboBox field="aptitudemagia"  name="aptitudemagia" align="client"	horzTextAlign="center"  fontFamily="Cinzel"	 transparent="true"  fontSize="20"   items="{'Escolha...', 'Divina', 'Clarevidência',	'Mental', 'Produção', 'Demoniaca', 'Invocação', 'Elemental', 'Espiritual'}"/>
                    <comboBox field="aptitudeaura"  name="aptitudeaura" align="client"	horzTextAlign="center"  fontFamily="Cinzel"	 transparent="true"  fontSize="20"   items="{'Escolha...', 'Reforço Fisico', 'Transmutação', 'Conjuração', 'Reforço Mental', 'Manipulação', 'Emissão'}"/>
