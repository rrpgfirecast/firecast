<?xml version="1.0" encoding="UTF-8"?>
<form name="templateVinculo_2" height="140" g="col" g-width="6" g-cnt-gutter="0">
    <rectangle name="indicador_corVinculo_2" color="#150e16" strokeSize="1" strokeColor="white" cornerType="round" xradius="5" yradius="5" g="col" g-width="12" height="140">
        <dataLink field="corVinculo_2">
            <event name="onChange">
                local cor = sheet.corVinculo_2 or "#ffffff"
                self.indicador_corVinculo_2.color = cor
            </event>
        </dataLink>
       
        <image name="imgVinculo_2" field="imagemVinculo_2" g="col" g-width="12" height="134" style="proportional" editable="true" animate="true" margins="{top=3,left=3,right=3,bottom=3}">
            
            <dataLink field="imagemVinculo_2" defaultValue="https://blob.firecast.com.br/blobs/GQNCNVTE_4313075/info.png">
                <event name="onChange">
                     if sheet == nil then return end
                        pcall(function()
                            if sheet.imagemVinculo_2 == nil then 
                                sheet.imagemVinculo_2 = "https://blob.firecast.com.br/blobs/GQNCNVTE_4313075/info.png"
                            end
                        end)
                  
                </event>
            </dataLink> 
            
            <label g="col" g-width="10"/>
            <button name="btnExcluirVinculo_2" text="✖" g="col" g-width="2" fontSize="6" height="21" margins="{top=3,right=3}"/>          

            <rectangle height="20" color="black" cornerType="round" g="col" g-width="12" strokeSize="1" strokeColor="white" xradius="5" yradius="5" margins="{top=90,right=2,left=2}">
                <edit field="nomeVinculo_2" g="col" g-width="12" transparent="true" fontSize="15" height="21" vertTextAlign="center" horzTextAlign="center" fontFamily="Wishes Script Caps Display"/>
            </rectangle>
        </image>
    </rectangle>

    <script>
        self.btnExcluirVinculo_2.onClick = function (_)
            local node = sheet
            if self.observer ~= nil then
                self.observer.enabled = false
                self.observer = nil
            end
            if node ~= nil then
                NDB.deleteNode(node)
            end
        end;
    </script> 
</form>