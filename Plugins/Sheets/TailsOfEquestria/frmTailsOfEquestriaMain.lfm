                <rectangle left="10" top="584" width="350" height="88" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(13);"/>
                <label left="24" top="594" width="320" height="20" text="CONFIANTE DEMAIS" fontColor="#A04470" fontSize="11" fontStyle="bold" hitTest="false"/>
                <label left="24" top="618" width="320" height="44" text="Assume estar pronto para qualquer desafio." wordWrap="true" fontColor="#754C60" fontSize="10" hitTest="false"/>
                <rectangle left="388" top="584" width="350" height="88" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(14);"/>
                <label left="402" top="594" width="320" height="20" text="DISTRAÍDO" fontColor="#684DAF" fontSize="11" fontStyle="bold" hitTest="false"/>
                <label left="402" top="618" width="320" height="44" text="Perde o foco facilmente durante tarefas importantes." wordWrap="true" fontColor="#5B4B70" fontSize="10" hitTest="false"/>

                <rectangle left="10" top="680" width="350" height="88" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(15);"/>
                <label left="24" top="690" width="320" height="20" text="PAVIO CURTO" fontColor="#A04470" fontSize="11" fontStyle="bold" hitTest="false"/>
                <label left="24" top="714" width="320" height="44" text="Fica bravo e reage de forma explosiva com facilidade." wordWrap="true" fontColor="#754C60" fontSize="10" hitTest="false"/>
                <rectangle left="388" top="680" width="350" height="88" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(16);"/>
                <label left="402" top="690" width="320" height="20" text="SUPER TÍMIDO" fontColor="#684DAF" fontSize="11" fontStyle="bold" hitTest="false"/>
                <label left="402" top="714" width="320" height="44" text="Timidez extrema atrapalha situações sociais." wordWrap="true" fontColor="#5B4B70" fontSize="10" hitTest="false"/>

                <rectangle left="10" top="776" width="728" height="88" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(17);"/>
                <label left="24" top="786" width="690" height="20" text="BOBÃO" fontColor="#A04470" fontSize="11" fontStyle="bold" hitTest="false"/>
