                <rectangle left="388" top="104" width="350" height="88" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(4);"/>
                <label left="402" top="114" width="320" height="20" text="MANDÃO" fontColor="#684DAF" fontSize="11" fontStyle="bold" hitTest="false"/>
