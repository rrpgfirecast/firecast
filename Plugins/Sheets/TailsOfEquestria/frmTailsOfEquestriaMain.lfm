        local INVENTORY_TABS = {
            {key="vestimentas", title="VESTIMENTAS"},
            {key="cura", title="CURA &amp; CUIDADO"},
            {key="ferramentas", title="FERRAMENTAS"},
            {key="viagem", title="VIAGEM"},
            {key="comidas", title="COMIDAS"},
            {key="artes", title="ARTES &amp; KITS"},
            {key="livros", title="LIVROS &amp; MAGIA"},
            {key="festas", title="FESTA &amp; DIVERSÃO"}
        };

        local activeInventoryPresetTab = "vestimentas";
        local visibleInventoryPresets = {};
        local INVENTORY_PRESET_SLOTS = 20;

        local function paint(controlName, color, strokeColor)
            local control = self[controlName];
            if control == nil then return; end;
            control.color = color;
            control.strokeColor = strokeColor;
        end;

        local function refreshImageStyles()
            if sheet == nil then return; end;
            if self.imgPortrait ~= nil then
                self.imgPortrait.style = sheet.portraitImageStyle or "proportional";
                self.imgPortrait.center = true;
            end;
            if self.imgCutieMark ~= nil then
                self.imgCutieMark.style = sheet.cutieMarkImageStyle or "proportional";
                self.imgCutieMark.center = true;
            end;
        end;

        local function updateLoadedCharacterTokens(character, url)
            if character == nil or url == nil or url == "" then return; end;
            local characterID = tonumber(character.codigoInterno);
            if characterID == nil then return; end;
            local tokenFrame = sheet ~= nil and (sheet.settingsTokenFrame or "boton") or "boton";
            local visionAngle = tonumber(sheet ~= nil and sheet.settingsTokenVisionAngle) or 240;
            local lightAngle = tonumber(sheet ~= nil and sheet.settingsTokenLightAngle) or 240;

            local scenes = SceneLib.getLoadedScenes() or {};
            for _, scene in ipairs(scenes) do
                local changedInScene = false;
                local items = scene.items;
                if items ~= nil then
                    for index = 1, #items do
                        local token = items[index];
                        local tokenImage = token ~= nil and token.image or nil;
                        if token ~= nil and token:isType("token")
                           and tonumber(token.ownerCharacter) == characterID
                           and (token.isMine == true or scene.isGM == true)
                           and tokenImage ~= nil
                           and (tokenImage.url ~= url
                                or tokenImage.frame ~= tokenFrame
                                or token.visionHaveVision ~= true
                                or tonumber(token.visionAngle) ~= visionAngle
                                or tonumber(token.lightAngle) ~= lightAngle) then
                            local beganUpdate = false;
                            local success = pcall(function()
                                token:beginUpdate();
                                beganUpdate = true;
                                tokenImage.url = url;
                                tokenImage.frame = tokenFrame;
                                token.visionHaveVision = true;
                                token.visionAngle = visionAngle;
                                token.lightAngle = lightAngle;
                            end);
                            if beganUpdate then
                                pcall(function() token:endUpdate(); end);
                            end;
                            if success then changedInScene = true; end;
                        end;
                    end;
                end;
                if changedInScene then
                    pcall(function() scene:sendDelayedUpdates(); end);
                end;
            end;
        end;

        local function syncPortraitToCharacterAvatar(url)
            if url == nil or url == "" then return; end;
            if portraitSyncInFlight then
                portraitSyncQueuedURL = url;
                return;
            end;

            local character = Firecast.getCharacterOf(sheet);
            if character == nil then return; end;
            updateLoadedCharacterTokens(character, url);

            portraitSyncInFlight = true;
            local success, promiseOrError = pcall(function()
                return character:asyncUpdate({avatar=url});
            end);

            local function finishSync()
                portraitSyncInFlight = false;
                local queuedURL = portraitSyncQueuedURL;
                portraitSyncQueuedURL = nil;
                if queuedURL ~= nil and queuedURL ~= "" and queuedURL ~= url then
                    syncPortraitToCharacterAvatar(queuedURL);
                end;
            end;

            if not success then
                finishSync();
                showMessage("Não foi possível atualizar a imagem do token: " .. tostring(promiseOrError));
                return;
            end;

            promiseOrError:onSuccess(function()
                finishSync();
            end);
            promiseOrError:onError(function(errorMessage)
                finishSync();
                showMessage("Não foi possível atualizar a imagem do token: " .. tostring(errorMessage));
            end);
        end;

        local function portraitURLChanged()
            if sheet == nil then return; end;
            local currentURL = sheet.portraitURL or "";
            if not portraitSyncReady then
                observedPortraitURL = currentURL;
                return;
            end;
            if currentURL == observedPortraitURL then return; end;
            observedPortraitURL = currentURL;
            if sheet.settingsAutoTokenSync == false then return; end;
            syncPortraitToCharacterAvatar(currentURL);
        end;

        local function armPortraitSync()
            observedPortraitURL = sheet ~= nil and (sheet.portraitURL or "") or "";
            setTimeout(function()
                portraitSyncReady = true;
                observedPortraitURL = sheet ~= nil and (sheet.portraitURL or "") or "";
            end, 500);
        end;

        local function showImageStylePopup(target)
            pendingImageTarget = target;
            if target == "portrait" then
                self.lblImageStyleTitle.text = "ENQUADRAMENTO DO RETRATO";
            else
                self.lblImageStyleTitle.text = "ENQUADRAMENTO DA CUTIE MARK";
            end;
            self.popImageStyle:show("center", self.lytStorybookCanvas);
        end;

        local function chooseImageStyle(style)
            if sheet == nil then return; end;
            if pendingImageTarget == "portrait" then
                sheet.portraitImageStyle = style;
            elseif pendingImageTarget == "cutieMark" then
                sheet.cutieMarkImageStyle = style;
            end;
            refreshImageStyles();
            self.popImageStyle:close();
        end;

        local function dieIndex(value)
            local numericValue = tonumber(value) or 4;
            for index, die in ipairs(DIE_SCALE) do
                if die == numericValue then return index; end;
            end;
            return 1;
        end;

        local function stepDie(value, direction)
            local index = dieIndex(value) + direction;
            if index &lt; 1 then index = 1; end;
            if index &gt; #DIE_SCALE then index = #DIE_SCALE; end;
            return DIE_SCALE[index];
        end;

        local function characterLabel()
            local name = sheet ~= nil and sheet.characterName or nil;
            if name == nil or name == "" then return "Personagem"; end;
            return name;
        end;

        local function rollOptions()
            if sheet == nil then return nil; end;
            return {
                palette = sheet.settingsRollPalette or "colorido",
                showExplosions = sheet.settingsRollExplosionText ~= false,
                showDetails = sheet.settingsRollShowDetails ~= false,
                bestFullGold = sheet.settingsRollBestFullGold == true
            };
        end;

        local function refreshDieReductionStatus()
            if self.rctPendingReduction == nil or self.lblPendingReduction == nil then return; end;
            local active = sheet ~= nil and sheet.pendingDieReduction == true;
            self.rctPendingReduction.visible = active;
            self.lblPendingReduction.visible = active;
            if active then
                self.lblPendingReduction.text = "↓ PRÓXIMO TESTE REBAIXADO: " .. (sheet.pendingDieReductionSource or "Capricho");
            end;
        end;

        local function clearDieReduction()
            if sheet == nil then return; end;
            sheet.pendingDieReduction = false;
            sheet.pendingDieReductionSource = nil;
            refreshDieReductionStatus();
        end;

        local function consumeDieReduction()
            if sheet == nil or sheet.pendingDieReduction ~= true then return false, nil; end;
            local source = sheet.pendingDieReductionSource or "Capricho";
            clearDieReduction();
            return true, source;
        end;

        local function reducedDie(sides, reductionActive)
            if reductionActive then return stepDie(sides, -1); end;
            return sides;
        end;

        local function reductionTitle(title, reductionActive, source)
            if reductionActive then return title .. " | ↓ " .. source; end;
            return title;
        end;

        local function sendRoll(sides, title)
            if sheet == nil then return; end;
            local room = Firecast.getMesaDe(sheet);
            if room == nil then
                showMessage("Abra a ficha dentro de uma mesa para enviar rolagens ao chat.");
                return;
            end;
            local reductionActive, source = consumeDieReduction();
            local finalSides = reducedDie(tonumber(sides) or 4, reductionActive);
            ExplodingRolls.rollSingleEx(room, finalSides, reductionTitle(title, reductionActive, source), nil, rollOptions());
        end;

        local function sendBestOfRoll(traitField, traitName, talent)
            if sheet == nil or talent == nil then return; end;
            local room = Firecast.getMesaDe(sheet);
            if room == nil then
                showMessage("Abra a ficha dentro de uma mesa para enviar rolagens ao chat.");
                return;
            end;

            local reductionActive, source = consumeDieReduction();
            local traitSides = reducedDie(tonumber(sheet[traitField]) or 4, reductionActive);
            local talentSides = reducedDie(tonumber(talent.die) or 4, reductionActive);
            local talentName = talent.name or "Talento";
            ExplodingRolls.rollBestOfEx(room, {
                {sides=traitSides, label=traitName},
                {sides=talentSides, label=talentName}
            }, reductionTitle(traitName .. " + " .. talentName, reductionActive, source), characterLabel(), rollOptions());
        end;

        local function getLinkedTalents(traitName)
            local found = {};
            if sheet == nil or sheet.talents == nil then return found; end;
            for _, talent in ipairs(NDB.getChildNodes(sheet.talents)) do
                if talent.linkedTrait == traitName then
                    found[#found + 1] = talent;
                end;
            end;
            return found;
        end;

        local function showLinkedTalentPopup(traitField, traitName)
            pendingTraitField = traitField;
            pendingTraitName = traitName;
            linkedTalentChoices = getLinkedTalents(traitName);

            if #linkedTalentChoices == 0 then
                sendRoll(tonumber(sheet[traitField]) or 4, traitName .. " de " .. characterLabel());
                return;
            end;

            for index = 1, LINKED_TALENT_SLOTS do
                local talent = linkedTalentChoices[index];
                local card = self["rctLinkedTalent" .. index];
                local nameLabel = self["lblLinkedTalentName" .. index];
                local dieLabel = self["lblLinkedTalentDie" .. index];
                if card ~= nil then card.visible = talent ~= nil; end;
                if nameLabel ~= nil then nameLabel.text = talent ~= nil and (talent.name or "Talento") or ""; end;
                if dieLabel ~= nil then dieLabel.text = talent ~= nil and ("D" .. tostring(tonumber(talent.die) or 4)) or ""; end;
            end;
            self.lblLinkedTraitTitle.text = "ROLAR " .. string.upper(traitName) .. " COM QUAL TALENTO?";
            self.popLinkedTalent:show("center", self.lytStorybookCanvas);
        end;

        local function chooseLinkedTalent(index)
            local talent = linkedTalentChoices[index];
            self.popLinkedTalent:close();
            if talent ~= nil then
                sendBestOfRoll(pendingTraitField, pendingTraitName, talent);
            end;
        end;

        local function rollPendingTraitAlone()
            self.popLinkedTalent:close();
            if pendingTraitField ~= nil then
                sendRoll(tonumber(sheet[pendingTraitField]) or 4, pendingTraitName .. " de " .. characterLabel());
            end;
        end;

        local function rollTrait(fieldName, traitName)
            if sheet == nil then return; end;
            if sheet.settingsAskLinkedTalent == false then
                sendRoll(tonumber(sheet[fieldName]) or 4, traitName .. " de " .. characterLabel());
                return;
            end;
            showLinkedTalentPopup(fieldName, traitName);
        end;

        local function rollCutieMark()
            if sheet == nil then return; end;
            local sides = tonumber(sheet.cutieMarkDie) or 6;
            local talent = sheet.cutieMarkTalent;
            if talent == nil or talent == "" then talent = "Talento Especial"; end;
            sendRoll(sides, "Cutie Mark: " .. talent);
        end;

        local function changeTrait(fieldName, direction)
            if sheet == nil then return; end;
            sheet[fieldName] = stepDie(sheet[fieldName], direction);
        end;

        local function refreshStamina()
            if sheet == nil then return; end;
            local suggested = (tonumber(sheet.bodyDie) or 4) + (tonumber(sheet.mindDie) or 4);
            if sheet.settingsAutoStamina == false then
                sheet.staminaMaxAuto = suggested;
                return;
            end;
            local oldAuto = tonumber(sheet.staminaMaxAuto);
            local currentMax = tonumber(sheet.staminaMax);

            if currentMax == nil or oldAuto == nil or currentMax == oldAuto then
                local current = tonumber(sheet.staminaCurrent);
                sheet.staminaMax = suggested;
                if current == nil then
                    sheet.staminaCurrent = suggested;
                elseif current &gt; suggested then
                    sheet.staminaCurrent = suggested;
                end;
            end;
            sheet.staminaMaxAuto = suggested;
        end;

        local function changeStamina(delta)
            if sheet == nil then return; end;
            local maximum = tonumber(sheet.staminaMax) or 0;
            local current = tonumber(sheet.staminaCurrent) or maximum;
            current = current + delta;
            if current &lt; 0 then current = 0; end;
            if current &gt; maximum then current = maximum; end;
            sheet.staminaCurrent = current;
        end;

        local function changeFriendship(delta)
            if sheet == nil then return; end;
            local current = (tonumber(sheet.friendshipCurrent) or 0) + delta;
            if current &lt; 0 then current = 0; end;
            sheet.friendshipCurrent = current;
        end;

        local function changeBits(delta)
            if sheet == nil then return; end;
            local current = (tonumber(sheet.bits) or 0) + delta;
            if current &lt; 0 then current = 0; end;
            sheet.bits = current;
        end;

        local function addTalent(name, die, kind, description, linkedTrait)
            local node = self.rclTalents:append();
            if node == nil then return nil; end;
            node.name = name or "Novo Talento";
            node.die = die or 4;
            node.kind = kind or "Adquirido";
            node.description = description or "";
            node.linkedTrait = linkedTrait or "Livre";
            return node;
        end;

        local function addPresetTalent(index)
            local preset = TALENT_PRESETS[index];
            if preset == nil then return; end;
            addTalent(preset.name, preset.die, preset.kind, preset.description, preset.trait);
            self.popTalentPresets:close();
        end;

        local function showTalentPresets()
            self.popTalentPresets:show("center", self.rctTalentPresets);
        end;

        local function addQuirk(name, trigger)
            local node = self.rclQuirks:append();
            if node == nil then return nil; end;
            node.name = name or "Novo Capricho";
            node.trigger = trigger or "Quando isso atrapalha a personagem...";
            node.earnedFriendship = false;
            return node;
        end;

        local function addPresetQuirk(index)
            local preset = QUIRK_PRESETS[index];
            if preset == nil then return; end;
            addQuirk(preset.name, preset.trigger);
            self.popQuirkPresets:close();
        end;

        local function showQuirkPresets()
            self.popQuirkPresets:show("center", self.rctQuirkPresets);
        end;

        local function addFriend()
            local node = self.rclFriends:append();
            if node == nil then return nil; end;
            node.name = "Novo Amigo";
            node.relationship = "Como nos conhecemos?";
            node.description = "";
            return node;
        end;

        local function addTimelineEntry()
            local node = self.rclTimeline:append();
            if node == nil then return nil; end;
            node.moment = "Nova aventura";
            node.event = "O que aconteceu?";
            node.impact = "O que mudou depois disso?";
            return node;
        end;

        local function addInventoryItem(name, category, quantity, cost, quickUse)
            local node = self.rclInventory:append();
            if node == nil then return nil; end;
            node.name = name or "Novo Item";
            node.category = category or "Outro";
            node.quantity = quantity or 1;
            node.cost = cost or 0;
            node.quickUse = quickUse or "Como este item ajuda na aventura?";
            return node;
        end;

        local function inventoryPresetTabFor(preset)
            local category = preset.category or "";
            local name = preset.name or "";

            if name == "Kit de banho e preparação" or name == "Chá calmante" then return "cura"; end;
            if name == "Kit de festa" or name == "Kit de pegadinha" or name == "Máquina de bolhas portátil" then return "festas"; end;
            if category == "Cura" then return "cura"; end;
            if category == "Comida" then return "comidas"; end;
            if category == "Livro" or category == "Utilidade mágica" or category == "Cosmético mágico" then return "livros"; end;
            if category == "Kit" or category == "Música" then return "artes"; end;
            if category == "Diversão" then return "festas"; end;
            if category == "Viagem" or category == "Exploração" or category == "Iluminação" or category == "Esporte" then return "viagem"; end;
            if category == "Proteção" or category == "Proteção leve" or category == "Moda" or category == "Moda útil"
               or category == "Moda mágica" or category == "Cosmético" or category == "Acessório" then return "vestimentas"; end;
            return "ferramentas";
        end;

        local function refreshInventoryPresetTab()
            visibleInventoryPresets = {};
            local activeTitle = "";

            for index, tab in ipairs(INVENTORY_TABS) do
                local selected = tab.key == activeInventoryPresetTab;
                local rect = self["rctInventoryTab" .. index];
                local label = self["lblInventoryTab" .. index];
                if selected then
                    activeTitle = tab.title;
                    rect.color = "#FFE08A";
                    rect.strokeColor = "#F3A64A";
                    label.fontColor = "#8B5A20";
                else
                    rect.color = "#F8E6CC";
                    rect.strokeColor = "#AFA29A";
                    label.fontColor = "#76665A";
                end;
            end;

            for _, preset in ipairs(INVENTORY_PRESETS) do
                if inventoryPresetTabFor(preset) == activeInventoryPresetTab then
                    table.insert(visibleInventoryPresets, preset);
                end;
            end;

            self.lblInventoryPresetSection.text = string.format("%s  •  %d ITENS", activeTitle, #visibleInventoryPresets);
            self.lytInventoryPresetCards.height = math.max(196, (math.ceil(#visibleInventoryPresets / 2) * 98) + 10);

            for slot = 1, INVENTORY_PRESET_SLOTS do
                local preset = visibleInventoryPresets[slot];
                local card = self["rctInventoryPreset" .. slot];
                local nameLabel = self["lblInventoryPresetName" .. slot];
                local metaLabel = self["lblInventoryPresetMeta" .. slot];
                local useLabel = self["lblInventoryPresetUse" .. slot];

                local visible = preset ~= nil;
                card.visible = visible;
                nameLabel.visible = visible;
                metaLabel.visible = visible;
                useLabel.visible = visible;

                if visible then
                    nameLabel.text = preset.name;
                    metaLabel.text = string.format("%s  •  %s  •  %d BITS", preset.source, preset.category, preset.cost);
                    useLabel.text = preset.use;

                    if preset.source == "Manual" then
                        card.color = "#FFE4A8";
                        card.strokeColor = "#F4B84A";
                        nameLabel.fontColor = "#B46C00";
                        metaLabel.fontColor = "#C78328";
                        useLabel.fontColor = "#6D5529";
                    else
                        card.color = "#E6D6FF";
                        card.strokeColor = "#B18CFF";
                        nameLabel.fontColor = "#7954C8";
                        metaLabel.fontColor = "#8F6ED6";
                        useLabel.fontColor = "#5B4773";
                    end;
                end;
            end;
        end;

        local function chooseInventoryPresetTab(index)
            local tab = INVENTORY_TABS[index];
            if tab == nil then return; end;
            activeInventoryPresetTab = tab.key;
            refreshInventoryPresetTab();
        end;

        local function addVisibleInventoryPreset(slot)
            local preset = visibleInventoryPresets[slot];
            if preset == nil then return; end;
            addInventoryItem(preset.name, preset.category, preset.quantity, preset.cost, preset.use);
            self.lblInventoryPresetStatus.text = "✓ " .. preset.name .. " foi colocado no Alforge. O custo é apenas referência.";
        end;

        local function showInventoryPresets()
            activeInventoryPresetTab = "vestimentas";
            self.lblInventoryPresetStatus.text = "Clique em um cartão para adicionar. Os Bits não são descontados automaticamente.";
            refreshInventoryPresetTab();
            self.popInventoryPresets:show("center", self.rctInventoryPresets);
        end;

        local CONDITION_CARDS = {
            {field="conditionHappy", control="rctConditionHappy", active="#FFE2F0", stroke="#F77DB8"},
            {field="conditionTired", control="rctConditionTired", active="#E5EAF8", stroke="#879AC8"},
            {field="conditionScared", control="rctConditionScared", active="#C9B9D8", stroke="#8067D9"},
            {field="conditionInspired", control="rctConditionInspired", active="#FFD469", stroke="#F2B84B"},
            {field="conditionHurt", control="rctConditionHurt", active="#D9B8B8", stroke="#F05F6A"},
            {field="conditionConfused", control="rctConditionConfused", active="#B4CDD9", stroke="#4BB8E8"},
            {field="conditionHungry", control="rctConditionHungry", active="#FFE08A", stroke="#F3A64A"},
            {field="conditionWet", control="rctConditionWet", active="#B4CDD9", stroke="#24A8D8"}
        };

        local function refreshConditions()
            if sheet == nil then return; end;
            for _, condition in ipairs(CONDITION_CARDS) do
                local card = self[condition.control];
                if card ~= nil then
                    if sheet[condition.field] == true then
                        card.color = condition.active;
                        card.strokeColor = condition.stroke;
                        card.strokeSize = 2;
                    else
                        card.color = "#FFF2D6";
                        card.strokeColor = "#E8CF99";
                        card.strokeSize = 1;
                    end;
                end;
            end;
        end;

        local function toggleCondition(fieldName)
            if sheet == nil then return; end;
            sheet[fieldName] = not (sheet[fieldName] == true);
            refreshConditions();
        end;

        local function showRacePopup()
            self.popRace:show("center", self.rctRaceSelector);
        end;

        local function chooseRace(value)
            if sheet ~= nil then sheet.race = value; end;
            self.popRace:close();
        end;

        local function showHarmonyPopup()
            self.popHarmony:show("center", self.rctHarmonySelector);
        end;

        local function chooseHarmony(value)
            if sheet ~= nil then sheet.elementOfHarmony = value; end;
            self.popHarmony:close();
        end;

        local function seedTalents()
            if sheet == nil or sheet.talentsSeeded == true then return; end;
            addTalent("Cutie Mark: Talento Especial", 6, "Principal", "Descreva o talento representado pela Cutie Mark.", "Livre");
            addTalent("Coração Intrépido", 6, "Inerente", "Role junto em feitos corajosos pelos quais o pônei se esforça grandiosamente.", "Corpo");
            sheet.talentsSeeded = true;
        end;

        local function ensureDefaults()
            if sheet == nil then return; end;
            NDB.beginUpdate(sheet);
            local schemaVersion = tonumber(sheet.schemaVersion) or 0;
            local migratePonyvilleTheme = schemaVersion &lt; 10;
            if schemaVersion &lt; 10 then sheet.schemaVersion = 10; end;
            if sheet.characterName == nil then sheet.characterName = ""; end;
            if sheet.playerName == nil then sheet.playerName = ""; end;
            if sheet.race == nil then sheet.race = "Pônei terrestre"; end;
            if sheet.level == nil then sheet.level = 1; end;
            if sheet.elementOfHarmony == nil then sheet.elementOfHarmony = "Bondade"; end;
            if sheet.bodyDie == nil then sheet.bodyDie = 8; end;
            if sheet.mindDie == nil then sheet.mindDie = 4; end;
            if sheet.charmDie == nil then sheet.charmDie = 6; end;
            if sheet.friendshipCurrent == nil then sheet.friendshipCurrent = 4; end;
            if sheet.bits == nil then sheet.bits = 400; end;
            if sheet.sceneObjective == nil then sheet.sceneObjective = ""; end;
            if sheet.loreOrigin == nil then sheet.loreOrigin = ""; end;
            if sheet.loreTurningPoint == nil then sheet.loreTurningPoint = ""; end;
            if sheet.loreDream == nil then sheet.loreDream = ""; end;
            if sheet.cutieMarkTalent == nil then sheet.cutieMarkTalent = ""; end;
            if sheet.cutieMarkDescription == nil then sheet.cutieMarkDescription = ""; end;
            if sheet.cutieMarkDie == nil then sheet.cutieMarkDie = 6; end;
            if sheet.portraitImageStyle == nil then sheet.portraitImageStyle = "proportional"; end;
            if sheet.cutieMarkImageStyle == nil then sheet.cutieMarkImageStyle = "proportional"; end;
            if sheet.pendingDieReduction == nil then sheet.pendingDieReduction = false; end;
            if sheet.settingsTheme == nil or migratePonyvilleTheme then sheet.settingsTheme = "day"; end;
            if sheet.settingsFontScale == nil or migratePonyvilleTheme then sheet.settingsFontScale = "large"; end;
            if sheet.settingsRollPalette == nil then sheet.settingsRollPalette = "colorido"; end;
            if sheet.settingsRollShowDetails == nil then sheet.settingsRollShowDetails = true; end;
            if sheet.settingsRollExplosionText == nil then sheet.settingsRollExplosionText = true; end;
            if sheet.settingsRollBestFullGold == nil then sheet.settingsRollBestFullGold = false; end;
            if sheet.settingsAskLinkedTalent == nil then sheet.settingsAskLinkedTalent = true; end;
            if sheet.settingsAutoStamina == nil then sheet.settingsAutoStamina = true; end;
            if sheet.settingsAutoTokenSync == nil then sheet.settingsAutoTokenSync = true; end;
            if sheet.settingsTokenFrame == nil then sheet.settingsTokenFrame = "boton"; end;
            if sheet.settingsTokenVisionAngle == nil then sheet.settingsTokenVisionAngle = 240; end;
            if sheet.settingsTokenLightAngle == nil then sheet.settingsTokenLightAngle = 240; end;
            refreshStamina();
            NDB.endUpdate(sheet);
            seedTalents();
            refreshConditions();
            refreshDieReductionStatus();
            refreshImageStyles();
            if applyVisualSettings ~= nil then applyVisualSettings(); end;
            if refreshSettingsPanel ~= nil then refreshSettingsPanel(); end;
        end;

        local function resetBackupRestore()
            backupRestoreArmed = false;
            if self.rctBackupRestore ~= nil then
                self.rctBackupRestore.color = "#3D334D";
                self.rctBackupRestore.strokeColor = "#B18CFF";
            end;
            if self.lblBackupRestore ~= nil then
                self.lblBackupRestore.text = "↺ RESTAURAR DO TEXTO";
                self.lblBackupRestore.fontColor = "#F5ECFF";
            end;
        end;

        local function updateBackupText()
            if sheet == nil or self.edtBackupText == nil then return; end;
            local success, backupOrError = pcall(NDB.exportXML, sheet);
            if success then
                self.edtBackupText.text = backupOrError or "";
                resetBackupRestore();
            else
                showMessage("Não foi possível gerar o backup: " .. tostring(backupOrError));
            end;
        end;

        local function showBackupPopup()
            updateBackupText();
            self.popBackup:show("center", self.lytStorybookCanvas);
        end;

        local function closeBackupPopup()
            resetBackupRestore();
            self.popBackup:close();
        end;

        local function restoreBackupText()
            if sheet == nil or self.edtBackupText == nil then return; end;
            local backupText = self.edtBackupText.text or "";
            if backupText == "" then
                showMessage("Cole ou gere um backup antes de restaurar.");
                return;
            end;

            if not backupRestoreArmed then
                backupRestoreArmed = true;
                self.rctBackupRestore.color = "#5B3039";
                self.rctBackupRestore.strokeColor = "#F07178";
                self.lblBackupRestore.text = "CONFIRMAR RESTAURAÇÃO";
                self.lblBackupRestore.fontColor = "#FFD7DA";
                return;
            end;

            local success, importError = pcall(NDB.importXML, sheet, backupText);
            resetBackupRestore();
            if success then
                self.popBackup:close();
                ensureDefaults();
                showMessage("Backup restaurado com sucesso.");
            else
                showMessage("Não foi possível restaurar o backup: " .. tostring(importError));
            end;
        end;

        local function boolLabel(value)
            if value == true then return "LIGADO"; end;
            return "DESLIGADO";
        end;

        local function themeLabel(value)
            if value == "night" then return "NOITE MÁGICA"; end;
            if value == "twilight" then return "CREPÚSCULO"; end;
            if value == "day" then return "DIA EM PONYVILLE"; end;
            return "MEIO-TERMO";
        end;

        local function fontLabel(value)
            if value == "huge" then return "GIGANTE"; end;
            if value == "large" then return "GRANDE"; end;
            if value == "small" then return "PEQUENA"; end;
            return "NORMAL";
        end;

        local function paletteLabel(value)
            if value == "epico" then return "ÉPICO"; end;
            if value == "minimal" then return "MINIMALISTA"; end;
            return "COLORIDO";
        end;

        local function imageStyleLabel(value)
            if value == "autoFit" then return "ZOOM / CORTADO"; end;
            if value == "originalSize" then return "ORIGINAL"; end;
            if value == "stretch" then return "ESTICADO"; end;
            return "ENCAIXADO";
        end;

        local function settingsStatus(text)
            if self.lblSettingsStatus ~= nil then
                self.lblSettingsStatus.text = text or "";
            end;
        end;

        applyVisualSettings = function()
            if sheet == nil then return; end;
            local theme = sheet.settingsTheme or "day";
            local fontScale = sheet.settingsFontScale or "large";
            local journalSize = 13;

            if fontScale == "small" then journalSize = 11; end;
            if fontScale == "large" then journalSize = 15; end;
            if fontScale == "huge" then journalSize = 17; end;

            local function setRectColors(controlName, color, strokeColor)
                local control = self[controlName];
                if control ~= nil then
                    control.color = color;
                    control.strokeColor = strokeColor or color;
                end;
            end;

            local visual = {
                race={"#BFEAFF", "#4BB8E8"},
                harmony={"#E6D6FF", "#B18CFF"},
                body={"#BFEAFF", "#4BB8E8"},
                mind={"#E6D6FF", "#B18CFF"},
                charm={"#DDC98E", "#F4B84A"},
                greenButton={"#D8F4C8", "#7FCB5C"}
            };

            if theme == "night" then
                visual = {
                    race={"#1F3440", "#4BB8E8"},
                    harmony={"#2C2544", "#B18CFF"},
                    body={"#1F3440", "#4BB8E8"},
                    mind={"#2C2544", "#B18CFF"},
                    charm={"#3B2F1F", "#F4B84A"},
                    greenButton={"#24382C", "#7FCB5C"}
                };
                if self.rctCanvasBackdrop ~= nil then
                    self.rctCanvasBackdrop.color = "#181A24";
                    self.rctCanvasBackdrop.strokeColor = "#181A24";
                end;
                if self.rctCanvasPaper ~= nil then
                    self.rctCanvasPaper.color = "#CFC4B8";
                    self.rctCanvasPaper.strokeColor = "#B18CFF";
                end;
                if self.rchJournal ~= nil then
                    self.rchJournal.backgroundColor = "#262834";
                    self.rchJournal.defaultFontColor = "#F1E7DC";
                end;
            elseif theme == "twilight" then
                visual = {
                    race={"#2A3D50", "#76C7E8"},
                    harmony={"#3C2E58", "#B18CFF"},
                    body={"#2A3D50", "#76C7E8"},
                    mind={"#3C2E58", "#B18CFF"},
                    charm={"#4A3540", "#F77DB8"},
                    greenButton={"#304534", "#79B65A"}
                };
                if self.rctCanvasBackdrop ~= nil then
                    self.rctCanvasBackdrop.color = "#343044";
                    self.rctCanvasBackdrop.strokeColor = "#343044";
                end;
                if self.rctCanvasPaper ~= nil then
                    self.rctCanvasPaper.color = "#D9D0C9";
                    self.rctCanvasPaper.strokeColor = "#F77DB8";
                end;
                if self.rchJournal ~= nil then
                    self.rchJournal.backgroundColor = "#2C2938";
                    self.rchJournal.defaultFontColor = "#F6E5F0";
                end;
            elseif theme == "day" then
                visual = {
                    race={"#BFEAFF", "#4BB8E8"},
                    harmony={"#E6D6FF", "#B18CFF"},
                    body={"#BFEAFF", "#4BB8E8"},
                    mind={"#E6D6FF", "#B18CFF"},
                    charm={"#DDC98E", "#F4B84A"},
                    greenButton={"#D8F4C8", "#7FCB5C"}
                };
                if self.rctCanvasBackdrop ~= nil then
                    self.rctCanvasBackdrop.color = "#8FD4F3";
                    self.rctCanvasBackdrop.strokeColor = "#8FD4F3";
                end;
                if self.rctCanvasPaper ~= nil then
                    self.rctCanvasPaper.color = "#FFF2D6";
                    self.rctCanvasPaper.strokeColor = "#F6C35B";
                end;
                if self.rchJournal ~= nil then
                    self.rchJournal.backgroundColor = "#FFF7E6";
                    self.rchJournal.defaultFontColor = "#51463E";
                end;
            else
                visual = {
                    race={"#CBEFFF", "#4BB8E8"},
                    harmony={"#E6D6FF", "#B18CFF"},
                    body={"#CBEFFF", "#4BB8E8"},
                    mind={"#E6D6FF", "#B18CFF"},
                    charm={"#FFE4A8", "#F4B84A"},
                    greenButton={"#D8F4C8", "#7FCB5C"}
                };
                if self.rctCanvasBackdrop ~= nil then
                    self.rctCanvasBackdrop.color = "#8FD4F3";
                    self.rctCanvasBackdrop.strokeColor = "#8FD4F3";
                end;
                if self.rctCanvasPaper ~= nil then
                    self.rctCanvasPaper.color = "#FFF2D6";
                    self.rctCanvasPaper.strokeColor = "#F6C35B";
                end;
                if self.rchJournal ~= nil then
                    self.rchJournal.backgroundColor = "#FFF2D6";
                    self.rchJournal.defaultFontColor = "#51463E";
                end;
            end;

            setRectColors("rctRaceSelector", visual.race[1], visual.race[2]);
            setRectColors("rctHarmonySelector", visual.harmony[1], visual.harmony[2]);
            setRectColors("rctRollBody", visual.body[1], visual.body[2]);
            setRectColors("rctRollMind", visual.mind[1], visual.mind[2]);
            setRectColors("rctRollCharm", visual.charm[1], visual.charm[2]);
            setRectColors("rctAddTalent", visual.greenButton[1], visual.greenButton[2]);
            setRectColors("rctRollCutieMark", visual.greenButton[1], visual.greenButton[2]);

            if self.rchJournal ~= nil then
                self.rchJournal.defaultFontSize = journalSize;
            end;
        end;

        refreshSettingsPanel = function()
            if sheet == nil then return; end;

            for index, tab in ipairs(SETTINGS_TABS) do
                local selected = activeSettingsTab == tab.key;
                local rect = self["rctSettingsTab" .. index];
                local label = self["lblSettingsTab" .. index];
                local layout = self["lytSettings" .. tab.layout];

                if rect ~= nil then
                    if selected then
                        rect.color = "#2F7FA4";
                        rect.strokeColor = "#F4B84A";
                    else
                        rect.color = "#F8E6CC";
                        rect.strokeColor = "#B89C80";
                    end;
                end;

                if label ~= nil then
                    if selected then
                        label.fontColor = "#FFF7C8";
                    else
                        label.fontColor = "#5B5148";
                    end;
                end;

                if layout ~= nil then
                    layout.visible = selected;
                end;
            end;

            if self.lblSettingsThemeValue ~= nil then self.lblSettingsThemeValue.text = themeLabel(sheet.settingsTheme); end;
            if self.lblSettingsFontValue ~= nil then self.lblSettingsFontValue.text = fontLabel(sheet.settingsFontScale); end;
            if self.lblSettingsPortraitStyleValue ~= nil then self.lblSettingsPortraitStyleValue.text = imageStyleLabel(sheet.portraitImageStyle); end;
            if self.lblSettingsCutieStyleValue ~= nil then self.lblSettingsCutieStyleValue.text = imageStyleLabel(sheet.cutieMarkImageStyle); end;
            if self.lblSettingsRollPaletteValue ~= nil then self.lblSettingsRollPaletteValue.text = paletteLabel(sheet.settingsRollPalette); end;
            if self.lblSettingsRollDetailsValue ~= nil then self.lblSettingsRollDetailsValue.text = boolLabel(sheet.settingsRollShowDetails); end;
            if self.lblSettingsRollExplosionValue ~= nil then self.lblSettingsRollExplosionValue.text = boolLabel(sheet.settingsRollExplosionText); end;
            if self.lblSettingsRollBestValue ~= nil then self.lblSettingsRollBestValue.text = sheet.settingsRollBestFullGold == true and "LINHA DOURADA" or "SÓ NÚMERO"; end;
            if self.lblSettingsAskTalentValue ~= nil then self.lblSettingsAskTalentValue.text = boolLabel(sheet.settingsAskLinkedTalent); end;
            if self.lblSettingsAutoStaminaValue ~= nil then self.lblSettingsAutoStaminaValue.text = boolLabel(sheet.settingsAutoStamina); end;
            if self.lblSettingsAutoTokenValue ~= nil then self.lblSettingsAutoTokenValue.text = boolLabel(sheet.settingsAutoTokenSync); end;
            if self.lblSettingsTokenFrameValue ~= nil then self.lblSettingsTokenFrameValue.text = "REDONDO"; end;
            if self.lblSettingsTokenVisionValue ~= nil then self.lblSettingsTokenVisionValue.text = tostring(tonumber(sheet.settingsTokenVisionAngle) or 240) .. "°"; end;
            if self.lblSettingsTokenLightValue ~= nil then self.lblSettingsTokenLightValue.text = tostring(tonumber(sheet.settingsTokenLightAngle) or 240) .. "°"; end;
        end;

        local function settingsSet(fieldName, value)
            if sheet == nil then return; end;
            sheet[fieldName] = value;
            applyVisualSettings();
            refreshImageStyles();
            refreshSettingsPanel();
            settingsStatus("Ajuste aplicado.");
        end;

        local function settingsToggle(fieldName)
            if sheet == nil then return; end;
            sheet[fieldName] = not (sheet[fieldName] == true);
            applyVisualSettings();
            refreshSettingsPanel();
            settingsStatus("Ajuste alternado.");
        end;

        local function settingsImageStyle(target, style)
            if sheet == nil then return; end;
            if target == "portrait" then
                sheet.portraitImageStyle = style;
            else
                sheet.cutieMarkImageStyle = style;
            end;
            refreshImageStyles();
            refreshSettingsPanel();
            settingsStatus("Enquadramento atualizado.");
        end;

        local function showSettingsPopup()
            activeSettingsTab = "visual";
            applyVisualSettings();
            refreshSettingsPanel();
            settingsStatus("Escolha uma aba para tunar a ficha.");
            self.popSettings:show("center", self.lytStorybookCanvas);
        end;

        local function closeSettingsPopup()
            self.popSettings:close();
        end;

        local function chooseSettingsTab(tabKey)
            activeSettingsTab = tabKey or "visual";
            refreshSettingsPanel();
        end;

        local function syncPortraitNow()
            if sheet == nil then return; end;
            local url = sheet.portraitURL or "";
            if url == "" then
                settingsStatus("Escolha um retrato antes de sincronizar o token.");
                showMessage("Escolha um retrato antes de sincronizar o token.");
                return;
            end;
            syncPortraitToCharacterAvatar(url);
            settingsStatus("Token atualizado com retrato, moldura e visão.");
        end;

        local function applyTokenPresetNow()
            syncPortraitNow();
        end;

        local function recalculateSheetNow()
            refreshStamina();
            refreshConditions();
            refreshDieReductionStatus();
            refreshImageStyles();
            applyVisualSettings();
            refreshSettingsPanel();
            settingsStatus("Ficha recalculada.");
        end;

        local function resetSettingsDefaults()
            if sheet == nil then return; end;
            NDB.beginUpdate(sheet);
            sheet.settingsTheme = "day";
            sheet.settingsFontScale = "large";
            sheet.settingsRollPalette = "colorido";
            sheet.settingsRollShowDetails = true;
            sheet.settingsRollExplosionText = true;
            sheet.settingsRollBestFullGold = false;
            sheet.settingsAskLinkedTalent = true;
            sheet.settingsAutoStamina = true;
            sheet.settingsAutoTokenSync = true;
            sheet.settingsTokenFrame = "boton";
            sheet.settingsTokenVisionAngle = 240;
            sheet.settingsTokenLightAngle = 240;
            NDB.endUpdate(sheet);
            recalculateSheetNow();
            settingsStatus("Ajustes restaurados para o padrão da ficha.");
        end;

        local function openBackupFromSettings()
            self.popSettings:close();
            showBackupPopup();
        end;

        local function openTalentPresetsFromSettings()
            self.popSettings:close();
            showTalentPresets();
        end;

        local function openQuirkPresetsFromSettings()
            self.popSettings:close();
            showQuirkPresets();
        end;

        local function openInventoryPresetsFromSettings()
            self.popSettings:close();
            showInventoryPresets();
        end;
    </script>

