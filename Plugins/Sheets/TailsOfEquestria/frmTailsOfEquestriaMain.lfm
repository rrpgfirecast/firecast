    <popup name="popTalentPresets" width="820" height="560" backOpacity="0.94"
           drawContainer="false" autoScopeNode="false">
        <rectangle align="client" color="#C3C0CE" strokeColor="#9D7FDC" strokeSize="2" cornerType="round" xradius="24" yradius="24"/>
        <label left="30" top="22" width="760" height="20" text="CATÁLOGO DE TALENTOS DO MANUAL" fontColor="#684DAF" fontSize="13" fontStyle="bold"/>
        <label left="30" top="50" width="760" height="30" text="Clique para adicionar. Cada preset já traz dado inicial, atributo relacionado e explicação de uso." fontColor="#59606E" fontSize="11"/>
        <scrollBox left="20" top="86" width="780" height="454">
            <layout width="750" height="1110">
                <rectangle left="12" top="10" width="318" height="122" color="#BFD3AF" strokeColor="#79B65A" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(1);"/>
                <label left="28" top="24" width="300" height="22" text="CORAÇÃO INTRÉPIDO • D6 • CORPO" fontColor="#356B48" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="28" top="54" width="318" height="60" text="Feitos corajosos realizados com grande esforço. Talento inerente de pônei terrestre." wordWrap="true" fontColor="#4D6547" fontSize="11" hitTest="false"/>
                <rectangle left="388" top="10" width="318" height="122" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(2);"/>
                <label left="404" top="24" width="300" height="22" text="TELECINESE • D6 • MENTE" fontColor="#684DAF" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="404" top="54" width="318" height="60" text="Move objetos, ilumina lugares e manipula coisas com magia. Talento inerente de unicórnio." wordWrap="true" fontColor="#5B4B70" fontSize="11" hitTest="false"/>

                <rectangle left="12" top="144" width="318" height="122" color="#B7CFD9" strokeColor="#76C7E8" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(3);"/>
                <label left="28" top="158" width="300" height="22" text="VOAR • D6 • CORPO" fontColor="#317EA0" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="28" top="188" width="318" height="60" text="Voa, observa do alto, toca nuvens e age com velocidade. Talento inerente de pégaso." wordWrap="true" fontColor="#426979" fontSize="11" hitTest="false"/>
                <rectangle left="388" top="144" width="318" height="122" color="#B7CFD9" strokeColor="#76C7E8" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(4);"/>
                <label left="404" top="158" width="310" height="22" text="ARRANJO DE NUVENS • D4 • MENTE" fontColor="#317EA0" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="404" top="188" width="318" height="60" text="Maneja o clima, movendo nuvens e criando chuva, neve, vento ou tempestades." wordWrap="true" fontColor="#426979" fontSize="11" hitTest="false"/>

                <rectangle left="12" top="278" width="318" height="122" color="#DDC48E" strokeColor="#E7B95B" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(5);"/>
                <label left="28" top="292" width="318" height="22" text="PÔNEI PRA QUALQUER NEGÓCIO • D4 • LIVRE" fontColor="#9A681E" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="28" top="322" width="318" height="60" text="Uma vez por aventura pode entrar em qualquer teste. Atenção: possui regra especial de soma." wordWrap="true" fontColor="#725B31" fontSize="11" hitTest="false"/>
                <rectangle left="388" top="278" width="318" height="122" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(6);"/>
                <label left="404" top="292" width="310" height="22" text="CAMPO DE FORÇA • D4 • MENTE" fontColor="#684DAF" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="404" top="322" width="318" height="60" text="Cria proteção mágica mantida enquanto o unicórnio permanece concentrado." wordWrap="true" fontColor="#5B4B70" fontSize="11" hitTest="false"/>

                <rectangle left="12" top="412" width="318" height="122" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(7);"/>
                <label left="28" top="426" width="310" height="22" text="DOM CRIATIVO • D4 • LIVRE" fontColor="#A04470" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="28" top="456" width="318" height="60" text="Especialidade artística ou prática, como cozinha, moda, música, comédia ou pintura." wordWrap="true" fontColor="#754C60" fontSize="11" hitTest="false"/>
                <rectangle left="388" top="412" width="318" height="122" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(8);"/>
                <label left="404" top="426" width="310" height="22" text="TOQUE DE CURA • D4 • CHARME" fontColor="#A04470" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="404" top="456" width="318" height="60" text="Uma vez por jogo, recupera a Energia de um aliado conforme o resultado rolado." wordWrap="true" fontColor="#754C60" fontSize="11" hitTest="false"/>

                <rectangle left="12" top="546" width="318" height="122" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(9);"/>
                <label left="28" top="560" width="318" height="22" text="CONHECIMENTO ESPECÍFICO • D4 • MENTE" fontColor="#684DAF" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="28" top="590" width="318" height="60" text="Facilidade para saber, recordar ou pesquisar informações de um assunto escolhido." wordWrap="true" fontColor="#5B4B70" fontSize="11" hitTest="false"/>
                <rectangle left="388" top="546" width="318" height="122" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(10);"/>
                <label left="404" top="560" width="310" height="22" text="LOCALIZAR • D4 • MENTE" fontColor="#684DAF" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="404" top="590" width="318" height="60" text="Usa o chifre como detector para encontrar um material ou recurso específico." wordWrap="true" fontColor="#5B4B70" fontSize="11" hitTest="false"/>

                <rectangle left="12" top="680" width="318" height="122" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(11);"/>
                <label left="28" top="694" width="310" height="22" text="SENTIDO PÔNEI • D4 • MENTE" fontColor="#684DAF" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="28" top="724" width="318" height="60" text="Prevê acontecimentos antes que ocorram. Quantidade de usos depende do nível do dado." wordWrap="true" fontColor="#5B4B70" fontSize="11" hitTest="false"/>
                <rectangle left="388" top="680" width="318" height="122" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(12);"/>
                <label left="404" top="694" width="318" height="22" text="FALAR COM OS ANIMAIS • D4 • CHARME" fontColor="#A04470" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="404" top="724" width="318" height="60" text="Entende e se comunica com animais interpretando sons, gestos e comportamento." wordWrap="true" fontColor="#754C60" fontSize="11" hitTest="false"/>

                <rectangle left="12" top="814" width="318" height="122" color="#BFD3AF" strokeColor="#79B65A" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(13);"/>
                <label left="28" top="828" width="310" height="22" text="ATLETICISMO • D4 • CORPO" fontColor="#356B48" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="28" top="858" width="318" height="60" text="Especialidade física treinada: escalar, correr, saltar, dançar, esconder-se ou coice." wordWrap="true" fontColor="#4D6547" fontSize="11" hitTest="false"/>
                <rectangle left="388" top="814" width="318" height="122" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(14);"/>
                <label left="404" top="828" width="318" height="22" text="RAIO ATORDOANTE • D4 • MENTE" fontColor="#684DAF" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="404" top="858" width="318" height="60" text="Dispara um raio mágico contra o adversário e pode causar perda de Energia." wordWrap="true" fontColor="#5B4B70" fontSize="11" hitTest="false"/>

                <rectangle left="12" top="948" width="318" height="122" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(15);"/>
                <label left="28" top="962" width="318" height="22" text="TELETRANSPORTE • D4 • MENTE" fontColor="#684DAF" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="28" top="992" width="318" height="60" text="Transporta magicamente o pônei. A dificuldade depende da distância e obstáculos." wordWrap="true" fontColor="#5B4B70" fontSize="11" hitTest="false"/>
                <rectangle left="388" top="948" width="318" height="122" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="16" yradius="16" cursor="handPoint" onClick="addPresetTalent(16);"/>
                <label left="404" top="962" width="310" height="22" text="ENCARAR • D4 • CHARME" fontColor="#A04470" fontSize="12" fontStyle="bold" hitTest="false"/>
                <label left="404" top="992" width="318" height="60" text="Paralisa alguém com um olhar determinado em uma disputa contra Mente." wordWrap="true" fontColor="#754C60" fontSize="11" hitTest="false"/>
            </layout>
        </scrollBox>
    </popup>

    <popup name="popQuirkPresets" width="820" height="560" backOpacity="0.94"
           drawContainer="false" autoScopeNode="false">
        <rectangle align="client" color="#C3C0CE" strokeColor="#F38BB8" strokeSize="2" cornerType="round" xradius="24" yradius="24"/>
        <label left="30" top="22" width="760" height="22" text="CAPRICHOS DO MANUAL" fontColor="#A04470" fontSize="13" fontStyle="bold"/>
        <label left="30" top="50" width="760" height="28" text="Clique para adicionar. Use APLICAR REDUÇÃO somente quando o Capricho atrapalhar a cena." fontColor="#695764" fontSize="11"/>
