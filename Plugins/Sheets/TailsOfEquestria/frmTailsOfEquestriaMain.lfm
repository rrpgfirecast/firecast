                <rectangle left="10" top="200" width="350" height="88" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(5);"/>
                <label left="24" top="210" width="320" height="20" text="MEDROSO" fontColor="#A04470" fontSize="11" fontStyle="bold" hitTest="false"/>
                <label left="24" top="234" width="320" height="44" text="Um medo específico ou geral interfere na ação." wordWrap="true" fontColor="#754C60" fontSize="10" hitTest="false"/>
                <rectangle left="388" top="200" width="350" height="88" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(6);"/>
                <label left="402" top="210" width="320" height="20" text="ESQUECIDO" fontColor="#684DAF" fontSize="11" fontStyle="bold" hitTest="false"/>
