                <rectangle left="10" top="296" width="350" height="88" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(7);"/>
                <label left="24" top="306" width="320" height="20" text="EUEUEUEUEU!" fontColor="#A04470" fontSize="11" fontStyle="bold" hitTest="false"/>
                <label left="24" top="330" width="320" height="44" text="Precisa ser o centro das atenções." wordWrap="true" fontColor="#754C60" fontSize="10" hitTest="false"/>
                <rectangle left="388" top="296" width="350" height="88" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(8);"/>
                <label left="402" top="306" width="320" height="20" text="BAGUNÇADO" fontColor="#684DAF" fontSize="11" fontStyle="bold" hitTest="false"/>
