            <layout width="750" height="890">
                <rectangle left="10" top="8" width="350" height="88" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(1);"/>
