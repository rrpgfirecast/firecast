        <label left="245" top="362" width="190" height="18" text="DIZER A VERDADE" horzTextAlign="center"
               fontColor="#74866B" fontSize="11" hitTest="false"/>

        <rectangle name="rctHarmonyMagic" left="460" top="260" width="190" height="140" color="#DED7C8"
                   strokeColor="#B6C99B" cornerType="round" xradius="18" yradius="18"
                   onClick="chooseHarmony('Magia');"
                   onMouseEnter="paint('rctHarmonyMagic', '#EFE5FA', '#8067D9');"
                   onMouseLeave="paint('rctHarmonyMagic', '#DED7C8', '#B6C99B');"/>
        <label left="460" top="278" width="190" height="52" text="✦" horzTextAlign="center"
               fontSize="31" hitTest="false"/>
        <label left="460" top="336" width="190" height="20" text="MAGIA" horzTextAlign="center"
               fontColor="#8067D9" fontSize="12" fontStyle="bold" hitTest="false"/>
        <label left="460" top="362" width="190" height="18" text="UNIR" horzTextAlign="center"
               fontColor="#74866B" fontSize="11" hitTest="false"/>
    </popup>

    <dataLink fields="{'bodyDie', 'mindDie'}">
        <event name="onChange">
            refreshStamina();
        </event>
    </dataLink>

    <dataLink fields="{'conditionHappy', 'conditionTired', 'conditionScared', 'conditionInspired', 'conditionHurt', 'conditionConfused', 'conditionHungry', 'conditionWet'}">
        <event name="onChange">
            refreshConditions();
        </event>
    </dataLink>

    <dataLink fields="{'pendingDieReduction', 'pendingDieReductionSource'}">
        <event name="onChange">
            refreshDieReductionStatus();
        </event>
    </dataLink>

    <dataLink fields="{'portraitImageStyle', 'cutieMarkImageStyle'}">
        <event name="onChange">
            refreshImageStyles();
            if refreshSettingsPanel ~= nil then refreshSettingsPanel(); end;
        </event>
    </dataLink>

    <dataLink fields="{'settingsTheme', 'settingsFontScale', 'settingsRollPalette', 'settingsRollShowDetails', 'settingsRollExplosionText', 'settingsRollBestFullGold', 'settingsAskLinkedTalent', 'settingsAutoStamina', 'settingsAutoTokenSync', 'settingsTokenFrame', 'settingsTokenVisionAngle', 'settingsTokenLightAngle'}">
        <event name="onChange">
            if applyVisualSettings ~= nil then applyVisualSettings(); end;
            if refreshSettingsPanel ~= nil then refreshSettingsPanel(); end;
        </event>
    </dataLink>

    <dataLink field="portraitURL">
        <event name="onChange">
            portraitURLChanged();
        </event>
    </dataLink>

    <event name="onNodeReady">
        ensureDefaults();
        armPortraitSync();
    </event>
</form>












