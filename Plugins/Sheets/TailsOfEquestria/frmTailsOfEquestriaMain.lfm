            {name="Sementes de flores rápidas", category="Jardinagem", quantity=5, cost=12, source="Equestria", use="Criam flores coloridas com cuidado, água e um pouco de paciência."},
            {name="Guarda-chuva de nuvem", category="Moda mágica", quantity=1, cost=35, source="Equestria", use="Uma pequena nuvem presa ao cabo acompanha o portador e bloqueia chuva ou sol."},
            {name="Patins de gelo", category="Esporte", quantity=1, cost=45, source="Equestria", use="Permitem deslizar por superfícies congeladas com velocidade e estilo."},
            {name="Prancha de nuvem", category="Esporte", quantity=1, cost=90, source="Equestria", use="Ajuda pégasos a surfar correntes de ar e transportar um passageiro leve."},
            {name="Máquina de bolhas portátil", category="Diversão", quantity=1, cost=25, source="Equestria", use="Cria uma nuvem de bolhas perfeita para festas, distrações e entradas alegres."},
            {name="Estojo de joias e fitas", category="Cosmético", quantity=1, cost=40, source="Equestria", use="Acessórios para decorar crinas, caudas, roupas e presentes."},
            {name="Câmera instantânea de lembranças", category="Utilidade mágica", quantity=1, cost=75, source="Equestria", use="Registra momentos da aventura e revela a imagem imediatamente."}
