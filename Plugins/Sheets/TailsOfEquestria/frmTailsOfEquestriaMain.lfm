                <rectangle left="10" top="392" width="350" height="88" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(9);"/>
                <label left="24" top="402" width="320" height="20" text="INGÊNUO" fontColor="#A04470" fontSize="11" fontStyle="bold" hitTest="false"/>
                <label left="24" top="426" width="320" height="44" text="Acredita facilmente e não percebe segundas intenções." wordWrap="true" fontColor="#754C60" fontSize="10" hitTest="false"/>
                <rectangle left="388" top="392" width="350" height="88" color="#C7B7D8" strokeColor="#9D7FDC" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(10);"/>
                <label left="402" top="402" width="320" height="20" text="MANIA DE PERFEIÇÃO" fontColor="#684DAF" fontSize="11" fontStyle="bold" hitTest="false"/>
                <label left="402" top="426" width="320" height="44" text="Não suporta coisas sujas, tortas ou imperfeitas." wordWrap="true" fontColor="#5B4B70" fontSize="10" hitTest="false"/>

                <rectangle left="10" top="488" width="350" height="88" color="#D8BCCB" strokeColor="#F38BB8" cornerType="round" xradius="15" yradius="15" cursor="handPoint" onClick="addPresetQuirk(11);"/>
                <label left="24" top="498" width="320" height="20" text="VISÃO RUIM" fontColor="#A04470" fontSize="11" fontStyle="bold" hitTest="false"/>
                <label left="24" top="522" width="320" height="44" text="Enxerga mal e confunde objetos, amigos ou perigos." wordWrap="true" fontColor="#754C60" fontSize="10" hitTest="false"/>
