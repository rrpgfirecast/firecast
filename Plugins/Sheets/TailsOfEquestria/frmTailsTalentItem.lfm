    <popup name="popDeleteTalent" width="520" height="300" backOpacity="0.94"
           drawContainer="false" autoScopeNode="true">
        <rectangle align="client" color="#FFE4A8" strokeColor="#F05F6A" strokeSize="1"
                   cornerType="round" xradius="16" yradius="16"/>
        <label left="30" top="24" width="460" height="18" text="EXCLUIR TALENTO"
               fontColor="#F05F6A" fontSize="13" fontStyle="bold"/>
        <label left="30" top="50" width="460" height="54" text="⚠" horzTextAlign="center"
               fontSize="33" hitTest="false"/>
        <label left="30" top="106" width="460" height="28"
               text="ESTA AÇÃO REMOVE O TALENTO DA FICHA."
               horzTextAlign="center" fontColor="#405237" fontSize="14" fontStyle="bold"/>
        <rectangle name="rctCancelDelete" left="42" top="164" width="196" height="104" color="#DED7C8"
                   strokeColor="#B6C99B" cornerType="round" xradius="18" yradius="18"
                   onClick="self.popDeleteTalent:close();"
                   onMouseEnter="paint('rctCancelDelete', '#EEF5E9', '#5F9F57');"
                   onMouseLeave="paint('rctCancelDelete', '#DED7C8', '#B6C99B');"/>
        <label left="42" top="176" width="196" height="38" text="↩" horzTextAlign="center"
               fontSize="24" hitTest="false"/>
        <label left="42" top="222" width="196" height="20" text="MANTER TALENTO"
               horzTextAlign="center" fontColor="#405237" fontSize="13" fontStyle="bold" hitTest="false"/>
        <rectangle name="rctConfirmDelete" left="282" top="164" width="196" height="104" color="#D8B7C0"
                   strokeColor="#F05F6A" cornerType="round" xradius="18" yradius="18"
                   onClick="deleteTalent();"
                   onMouseEnter="paint('rctConfirmDelete', '#FFD0D8', '#C73658');"
                   onMouseLeave="paint('rctConfirmDelete', '#D8B7C0', '#F05F6A');"/>
        <label left="282" top="176" width="196" height="38" text="✖" horzTextAlign="center"
               fontSize="24" hitTest="false"/>
        <label left="282" top="222" width="196" height="20" text="EXCLUIR AGORA"
               horzTextAlign="center" fontColor="#C73658" fontSize="13" fontStyle="bold" hitTest="false"/>
    </popup>

    <dataLink field="name" defaultValue="Novo Talento"/>
    <dataLink field="kind" defaultValue="Adquirido"/>
    <dataLink field="die" defaultValue="4"/>
    <dataLink field="linkedTrait" defaultValue="Livre"/>
    <dataLink field="usedThisAdventure" defaultValue="false">
        <event name="onChange">
            refreshUsedState();
        </event>
    </dataLink>
    <event name="onNodeReady">
        ensureLinkedTrait();
        refreshUsedState();
    </event>
</form>





