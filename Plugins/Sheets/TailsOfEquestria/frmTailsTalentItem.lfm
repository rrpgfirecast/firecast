<?xml version="1.0" encoding="UTF-8"?>
<form name="frmTailsTalentItem" height="136" theme="light">
    <script>
        require("rrpg.lua");
        require("ndb.lua");
        local ExplodingRolls = require("tails_exploding_rolls.lua");

        local function paint(controlName, color, strokeColor)
            local control = self[controlName];
            if control == nil then return; end;
            control.color = color;
            control.strokeColor = strokeColor;
        end;

        local function linkedTraitField()
            if sheet == nil then return nil, nil; end;
            if sheet.linkedTrait == "Corpo" then return "bodyDie", "Corpo"; end;
            if sheet.linkedTrait == "Mente" then return "mindDie", "Mente"; end;
            if sheet.linkedTrait == "Charme" then return "charmDie", "Charme"; end;
            return nil, nil;
        end;

        local function reduceDie(sides)
            local scale = {4, 6, 8, 10, 12, 20};
            local numericSides = tonumber(sides) or 4;
            for index, value in ipairs(scale) do
                if value == numericSides then
                    if index &gt; 1 then return scale[index - 1]; end;
                    return scale[1];
                end;
            end;
            return 4;
        end;

        local function rollOptions(root)
            if root == nil then return nil; end;
            return {
                palette = root.settingsRollPalette or "colorido",
                showExplosions = root.settingsRollExplosionText ~= false,
                showDetails = root.settingsRollShowDetails ~= false,
                bestFullGold = root.settingsRollBestFullGold == true
            };
        end;

        local function rollTalent()
            if sheet == nil then return; end;
            local room = Firecast.getMesaDe(sheet);
            if room == nil then
                showMessage("Abra a ficha dentro de uma mesa para enviar rolagens ao chat.");
                return;
            end;
            local talentSides = tonumber(sheet.die) or 4;
            local name = sheet.name or "Talento";
            local traitField, traitName = linkedTraitField();
            local talentsNode = NDB.getParent(sheet);
            local root = NDB.getParent(talentsNode);
            local reductionActive = root ~= nil and root.pendingDieReduction == true;
            local reductionSource = root ~= nil and root.pendingDieReductionSource or "Capricho";
            local options = rollOptions(root);
            if reductionActive then
                talentSides = reduceDie(talentSides);
                root.pendingDieReduction = false;
                root.pendingDieReductionSource = nil;
            end;
            local titleSuffix = reductionActive and (" | ↓ " .. reductionSource) or "";
            local characterName = root ~= nil and root.characterName or "Personagem";
            if characterName == nil or characterName == "" then characterName = "Personagem"; end;

            if traitField == nil or root == nil then
                ExplodingRolls.rollSingleEx(room, talentSides, name .. titleSuffix, characterName, options);
                return;
            end;

            local traitSides = tonumber(root[traitField]) or 4;
            if reductionActive then traitSides = reduceDie(traitSides); end;
            ExplodingRolls.rollBestOfEx(room, {
                {sides=traitSides, label=traitName},
                {sides=talentSides, label=name}
            }, traitName .. " + " .. name .. titleSuffix, characterName, options);
        end;

        local function showKindPopup()
            self.popTalentKind:show("center", self.rctKind);
        end;

        local function chooseKind(value)
            if sheet ~= nil then sheet.kind = value; end;
            self.popTalentKind:close();
        end;

        local function showTraitPopup()
            self.popTalentTrait:show("center", self.rctTrait);
        end;

        local function chooseTrait(value)
            if sheet ~= nil then sheet.linkedTrait = value; end;
            self.popTalentTrait:close();
        end;

        local function showDiePopup()
            self.popTalentDie:show("center", self.rctDie);
        end;

        local function chooseDie(value)
            if sheet ~= nil then sheet.die = value; end;
            self.popTalentDie:close();
        end;

        local function showDeletePopup()
            self.popDeleteTalent:show("center", self.rctDelete);
        end;

        local function refreshUsedState()
            if self.rctUsed == nil or self.lblUsed == nil then return; end;
            local used = sheet ~= nil and sheet.usedThisAdventure == true;
            if used then
                self.rctUsed.color = "#FFD469";
                self.rctUsed.strokeColor = "#F2B84B";
                self.lblUsed.text = "USADO ★";
            else
                self.rctUsed.color = "#DFD5B9";
                self.rctUsed.strokeColor = "#B6C99B";
                self.lblUsed.text = "MARCAR USO";
            end;
        end;

        local function toggleUsed()
            if sheet == nil then return; end;
            sheet.usedThisAdventure = not (sheet.usedThisAdventure == true);
            refreshUsedState();
        end;

        local function deleteTalent()
            self.popDeleteTalent:close();
            NDB.deleteNode(sheet);
        end;

        local function ensureLinkedTrait()
            if sheet == nil or sheet.linkedTrait ~= nil then return; end;
            if sheet.name == "Coração Intrépido" then
                sheet.linkedTrait = "Corpo";
            elseif sheet.name == "Telecinese" then
                sheet.linkedTrait = "Mente";
            elseif sheet.name == "Voar" then
                sheet.linkedTrait = "Corpo";
            else
                sheet.linkedTrait = "Livre";
            end;
        end;
    </script>

    <rectangle align="client" margins="{left=2, right=2, top=4, bottom=4}"
               color="#FFF2D6" strokeColor="#7FCB5C" strokeSize="1"
               cornerType="round" xradius="16" yradius="16"/>
