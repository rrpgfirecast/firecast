    <edit transparent="true" left="16" top="32" width="270" height="34" field="name"
          fontColor="#33452D" fontSize="13" fontStyle="bold"/>
    <edit transparent="true" left="16" top="76" width="270" height="42" field="description"
          fontColor="#5F9F57" fontSize="13"/>

