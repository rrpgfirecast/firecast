<?xml version="1.0" encoding="UTF-8"?>
<form name="templateSkinPlayer" width="150" height="220" margins="{top=4,bottom=4,left=4,right=4}">
<style>
label, button {
    fontFamily: Cambria;
    fontColor: white;
    fontStyle: bold;
}
</style>

<script><![CDATA[
local function atualizarCard(form)
    if form == nil or form.sheet == nil then return end

    local liberada = tostring(form.sheet.liberada or "") == "true"
    form.visible = liberada

    local btn = form:findControlByName("btnEquiparSkin")
    local ficha = NDB.getRoot(form.sheet)

    if btn ~= nil then
        if ficha ~= nil and tostring(ficha.SkinEquipadaUid or "") == tostring(form.sheet.uidSkin or "") then
            btn.text = "Desequipar"
        else
            btn.text = "Equipar"
        end
    end
end
]]></script>

<rectangle align="client" color="#202020DD" strokeColor="#A07A2D" strokeSize="1" xradius="6" yradius="6" cornerType="round">
    <image field="imagemSkin" left="5" top="5" width="140" height="210" style="autoFit" animate="true" showProgress="false"/>

    <rectangle left="18" top="6" width="114" height="32" color="#00000055" strokeColor="#00000000" strokeSize="0"/>

    <label field="nomeSkin" left="16" top="8" width="114" height="28"
           horzTextAlign="center" vertTextAlign="center" fontSize="12" fontColor="#000000"/>
    <label field="nomeSkin" left="20" top="8" width="114" height="28"
           horzTextAlign="center" vertTextAlign="center" fontSize="12" fontColor="#000000"/>
    <label field="nomeSkin" left="18" top="6" width="114" height="28"
           horzTextAlign="center" vertTextAlign="center" fontSize="12" fontColor="#000000"/>
    <label field="nomeSkin" left="18" top="10" width="114" height="28"
           horzTextAlign="center" vertTextAlign="center" fontSize="12" fontColor="#000000"/>
    <label field="nomeSkin" left="18" top="8" width="114" height="28"
           horzTextAlign="center" vertTextAlign="center" fontSize="12" fontColor="#FFFFFF"/>

    <rectangle left="24" top="186" width="102" height="28" color="#00000077" strokeColor="#A07A2D" strokeSize="1" xradius="4" yradius="4" cornerType="round"/>

    <button name="btnEquiparSkin" left="26" top="188" width="98" height="24" text="Equipar">
        <event name="onClick"><![CDATA[
            CWNA_equiparOuDesequiparSkin(sheet)
            atualizarCard(self)
        ]]></event>
    </button>

    <dataLink fields="{'nomeSkin','imagemSkin','liberada','uidSkin','atualizacaoSkin'}">
        <event name="onChange"><![CDATA[
            atualizarCard(self)
        ]]></event>
    </dataLink>
</rectangle>
</form>
