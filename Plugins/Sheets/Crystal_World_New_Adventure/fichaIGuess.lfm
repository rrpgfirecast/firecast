<rectangle left="110" top="167" width="44" height="22" color="#000000">

    <edit
        name="edtXP"
        field="XP"
        align="client"
        type="number"
        fontColor="white"
        horzTextAlign="center"
        enabled="false"/>

</rectangle>

<dataLink field="XP" defaultValue="0"/>

<button
    text="🔒"
    left="86"
    top="167"
    width="22"
    height="22">

    <event name="onClick"><![CDATA[

        Dialogs.inputQuery(
            "Senha",
            "Senha ADM:",
            "",

            function(senha)

                if senha == nil then
                    return
                end

                if senha ~= "151289" then
                    showMessage("Senha incorreta!")
                    return
                end

                local xpEdit = self:findControlByName("edtNovaXP")
                local painel = self:findControlByName("PainelEditarXP")

                xpEdit.text = tostring(sheet.XP or 0)

                painel.visible = true

            end
        )

    ]]></event>

</button>

<rectangle
    name="PainelEditarXP"
    left="400"
    top="300"
    width="220"
    height="150"
    color="#111111"
    visible="false">

    <!-- TOPO -->
    <rectangle
        left="0"
        top="0"
        width="220"
        height="30"
        color="#3A3A3A">

        <label
            left="0"
            top="5"
            width="220"
            height="20"
            text="GERENCIAR XP"
            fontColor="white"
            horzTextAlign="center"/>

    </rectangle>

    <!-- LINHA -->
    <rectangle
        left="10"
        top="35"
        width="200"
        height="2"
        color="#C8A000"/>

    <label
        left="20"
        top="55"
        width="80"
        height="20"
        text="XP:"
        fontColor="#FFD700"/>

    <edit
        name="edtNovaXP"
        left="105"
        top="52"
        width="90"
        height="25"
        type="number"
        horzTextAlign="center"
        fontColor="white"/>

    <!-- TRAVAR/DESBLOQUEAR -->

    <button
        name="btnPermitirEdicaoXP"
        text="🔒"
        left="165"
        top="90"
        width="30"
        height="25">

        <event name="onClick"><![CDATA[

            local xp = self:findControlByName("edtXP")
            local botao = self:findControlByName("btnPermitirEdicaoXP")

            if xp == nil then
                showMessage("Campo XP não encontrado.")
                return
            end

            if tostring(sheet.PermitirEditarXP or "true") == "true" then

                sheet.PermitirEditarXP = "false"
                xp.enabled = false
                botao.text = "🔒"

            else

                sheet.PermitirEditarXP = "true"
                xp.enabled = true
                botao.text = "🔓"

            end

        ]]></event>

    </button>

    <!-- CONFIRMAR -->

    <button
        name="btnConfirmarXP"
        text="CONFIRMAR"
        left="55"
        top="120"
        width="110"
        height="22">

        <event name="onClick"><![CDATA[

            local xpEdit = self:findControlByName("edtNovaXP")

            local xp = tonumber(xpEdit.text)

            if xp == nil then
                showMessage("Digite um valor válido.")
                return
            end

            if xp < 0 then
                xp = 0
            end

            sheet.XP = xp

            local painel = self:findControlByName("PainelEditarXP")
            painel.visible = false

        ]]></event>

    </button>

</rectangle>

<dataLink field="PermitirEditarXP" defaultValue="true">
    <event name="onChange"><![CDATA[
        local xp = self:findControlByName("edtXP")
        local botao = self:findControlByName("btnPermitirEdicaoXP")
        local liberado = tostring(self.sheet.PermitirEditarXP or "true") == "true"

        if xp ~= nil then
            xp.enabled = liberado
        end

        if botao ~= nil then
            botao.text = liberado and "🔓" or "🔒"
        end
    ]]></event>
</dataLink>
















