<script><![CDATA[

--------------------------------------------------
-- UTILS
--------------------------------------------------

local slots = {"Capacete", "Peitoral", "Escudo", "Bota", "Calca", "Arma"}

local function n(v)
    if v == nil then return 0 end
    local s = tostring(v):gsub(",", ".")
    return tonumber(s) or 0
end

function CWNA_mostrarAvisoPerfil(controle, texto, duracao)
    local ctrl = controle
    local aviso = nil
    local label = nil

    while ctrl ~= nil and aviso == nil do
        if ctrl.findControlByName ~= nil then
            aviso = ctrl:findControlByName("avisoPerfilFicha")
            label = ctrl:findControlByName("lblAvisoPerfilFicha")
        end

        ctrl = ctrl.parent
    end

    if aviso == nil then
        showMessage(texto or "")
        return
    end

    if label ~= nil then
        label.text = texto or ""
    end

    aviso.visible = true
    pcall(function() aviso:bringToFront() end)
    setTimeout(function()
        if aviso ~= nil then
            pcall(function() aviso:bringToFront() end)
        end
    end, 1)

    setTimeout(function()
        if aviso ~= nil then
            aviso.visible = false
        end
    end, duracao or 2600)
end

local function CWNA_gastarPPAtaque(sheet, campoCustoPP, nomeAtaque, controleOrigem)
    local custo = math.max(0, n(sheet[campoCustoPP]))

    if custo <= 0 then
        return true
    end

    local mesa = Firecast.getMesaDe(sheet)

    if mesa == nil then
        return false
    end

    local jogador = mesa.me
    local chat = mesa.activeChat or mesa.chat

    if jogador == nil or chat == nil then
        CWNA_mostrarAvisoPerfil(controleOrigem, "Jogador ou chat nao disponivel.")
        return false
    end

    local ppAtual = nil
    pcall(function()
        ppAtual = jogador:getBarValue(2)
    end)

    if ppAtual == nil then
        CWNA_mostrarAvisoPerfil(controleOrigem, "Barra de PP nao disponivel.")
        return false
    end

    if ppAtual < custo then
        CWNA_mostrarAvisoPerfil(controleOrigem, "PP insuficiente para usar " .. nomeAtaque .. ".")
        return false
    end

    pcall(function()
        chat:enviarMensagem("/PP -" .. custo)
    end)

    return true
end

local slotsPorTipoInventario = {
    capacete = "Capacete",
    peitoral = "Peitoral",
    escudo = "Escudo",
    bota = "Bota",
    calca = "Calca",
    ["calÃƒÂ§a"] = "Calca",
    arma = "Arma"
}

local tiposPotionInventario = {
    ["potion hp"] = "HP",
    ["potion pp"] = "PP"
}

local imagensPadraoInventario = {
    Capacete = "/Frames/Capacete.png",
    Peitoral = "/Frames/Peitoral.png",
    Escudo = "/Frames/Escudo.png",
    Bota = "/Frames/Bota.png",
    Calca = "/Frames/Calca.png",
    Arma = "/Frames/Arma.png"
}

local partesBonecoInventario = {
    Capacete = "capacete",
    Peitoral = "peitoral",
    Bota = "bota",
    Calca = "calca"
}

local camposDadosItemInventario = {
    "uidInventario",
    "nomeItem",
    "tipoItem",
    "subtipoMaterial",
    "RankItem",
    "imagemestilo2",
    "quantidade",
    "hp",
    "pp",
    "ca",
    "rd",
    "dano",
    "cura",
    "origemLoja",
    "uidLojaOrigem",
    "precoLojaPrata",
    "descricaoLoja"
}

local catalogoVisualEquipamentosInventario = {
    ["rank e"] = {rank = "e"},
    ["rank d"] = {rank = "d"},
    ["rank c"] = {rank = "c"},
    ["rank b"] = {rank = "b"},
    ["rank a"] = {rank = "a"},
    ["rank s"] = {rank = "s"},
    ["rank ss"] = {rank = "s"},

    ["capacete de pano velho"] = {rank = "e", partes = {Capacete = "capacete_e"}},
    ["camisa esfarrapada"] = {rank = "e", partes = {Peitoral = "peitoral_e"}},
    ["calcas rasgadas"] = {rank = "e", partes = {Calca = "calca_e"}},
    ["sandalias de couro gastas"] = {rank = "e", partes = {Bota = "bota_e"}},

    ["chapeu de viagem"] = {rank = "d", partes = {Capacete = "capacete_d"}},
    ["tunica reforcada"] = {rank = "d", partes = {Peitoral = "peitoral_d"}},
    ["calcas de lona"] = {rank = "d", partes = {Calca = "calca_d"}},
    ["botas de algodao grosso"] = {rank = "d", partes = {Bota = "bota_d"}},

    ["elmo de couro enrijecido"] = {rank = "c", partes = {Capacete = "capacete_c"}},
    ["peitoral de couro curtido"] = {rank = "c", partes = {Peitoral = "peitoral_c"}},
    ["perneiras de couro com fivelas"] = {rank = "c", partes = {Calca = "calca_c"}},
    ["botas altas de couro"] = {rank = "c", partes = {Bota = "bota_c"}},

    ["elmo de cobre com narigueira"] = {rank = "b", partes = {Capacete = "capacete_b"}},
    ["peitoral de escamas de cobre"] = {rank = "b", partes = {Peitoral = "peitoral_b"}},
    ["grevas de cobre leves"] = {rank = "b", partes = {Calca = "calca_b"}},
    ["botas de cobre reforcadas"] = {rank = "b", partes = {Bota = "bota_b"}}
}

local atributosInventario = {
    {campoItem = "hp", prefixoSlot = "Hp"},
    {campoItem = "pp", prefixoSlot = "Pp"},
    {campoItem = "ca", prefixoSlot = "Ca"},
    {campoItem = "rd", prefixoSlot = "Rd"},
    {campoItem = "dano", prefixoSlot = "Dano"},
    {campoItem = "cura", prefixoSlot = "Cura"}
}

local function limparTextoInventario(valor)
    return string.lower(tostring(valor or "")):gsub("^%s*(.-)%s*$", "%1")
end

local function normalizarChaveCatalogoInventario(valor)
    local texto = limparTextoInventario(valor)
    texto = texto:gsub("á", "a"):gsub("à", "a"):gsub("ã", "a"):gsub("â", "a")
    texto = texto:gsub("é", "e"):gsub("ê", "e")
    texto = texto:gsub("í", "i")
    texto = texto:gsub("ó", "o"):gsub("ô", "o"):gsub("õ", "o")
    texto = texto:gsub("ú", "u"):gsub("ü", "u")
    texto = texto:gsub("ç", "c")
    return texto
end

local function slotDoItemInventario(item)
    return slotsPorTipoInventario[normalizarChaveCatalogoInventario(item and item.tipoItem)]
end

local function tipoPotionDoItemInventario(item)
    return tiposPotionInventario[limparTextoInventario(item and item.tipoItem)]
end

local function rotuloTipoItemInventario(item)
    local tipo = limparTextoInventario(item and item.tipoItem)

    if tipo == "" then
        return "outros"
    end

    return tipo
end

local function chaveNomeItemInventario(item)
    local nome = normalizarChaveCatalogoInventario(item and item.nomeItem)
    nome = nome:gsub("[_%-%:]+", " ")
    nome = nome:gsub("%s+", " ")

    return nome
end

local function visualDoItemInventario(item)
    local nome = chaveNomeItemInventario(item)
    local entrada = catalogoVisualEquipamentosInventario[nome]

    if entrada ~= nil then
        return entrada
    end

    local rankNoNome = nome:match("rank%s+(%a+)")

    if rankNoNome ~= nil then
        return catalogoVisualEquipamentosInventario["rank " .. rankNoNome]
    end

    return nil
end

local function imagemBaseBonecoInventario(slot)
    local parte = partesBonecoInventario[slot]

    if parte == nil then
        return nil
    end

    return "/Frames/equipes/" .. parte .. "_base.png"
end

local function imagemEquipamentoBonecoInventario(item, slot)
    local parte = partesBonecoInventario[slot]
    local entrada = visualDoItemInventario(item)

    if parte == nil or entrada == nil then
        return imagemBaseBonecoInventario(slot)
    end

    local nomeArquivo = nil

    if entrada.partes ~= nil then
        nomeArquivo = entrada.partes[slot]
    end

    if nomeArquivo == nil and entrada.rank ~= nil then
        nomeArquivo = parte .. "_" .. entrada.rank
    end

    if nomeArquivo == nil or entrada.rank == nil then
        return imagemBaseBonecoInventario(slot)
    end

    return "/Frames/equipes/" .. entrada.rank .. "/" .. nomeArquivo .. ".png"
end

function CWNA_uidSkin()
    return tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
end

local SKIN_RANK_C_TESTE_UID = "cwna_skin_rank_c_teste"
local SKIN_RANK_C_TESTE_NOME = "RANK C TESTE"
local SKIN_RANK_C_TESTE_IMAGEM = "https://blob.firecast.com.br/blobs/HIGCMCDM_4483065/Firefly_preciso_somente_da_capa_se_mechend.mp4"

function CWNA_recalcularVisualSkinInventario(ficha, controleOrigem)
    if atualizarVisualSkinInventario ~= nil then
        atualizarVisualSkinInventario(ficha, controleOrigem)
    end
end

local function CWNA_atualizarCardsSkinInventario(ficha)
    if ficha == nil or ficha.skins == nil then
        return
    end

    local marcador = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))

    for _, skin in ipairs(NDB.getChildNodes(ficha.skins)) do
        skin.atualizacaoSkin = marcador
    end
end

local function skinEquipadaInventario(ficha)
    if ficha == nil or ficha.skins == nil or ficha.SkinEquipadaUid == nil or ficha.SkinEquipadaUid == "" then
        return nil
    end

    for _, skin in ipairs(NDB.getChildNodes(ficha.skins)) do
        if tostring(skin.uidSkin or "") == tostring(ficha.SkinEquipadaUid or "") then
            return skin
        end
    end

    return nil
end

local skinsAutomaticasRankInventario = {
    {rank = "c", campo = "BonecoSkinRankC", imagem = "/Frames/Skins/rankc.png"},
    {rank = "b", campo = "BonecoSkinRankB", imagem = "/Frames/Skins/rankb.png"},
    {rank = "a", campo = "BonecoSkinRankA", imagem = "/Frames/Skins/ranka.png"},
    {rank = "s", campo = "BonecoSkinRankS", imagem = "/Frames/Skins/ranks.png"}
}

local function skinPorUidInventario(ficha, uid)
    if ficha == nil or ficha.skins == nil or uid == nil then
        return nil
    end

    for _, skin in ipairs(NDB.getChildNodes(ficha.skins)) do
        if tostring(skin.uidSkin or "") == tostring(uid or "") then
            return skin
        end
    end

    return nil
end

local function ehSkinRankCTesteInventario(skin)
    return skin ~= nil and (
        tostring(skin.uidSkin or "") == SKIN_RANK_C_TESTE_UID or
        string.upper(tostring(skin.nomeSkin or "")) == SKIN_RANK_C_TESTE_NOME
    )
end

local function garantirSkinRankCTesteInventario(ficha)
    if ficha == nil then
        return
    end

    if ficha.skins == nil then
        NDB.createChildNode(ficha, "skins")
    end

    local skin = skinPorUidInventario(ficha, SKIN_RANK_C_TESTE_UID)

    if skin == nil then
        for _, skinExistente in ipairs(NDB.getChildNodes(ficha.skins)) do
            if string.upper(tostring(skinExistente.nomeSkin or "")) == SKIN_RANK_C_TESTE_NOME then
                skin = skinExistente
                break
            end
        end
    end

    if skin == nil then
        skin = NDB.createChildNode(ficha.skins, "skin")
    end

    skin.uidSkin = SKIN_RANK_C_TESTE_UID
    skin.nomeSkin = SKIN_RANK_C_TESTE_NOME
    skin.imagemSkin = SKIN_RANK_C_TESTE_IMAGEM
    skin.liberada = "true"
end

local function removerSkinRankCTesteNaoDesbloqueadaInventario(ficha)
    if ficha == nil or ficha.skins == nil then
        return false
    end

    local removeu = false

    for _, skin in ipairs(NDB.getChildNodes(ficha.skins)) do
        if ehSkinRankCTesteInventario(skin) and tostring(skin.desbloqueioSetC or "") ~= "true" then
            if tostring(ficha.SkinEquipadaUid or "") == tostring(skin.uidSkin or "") then
                ficha.SkinEquipadaUid = ""
            end

            NDB.deleteNode(skin)
            removeu = true
        end
    end

    return removeu
end

local function corrigirSkinRankCTesteEquipadaAntigaInventario(ficha)
    if ficha == nil then
        return false
    end

    if tostring(ficha.SkinEquipadaUid or "") == SKIN_RANK_C_TESTE_UID and tostring(ficha.SkinRankCTesteEquipCorrigido or "") ~= "true" then
        ficha.SkinEquipadaUid = ""
        ficha.SkinRankCTesteEquipCorrigido = "true"
        return true
    end

    if tostring(ficha.SkinEquipadaUid or "") ~= SKIN_RANK_C_TESTE_UID then
        ficha.SkinRankCTesteEquipCorrigido = "true"
    end

    return false
end

local function desbloquearSkinRankCTesteInventario(ficha, controleOrigem)
    if ficha == nil then
        return false
    end

    if ficha.skins == nil then
        NDB.createChildNode(ficha, "skins")
    end

    local skin = skinPorUidInventario(ficha, SKIN_RANK_C_TESTE_UID)

    if skin == nil then
        for _, skinExistente in ipairs(NDB.getChildNodes(ficha.skins)) do
            if string.upper(tostring(skinExistente.nomeSkin or "")) == SKIN_RANK_C_TESTE_NOME then
                skin = skinExistente
                break
            end
        end
    end

    local desbloqueouAgora = skin == nil or tostring(skin.desbloqueioSetC or "") ~= "true"
    local limparEquipamentoAntigo = desbloqueouAgora and skin ~= nil and tostring(ficha.SkinEquipadaUid or "") == tostring(skin.uidSkin or "")

    if skin == nil then
        skin = NDB.createChildNode(ficha.skins, "skin")
    end

    skin.uidSkin = SKIN_RANK_C_TESTE_UID
    skin.nomeSkin = SKIN_RANK_C_TESTE_NOME
    skin.imagemSkin = SKIN_RANK_C_TESTE_IMAGEM
    skin.liberada = "true"
    skin.desbloqueioSetC = "true"

    if limparEquipamentoAntigo then
        ficha.SkinEquipadaUid = ""
    end

    if desbloqueouAgora then
        return true
    end

    return false
end

local function conjuntoRankCompletoInventario(dadosPorSlot, rank)
    local slotsSet = {"Capacete", "Peitoral", "Calca", "Bota"}

    for _, slot in ipairs(slotsSet) do
        local dados = dadosPorSlot and dadosPorSlot[slot] or nil
        local entrada = visualDoItemInventario(dados)

        if entrada == nil or tostring(entrada.rank or "") ~= tostring(rank or "") then
            return false
        end
    end

    return true
end

local function limparSkinsAutomaticasAntigasInventario(ficha)
    if ficha == nil or ficha.skins == nil then
        return false
    end

    local removeu = false

    for _, skin in ipairs(NDB.getChildNodes(ficha.skins)) do
        if tostring(skin.skinAutomatica or "") == "true" then
            if tostring(ficha.SkinEquipadaUid or "") == tostring(skin.uidSkin or "") then
                ficha.SkinEquipadaUid = ""
            end

            NDB.deleteNode(skin)
            removeu = true
        end
    end

    return removeu
end

local function skinRankAtivaInventario(dadosPorSlot)
    for _, skinAuto in ipairs(skinsAutomaticasRankInventario) do
        if conjuntoRankCompletoInventario(dadosPorSlot, skinAuto.rank) then
            return skinAuto
        end
    end

    return nil
end

local function limparCamposSkinRankInventario(ficha)
    if ficha == nil then
        return
    end

    ficha.BonecoSkinRankCTeste = ""

    for _, skinAuto in ipairs(skinsAutomaticasRankInventario) do
        ficha[skinAuto.campo] = ""
    end
end

local function fixNumeroInventario(v)
    if v == nil then return 0 end

    local s = tostring(v)
    s = s:gsub("%s+", "")
    s = s:gsub(",", ".")

    return tonumber(s) or 0
end

local function uidInventarioItem(item)
    if item == nil then
        return nil
    end

    if item.uidInventario == nil or item.uidInventario == "" then
        item.uidInventario = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
    end

    return item.uidInventario
end

local function procurarItemInventarioPorUid(ficha, uid)
    if ficha == nil or uid == nil then
        return nil
    end

    local lista = ficha.magias2

    if lista == nil then
        return nil
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if item.uidInventario == uid then
            return item
        end
    end

    return nil
end

local function ehSlotVazioInventario(item)
    return item ~= nil and tostring(item.slotVazio or "") == "true"
end

local function contarItensReaisInventario(lista)
    local total = 0

    if lista == nil then
        return total
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if not ehSlotVazioInventario(item) then
            total = total + 1
        end
    end

    return total
end

local function contarNosInventario(lista)
    local total = 0

    if lista == nil then
        return total
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        total = total + 1
    end

    return total
end

local function prepararSlotVazioInventario(slot, ordem)
    if slot == nil then
        return
    end

    slot.slotVazio = "true"
    slot.ordemInventario = ordem
    slot.uidInventario = "slot_" .. tostring(ordem)
    slot.nomeItem = ""
    slot.tipoItem = ""
    slot.RankItem = ""
    slot.imagemestilo2 = ""
    slot.equipadoEm = ""
    slot.quantidade = ""
    slot.hp = 0
    slot.pp = 0
    slot.ca = 0
    slot.rd = 0
    slot.dano = 0
    slot.cura = 0
    slot.origemLoja = ""
    slot.uidLojaOrigem = ""
    slot.precoLojaPrata = ""
    slot.descricaoLoja = ""
    slot.subtipoMaterial = ""
end

function CWNA_inicializarSlotsInventario(ficha, listaControle)
    if ficha == nil then
        return
    end

    local lista = ficha.magias2

    if lista == nil and listaControle ~= nil then
        lista = listaControle.node
    end

    if lista == nil then
        lista = NDB.createChildNode(ficha, "magias2")
    end

    if lista == nil then
        return
    end

    local totalNos = contarNosInventario(lista)

    if totalNos >= 60 then
        CWNA_garantirSlotsInventario(ficha, listaControle)
        ficha.SlotsInventarioCriados = "true"
        return
    end

    if ficha.SlotsInventarioCriados == "true" then
        return
    end

    local usados = {}

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        local ordem = tonumber(item.ordemInventario)

        if ordem ~= nil and ordem >= 1 and ordem <= 60 then
            usados[ordem] = true
        end
    end

    for i = 1, 60 do
        if totalNos >= 60 then
            break
        end

        if usados[i] ~= true then
            local slot = nil

            if listaControle ~= nil and listaControle.append ~= nil then
                slot = listaControle:append()
            end

            if slot == nil then
                slot = NDB.createChildNode(lista, "item")
            end

            if slot ~= nil then
                prepararSlotVazioInventario(slot, i)
                usados[i] = true
                totalNos = totalNos + 1
            end
        end
    end

    ficha.SlotsInventarioCriados = "true"
end

function CWNA_garantirSlotsInventario(ficha, listaControle)
    if ficha == nil and listaControle == nil then
        return
    end

    local lista = ficha and ficha.magias2 or nil

    if lista == nil and listaControle ~= nil then
        lista = listaControle.node
    end

    if lista == nil then
        return
    end

    local totalNos = 0
    local slotsVazios = {}

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        totalNos = totalNos + 1

        if ehSlotVazioInventario(item) then
            table.insert(slotsVazios, item)
        end
    end

    if totalNos > 60 then
        table.sort(slotsVazios, function(a, b)
            local ordemA = tonumber(a.ordemInventario) or 999999
            local ordemB = tonumber(b.ordemInventario) or 999999

            if ordemA ~= ordemB then
                return ordemA > ordemB
            end

            return tostring(a.uidInventario or "") > tostring(b.uidInventario or "")
        end)

        for _, slot in ipairs(slotsVazios) do
            if totalNos <= 60 then
                break
            end

            NDB.deleteNode(slot)
            totalNos = totalNos - 1
        end
    end

    local usados = {}
    local livres = {}

    for i = 1, 60 do
        livres[i] = true
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if item.uidInventario == nil or item.uidInventario == "" then
            item.uidInventario = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
        end

        local ordem = tonumber(item.ordemInventario)

        if ordem ~= nil and ordem >= 1 and ordem <= 60 and usados[ordem] == nil then
            usados[ordem] = item
            livres[ordem] = nil
        end
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        local ordem = tonumber(item.ordemInventario)

        if ordem == nil or ordem < 1 or ordem > 60 or usados[ordem] ~= item then
            for i = 1, 60 do
                if livres[i] then
                    item.ordemInventario = i
                    usados[i] = item
                    livres[i] = nil
                    break
                end
            end
        end
    end

    for i = 1, 60 do
        if usados[i] == nil then
            if totalNos >= 60 then
                return
            end

            local slot = nil

            if listaControle ~= nil and listaControle.append ~= nil then
                slot = listaControle:append()
            end

            if slot == nil then
                return
            end

            slot.slotVazio = "true"
            slot.ordemInventario = i
            slot.uidInventario = "slot_" .. tostring(i)
            slot.nomeItem = ""
            slot.tipoItem = ""
            slot.RankItem = ""
            slot.imagemestilo2 = ""
            slot.equipadoEm = ""
            slot.quantidade = ""
            usados[i] = slot
            totalNos = totalNos + 1
        end
    end
end

function CWNA_repopularSlotsInventario(ficha, listaControle)
    if ficha == nil and listaControle == nil then
        return
    end

    local lista = ficha and ficha.magias2 or nil

    if lista == nil and listaControle ~= nil then
        lista = listaControle.node
    end

    if lista == nil then
        return
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if ehSlotVazioInventario(item) then
            NDB.deleteNode(item)
        end
    end

    CWNA_garantirSlotsInventario(ficha, listaControle)

    if listaControle ~= nil and listaControle.sort ~= nil then
        listaControle:sort()
    end
end

local function procurarPrimeiroSlotVazioInventario(lista)
    if lista == nil then
        return nil
    end

    local melhor = nil
    local melhorOrdem = 999999

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if ehSlotVazioInventario(item) then
            local ordem = tonumber(item.ordemInventario) or 999999

            if ordem < melhorOrdem then
                melhor = item
                melhorOrdem = ordem
            end
        end
    end

    return melhor
end

local function procurarItemLojaPorUid(ficha, uid)
    if ficha == nil or ficha.lojaItens == nil or uid == nil then
        return nil
    end

    for _, item in ipairs(NDB.getChildNodes(ficha.lojaItens)) do
        if tostring(item.uidLoja or "") == tostring(uid or "") then
            return item
        end
    end

    return nil
end

local function valorRankLoja(rank)
    local r = string.upper(limparTextoInventario(rank))

    if r == "SS" then return 7 end
    if r == "S" then return 6 end
    if r == "A" then return 5 end
    if r == "B" then return 4 end
    if r == "C" then return 3 end
    if r == "D" then return 2 end
    if r == "E" then return 1 end

    return 0
end

local function corRankLoja(rank)
    local r = string.upper(limparTextoInventario(rank))

    if r == "SS" then return "#FFD700" end
    if r == "S" then return "#FF4D4D" end
    if r == "A" then return "#FF9F1C" end
    if r == "B" then return "#B15CFF" end
    if r == "C" then return "#4DA3FF" end
    if r == "D" then return "#5DD46F" end
    if r == "E" then return "#BFC3C7" end

    return "#FFFFFF"
end

local function codigoCorRankChatLoja(rank)
    local r = string.upper(limparTextoInventario(rank))

    if r == "SS" then return "10" end
    if r == "E" then return "14" end
    if r == "D" then return "9" end
    if r == "C" then return "11" end
    if r == "B" then return "13" end
    if r == "A" then return "8" end
    if r == "S" then return "4" end

    return "1"
end

local function ordemTipoLoja(tipo)
    local t = limparTextoInventario(tipo)

    if t == "peitoral" or t == "armadura" then return 1 end
    if t == "calca" or t == "calça" then return 2 end
    if t == "capacete" then return 3 end
    if t == "bota" then return 4 end
    if t == "arma" then return 5 end
    if t == "escudo" then return 6 end
    if t == "potion hp" or t == "potion pp" then return 7 end
    if t == "material" or t == "minério" or t == "minerio" or t == "outros" then return 8 end

    return 9
end

local function grupoOrdenacaoTipoLoja(tipo)
    local ordem = ordemTipoLoja(tipo)

    if ordem >= 1 and ordem <= 6 then return 1 end
    if ordem == 7 then return 2 end
    if ordem == 8 then return 3 end

    return 4
end

local function subtipoMaterialLoja(item)
    local subtipo = limparTextoInventario(item and item.subtipoMaterial)
    local tipo = limparTextoInventario(item and item.tipoItem)

    if subtipo ~= "" then
        return subtipo
    end

    if tipo == "minério" or tipo == "minerio" then
        return "minerios"
    end

    if tipo == "outros" or tipo == "material" then
        return "outros"
    end

    return ""
end

local function ordemSubtipoLoja(item)
    local t = limparTextoInventario(item and item.tipoItem)
    local subtipo = subtipoMaterialLoja(item)

    if t == "potion hp" then return 1 end
    if t == "potion pp" then return 2 end

    if subtipo == "minérios" or subtipo == "minerios" then return 1 end
    if subtipo == "couros" then return 2 end
    if subtipo == "ervas" then return 3 end
    if subtipo == "outros" then return 4 end

    return 5
end

local function ehMaterialLoja(item)
    local t = limparTextoInventario(item and item.tipoItem)

    return t == "material" or t == "minério" or t == "minerio" or t == "outros"
end

local function itemLojaPassaFiltro(ficha, item)
    if ficha == nil or item == nil then
        return false
    end

    local filtroTipo = string.upper(tostring(ficha.LojaFiltroTipo or "TODOS"))
    local filtroRank = string.upper(tostring(ficha.LojaFiltroRank or "TODOS"))
    local tipo = limparTextoInventario(item.tipoItem)
    local rank = string.upper(tostring(item.RankItem or ""))

    if filtroRank ~= "TODOS" and rank ~= filtroRank then
        return false
    end

    if filtroTipo == "TODOS" or filtroTipo == "RANK" then
        return true
    end

    if filtroTipo == "ARMA" then
        return tipo == "arma"
    end

    if filtroTipo == "ESCUDO" or filtroTipo == "ESCUDOS" then
        return tipo == "escudo"
    end

    if filtroTipo == "CAPACETE" then
        return tipo == "capacete"
    end

    if filtroTipo == "PEITORAL" then
        return tipo == "peitoral" or tipo == "armadura"
    end

    if filtroTipo == "CALCA" or filtroTipo == "CALÇA" then
        return tipo == "calca" or tipo == "calça"
    end

    if filtroTipo == "BOTA" then
        return tipo == "bota"
    end

    if filtroTipo == "POTIONS" then
        return tipo == "potion hp" or tipo == "potion pp"
    end

    if filtroTipo == "MATERIAL" then
        return ehMaterialLoja(item)
    end

    return true
end

local function itensFiltradosLoja(ficha)
    local itens = {}

    if ficha == nil or ficha.lojaItens == nil then
        return itens
    end

    for _, item in ipairs(NDB.getChildNodes(ficha.lojaItens)) do
        if itemLojaPassaFiltro(ficha, item) then
            table.insert(itens, item)
        end
    end

    table.sort(itens, function(a, b)
        local grupoA = grupoOrdenacaoTipoLoja(a.tipoItem)
        local grupoB = grupoOrdenacaoTipoLoja(b.tipoItem)

        if grupoA ~= grupoB then
            return grupoA < grupoB
        end

        local tipoA = ordemTipoLoja(a.tipoItem)
        local tipoB = ordemTipoLoja(b.tipoItem)
        local rankA = valorRankLoja(a.RankItem)
        local rankB = valorRankLoja(b.RankItem)

        if grupoA == 1 then
            if rankA ~= rankB then
                return rankA > rankB
            end

            if tipoA ~= tipoB then
                return tipoA < tipoB
            end
        else
            if tipoA ~= tipoB then
                return tipoA < tipoB
            end

            if rankA ~= rankB then
                return rankA > rankB
            end
        end

        local subtipoA = ordemSubtipoLoja(a)
        local subtipoB = ordemSubtipoLoja(b)

        if subtipoA ~= subtipoB then
            return subtipoA < subtipoB
        end

        local ordemA = tonumber(a.ordemLoja) or 999999
        local ordemB = tonumber(b.ordemLoja) or 999999

        if ordemA ~= ordemB then
            return ordemA < ordemB
        end

        return tostring(a.uidLoja or "") < tostring(b.uidLoja or "")
    end)

    return itens
end

local function CWNA_atualizarCardsLoja(ficha)
    if ficha == nil or ficha.lojaItens == nil then
        return
    end

    CWNA_recriarPaginaLoja(ficha)
end

local function CWNA_garantirOrdemLoja(ficha)
    if ficha == nil or ficha.lojaItens == nil then
        return
    end

    local itens = {}

    for _, item in ipairs(NDB.getChildNodes(ficha.lojaItens)) do
        table.insert(itens, item)
    end

    table.sort(itens, function(a, b)
        local ordemA = tonumber(a.ordemLoja) or 999999
        local ordemB = tonumber(b.ordemLoja) or 999999

        if ordemA ~= ordemB then
            return ordemA < ordemB
        end

        return tostring(a.uidLoja or "") < tostring(b.uidLoja or "")
    end)

    for i, item in ipairs(itens) do
        item.ordemLoja = i
    end
end

local camposPaginaLoja = {
    "uidLoja",
    "ordemLoja",
    "LojaDestravadaPagina",
    "nomeItem",
    "tipoItem",
    "RankItem",
    "imagemestilo2",
    "precoPrata",
    "quantidade",
    "descricaoItem",
    "hp",
    "pp",
    "ca",
    "rd",
    "dano",
    "cura"
}

local LOJA_ITENS_POR_PAGINA = 24

local function CWNA_listaPaginaLoja(ficha, buffer)
    if ficha == nil then
        return nil
    end

    local campo = buffer == "B" and "lojaItensPaginaB" or "lojaItensPaginaA"

    if ficha[campo] == nil then
        NDB.createChildNode(ficha, campo)
    end

    return ficha[campo]
end

local function CWNA_preencherBufferPaginaLoja(ficha, buffer, itens, inicio, porPagina)
    local listaPagina = CWNA_listaPaginaLoja(ficha, buffer)

    if listaPagina == nil then
        return
    end

    local clones = NDB.getChildNodes(listaPagina)

    for posPagina = 1, porPagina do
        local clone = clones[posPagina]

        if clone == nil then
            clone = NDB.createChildNode(listaPagina, "itemLojaPagina")
        end

        if clone.LojaCardVisivel ~= "false" then
            clone.LojaCardVisivel = "false"
        end
    end

    for posPagina = 1, porPagina do
        local item = itens[inicio + posPagina - 1]
        local clone = clones[posPagina]

        if item ~= nil then
            for _, campo in ipairs(camposPaginaLoja) do
                local valor = item[campo] or ""
                if clone[campo] ~= valor then
                    clone[campo] = valor
                end
            end
        else
            for _, campo in ipairs(camposPaginaLoja) do
                if clone[campo] ~= "" then
                    clone[campo] = ""
                end
            end
        end

        if clone.LojaDestravadaPagina ~= (ficha.LojaDestravada or "") then
            clone.LojaDestravadaPagina = ficha.LojaDestravada or ""
        end

        if item ~= nil and clone.LojaCardVisivel ~= "true" then
            clone.LojaCardVisivel = "true"
        end
    end
end

function CWNA_recriarPaginaLoja(ficha)
    if ficha == nil then
        return
    end

    if ficha.lojaItens == nil then
        NDB.createChildNode(ficha, "lojaItens")
    end

    local itens = itensFiltradosLoja(ficha)

    local porPagina = LOJA_ITENS_POR_PAGINA
    ficha.LojaItensPorPagina = porPagina
    local pagina = tonumber(ficha.LojaPaginaAtual) or 1
    local maxPagina = math.max(1, math.ceil(#itens / porPagina))

    if pagina > maxPagina then pagina = maxPagina end
    if pagina < 1 then pagina = 1 end

    ficha.LojaPaginaAtual = pagina
    ficha.LojaPaginaTexto = tostring(pagina) .. "/" .. tostring(maxPagina)

    local inicio = ((pagina - 1) * porPagina) + 1
    local bufferAtual = tostring(ficha.LojaPaginaBufferAtivo or "")
    local bufferDestino = bufferAtual == "A" and "B" or "A"

    CWNA_preencherBufferPaginaLoja(ficha, bufferDestino, itens, inicio, porPagina)
    ficha.LojaPaginaBufferAtivo = bufferDestino
end

local function CWNA_ordemInsercaoLoja(ficha)
    if ficha == nil or ficha.lojaItens == nil then
        return 1
    end

    CWNA_garantirOrdemLoja(ficha)

    local total = 0
    for _, _ in ipairs(NDB.getChildNodes(ficha.lojaItens)) do
        total = total + 1
    end

    local porPagina = LOJA_ITENS_POR_PAGINA
    ficha.LojaItensPorPagina = porPagina
    local pagina = tonumber(ficha.LojaPaginaAtual) or 1
    local inicio = ((pagina - 1) * porPagina) + 1
    local fim = pagina * porPagina

    if total < inicio then
        return total + 1
    end

    local ocupadosNaPagina = math.max(0, math.min(total, fim) - inicio + 1)

    if ocupadosNaPagina < porPagina then
        return inicio + ocupadosNaPagina
    end

    return total + 1
end

local function CWNA_totalItensLoja(ficha)
    return #itensFiltradosLoja(ficha)
end

function CWNA_mudarPaginaLoja(ficha, delta)
    if ficha == nil then
        return
    end

    ficha.LojaPaginaAtual = (tonumber(ficha.LojaPaginaAtual) or 1) + (tonumber(delta) or 0)
    CWNA_recriarPaginaLoja(ficha)
end

function CWNA_definirFiltroLoja(ficha, tipoFiltro, valor)
    if ficha == nil then
        return
    end

    if tipoFiltro == "rank" then
        ficha.LojaFiltroRank = string.upper(tostring(valor or "TODOS"))
    else
        ficha.LojaFiltroTipo = string.upper(tostring(valor or "TODOS"))
    end

    ficha.LojaPaginaAtual = 1
    CWNA_mudarPaginaLoja(ficha, 0)
end

function CWNA_atualizarFiltroLojaVisual(controle)
    if controle == nil or controle.sheet == nil then
        return
    end

    local raiz = controle

    while raiz ~= nil do
        if raiz.name == "frameLojaInventario" or raiz.name == "frameEditorLoja" then
            break
        end

        raiz = raiz.parent
    end

    if raiz == nil then
        raiz = controle
    end

    local tipoAtual = string.upper(tostring(controle.sheet.LojaFiltroTipo or "TODOS"))
    local sufixo = ""

    if raiz.name == "frameEditorLoja" then
        sufixo = "Editor"
    end

    local filtros = {
        {nome = "rectFiltroLojaTodos", valor = "TODOS"},
        {nome = "rectFiltroLojaArmas", valor = "ARMA"},
        {nome = "rectFiltroLojaEscudos", valor = "ESCUDO"},
        {nome = "rectFiltroLojaCapacete", valor = "CAPACETE"},
        {nome = "rectFiltroLojaPeitoral", valor = "PEITORAL"},
        {nome = "rectFiltroLojaCalca", valor = "CALCA"},
        {nome = "rectFiltroLojaBota", valor = "BOTA"},
        {nome = "rectFiltroLojaPotion", valor = "POTIONS"},
        {nome = "rectFiltroLojaMaterial", valor = "MATERIAL"}
    }

    for _, filtro in ipairs(filtros) do
        local rect = raiz:findControlByName(filtro.nome .. sufixo)

        if rect ~= nil then
            local selecionado = tipoAtual == filtro.valor
            rect.strokeColor = selecionado and "#FF8C00" or "#00000000"
            rect.strokeSize = selecionado and 2 or 0
        end
    end

    local rectRank = raiz:findControlByName("rectFiltroLojaRank" .. sufixo)

    if rectRank ~= nil then
        local rankAtual = string.upper(tostring(controle.sheet.LojaFiltroRank or "TODOS"))
        local rankSelecionado = rankAtual ~= "" and rankAtual ~= "TODOS"
        rectRank.strokeColor = rankSelecionado and "#FF8C00" or "#00000000"
        rectRank.strokeSize = rankSelecionado and 2 or 0
    end
end

local camposJsonLoja = {"uidLoja","ordemLoja","nomeItem","tipoItem","subtipoMaterial","RankItem","imagemestilo2","precoPrata","quantidade","estoqueInfinito","estoqueDisponivel","descricaoItem","hp","pp","ca","rd","dano","cura"}

local function CWNA_campoNumericoJsonLoja(campo)
    return campo == "ordemLoja" or campo == "precoPrata" or campo == "quantidade" or campo == "hp" or campo == "pp" or campo == "ca" or campo == "rd" or campo == "dano" or campo == "cura"
end

local function CWNA_numeroLoja(valor, padrao)
    if valor == nil then return padrao or 0 end
    local texto = tostring(valor)
    texto = texto:gsub("%s+", "")
    texto = texto:gsub(",", ".")
    return tonumber(texto) or padrao or 0
end

local function CWNA_jsonValorLoja(valor)
    valor = tostring(valor or "")
    valor = valor:gsub("\\", "\\\\")
    valor = valor:gsub('"', '\\"')
    valor = valor:gsub("\r", " ")
    valor = valor:gsub("\n", " ")
    return '"' .. valor .. '"'
end

local function CWNA_exportarLojaJsonTexto(ficha)
    if ficha == nil or ficha.lojaItens == nil then return "{\n  \"items\": []\n}" end
    CWNA_garantirOrdemLoja(ficha)

    local saida = {"{", "  \"items\": ["}
    local itens = NDB.getChildNodes(ficha.lojaItens)

    for i, item in ipairs(itens) do
        table.insert(saida, "    {")

        for c, campo in ipairs(camposJsonLoja) do
            local valor = item[campo]
            local linha = "      " .. CWNA_jsonValorLoja(campo) .. ": "

            if campo == "estoqueInfinito" then
                local v = tostring(valor or "true")
                linha = linha .. ((v == "false" or v == "0") and "false" or "true")
            elseif CWNA_campoNumericoJsonLoja(campo) then
                linha = linha .. tostring(CWNA_numeroLoja(valor, 0))
            else
                linha = linha .. CWNA_jsonValorLoja(valor)
            end

            if c < #camposJsonLoja then linha = linha .. "," end
            table.insert(saida, linha)
        end

        table.insert(saida, i < #itens and "    }," or "    }")
    end

    table.insert(saida, "  ]")
    table.insert(saida, "}")
    return table.concat(saida, "\n")
end
function CWNA_importarLojaJsonTexto(ficha, texto, controleOrigem)
    if ficha == nil then return false end
    texto = tostring(texto or "")

    local itensImportados = {}

    local function lerCampo(bloco, campo)
        local valor = bloco:match('"' .. campo .. '"%s*:%s*"(.-)"')
        if valor == nil then
            valor = bloco:match('"' .. campo .. '"%s*:%s*(true)') or bloco:match('"' .. campo .. '"%s*:%s*(false)') or bloco:match('"' .. campo .. '"%s*:%s*([%-]?%d+%.?%d*)')
        else
            valor = tostring(valor):gsub('\\"', '"'):gsub('\\n', '\n'):gsub('\\r', '\r'):gsub('\\\\', '\\')
        end
        return valor
    end

    local function adicionarBloco(bloco)
        if bloco == nil or bloco:find('"nomeItem"') == nil then return end
        local dados = {}

        for _, campo in ipairs(camposJsonLoja) do
            local valor = lerCampo(bloco, campo)
            if valor ~= nil then
                if CWNA_campoNumericoJsonLoja(campo) then
                    dados[campo] = CWNA_numeroLoja(valor, 0)
                else
                    dados[campo] = valor
                end
            end
        end

        if tostring(dados.nomeItem or "") ~= "" then table.insert(itensImportados, dados) end
    end

    local function blocosArrayItems(json)
        local blocos = {}
        local inicioItems = json:find('"items"%s*:%s*%[')
        if inicioItems == nil then return blocos end

        local inicioArray = json:find('%[', inicioItems)
        if inicioArray == nil then return blocos end

        local profundidade = 0
        local inicioObjeto = nil
        local emString = false
        local escape = false

        for i = inicioArray + 1, #json do
            local ch = json:sub(i, i)

            if emString then
                if escape then
                    escape = false
                elseif ch == '\\' then
                    escape = true
                elseif ch == '"' then
                    emString = false
                end
            else
                if ch == '"' then
                    emString = true
                elseif ch == '{' then
                    if profundidade == 0 then inicioObjeto = i end
                    profundidade = profundidade + 1
                elseif ch == '}' then
                    profundidade = profundidade - 1
                    if profundidade == 0 and inicioObjeto ~= nil then
                        table.insert(blocos, json:sub(inicioObjeto, i))
                        inicioObjeto = nil
                    end
                elseif ch == ']' and profundidade == 0 then
                    break
                end
            end
        end

        return blocos
    end

    for _, bloco in ipairs(blocosArrayItems(texto)) do
        adicionarBloco(bloco)
    end

    if #itensImportados == 0 then
        for bloco in texto:gmatch('"item%d+"%s*:%s*(%b{})') do
            adicionarBloco(bloco)
        end
    end

    if #itensImportados == 0 then
        CWNA_mostrarAvisoInventario(controleOrigem, "Nenhum item foi encontrado nesse JSON da loja.")
        return false
    end

    if ficha.lojaItens == nil then NDB.createChildNode(ficha, "lojaItens") end
    for _, item in ipairs(NDB.getChildNodes(ficha.lojaItens)) do NDB.deleteNode(item) end

    for i, dados in ipairs(itensImportados) do
        local item = NDB.createChildNode(ficha.lojaItens, "itemLoja")
        item.uidLoja = tostring(dados.uidLoja or "") ~= "" and dados.uidLoja or (tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999)) .. "_" .. tostring(i))
        item.ordemLoja = CWNA_numeroLoja(dados.ordemLoja, i)

        for _, campo in ipairs(camposJsonLoja) do
            if campo ~= "uidLoja" and campo ~= "ordemLoja" and dados[campo] ~= nil then item[campo] = dados[campo] end
        end
    end

    ficha.LojaPaginaAtual = 1
    CWNA_recriarPaginaLoja(ficha)
    CWNA_mostrarAvisoInventario(controleOrigem, "Loja importada: " .. tostring(#itensImportados) .. " itens.")
    return true
end
local function CWNA_lerArquivoTextoLoja(caminho)
    local arq = io.open(caminho, "r")
    if arq == nil then return nil end
    local conteudo = arq:read("*a")
    arq:close()
    return conteudo
end

local function CWNA_salvarArquivoTextoLoja(caminho, conteudo)
    local arq = io.open(caminho, "w")
    if arq == nil then return false end
    arq:write(conteudo or "")
    arq:close()
    return true
end

local function CWNA_streamParaTextoLoja(stream)
    if stream == nil then return nil end

    local ok, texto = pcall(function()
        stream.position = 0
        return stream:readBinary("s")
    end)

    if ok and texto ~= nil and tostring(texto) ~= "" then
        return tostring(texto)
    end

    local ok2, bytes = pcall(function()
        stream.position = 0
        local dados = {}
        local lidos = stream:read(dados, stream.size or stream.remainingBytes or 0)
        local partes = {}
        for i = 1, lidos do partes[i] = string.char(dados[i] or 0) end
        return table.concat(partes)
    end)

    if ok2 then return bytes end
    return nil
end

local function CWNA_textoParaStreamLoja(texto)
    local utils = require("utils.lua")
    local stream = utils.newMemoryStream()
    texto = tostring(texto or "")

    local bytes = {}
    for i = 1, #texto do
        bytes[i] = string.byte(texto, i)
    end

    if #bytes > 0 then
        stream:write(bytes, #bytes)
    end

    stream.position = 0
    return stream
end
function CWNA_importarLojaJson(ficha, controleOrigem)
    Dialogs.openFile("Importar loja JSON", "application/json,.json", false,
        function(arquivos)
            local arquivo = arquivos and arquivos[1] or nil
            if arquivo == nil or arquivo.stream == nil then
                CWNA_mostrarAvisoInventario(controleOrigem, "Nenhum arquivo JSON foi selecionado.")
                return
            end

            local texto = CWNA_streamParaTextoLoja(arquivo.stream)
            if texto == nil or texto == "" then
                CWNA_mostrarAvisoInventario(controleOrigem, "Nao foi possivel ler o arquivo JSON da loja.")
                return
            end

            CWNA_importarLojaJsonTexto(ficha, texto, controleOrigem)
        end,
        function()
        end)
end

local function CWNA_nomeExportacaoLoja(ficha)
    if ficha == nil then return "loja_crystal_world.json" end

    local indice = tonumber(ficha.LojaExportIndice) or 0
    local nome = "loja_crystal_world.json"

    if indice > 0 then
        nome = "loja_crystal_world(" .. tostring(indice) .. ").json"
    end

    ficha.LojaExportIndice = indice + 1
    return nome
end

function CWNA_exportarLojaJson(ficha, controleOrigem)
    local texto = CWNA_exportarLojaJsonTexto(ficha)
    if texto == nil or tostring(texto) == "" then
        CWNA_mostrarAvisoInventario(controleOrigem, "Nao ha dados da loja para exportar.")
        return
    end
    local stream = CWNA_textoParaStreamLoja(texto)
    local nomeArquivo = CWNA_nomeExportacaoLoja(ficha)

    Dialogs.saveFile("Exportar loja JSON", stream, nomeArquivo, "application/json",
        function()
            CWNA_mostrarAvisoInventario(controleOrigem, "Loja exportada com sucesso.")
        end,
        function()
        end)
end
local function enviarMensagemLoja(ficha, acao, item, valor, quantidade)
    local mesa = rrpg.getMesaDe(ficha) or Firecast.getMesaDe(ficha)
    local jogador = mesa and mesa.me or nil
    local chat = mesa and (mesa.activeChat or mesa.chat) or nil

    if jogador == nil or chat == nil or item == nil then
        return
    end

    local nomeJogador = "Jogador"
    pcall(function()
        nomeJogador = tostring(jogador.nick or jogador.nickname or jogador.nome or jogador.name or jogador.login or "Jogador")
    end)

    local nomeItem = tostring(item.nomeItem or "Item")
    local cor = codigoCorRankChatLoja(item.RankItem)
    local qtd = math.max(1, math.floor(CWNA_numeroLoja(quantidade, 1)))
    local marcadorCor = "[" .. string.char(194, 167) .. "K"
    local marcadorImagem = "[" .. string.char(194, 167) .. "I "
    local imagem = tostring(item.imagemestilo2 or "")
    local texto = "<" .. nomeJogador .. "> " .. marcadorCor .. "1]" .. tostring(acao or "") .. ":\n" ..
                 tostring(qtd) .. "x " .. marcadorCor .. cor .. "]" .. nomeItem .. marcadorCor .. "1]"

    if imagem ~= "" then
        texto = texto .. "\n" .. marcadorImagem .. imagem .. "]"
    end

    if valor ~= nil then
        texto = texto .. "\npor " .. tostring(valor) .. " prata"
    end

    pcall(function()
        chat:enviarMensagem(texto)
    end)
end

local function copiarItemLojaParaInventario(origem, destino)
    if origem == nil or destino == nil then
        return
    end

    destino.slotVazio = nil
    destino.uidInventario = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
    destino.nomeItem = origem.nomeItem or ""
    destino.tipoItem = origem.tipoItem or ""
    destino.subtipoMaterial = origem.subtipoMaterial or ""
    destino.RankItem = origem.RankItem or "E"
    destino.imagemestilo2 = origem.imagemestilo2 or ""
    destino.quantidade = origem.quantidade or 1
    destino.hp = origem.hp or 0
    destino.pp = origem.pp or 0
    destino.ca = origem.ca or 0
    destino.rd = origem.rd or 0
    destino.dano = origem.dano or 0
    destino.cura = origem.cura or 0
    destino.equipadoEm = ""
    destino.origemLoja = "true"
    destino.uidLojaOrigem = origem.uidLoja or ""
    destino.precoLojaPrata = CWNA_numeroLoja(origem.precoPrata, 0)
    destino.descricaoLoja = origem.descricaoItem or ""
end

local function prataAtualLoja(ficha)
    return CWNA_numeroLoja(ficha and ficha.PrataPersonagem, 0)
end

local function itemLojaEmpilhavel(item)
    local tipo = limparTextoInventario(item and item.tipoItem)
    return tipo == "material" or tipo == "outros" or tipo == "potion hp" or tipo == "potion pp" or tipo == "minério" or tipo == "minerio"
end

local function itemInventarioBateComLoja(item, loja)
    if item == nil or loja == nil or not itemLojaEmpilhavel(loja) then
        return false
    end

    return tostring(item.origemLoja or "") == "true"
        and tostring(item.nomeItem or "") == tostring(loja.nomeItem or "")
        and limparTextoInventario(item.tipoItem) == limparTextoInventario(loja.tipoItem)
        and limparTextoInventario(item.subtipoMaterial) == limparTextoInventario(loja.subtipoMaterial)
        and string.upper(limparTextoInventario(item.RankItem)) == string.upper(limparTextoInventario(loja.RankItem))
        and tostring(item.imagemestilo2 or "") == tostring(loja.imagemestilo2 or "")
        and CWNA_numeroLoja(item.precoLojaPrata, 0) == CWNA_numeroLoja(loja.precoPrata, 0)
        and CWNA_numeroLoja(item.hp, 0) == CWNA_numeroLoja(loja.hp, 0)
        and CWNA_numeroLoja(item.pp, 0) == CWNA_numeroLoja(loja.pp, 0)
        and CWNA_numeroLoja(item.ca, 0) == CWNA_numeroLoja(loja.ca, 0)
        and CWNA_numeroLoja(item.rd, 0) == CWNA_numeroLoja(loja.rd, 0)
        and CWNA_numeroLoja(item.dano, 0) == CWNA_numeroLoja(loja.dano, 0)
        and CWNA_numeroLoja(item.cura, 0) == CWNA_numeroLoja(loja.cura, 0)
end

local function itemInventarioBateComLojaParaVenda(ficha, item)
    if ficha == nil or item == nil or tostring(item.origemLoja or "") ~= "true" then
        return false
    end

    local uidOrigem = tostring(item.uidLojaOrigem or "")

    if uidOrigem == "" then
        return true
    end

    local loja = procurarItemLojaPorUid(ficha, uidOrigem)

    if loja == nil then
        return false
    end

    return tostring(item.nomeItem or "") == tostring(loja.nomeItem or "")
        and limparTextoInventario(item.tipoItem) == limparTextoInventario(loja.tipoItem)
        and limparTextoInventario(item.subtipoMaterial) == limparTextoInventario(loja.subtipoMaterial)
        and string.upper(limparTextoInventario(item.RankItem)) == string.upper(limparTextoInventario(loja.RankItem))
        and tostring(item.imagemestilo2 or "") == tostring(loja.imagemestilo2 or "")
        and CWNA_numeroLoja(item.precoLojaPrata, 0) == CWNA_numeroLoja(loja.precoPrata, 0)
        and CWNA_numeroLoja(item.hp, 0) == CWNA_numeroLoja(loja.hp, 0)
        and CWNA_numeroLoja(item.pp, 0) == CWNA_numeroLoja(loja.pp, 0)
        and CWNA_numeroLoja(item.ca, 0) == CWNA_numeroLoja(loja.ca, 0)
        and CWNA_numeroLoja(item.rd, 0) == CWNA_numeroLoja(loja.rd, 0)
        and CWNA_numeroLoja(item.dano, 0) == CWNA_numeroLoja(loja.dano, 0)
        and CWNA_numeroLoja(item.cura, 0) == CWNA_numeroLoja(loja.cura, 0)
end

local function removerMarcaLojaInvalida(item)
    if item == nil then
        return
    end

    item.origemLoja = ""
    item.uidLojaOrigem = ""
    item.precoLojaPrata = ""
    item.descricaoLoja = ""
end

local function procurarItemEmpilhavelDaLoja(ficha, itemLoja)
    if ficha == nil or ficha.magias2 == nil then
        return nil
    end

    for _, item in ipairs(NDB.getChildNodes(ficha.magias2)) do
        if itemInventarioBateComLoja(item, itemLoja) then
            return item
        end
    end

    return nil
end

local function procurarFrameAcimaLoja(controle, nomeFrame)
    local ctrl = controle

    while ctrl ~= nil do
        if ctrl.findControlByName ~= nil then
            local frame = ctrl:findControlByName(nomeFrame)
            if frame ~= nil then
                return frame
            end
        end

        ctrl = ctrl.parent
    end

    return nil
end

function CWNA_confirmarCompraItemLoja(ficha, controleOrigem)
    if ficha == nil then
        return
    end

    local itemLoja = procurarItemLojaPorUid(ficha, ficha.TempCompraLojaUid)

    if itemLoja == nil then
        CWNA_mostrarAvisoInventario(controleOrigem, "Item da loja nao encontrado.")
        return
    end

    local qtdCompra = math.max(1, math.floor(CWNA_numeroLoja(ficha.TempCompraLojaQuantidade, 1)))
    local qtdBase = math.max(1, math.floor(CWNA_numeroLoja(itemLoja.quantidade, 1)))

    if not itemLojaEmpilhavel(itemLoja) then
        qtdCompra = 1
    end

    ficha.TempCompraLojaQuantidade = qtdCompra

    local qtdTotal = qtdCompra * qtdBase
    local custo = CWNA_numeroLoja(itemLoja.precoPrata, 0) * qtdCompra

    if prataAtualLoja(ficha) < custo then
        CWNA_mostrarAvisoInventario(controleOrigem, "Prata insuficiente.")
        return
    end

    if ficha.magias2 == nil then
        NDB.createChildNode(ficha, "magias2")
    end

    local lista = ficha.magias2
    local slotDestino = nil
    local uidSlotDestino = tostring(ficha.TempCompraLojaSlotDestinoUid or "")

    if uidSlotDestino ~= "" then
        local candidato = procurarItemInventarioPorUid(ficha, uidSlotDestino)

        if candidato ~= nil and ehSlotVazioInventario(candidato) then
            slotDestino = candidato
        else
            ficha.TempCompraLojaSlotDestinoUid = ""
            uidSlotDestino = ""
        end
    end

    local itemExistente = nil

    if itemLojaEmpilhavel(itemLoja) then
        itemExistente = procurarItemEmpilhavelDaLoja(ficha, itemLoja)
    end

    if itemExistente ~= nil then
        ficha.PrataPersonagem = prataAtualLoja(ficha) - custo
        itemExistente.quantidade = CWNA_numeroLoja(itemExistente.quantidade, 0) + qtdTotal
        enviarMensagemLoja(ficha, "comprou", itemLoja, custo, qtdTotal)
        recalcularDefesa(ficha)
        return
    end

    CWNA_inicializarSlotsInventario(ficha, nil)
    local slot = slotDestino or procurarPrimeiroSlotVazioInventario(lista)

    if slot == nil then
        CWNA_mostrarAvisoInventario(controleOrigem, "Limite maximo de 60 itens.")
        return
    end

    ficha.PrataPersonagem = prataAtualLoja(ficha) - custo
    copiarItemLojaParaInventario(itemLoja, slot)
    slot.quantidade = qtdTotal
    enviarMensagemLoja(ficha, "comprou", itemLoja, custo, qtdTotal)
    ficha.TempCompraLojaSlotDestinoUid = ""
    recalcularDefesa(ficha)
end

function CWNA_comprarItemLoja(itemLoja, controleOrigem, slotDestinoInventario)
    if itemLoja == nil then
        return
    end

    local ficha = NDB.getRoot(itemLoja)

    if ficha == nil then
        showMessage("Ficha não encontrada para comprar o item.")
        return
    end

    local uid = tostring(itemLoja.uidLoja or "")
    local qtdAtual = math.max(1, math.floor(CWNA_numeroLoja(ficha.TempCompraLojaQuantidade, 1)))

    if tostring(ficha.TempCompraLojaUid or "") ~= uid or not itemLojaEmpilhavel(itemLoja) then
        qtdAtual = 1
    end

    ficha.TempCompraLojaUid = uid
    ficha.TempCompraLojaNome = itemLoja.nomeItem or ""
    ficha.TempCompraLojaNomeDisplay = "NOME: " .. tostring(itemLoja.nomeItem or "")
    ficha.TempCompraLojaRank = itemLoja.RankItem or ""
    ficha.TempCompraLojaRankDisplay = "RANK: " .. tostring(itemLoja.RankItem or "")
    ficha.TempCompraLojaImagem = itemLoja.imagemestilo2 or ""
    ficha.TempCompraLojaDescricao = itemLoja.descricaoItem or ""
    ficha.TempCompraLojaPreco = CWNA_numeroLoja(itemLoja.precoPrata, 0)
    ficha.TempCompraLojaPrecoDisplay = "● PRECO: " .. tostring(CWNA_numeroLoja(itemLoja.precoPrata, 0))
    ficha.TempCompraLojaCorRank = corRankLoja(itemLoja.RankItem)
    ficha.TempCompraLojaConfirmTexto = "por " .. tostring(CWNA_numeroLoja(itemLoja.precoPrata, 0) * qtdAtual) .. " prata?"
    ficha.TempCompraLojaQuantidade = qtdAtual
    ficha.TempCompraLojaPermiteQuantidade = itemLojaEmpilhavel(itemLoja) and "true" or "false"
    ficha.TempCompraLojaSlotDestinoUid = ""

    if slotDestinoInventario ~= nil then
        ficha.TempCompraLojaSlotDestinoUid = tostring(slotDestinoInventario.uidInventario or "")
    end

    local frame = procurarFrameAcimaLoja(controleOrigem, "frameConfirmarCompraLoja")

    if frame ~= nil then
        frame.visible = true
        pcall(function() frame:bringToFront() end)
        return
    end

    CWNA_confirmarCompraItemLoja(ficha, controleOrigem)
end

function CWNA_comprarItemLojaPorUid(ficha, uid, controleOrigem, slotDestinoInventario)
    local itemLoja = procurarItemLojaPorUid(ficha, uid)
    CWNA_comprarItemLoja(itemLoja, controleOrigem, slotDestinoInventario)
end

function CWNA_carregarDetalheCompraLoja(itemLoja)
    if itemLoja == nil then
        return
    end

    local ficha = NDB.getRoot(itemLoja)

    if ficha == nil then
        return
    end

    local uid = tostring(itemLoja.uidLoja or "")
    if tostring(ficha.TempCompraLojaUid or "") == uid then
        ficha.TempCompraLojaUid = ""
        ficha.TempCompraLojaNome = ""
        ficha.TempCompraLojaNomeDisplay = "NOME:"
        ficha.TempCompraLojaRank = ""
        ficha.TempCompraLojaRankDisplay = "RANK:"
        ficha.TempCompraLojaImagem = ""
        ficha.TempCompraLojaDescricao = ""
        ficha.TempCompraLojaAtributos = ""
        ficha.TempCompraLojaDisponivelDisplay = "DISPONIVEL:"
        ficha.TempCompraLojaPreco = ""
        ficha.TempCompraLojaPrecoDisplay = "● PRECO:"
        ficha.TempCompraLojaCorRank = "#FFFFFF"
        ficha.TempCompraLojaConfirmTexto = ""
        ficha.TempCompraLojaQuantidade = 1
        ficha.TempCompraLojaPermiteQuantidade = "false"
        return
    end

    local atributos = {}
    local function addAtributo(nome, valor)
        local numero = tonumber(valor) or 0
        if numero ~= 0 then
            table.insert(atributos, nome .. " +" .. tostring(numero))
        end
    end

    addAtributo("HP", itemLoja.hp)
    addAtributo("PP", itemLoja.pp)
    addAtributo("CA", itemLoja.ca)
    addAtributo("RD", itemLoja.rd)
    addAtributo("DANO", itemLoja.dano)
    addAtributo("CURA", itemLoja.cura)

    ficha.TempCompraLojaUid = uid
    ficha.TempCompraLojaNome = itemLoja.nomeItem or ""
    ficha.TempCompraLojaNomeDisplay = "NOME: " .. tostring(itemLoja.nomeItem or "")
    ficha.TempCompraLojaRank = itemLoja.RankItem or ""
    ficha.TempCompraLojaImagem = itemLoja.imagemestilo2 or ""
    ficha.TempCompraLojaDescricao = itemLoja.descricaoItem or ""
    local textoAtributos = table.concat(atributos, "  ")
    ficha.TempCompraLojaAtributos = textoAtributos == "" and "ATRIBUTOS:" or ("ATRIBUTOS: " .. textoAtributos)
    local disponivel = itemLoja.estoqueDisponivel or itemLoja.estoque or itemLoja.quantidadeDisponivel or itemLoja.disponivel or ""
    if tostring(itemLoja.estoqueInfinito or "") == "true" or tostring(disponivel or "") == "" then
        disponivel = "∞"
    end
    ficha.TempCompraLojaDisponivelDisplay = "DISPONIVEL: " .. tostring(disponivel)
    ficha.TempCompraLojaRankDisplay = "RANK: " .. tostring(itemLoja.RankItem or "")
    ficha.TempCompraLojaPreco = CWNA_numeroLoja(itemLoja.precoPrata, 0)
    ficha.TempCompraLojaPrecoDisplay = "● PRECO: " .. tostring(CWNA_numeroLoja(itemLoja.precoPrata, 0))
    ficha.TempCompraLojaCorRank = corRankLoja(itemLoja.RankItem)
    ficha.TempCompraLojaConfirmTexto = "por " .. tostring(CWNA_numeroLoja(itemLoja.precoPrata, 0)) .. " prata?"
    ficha.TempCompraLojaQuantidade = 1
    ficha.TempCompraLojaPermiteQuantidade = itemLojaEmpilhavel(itemLoja) and "true" or "false"
end

local function CWNA_senhaLojaEnterPressionado(codigo, tecla)
    return codigo == 13
        or tecla == 13
        or tostring(codigo or "") == "13"
        or string.lower(tostring(tecla or "")) == "enter"
        or string.lower(tostring(tecla or "")) == "return"
end

function CWNA_confirmarSenhaLoja(controle)
    if controle == nil then return end

    local edt = controle:findControlByName("edtSenhaLoja")
    local senha = edt and edt.text or ""

    if senha ~= "151289" then
        showMessage("Senha incorreta!")
        return
    end

    if edt ~= nil then edt.text = "" end
    local senhaFrame = controle:findControlByName("frameSenhaLoja")
    if senhaFrame ~= nil then senhaFrame.visible = false end

    local ficha = controle.sheet
    if ficha == nil then return end

    ficha.TempCompraLojaUid = ""
    ficha.TempCompraLojaNome = ""
    ficha.TempCompraLojaNomeDisplay = "NOME:"
    ficha.TempCompraLojaRank = ""
    ficha.TempCompraLojaRankDisplay = "RANK:"
    ficha.TempCompraLojaImagem = ""
    ficha.TempCompraLojaDescricao = ""
    ficha.TempCompraLojaAtributos = ""
    ficha.TempCompraLojaDisponivelDisplay = "DISPONIVEL:"
    ficha.TempCompraLojaPreco = ""
    ficha.TempCompraLojaPrecoDisplay = "● PRECO:"
        ficha.TempCompraLojaCorRank = "#FFFFFF"
        ficha.TempCompraLojaConfirmTexto = ""
        ficha.TempCompraLojaQuantidade = 1
        ficha.TempCompraLojaPermiteQuantidade = "false"
        ficha.LojaDestravada = "true"
    CWNA_atualizarCardsLoja(ficha)
    local painel = controle:findControlByName("frameEditorLoja")
    if painel ~= nil then
        painel.visible = true
        pcall(function() painel:bringToFront() end)
    end
end

