    <frame name="frameConfirmarCompraLoja" left="296" top="243" width="282" height="146" visible="false">
        <rectangle align="client" color="#171717F0" strokeColor="#C8A000" strokeSize="2" xradius="6" yradius="6" cornerType="round">
            <label text="Comprar" left="18" top="12" width="246" height="20"
                   fontColor="white" fontStyle="bold" horzTextAlign="center"/>
            <label name="lblConfirmCompraNomeLoja" field="TempCompraLojaNome" left="18" top="36" width="246" height="28"
                   fontColor="white" fontStyle="bold" horzTextAlign="center" vertTextAlign="center"/>
            <button text="-" left="82" top="66" width="24" height="20">
                <event name="onClick"><![CDATA[
                    local qtd = math.max(1, math.floor(CWNA_numeroLoja(sheet.TempCompraLojaQuantidade, 1)) - 1)
                    sheet.TempCompraLojaQuantidade = qtd
                    sheet.TempCompraLojaConfirmTexto = "por " .. tostring(CWNA_numeroLoja(sheet.TempCompraLojaPreco, 0) * qtd) .. " prata?"
                ]]></event>
            </button>
            <label field="TempCompraLojaQuantidade" left="110" top="66" width="28" height="20" fontColor="white" fontStyle="bold" horzTextAlign="center"/>
            <button text="+" left="142" top="66" width="24" height="20">
                <event name="onClick"><![CDATA[
                    if tostring(sheet.TempCompraLojaPermiteQuantidade or "") ~= "true" then
                        sheet.TempCompraLojaQuantidade = 1
                        return
                    end

                    local qtd = math.max(1, math.floor(CWNA_numeroLoja(sheet.TempCompraLojaQuantidade, 1)) + 1)
                    sheet.TempCompraLojaQuantidade = qtd
                    sheet.TempCompraLojaConfirmTexto = "por " .. tostring(CWNA_numeroLoja(sheet.TempCompraLojaPreco, 0) * qtd) .. " prata?"
                ]]></event>
            </button>
            <label field="TempCompraLojaConfirmTexto" left="18" top="88" width="246" height="22"
                   fontColor="white" fontStyle="bold" horzTextAlign="center"/>

            <button text="SIM" left="62" top="112" width="68" height="24">
                <event name="onClick"><![CDATA[
                    local frame = self:findControlByName("frameConfirmarCompraLoja")
                    if frame ~= nil then frame.visible = false end
                    CWNA_confirmarCompraItemLoja(sheet, self)
                ]]></event>
            </button>

            <button text="NÃO" left="152" top="112" width="68" height="24">
                <event name="onClick"><![CDATA[
                    local frame = self:findControlByName("frameConfirmarCompraLoja")
                    if frame ~= nil then frame.visible = false end
                ]]></event>
            </button>
        </rectangle>
    </frame>

    <frame name="frameSenhaLoja" left="317" top="192" width="214" height="118" visible="false">
        <rectangle align="client" color="#111111EE" strokeColor="#C8A000" strokeSize="2" xradius="6" yradius="6" cornerType="round">
            <label text="SENHA ADM" left="0" top="10" width="214" height="20" horzTextAlign="center" fontColor="white" fontStyle="bold"/>
            <rectangle left="32" top="42" width="150" height="24" color="#00000066" strokeColor="#A07A2D" strokeSize="1"/>
            <edit name="edtSenhaLoja" left="34" top="43" width="146" height="22" isPasswordEdit="true" transparent="true" fontColor="white" horzTextAlign="center">
                <event name="onKeyDown"><![CDATA[
