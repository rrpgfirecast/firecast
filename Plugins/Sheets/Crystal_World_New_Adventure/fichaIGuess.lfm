    ficha.TempCompraLojaRankDisplay = "RANK:"
    ficha.TempCompraLojaImagem = ""
    ficha.TempCompraLojaDescricao = ""
    ficha.TempCompraLojaAtributos = ""
    ficha.TempCompraLojaDisponivelDisplay = "DISPONIVEL:"
    ficha.TempCompraLojaPreco = ""
    ficha.TempCompraLojaPrecoDisplay = "● PRECO:"
    ficha.TempCompraLojaCorRank = "#FFFFFF"
    ficha.TempCompraLojaConfirmTexto = ""
    ficha.TempCompraLojaQuantidade = 1
