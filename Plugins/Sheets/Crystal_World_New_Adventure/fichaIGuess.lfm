<!-- HB 1 -->
<rectangle left="570" top="550" width="300" height="24" color="#00000000">
    <comboBox field="HB1" fontSize="12" align="client"
        items="{'-','APRIMORAMENTO DE ATRIBUTO','APRENDIZADO EXCEPCIONAL','ARTESÃO PRÁTICO','BENÇÃO PROTETORA',
'CONTROLE DE RESPIRAÇÃO','CONCENTRAÇÃO INABALÁVEL','CURA EMERGENCIAL','DEFESA OFENSIVA','ECO TEMPORAL','ENGANAR O ALVO',
