            <label text="CURA" left="162" top="420" width="40" height="18"/>
            <edit field="TempLojaCura" left="202" top="416" width="24" height="24" fontColor="white" horzTextAlign="center"/>

            <rectangle left="10" top="478" width="218" height="36" color="#1F2125" strokeColor="#3A3D44" strokeSize="1" xradius="5" yradius="5" cornerType="round"/>
            <button text="NOVO" left="18" top="484" width="58" height="24">
                <event name="onClick"><![CDATA[
                    CWNA_limparEditorLoja(sheet)
                ]]></event>
            </button>

            <button text="SALVAR" left="86" top="484" width="62" height="24">
                <event name="onClick"><![CDATA[
                    CWNA_salvarItemLoja(sheet)
                ]]></event>
            </button>

            <button text="EXCLUIR" left="154" top="484" width="62" height="24">
                <event name="onClick"><![CDATA[
                    local item = procurarItemLojaPorUid(sheet, sheet.TempLojaUid)
                    if item ~= nil then
                        CWNA_excluirItemLoja(item)
                    end
                ]]></event>
            </button>
        </rectangle>

    </frame>

    <rectangle name="avisoLojaInterno"
               left="264" top="252"
               width="330" height="42"
               color="#1B1B1BEE"
               strokeColor="#C8A000"
               strokeSize="2"
               xradius="8" yradius="8" cornerType="round"
               visible="false">
        <label name="lblAvisoLojaInterno"
               align="client"
               text="Aviso"
               fontColor="white"
               fontSize="14"
               fontStyle="bold"
               horzTextAlign="center"
               vertTextAlign="center"/>
    </rectangle>
    <dataLink field="LojaDestravada" defaultValue="false">
        <event name="onChange"><![CDATA[
            local painel = self:findControlByName("frameEditorLoja")
            local cadeado = self:findControlByName("btnCadeadoLoja")
            local aberto = tostring(sheet.LojaDestravada or "") == "true"

            if painel ~= nil then painel.visible = aberto end
            if cadeado ~= nil then cadeado.text = aberto and "🔓" or "🔒" end
            CWNA_atualizarCardsLoja(sheet)
        ]]></event>
    </dataLink>
</frame>

<frame name="frameDetalheItemLoja" left="310" top="35" width="238" height="496" visible="false">
    <rectangle align="client" color="#2B2D31" strokeColor="#9A6A2A" strokeSize="2" xradius="8" yradius="8" cornerType="round">
        <rectangle left="8" top="8" width="222" height="30" color="#1F2125" strokeColor="#3A3D44" strokeSize="1" xradius="5" yradius="5" cornerType="round"/>
        <label text="DETALHES DO ITEM" left="0" top="8" width="230" height="24"
               horzTextAlign="center" fontColor="white" fontStyle="bold"/>
        <button text="x" left="202" top="12" width="22" height="20">
            <event name="onClick"><![CDATA[
                local frame = self:findControlByName("frameDetalheItemLoja")
                if frame ~= nil then frame.visible = false end
            ]]></event>
        </button>

        <dataLink fields="{'LojaAberta','LojaDestravada'}">
            <event name="onChange"><![CDATA[
                local btn = self:findControlByName("btnConfigSkins")
                local lojaAberta = tostring(sheet.LojaAberta or "") == "true" or tostring(sheet.LojaDestravada or "") == "true"

                if btn ~= nil then
                    btn.visible = not lojaAberta
                    btn.enabled = not lojaAberta
                end
            ]]></event>
        </dataLink>

        <rectangle left="10" top="38" width="218" height="86" color="#32353B" strokeColor="#50545E" strokeSize="1" xradius="6" yradius="6" cornerType="round"/>
        <label text="NOME" left="14" top="44" width="60" height="18" fontColor="#C8A000" fontStyle="bold"/>
        <label name="lblDetalheNomeLoja" field="TempDetalheNome" left="14" top="64" width="198" height="24" fontColor="white" fontStyle="bold" fontSize="14" horzTextAlign="center"/>
        <label field="TempDetalheRankTexto" left="14" top="94" width="94" height="18" fontColor="#C8A000" fontStyle="bold"/>
        <label text="TIPO" left="112" top="94" width="42" height="18" fontColor="#C8A000" fontStyle="bold"/>
        <label field="TempDetalheTipo" left="154" top="94" width="58" height="18" fontColor="white"/>

        <dataLink fields="{'TempDetalheCorRank','TempDetalheNome'}">
            <event name="onChange"><![CDATA[
                local cor = tostring(sheet.TempDetalheCorRank or "#FFFFFF")
                local nome = self:findControlByName("lblDetalheNomeLoja")
                local confirmacao = self:findControlByName("lblConfirmVendaNomeLoja")

                if nome ~= nil then nome.fontColor = cor end
                if confirmacao ~= nil then confirmacao.fontColor = cor end
            ]]></event>
        </dataLink>

        <rectangle left="10" top="130" width="218" height="116" color="#24272C" strokeColor="#50545E" strokeSize="1" xradius="6" yradius="6" cornerType="round"/>
        <rectangle left="14" top="134" width="210" height="108" color="#16181C" strokeColor="#3A3D44" strokeSize="1" xradius="5" yradius="5" cornerType="round"/>
        <image field="TempDetalheImagem" left="16" top="136" width="206" height="104" style="autoFit" animate="true" showProgress="false"/>

        <rectangle left="10" top="252" width="218" height="64" color="#32353B" strokeColor="#50545E" strokeSize="1" xradius="6" yradius="6" cornerType="round"/>
        <label text="ATRIBUTOS" left="14" top="258" width="100" height="18" fontColor="#C8A000" fontStyle="bold"/>
        <label field="TempDetalheAtributos" left="14" top="280" width="198" height="24" fontColor="white"/>

        <rectangle left="10" top="322" width="218" height="82" color="#24272C" strokeColor="#50545E" strokeSize="1" xradius="6" yradius="6" cornerType="round"/>
        <label text="DESCRICAO" left="14" top="328" width="120" height="18" fontColor="#C8A000" fontStyle="bold"/>
        <rectangle left="14" top="348" width="198" height="44" color="#1F2125" strokeColor="#3A3D44" strokeSize="1" xradius="5" yradius="5" cornerType="round"/>
        <textEditor field="TempDetalheDescricao" left="16" top="350" width="194" height="40" fontColor="white" readOnly="true"/>

        <rectangle left="10" top="410" width="218" height="40" color="#32353B" strokeColor="#50545E" strokeSize="1" xradius="6" yradius="6" cornerType="round"/>
        <label text="QTD" left="14" top="422" width="34" height="18" fontColor="#C8A000" fontStyle="bold"/>
        <rectangle left="50" top="416" width="48" height="26" color="#1F2125" strokeColor="#A07A2D" strokeSize="1" xradius="4" yradius="4" cornerType="round"/>
        <edit field="TempDetalheQuantidadeVenda" left="52" top="418" width="44" height="22" type="number" fontColor="white" horzTextAlign="center">
            <event name="onChange"><![CDATA[
                local qtd = math.floor(tonumber(sheet.TempDetalheQuantidadeVenda) or 1)
                local max = math.max(1, tonumber(sheet.TempDetalheQuantidadeMax) or 1)

                if qtd < 1 then qtd = 1 end
                if qtd > max then qtd = max end

                sheet.TempDetalheQuantidadeVenda = qtd
                sheet.TempDetalhePrecoVenda = (tonumber(sheet.TempDetalhePrecoVendaUnitario) or 0) * qtd
            ]]></event>
        </edit>
        <label text="/" left="100" top="422" width="12" height="18" fontColor="white"/>
        <label field="TempDetalheQuantidadeMax" left="112" top="422" width="34" height="18" fontColor="white"/>
        <label text="VENDA" left="150" top="422" width="46" height="18" fontColor="#C8A000" fontStyle="bold"/>
        <label field="TempDetalhePrecoVenda" left="194" top="422" width="30" height="18" fontColor="#C0C0C0" horzTextAlign="center" fontStyle="bold"/>

        <rectangle left="10" top="458" width="218" height="28" color="#1F2125" strokeColor="#3A3D44" strokeSize="1" xradius="5" yradius="5" cornerType="round"/>
        <button text="VENDER" left="82" top="460" width="74" height="24">
            <event name="onClick"><![CDATA[
                CWNA_venderItemLojaCompradoPorHandle(sheet, self)
            ]]></event>
        </button>

        <frame name="frameConfirmarVendaLoja" left="-22" top="175" width="282" height="146" visible="false">
            <rectangle align="client" color="#171717F0" strokeColor="#9A6A2A" strokeSize="2" xradius="6" yradius="6" cornerType="round">
                <label text="Deseja vender" left="18" top="12" width="246" height="20"
                       fontColor="white" fontStyle="bold" horzTextAlign="center"/>
                <label name="lblConfirmVendaNomeLoja" field="TempDetalheNome" left="18" top="36" width="246" height="28"
                       fontColor="white" fontStyle="bold" horzTextAlign="center" vertTextAlign="center"/>
                <label field="TempDetalheConfirmVendaTexto" left="18" top="68" width="246" height="22"
                       fontColor="white" fontStyle="bold" horzTextAlign="center"/>

                <button text="SIM" left="62" top="94" width="68" height="28">
                    <event name="onClick"><![CDATA[
                        local frame = self:findControlByName("frameConfirmarVendaLoja")
                        if frame ~= nil then frame.visible = false end
                        CWNA_confirmarVendaItemLojaComprado(sheet, self)
                    ]]></event>
                </button>

                <button text="NÃO" left="152" top="94" width="68" height="28">
                    <event name="onClick"><![CDATA[
                        local frame = self:findControlByName("frameConfirmarVendaLoja")
                        if frame ~= nil then frame.visible = false end
                    ]]></event>
                </button>
            </rectangle>
        </frame>
    </rectangle>
</frame>
        

    </layout>

</tab>

                <tab title="              SKILLS              .">
                    <image width="895" height="1158"
                    url="Frames/SKILLS.png" animate="true"/>

                    <rectangle align="top" height="30" xradius="5" yradius="5" cornerType="round" color="#21212100" margins="{left=20, right=20}">
									
									<button left="225" top="28" text="✚" width="30" onClick='self.rclMagias:append();'/>
								</rectangle>
								
								<recordList align="client" layout="horizontalTiles" name="rclMagias" field="magias" templateForm="templateMagias" 
								onSelect="self.rclMagias:sort();" onItemAdded="self.rclMagias:sort();" onItemRemoved="self.rclMagias:sort();" margins="{left = 30, right = -20, top = 35, bottom = 30}">
									<event name="onCompare">
									<![CDATA[               
										if(nodeA.elemMagia == nodeB.elemMagia) then
										
											if (nodeA.lvlMagia or 0) > (nodeB.lvlMagia or 0) then
													return 1;
											elseif (nodeA.lvlMagia or 0) < (nodeB.lvlMagia or 0) then
													return -1;
											else   
													return Utils.compareStringPtBr(nodeA.nomeMagia, nodeB.nomeMagia);
											end;
										
										elseif(nodeA.elemMagia == "Water" and 
										(nodeB.elemMagia == "Air" or nodeB.elemMagia == "Fire" or nodeB.elemMagia == "Earth" or nodeB.elemMagia == "Void" or nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Air" and 
										(nodeB.elemMagia == "Fire" or nodeB.elemMagia == "Earth" or nodeB.elemMagia == "Void" or nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Fire" and 
										(nodeB.elemMagia == "Earth" or nodeB.elemMagia == "Void" or nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Earth" and 
										(nodeB.elemMagia == "Void" or nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Void" and 
										(nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Universal" and 
										(nodeB.elemMagia == "Water" or nodeB.elemMagia == "Air" or nodeB.elemMagia == "Fire" or nodeB.elemMagia == "Earth" or nodeB.elemMagia == "Void")) then
											return 1;
										elseif(nodeA.elemMagia == "Void" and 
										(nodeB.elemMagia == "Water" or nodeB.elemMagia == "Air" or nodeB.elemMagia == "Fire" or nodeB.elemMagia == "Earth")) then
											return 1;
										elseif(nodeA.elemMagia == "Earth" and 
										(nodeB.elemMagia == "Water" or nodeB.elemMagia == "Air" or nodeB.elemMagia == "Fire")) then
											return 1;
										elseif(nodeA.elemMagia == "Fire" and 
										(nodeB.elemMagia == "Water" or nodeB.elemMagia == "Air")) then
											return 1;
										elseif(nodeA.elemMagia == "Air" and 
										(nodeB.elemMagia == "Water")) then
											return 1;
										end;
									]]>
									</event>
								</recordList>
                </tab>

                <tab title="            DIÁRIO            .">
                    <image width="895" height="1158"
                    url="Frames/fundo_branco.png" animate="true"/>
                    <richEdit align="client" field="background2" backgroundColor="#272727" defaultFontColor="white" margins="{left=15, top=20, right=15, bottom=20}"/>
                </tab>

                <tab title="          ANOTAÇÕES          .">
                    <image width="895" height="1158"
                    url="Frames/fundo_branco.png" animate="true"/>
                    <richEdit align="client" field="anotacao1" backgroundColor="#272727" defaultFontColor="white" margins="{left=15, top=20, right=15,  bottom=20}"/>
                </tab>

                <tab title="         PROFISSÕES         .">
                    <image width="895" height="1158"
                    url="Frames/ferreiro.png" animate="true"/>
                </tab>

            </tabControl>

        </layout>

    </scrollBox>

</layout>

<layout align="client" frameStyle="/Frames/frameFundo.xml"/>

<rectangle name="avisoGlobalInventario"
           left="100" top="203"
           width="330" height="42"
           color="#1B1B1BEE"
           strokeColor="#C8A000"
           strokeSize="2"
           xradius="8" yradius="8"
           cornerType="round"
           visible="false"
           hitTest="false">
    <label name="lblAvisoGlobalInventario"
           align="client"
           text="Aviso"
           fontColor="white"
           fontFamily="Cambria"
           fontSize="14"
           fontStyle="bold"
           horzTextAlign="center"
           vertTextAlign="center"/>
</rectangle>

</form>
