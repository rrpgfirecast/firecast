<dataLink field="Classe">
    <event name="onChange"><![CDATA[
        recalcularDefesa(self.sheet)
    ]]></event>
</dataLink>

<dataLink field="XP">
    <event name="onChange"><![CDATA[
        atualizarNivel(self.sheet)
        recalcularDefesa(self.sheet)
    ]]></event>
</dataLink>

