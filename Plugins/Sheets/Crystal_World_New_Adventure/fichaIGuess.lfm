<event name="onNodeReady"><![CDATA[
    CWNA_inicializarSlotsInventario(sheet)
    CWNA_sincronizarSlotsEspeciaisInventario(sheet)
    CWNA_verificarAtualizacaoFicha(sheet, true, false)
]]></event>



<script><![CDATA[
contador = 0
CWNA_VERSAO_ATUAL = "2.1.1"
CWNA_URL_ATUALIZACAO = "https://github.com/rrpgfirecast/firecast/blob/master/Plugins/Sheets/Crystal_World_New_Adventure/output/Crystal_World_New_Adventure.rpk?raw=true"
CWNA_URL_CHANGELOG = "https://github.com/rrpgfirecast/firecast/blob/master/Plugins/Sheets/Crystal_World_New_Adventure/README.md"
CWNA_ID_PLUGIN_ATUALIZACAO = "Alem_do_veu_Hiperion"
local function CWNA_isNewVersion(installed, downloaded)
    local installedVersion = {}
    local installedIndex = 0

    for i in string.gmatch(tostring(installed or "0"), "[^%.]+") do
        installedIndex = installedIndex + 1
        installedVersion[installedIndex] = i
    end

    local downloadedVersion = {}
    local downloadedIndex = 0

    for i in string.gmatch(tostring(downloaded or "0"), "[^%.]+") do
        downloadedIndex = downloadedIndex + 1
        downloadedVersion[downloadedIndex] = i
    end

    for i=1, math.min(installedIndex, downloadedIndex), 1 do
        local installedPart = tonumber(installedVersion[i]) or 0
        local downloadedPart = tonumber(downloadedVersion[i]) or 0

        if installedPart > downloadedPart then
            return false
        elseif installedPart < downloadedPart then
            return true
        end
    end

    return downloadedIndex > installedIndex
end
function CWNA_atualizarVersaoInstalada(ficha)
    local versao = CWNA_VERSAO_ATUAL
    local installed = Firecast.Plugins.getInstalledPlugins()

    for i=1, #installed, 1 do
        if installed[i].moduleId == CWNA_ID_PLUGIN_ATUALIZACAO then
            versao = installed[i].version or versao
            break
        end
    end

    ficha.versionInstalled = "SUA VERSAO: " .. tostring(versao)
    return versao
end

function CWNA_verificarAtualizacaoFicha(ficha, perguntar, avisarSemAtualizacao)
    local versaoInstalada = CWNA_atualizarVersaoInstalada(ficha)
    ficha.versionDownloaded = "VERSAO ATUAL: verificando..."

    Internet.download(
        CWNA_URL_ATUALIZACAO,
        function(stream, contentType)
            local info = nil

            if stream ~= nil then
                info = Firecast.Plugins.getRPKDetails(stream)
            end

            if info == nil then
                ficha.versionDownloaded = "VERSAO ATUAL: indisponivel"
                if avisarSemAtualizacao then
                    CWNA_mostrarAvisoPerfil(self, "Nao foi possivel verificar a atualizacao.", 9000)
                end
                return
            end

            local versaoDisponivel = tostring(info.version)
            local instalada = versaoInstalada
            local installed = Firecast.Plugins.getInstalledPlugins()

            for i=1, #installed, 1 do
                if installed[i].moduleId == info.moduleId then
                    instalada = installed[i].version or instalada
                    break
                end
            end

            if CWNA_isNewVersion(instalada, versaoDisponivel) then
                ficha.versionInstalled = "SUA VERSAO: " .. tostring(instalada)
                ficha.versionDownloaded = "VERSAO ATUAL: " .. versaoDisponivel

                if perguntar then
                    Dialogs.confirmYesNo(
                        "Sua ficha esta desatualizada, deseja baixar a nova versao?",
                        function(confirmado)
                            if confirmado then
                                GUI.openInBrowser(CWNA_URL_ATUALIZACAO)
                            end
                        end
                    )
                end
            else
                ficha.versionInstalled = "SUA VERSAO: " .. tostring(instalada)
                ficha.versionDownloaded = "VERSAO ATUAL: " .. tostring(instalada)

                if avisarSemAtualizacao then
                    CWNA_mostrarAvisoPerfil(self, "Voce ja tem instalada a versao mais recente!")
                end
            end
        end,
        function(errorMsg)
            ficha.versionDownloaded = "VERSAO ATUAL: indisponivel"
            if avisarSemAtualizacao then
                CWNA_mostrarAvisoPerfil(self, "Erro ao verificar atualizacao.", 9000)
            end
        end,
        nil,
        "checkForModification"
    )
end
local function compareMagia(nodeA, nodeB)

    if (nodeA.elemMagia == nodeB.elemMagia) then

        if (nodeA.lvlMagia or 0) > (nodeB.lvlMagia or 0) then
            return 1
        elseif (nodeA.lvlMagia or 0) < (nodeB.lvlMagia or 0) then
            return -1
        else
            return Utils.compareStringPtBr(nodeA.nomeMagia, nodeB.nomeMagia)
        end

    end

    local ordem = {
        Water = 1,
        Air = 2,
        Fire = 3,
        Earth = 4,
        Void = 5,
        Universal = 6
    }

    local a = ordem[nodeA.elemMagia] or 999
    local b = ordem[nodeB.elemMagia] or 999

    if a < b then return -1 end
    if a > b then return 1 end

    return 0
end
]]></script>

