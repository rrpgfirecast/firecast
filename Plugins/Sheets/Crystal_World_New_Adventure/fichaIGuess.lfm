    checkedImage="https://blob.firecast.com.br/blobs/PQLQEJWT_3805070/dado.png"
    uncheckedImage="https://blob.firecast.com.br/blobs/PQLQEJWT_3805070/dado.png">

    <event name="onClick">
        local total = n(sheet.SuporteFrioCalorTotal)
        local rolagem = Firecast.interpretarRolagem("1d20 + " .. total)

        local mesa = Firecast.getMesaDe(sheet)
        if mesa ~= nil then
            mesa.activeChat:rolarDados(rolagem, "Suporte frio calor")
        end
    </event>
</imageCheckBox>

	<imageCheckBox name="CURTO"
		left="577" top="985" width="28" height="55"
		checkedImage=""
		uncheckedImage="">

		<event name="onClick">

		local mesa = Firecast.getMesaDe(sheet);
		local acerto = tonumber(sheet.AcertoCurtoAlcanceTotal) or 0;
        local prof = tonumber(sheet.Prof) or 0;
		local r1 = Firecast.interpretarRolagem("1d20+" .. acerto .. "+" .. prof);

		if mesa then
			mesa.activeChat:rolarDados(r1, "Acerto Curto Alcance");
		end;

		if sheet.DanoMonstro1 and sheet.DanoMonstro1 ~= "" then
			local danoBase = tonumber(sheet.DanoCurtoAlcanceTotal) or 0;
			local prof = tonumber(sheet.Prof) or 0;

			local r2 = Firecast.interpretarRolagem(
				sheet.DanoMonstro1 .. "+" .. danoBase .. "+" .. prof
			);

			if mesa then
				mesa.activeChat:rolarDados(r2, "Dano Curto Alcance");
			end;
		end;

		</event>

	</imageCheckBox>

