    <layout align="client">

        <!-- FUNDO -->
        <image align="client" style="stretch" url="Frames/inventario.png"/>

        <!-- STATUS -->
        <label field="CaPersonagem" left="792" top="482" width="30"
               fontColor="white" fontStyle="bold" horzTextAlign="center"/>
        <dataLink field="CaPersonagem" defaultValue="0"/>

        <label field="RdPersonagem" left="792" top="524" width="30"
               fontColor="white" fontStyle="bold" horzTextAlign="center"/>
        <dataLink field="RdPersonagem" defaultValue="0"/>

    

        

        <!-- CAPACETE -->
        <dataLink field="ImagemCapacete" defaultValue="/Frames/Capacete.png"/>
        <rectangle left="58" top="103" width="84" height="88" color="#40404000">
            <image field="ImagemCapacete"
                   left="0" top="0"
                   width="84" height="88"
                   style="stretch"/>
        </rectangle>

        <!-- PEITORAL -->
        <dataLink field="ImagemPeitoral" defaultValue="/Frames/Peitoral.png"/>
        <rectangle left="58" top="256" width="84" height="88" color="#40404000">
            <image field="ImagemPeitoral"
                   left="0" top="0"
                   width="84" height="88"
                   style="stretch"/>
        </rectangle>

        <!-- CALÇA -->
        <dataLink field="ImagemCalca" defaultValue="/Frames/Calca.png"/>
        <rectangle left="58" top="407" width="84" height="88" color="#40404000">
            <image field="ImagemCalca"
                   left="0" top="0"
                   width="84" height="88"
                   style="stretch"/>
        </rectangle>

        <!-- ARMA -->
        <dataLink field="ImagemArma" defaultValue="/Frames/Arma.png"/>
        <rectangle left="389" top="103" width="84" height="88" color="#40404000">
            <image field="ImagemArma"
                   left="0" top="0"
                   width="84" height="88"
                   style="stretch"/>
        </rectangle>

        <!-- ESCUDO -->
        <dataLink field="ImagemEscudo" defaultValue="/Frames/Escudo.png"/>
        <rectangle left="389" top="256" width="84" height="88" color="#40404000">
            <image field="ImagemEscudo"
                   left="0" top="0"
                   width="84" height="88"
                   style="stretch"/>
        </rectangle>

        <!-- BOTA -->
        <dataLink field="ImagemBota" defaultValue="/Frames/Bota.png"/>
        <rectangle left="389" top="407" width="84" height="88" color="#40404000">
            <image field="ImagemBota"
                   left="0" top="0"
                   width="84" height="88"
                   style="stretch"/>
        </rectangle>

        <!-- ÁREA LISTA -->
        <rectangle align="client" color="#00000000">

            <!-- BARRA SUPERIOR -->
            <rectangle left="20" top="566" width="855" height="30" color="#00000000">

                <button left="100" top="4" width="30" text="🞦">
                    <event name="onClick"><![CDATA[
                        local lista = self.rclMagias2
                        if lista == nil then return end

                        local node = lista.node
                        local itens = (node and NDB.getChildNodes(node)) or {}

                        if #itens >= 60 then
                            showMessage("Limite máximo de 60 itens.")
                            return
                        end

                        lista:append()

                        -- ATUALIZA STATUS DA FICHA
                        recalcularDefesa(self.sheet)
                    ]]></event>
                </button>

                <label left="20" top="6"
                       text="ADICIONAR"
                       fontStyle="bold"
                       fontFamily="Constantia"/>
            </rectangle>

            <!-- LISTA -->
            <recordList align="client"
                        layout="horizontalTiles"
                        name="rclMagias2"
                        field="magias2"
                        templateForm="templateMagias2"
                        onSelect="self.rclMagias2:sort();"
                        margins="{left = 25, right = 15, top = 602, bottom = 15}">

                <event name="onCompare"><![CDATA[
                    if(nodeA.elemMagia == nodeB.elemMagia) then
                        if (nodeA.lvlMagia or 0) > (nodeB.lvlMagia or 0) then
                            return 1;
                        elseif (nodeA.lvlMagia or 0) < (nodeB.lvlMagia or 0) then
                            return -1;
                        else
                            return Utils.compareStringPtBr(nodeA.nomeMagia, nodeB.nomeMagia);
                        end;
                    end;
                ]]></event>

            </recordList>

        </rectangle>
<rectangle left="230" top="571" width="44" height="22" color="#131313">

    <edit
    name="edtOuro"
    field="OuroPersonagem"
    align="client"
    horzTextAlign="center"
    type="number"
    max="99999"
    fontColor="white"
    enabled="false"/>

    <dataLink field="OuroPersonagem" defaultValue="0"/>

</rectangle>


<rectangle left="314" top="571" width="44" height="22" color="#131313">

    <edit
    name="edtPrata"
    field="PrataPersonagem"
    align="client"
    horzTextAlign="center"
    type="number"
    max="99999"
    fontColor="white"
    enabled="false"/>

    <dataLink field="PrataPersonagem" defaultValue="0"/>

</rectangle>


<button text="🔒" left="359" top="571" width="22" height="22">
    <event name="onClick"><![CDATA[

        Dialogs.inputQuery(
            "Senha",
            "senha ADM:",
            "",

            function(senha)

                if senha == nil then
                    return
                end


                if senha ~= "151289" then
                    showMessage("Senha incorreta!")
                    return
                end


                local ouroEdit = self:findControlByName("edtNovoOuro")
                local prataEdit = self:findControlByName("edtNovaPrata")
                local painel = self:findControlByName("PainelEditarDinheiro")


                ouroEdit.text = tostring(sheet.OuroPersonagem or 0)
                prataEdit.text = tostring(sheet.PrataPersonagem or 0)


                painel.visible = true


            end
        )


    ]]></event>
</button>

<rectangle name="PainelEditarDinheiro"
    left="400"
    top="300"
    width="220"
    height="180"
    color="#111111"
    visible="false">


    <!-- BORDA SUPERIOR -->
    <rectangle
        left="0"
        top="0"
        width="220"
        height="30"
        color="#3A3A3A">

        <label
            left="0"
            top="5"
            width="220"
            height="20"
            text="⚜ GERENCIAR MOEDAS ⚜"
            fontColor="white"
            horzTextAlign="center"/>

    </rectangle>



    <!-- LINHA DIVISORIA -->
    <rectangle
        left="10"
        top="35"
        width="200"
        height="2"
        color="#C8A000"/>




    <!-- OURO -->

    <label
        left="20"
        top="55"
        width="80"
        height="20"
        text="🪙 Ouro:"
        fontColor="#FFD700"/>


    <edit
        name="edtNovoOuro"
        left="105"
        top="52"
        width="90"
        height="25"
        type="number"
        horzTextAlign="center"
        fontColor="white"/>




    <!-- PRATA -->

    <label
        left="20"
        top="90"
        width="80"
        height="20"
        text="🥈 Prata:"
        fontColor="#C0C0C0"/>


    <edit
        name="edtNovaPrata"
        left="105"
        top="87"
        width="90"
        height="25"
        type="number"
        horzTextAlign="center"
        fontColor="white"/>




    <!-- CADEADO -->

    <button
        name="btnPermitirEdicaoDinheiro"
        text="🔒"
        left="165"
        top="120"
        width="30"
        height="25">


        <event name="onClick"><![CDATA[


            local ouro = self:findControlByName("edtOuro")
            local prata = self:findControlByName("edtPrata")
            local botao = self:findControlByName("btnPermitirEdicaoDinheiro")



            if ouro == nil or prata == nil then

                showMessage("Erro: campos Ouro/Prata não encontrados.")
                return

            end




            if sheet.PermitirEditarDinheiro == true then


                sheet.PermitirEditarDinheiro = false


                ouro.enabled = false
                prata.enabled = false


                botao.text = "🔒"



            else


                sheet.PermitirEditarDinheiro = true


                ouro.enabled = true
                prata.enabled = true


                botao.text = "🔓"



            end



        ]]></event>


    </button>





    <!-- BOTAO CONFIRMAR -->

    <button
        name="btnConfirmarDinheiro"
        text="✓ CONFIRMAR"
        left="55"
        top="150"
        width="110"
        height="22">


        <event name="onClick"><![CDATA[


            local ouroEdit = self:findControlByName("edtNovoOuro")
            local prataEdit = self:findControlByName("edtNovaPrata")


            local ouro = tonumber(ouroEdit.text)
            local prata = tonumber(prataEdit.text)



            if ouro == nil or prata == nil then

                showMessage("Digite valores válidos.")
                return

            end



            if ouro < 0 then ouro = 0 end
            if prata < 0 then prata = 0 end


            if ouro > 99999 then ouro = 99999 end
            if prata > 99999 then prata = 99999 end



            sheet.OuroPersonagem = ouro
            sheet.PrataPersonagem = prata



            local painel = self:findControlByName("PainelEditarDinheiro")

            painel.visible = false



        ]]></event>


    </button>



</rectangle>
        

    </layout>

</tab>

