                            <rectangle left="286" top="151" width="36" height="24" color="#00000044" strokeColor="#A07A2D" strokeSize="1" xradius="3" yradius="3" cornerType="round"/>
                            <edit field="TempSkinRD" left="286" top="151" width="36" height="24" type="number" transparent="true" fontColor="white" horzTextAlign="center"/>

                            <label text="HP" left="174" top="186" width="30" height="18" horzTextAlign="center"/>
                            <rectangle left="208" top="183" width="36" height="24" color="#00000044" strokeColor="#A07A2D" strokeSize="1" xradius="3" yradius="3" cornerType="round"/>
                            <edit field="TempSkinHP" left="208" top="183" width="36" height="24" type="number" transparent="true" fontColor="white" horzTextAlign="center"/>
                            <label text="PP" left="252" top="186" width="30" height="18" horzTextAlign="center"/>
                            <rectangle left="286" top="183" width="36" height="24" color="#00000044" strokeColor="#A07A2D" strokeSize="1" xradius="3" yradius="3" cornerType="round"/>
                            <edit field="TempSkinPP" left="286" top="183" width="36" height="24" type="number" transparent="true" fontColor="white" horzTextAlign="center"/>

                            <label text="Deixe em branco ou 0 para nao aplicar bonus." left="174" top="226" width="132" height="42" horzTextAlign="center" vertTextAlign="center" fontSize="10"/>

                            <button text="SALVAR" left="178" top="350" width="82" height="28">
                                <event name="onClick"><![CDATA[
                                    local nome = tostring(sheet.TempNomeSkin or "")
                                    local imagem = tostring(sheet.TempImagemSkin or "")
                                    local uidEdicao = tostring(sheet.TempEditSkinUid or "")

                                    if nome == "" or imagem == "" then
                                        showMessage("Preencha nome e imagem da skin.")
                                        return
                                    end

                                    if sheet.skins == nil then
                                        NDB.createChildNode(sheet, "skins")
                                    end

                                    local skin = nil

                                    if uidEdicao ~= "" then
                                        skin = skinPorUidInventario(sheet, uidEdicao)
                                    end

                                    if skin == nil then
                                        skin = NDB.createChildNode(sheet.skins, "skin")
                                        skin.uidSkin = CWNA_uidSkin()
                                        skin.liberada = "false"
                                    end

                                    skin.nomeSkin = nome
                                    skin.imagemSkin = imagem
                                    skin.bonusForca = sheet.TempSkinForca
                                    skin.bonusDestreza = sheet.TempSkinDestreza
                                    skin.bonusConstituicao = sheet.TempSkinConstituicao
                                    skin.bonusInteligencia = sheet.TempSkinInteligencia
                                    skin.bonusSabedoria = sheet.TempSkinSabedoria
                                    skin.bonusCarisma = sheet.TempSkinCarisma
                                    skin.bonusCA = sheet.TempSkinCA
                                    skin.bonusRD = sheet.TempSkinRD
                                    skin.bonusHP = sheet.TempSkinHP
                                    skin.bonusPP = sheet.TempSkinPP

                                    CWNA_recalcularVisualSkinInventario(sheet)
                                    CWNA_atualizarCardsSkinInventario(sheet)
                                    recalcularDefesa(sheet)
                                    CWNA_limparEditorSkin(sheet)
                                ]]></event>
                            </button>
                        </rectangle>
                    </tab>
                </tabControl>
            </rectangle>
        </frame>

