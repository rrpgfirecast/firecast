function CWNA_salvarItemLoja(ficha)
    if ficha == nil then
        return
    end

    local nome = tostring(ficha.TempLojaNome or "")

    if nome == "" then
        showMessage("Preencha o nome do item da loja.")
        return
    end

    if ficha.lojaItens == nil then
        NDB.createChildNode(ficha, "lojaItens")
    end

    local item = procurarItemLojaPorUid(ficha, ficha.TempLojaUid)

    if item == nil then
        local novaOrdem = CWNA_ordemInsercaoLoja(ficha)

        for _, itemExistente in ipairs(NDB.getChildNodes(ficha.lojaItens)) do
            local ordemExistente = CWNA_numeroLoja(itemExistente.ordemLoja, 0)
            if ordemExistente >= novaOrdem then
                itemExistente.ordemLoja = ordemExistente + 1
            end
        end

        item = NDB.createChildNode(ficha.lojaItens, "itemLoja")
        item.uidLoja = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
        item.ordemLoja = novaOrdem
    end

    item.nomeItem = ficha.TempLojaNome
    item.tipoItem = ficha.TempLojaTipo
    item.subtipoMaterial = ficha.TempLojaSubtipoMaterial
    item.RankItem = ficha.TempLojaRank
    item.imagemestilo2 = ficha.TempLojaImagem
    item.precoPrata = CWNA_numeroLoja(ficha.TempLojaPrecoPrata, 0)
    item.quantidade = CWNA_numeroLoja(ficha.TempLojaQuantidade, 1)
    item.descricaoItem = ficha.TempLojaDescricao or ""
    item.hp = CWNA_numeroLoja(ficha.TempLojaHP, 0)
    item.pp = CWNA_numeroLoja(ficha.TempLojaPP, 0)
    item.ca = CWNA_numeroLoja(ficha.TempLojaCA, 0)
    item.rd = CWNA_numeroLoja(ficha.TempLojaRD, 0)
    item.dano = CWNA_numeroLoja(ficha.TempLojaDano, 0)
    item.cura = CWNA_numeroLoja(ficha.TempLojaCura, 0)

    CWNA_limparEditorLoja(ficha)
    CWNA_mudarPaginaLoja(ficha, 0)
end

function CWNA_excluirItemLoja(itemLoja)
    if itemLoja == nil then
        return
    end

    local ficha = NDB.getRoot(itemLoja)

    if ficha ~= nil and tostring(ficha.TempLojaUid or "") == tostring(itemLoja.uidLoja or "") then
        CWNA_limparEditorLoja(ficha)
    end

    local itemReal = procurarItemLojaPorUid(ficha, itemLoja.uidLoja)

    if itemReal ~= nil then
        NDB.deleteNode(itemReal)
    else
        NDB.deleteNode(itemLoja)
    end

    if ficha ~= nil then
        CWNA_garantirOrdemLoja(ficha)
        CWNA_mudarPaginaLoja(ficha, 0)
    end
end

function CWNA_abrirDetalheItemLojaComprado(item, controle)
    if item == nil or tostring(item.origemLoja or "") ~= "true" then
        return false
    end

    local ficha = NDB.getRoot(item)

    if ficha == nil then
        return true
    end

    ficha.TempDetalheItemHandle = NDB.getNodeHandle(item)
    ficha.TempDetalheItemUid = uidInventarioItem(item)
    ficha.TempDetalheNome = item.nomeItem or ""
    ficha.TempDetalheRank = item.RankItem or ""
    ficha.TempDetalheRankTexto = "RANK: " .. tostring(item.RankItem or "")
    ficha.TempDetalheCorRank = corRankLoja(item.RankItem)
    ficha.TempDetalheImagem = item.imagemestilo2 or ""
    ficha.TempDetalheDescricao = item.descricaoLoja or ""
    ficha.TempDetalheTipo = item.tipoItem or ""
    local atributosDetalhe = {}
    local function addAtributoDetalhe(nome, valor)
        local numero = CWNA_numeroLoja(valor, 0)
        if numero ~= 0 then
            table.insert(atributosDetalhe, nome .. " +" .. tostring(numero))
        end
    end
    addAtributoDetalhe("HP", item.hp)
    addAtributoDetalhe("PP", item.pp)
    addAtributoDetalhe("CA", item.ca)
    addAtributoDetalhe("RD", item.rd)
    addAtributoDetalhe("DANO", item.dano)
    addAtributoDetalhe("CURA", item.cura)
    ficha.TempDetalheAtributos = table.concat(atributosDetalhe, "  ")
    ficha.TempDetalheQuantidadeMax = CWNA_numeroLoja(item.quantidade, 1)
    ficha.TempDetalheQuantidadeVenda = 1
    ficha.TempDetalhePrecoVendaUnitario = math.floor(CWNA_numeroLoja(item.precoLojaPrata, 0) / 2)
    ficha.TempDetalhePrecoVenda = ficha.TempDetalhePrecoVendaUnitario

    local ctrl = controle

    while ctrl ~= nil do
        if ctrl.findControlByName ~= nil then
            local frame = ctrl:findControlByName("frameDetalheItemLoja")
            if frame ~= nil then
                frame.visible = true
                pcall(function() frame:bringToFront() end)
                return true
            end
        end

        ctrl = ctrl.parent
    end

    return true
end

local function procurarItemDetalheLoja(ficha)
    if ficha == nil then
        return nil
    end

    if ficha.TempDetalheItemHandle ~= nil then
        local ok, item = pcall(function() return NDB.openNode(ficha.TempDetalheItemHandle) end)

        if ok and item ~= nil then
            return item
        end
    end

    return procurarItemInventarioPorUid(ficha, ficha.TempDetalheItemUid)
end

local function fecharDetalheItemLoja(controle)
    local ctrl = controle

    while ctrl ~= nil do
        if ctrl.findControlByName ~= nil then
            local frame = ctrl:findControlByName("frameDetalheItemLoja")
            if frame ~= nil then
                frame.visible = false
                return
            end
        end

        ctrl = ctrl.parent
    end
end

function CWNA_venderItemLojaCompradoPorHandle(ficha, controle)
    if ficha == nil then
        return
    end

    local item = procurarItemDetalheLoja(ficha)

    if item == nil or tostring(item.origemLoja or "") ~= "true" then
        showMessage("Item da loja não encontrado no inventário.")
        return
    end

    if not itemInventarioBateComLojaParaVenda(ficha, item) then
        removerMarcaLojaInvalida(item)
        CWNA_mostrarAvisoInventario(controle, "Este item nao pode ser vendido.")
        fecharDetalheItemLoja(controle)
        return
    end

    local qtdDisponivel = CWNA_numeroLoja(item.quantidade, 0)
    if qtdDisponivel <= 0 then
        prepararSlotVazioInventario(item, item.ordemInventario)
        CWNA_mostrarAvisoInventario(controle, "Este item nao tem quantidade disponivel.")
        fecharDetalheItemLoja(controle)
        return
    end

    local qtdVenda = math.floor(CWNA_numeroLoja(ficha.TempDetalheQuantidadeVenda, 1))
    local valorUnitario = math.floor(CWNA_numeroLoja(item.precoLojaPrata, 0) / 2)

    if qtdVenda < 1 then qtdVenda = 1 end
    if qtdVenda > qtdDisponivel then qtdVenda = qtdDisponivel end

    ficha.TempDetalheQuantidadeVenda = qtdVenda
    ficha.TempDetalhePrecoVenda = valorUnitario * qtdVenda

    local valor = valorUnitario * qtdVenda
    ficha.TempDetalheConfirmVendaTexto = "por " .. tostring(valor) .. " prata?"

    local ctrl = controle
    while ctrl ~= nil do
        if ctrl.findControlByName ~= nil then
            local frame = ctrl:findControlByName("frameConfirmarVendaLoja")
            if frame ~= nil then
                frame.visible = true
                pcall(function() frame:bringToFront() end)
                return
            end
        end

        ctrl = ctrl.parent
    end
end

function CWNA_confirmarVendaItemLojaComprado(ficha, controle)
    if ficha == nil then
        return
    end

    local item = procurarItemDetalheLoja(ficha)

    if item == nil or tostring(item.origemLoja or "") ~= "true" then
        showMessage("Item da loja não encontrado no inventário.")
        return
    end

    if not itemInventarioBateComLojaParaVenda(ficha, item) then
        removerMarcaLojaInvalida(item)
        ficha.TempDetalheItemHandle = nil
        ficha.TempDetalheItemUid = ""
        ficha.TempDetalheConfirmVendaTexto = ""
        ficha.TempDetalheCorRank = "#FFFFFF"
        CWNA_mostrarAvisoInventario(controle, "Este item nao pode ser vendido.")
        fecharDetalheItemLoja(controle)
        return
    end

    local qtdDisponivel = CWNA_numeroLoja(item.quantidade, 0)
    if qtdDisponivel <= 0 then
        prepararSlotVazioInventario(item, item.ordemInventario)
        ficha.TempDetalheItemHandle = nil
        ficha.TempDetalheItemUid = ""
        ficha.TempDetalheConfirmVendaTexto = ""
        ficha.TempDetalheCorRank = "#FFFFFF"
        CWNA_mostrarAvisoInventario(controle, "Este item nao tem quantidade disponivel.")
        fecharDetalheItemLoja(controle)
        return
    end

    local qtdVenda = math.floor(CWNA_numeroLoja(ficha.TempDetalheQuantidadeVenda, 1))
    local valorUnitario = math.floor(CWNA_numeroLoja(item.precoLojaPrata, 0) / 2)

    if qtdVenda < 1 then qtdVenda = 1 end
    if qtdVenda > qtdDisponivel then qtdVenda = qtdDisponivel end

    local valor = valorUnitario * qtdVenda
    ficha.PrataPersonagem = prataAtualLoja(ficha) + valor
    enviarMensagemLoja(ficha, "vendeu", item, valor, qtdVenda)

    if qtdDisponivel > qtdVenda and itemLojaEmpilhavel(item) then
        item.quantidade = qtdDisponivel - qtdVenda
    else
        item.slotVazio = "true"
        item.uidInventario = "slot_" .. tostring(item.ordemInventario or "")
        item.nomeItem = ""
        item.tipoItem = ""
        item.subtipoMaterial = ""
        item.RankItem = ""
        item.imagemestilo2 = ""
        item.equipadoEm = ""
        item.quantidade = ""
        item.hp = 0
        item.pp = 0
        item.ca = 0
        item.rd = 0
        item.dano = 0
        item.cura = 0
        item.origemLoja = ""
        item.uidLojaOrigem = ""
        item.precoLojaPrata = ""
        item.descricaoLoja = ""
    end

    ficha.TempDetalheItemHandle = nil
    ficha.TempDetalheItemUid = ""
    ficha.TempDetalheConfirmVendaTexto = ""
    ficha.TempDetalheCorRank = "#FFFFFF"
    fecharDetalheItemLoja(controle)
end

local limparSlotInventario

local function campoSlotEspecialInventario(slot, campo)
    return "SlotEspecial" .. tostring(slot or "") .. "_" .. tostring(campo or "")
end

local function dadosDoItemInventario(item)
    if item == nil or ehSlotVazioInventario(item) then
        return nil
    end

    local dados = {}

    for _, campo in ipairs(camposDadosItemInventario) do
        dados[campo] = item[campo]
    end

    if dados.uidInventario == nil or dados.uidInventario == "" then
        dados.uidInventario = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
    end

    return dados
end

local function slotEspecialTemItemInventario(ficha, slot)
    if ficha == nil or slot == nil then
        return false
    end

    return tostring(ficha[campoSlotEspecialInventario(slot, "tipoItem")] or "") ~= ""
end

local function dadosDoSlotEspecialInventario(ficha, slot)
    if not slotEspecialTemItemInventario(ficha, slot) then
        return nil
    end

    local dados = {}

    for _, campo in ipairs(camposDadosItemInventario) do
        dados[campo] = ficha[campoSlotEspecialInventario(slot, campo)]
    end

    return dados
end

function atualizarVisualSkinInventario(ficha, controleOrigem)
    if ficha == nil then
        return
    end

    local slotsSet = {"Capacete", "Peitoral", "Calca", "Bota"}
    local slotsDesbloqueioSkin = {"Capacete", "Peitoral", "Calca", "Bota", "Arma"}
    local skinEquipada = skinEquipadaInventario(ficha)
    local dadosPorSlot = {}

    for _, slot in ipairs(slotsDesbloqueioSkin) do
        dadosPorSlot[slot] = dadosDoSlotEspecialInventario(ficha, slot)
    end

    if limparSkinsAutomaticasAntigasInventario(ficha) then
        CWNA_atualizarCardsSkinInventario(ficha)
    end

    local atualizouCardsSkin = false

    if conjuntoRankCompletoComArmaInventario(dadosPorSlot, "c") then
        atualizouCardsSkin = desbloquearSkinRankCTesteInventario(ficha, controleOrigem) or atualizouCardsSkin
    else
        atualizouCardsSkin = removerSkinRankCTesteNaoDesbloqueadaInventario(ficha) or atualizouCardsSkin
    end

    corrigirSkinRankCTesteEquipadaAntigaInventario(ficha)
    skinEquipada = skinEquipadaInventario(ficha)

    if atualizouCardsSkin then
        CWNA_atualizarCardsSkinInventario(ficha)
    end

    limparCamposSkinRankInventario(ficha)

    if skinEquipada ~= nil and tostring(skinEquipada.imagemSkin or "") ~= "" then
        if ehSkinRankCTesteInventario(skinEquipada) then
            ficha.BonecoSkinEspecial = ""
            ficha.BonecoSkinRankCTeste = skinEquipada.imagemSkin
        else
            ficha.BonecoSkinEspecial = skinEquipada.imagemSkin
        end

        for _, slot in ipairs(slotsSet) do
            ficha["Boneco" .. slot] = ""
        end
    else
        local skinRank = skinRankAtivaInventario(dadosPorSlot)
        ficha.BonecoSkinEspecial = ""

        if skinRank ~= nil then
            ficha[skinRank.campo] = skinRank.imagem

            for _, slot in ipairs(slotsSet) do
                ficha["Boneco" .. slot] = ""
            end
        else
            for _, slot in ipairs(slotsSet) do
                local dados = dadosPorSlot[slot]

                if dados ~= nil then
                    ficha["Boneco" .. slot] = imagemEquipamentoBonecoInventario(dados, slot)
                else
                    ficha["Boneco" .. slot] = imagemBaseBonecoInventario(slot)
                end
            end
        end
    end
end

function CWNA_alternarLiberacaoSkin(skin)
    if skin == nil then
        return
    end

    if tostring(skin.liberada or "") == "true" then
        skin.liberada = "false"
    else
        skin.liberada = "true"
    end

    local ficha = NDB.getRoot(skin)

    if ficha ~= nil and ficha.SkinEquipadaUid == skin.uidSkin and tostring(skin.liberada or "") ~= "true" then
        ficha.SkinEquipadaUid = ""
        CWNA_recalcularVisualSkinInventario(ficha)
        CWNA_atualizarCardsSkinInventario(ficha)
        recalcularDefesa(ficha)
    end
end

function CWNA_equiparOuDesequiparSkin(skin)
    if skin == nil or tostring(skin.liberada or "") ~= "true" then
        return
    end

    local ficha = NDB.getRoot(skin)

    if ficha == nil then
        return
    end

    if tostring(ficha.SkinEquipadaUid or "") == tostring(skin.uidSkin or "") then
        ficha.SkinEquipadaUid = ""
    else
        ficha.SkinEquipadaUid = skin.uidSkin
    end

    CWNA_recalcularVisualSkinInventario(ficha)
    CWNA_atualizarCardsSkinInventario(ficha)
    recalcularDefesa(ficha)
end

function CWNA_limparEditorSkin(ficha)
    if ficha == nil then
        return
    end

    ficha.TempEditSkinUid = ""
    ficha.TempNomeSkin = ""
    ficha.TempImagemSkin = ""
    ficha.TempSkinForca = ""
    ficha.TempSkinDestreza = ""
    ficha.TempSkinConstituicao = ""
    ficha.TempSkinInteligencia = ""
    ficha.TempSkinSabedoria = ""
    ficha.TempSkinCarisma = ""
    ficha.TempSkinCA = ""
    ficha.TempSkinRD = ""
    ficha.TempSkinHP = ""
    ficha.TempSkinPP = ""
end

function CWNA_carregarSkinNoEditor(skin)
    if skin == nil then
        return
    end

    local ficha = NDB.getRoot(skin)

    if ficha == nil then
        return
    end

    ficha.TempEditSkinUid = tostring(skin.uidSkin or "")
    ficha.TempNomeSkin = skin.nomeSkin or ""
    ficha.TempImagemSkin = skin.imagemSkin or ""
    ficha.TempSkinForca = skin.bonusForca or ""
    ficha.TempSkinDestreza = skin.bonusDestreza or ""
    ficha.TempSkinConstituicao = skin.bonusConstituicao or ""
    ficha.TempSkinInteligencia = skin.bonusInteligencia or ""
    ficha.TempSkinSabedoria = skin.bonusSabedoria or ""
    ficha.TempSkinCarisma = skin.bonusCarisma or ""
    ficha.TempSkinCA = skin.bonusCA or ""
    ficha.TempSkinRD = skin.bonusRD or ""
    ficha.TempSkinHP = skin.bonusHP or ""
    ficha.TempSkinPP = skin.bonusPP or ""
end

function CWNA_excluirSkin(skin)
    if skin == nil then
        return
    end

    local ficha = NDB.getRoot(skin)
    local uid = tostring(skin.uidSkin or "")

    if ficha ~= nil and tostring(ficha.SkinEquipadaUid or "") == uid then
        ficha.SkinEquipadaUid = ""
    end

    if ficha ~= nil and tostring(ficha.TempEditSkinUid or "") == uid then
        CWNA_limparEditorSkin(ficha)
    end

    NDB.deleteNode(skin)

    if ficha ~= nil then
        CWNA_recalcularVisualSkinInventario(ficha)
        CWNA_atualizarCardsSkinInventario(ficha)
        recalcularDefesa(ficha)
    end
end

function CWNA_fecharFramePorNome(controle, nomeFrame)
    local ctrl = controle

    while ctrl ~= nil do
        if ctrl.name == nomeFrame then
            ctrl.visible = false
            return
        end

        if ctrl.findControlByName ~= nil then
            local frame = ctrl:findControlByName(nomeFrame)

            if frame ~= nil then
                frame.visible = false
                return
            end
        end

        ctrl = ctrl.parent
    end
end

local function aplicarDadosNoItemInventario(item, dados, ordem)
    if item == nil then
        return
    end

    if dados == nil then
        prepararSlotVazioInventario(item, ordem or item.ordemInventario)
        return
    end

    item.slotVazio = nil
    item.ordemInventario = ordem or item.ordemInventario
    item.equipadoEm = ""

    for _, campo in ipairs(camposDadosItemInventario) do
        item[campo] = dados[campo] or ""
    end

    if item.uidInventario == nil or item.uidInventario == "" then
        item.uidInventario = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
    end
end

local function atualizarVisualSlotEspecialInventario(ficha, slot, controleOrigem)
    if ficha == nil or slot == nil then
        return
    end

    local dados = dadosDoSlotEspecialInventario(ficha, slot)

    if dados == nil then
        limparSlotInventario(ficha, slot)
        atualizarVisualSkinInventario(ficha, controleOrigem)
        return
    end

    ficha["Imagem" .. slot] = dados.imagemestilo2 or imagensPadraoInventario[slot]
    ficha["ItemEquipado" .. slot] = dados.nomeItem or ""
    ficha["ItemEquipadoHandle" .. slot] = nil
    ficha["ItemEquipadoUid" .. slot] = dados.uidInventario

    if partesBonecoInventario[slot] ~= nil then
        ficha["Boneco" .. slot] = imagemEquipamentoBonecoInventario(dados, slot)
    end

    for _, atributo in ipairs(atributosInventario) do
        ficha[atributo.prefixoSlot .. slot] = fixNumeroInventario(dados[atributo.campoItem])
    end

    atualizarVisualSkinInventario(ficha, controleOrigem)
end

function conjuntoRankCompletoComArmaInventario(dadosPorSlot, rank)
    if not conjuntoRankCompletoInventario(dadosPorSlot, rank) then
        return false
    end

    local dadosArma = dadosPorSlot and dadosPorSlot.Arma or nil
    local entradaArma = visualDoItemInventario(dadosArma)

    return entradaArma ~= nil and tostring(entradaArma.rank or "") == tostring(rank or "")
end

local function aplicarDadosNoSlotEspecialInventario(ficha, slot, dados, controleOrigem)
    if ficha == nil or slot == nil then
        return
    end

    for _, campo in ipairs(camposDadosItemInventario) do
        ficha[campoSlotEspecialInventario(slot, campo)] = dados and (dados[campo] or "") or ""
    end

    atualizarVisualSlotEspecialInventario(ficha, slot, controleOrigem)
end

function limparSlotInventario(ficha, slot)
    if ficha == nil or slot == nil then
        return
    end

    ficha["Imagem" .. slot] = imagensPadraoInventario[slot] or ""
    ficha["ItemEquipado" .. slot] = ""
    ficha["ItemEquipadoHandle" .. slot] = nil
    ficha["ItemEquipadoUid" .. slot] = nil

    if partesBonecoInventario[slot] ~= nil then
        ficha["Boneco" .. slot] = imagemBaseBonecoInventario(slot)
    end

    for _, atributo in ipairs(atributosInventario) do
        ficha[atributo.prefixoSlot .. slot] = 0
    end

    atualizarVisualSkinInventario(ficha)
end

local function desmarcarItemAnteriorInventario(itemAtual, slot)
    local lista = NDB.getParent(itemAtual)

    if lista == nil then
        return
    end

    local handleAtual = NDB.getNodeHandle(itemAtual)

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if NDB.getNodeHandle(item) ~= handleAtual and item.equipadoEm == slot then
            item.equipadoEm = ""
        end
    end
end

function CWNA_desequiparSlotInventario(ficha, slot)
    if ficha == nil or slot == nil or slot == "" then
        return
    end

    local handle = ficha["ItemEquipadoHandle" .. slot]

    if handle ~= nil then
        local ok, item = pcall(function() return NDB.openNode(handle) end)

        if ok and item ~= nil then
            item.equipadoEm = ""
        end
    end

    limparSlotInventario(ficha, slot)
    recalcularDefesa(ficha)
end

function CWNA_equiparItemInventario(ficha, item, slotAlvo, controleOrigem)
    if ficha == nil or item == nil then
        return
    end

    local slotItem = slotDoItemInventario(item)

    if slotItem == nil then
        showMessage("Este item nao pode ser equipado.")
        return
    end

    if slotAlvo ~= nil and slotItem ~= slotAlvo then
        return
    end

    local dadosOrigem = dadosDoItemInventario(item)

    if dadosOrigem == nil then
        return
    end

    local ordemOrigem = item.ordemInventario
    local dadosEspecial = dadosDoSlotEspecialInventario(ficha, slotItem)

    aplicarDadosNoSlotEspecialInventario(ficha, slotItem, dadosOrigem, controleOrigem)
    aplicarDadosNoItemInventario(item, dadosEspecial, ordemOrigem)
    recalcularDefesa(ficha)
end

function CWNA_sincronizarSlotsEspeciaisInventario(ficha)
    if ficha == nil then
        return
    end

    for slot, _ in pairs(imagensPadraoInventario) do
        if slotDoItemInventario({tipoItem = slot}) ~= nil then
            atualizarVisualSlotEspecialInventario(ficha, slot)
        end
    end

    recalcularDefesa(ficha)
end

function CWNA_soltarSlotEspecialNoInventario(ficha, itemAlvo, slotOrigem, controleOrigem)
    if ficha == nil or itemAlvo == nil or slotOrigem == nil then
        return
    end

    local dadosEspecial = dadosDoSlotEspecialInventario(ficha, slotOrigem)

    if dadosEspecial == nil then
        return
    end

    local dadosAlvo = dadosDoItemInventario(itemAlvo)
    local ordemAlvo = itemAlvo.ordemInventario

    if dadosAlvo ~= nil and slotDoItemInventario(dadosAlvo) ~= slotOrigem then
        CWNA_mostrarAvisoInventario(controleOrigem, "O item destino nao pode ser equipado aqui")
        return
    end

    aplicarDadosNoItemInventario(itemAlvo, dadosEspecial, ordemAlvo)
    aplicarDadosNoSlotEspecialInventario(ficha, slotOrigem, dadosAlvo, controleOrigem)
    recalcularDefesa(ficha)
end

function CWNA_dropItemInventario(ficha, slotAlvo, uid, controleOrigem)
    if uid == nil then
        return
    end

    local item = procurarItemInventarioPorUid(ficha, uid)

    if item ~= nil then
        CWNA_equiparItemInventario(ficha, item, slotAlvo, controleOrigem)
    end
end

function CWNA_usarPotionArrastadaNoBoneco(ficha, uid, controleOrigem)
    if ficha == nil or uid == nil then
        return
    end

    local item = procurarItemInventarioPorUid(ficha, uid)

    if item == nil then
        return
    end

    local tipoPotion = tipoPotionDoItemInventario(item)

    if tipoPotion == nil then
        CWNA_mostrarAvisoInventario(controleOrigem, "Solte aqui apenas potion HP ou PP")
        return
    end

    local mesa = rrpg.getMesaDe(ficha)
    local jogador = mesa and mesa.me or nil
    local chat = mesa and mesa.chat or nil

    if jogador == nil or chat == nil then
        showMessage("Jogador ou chat nao disponivel.")
        return
    end

    local indexBarra = nil
    local valorBase = 0
    local prefixo = nil

    if tipoPotion == "HP" then
        indexBarra = 1
        valorBase = fixNumeroInventario(item.cura)
        prefixo = "HP"
    elseif tipoPotion == "PP" then
        indexBarra = 2
        valorBase = fixNumeroInventario(item.pp)
        prefixo = "PP"
    else
        return
    end

    local atual, maximo = jogador:getBarValue(indexBarra)

    if atual == nil or maximo == nil then
        showMessage("Barra nao disponivel ou invisivel.")
        return
    end

    if atual >= maximo then
        if prefixo == "HP" then
            CWNA_mostrarAvisoInventario(controleOrigem, "Seu HP esta cheio")
        else
            CWNA_mostrarAvisoInventario(controleOrigem, "Seu PP esta cheio")
        end

        return
    end

    local curaReal = math.min(valorBase, maximo - atual)

    if curaReal <= 0 then
        return
    end

    local quantidade = fixNumeroInventario(item.quantidade)

    if quantidade <= 0 then
        CWNA_mostrarAvisoInventario(controleOrigem, "Este item nao tem quantidade disponivel.")
        return
    end

    local nomeJogador = "Jogador"
    pcall(function()
        nomeJogador = tostring(jogador.nick or jogador.nickname or jogador.nome or jogador.name or jogador.login or "Jogador")
    end)

    local nomePotion = tostring(item.nomeItem or item.tipoItem or ("Potion " .. prefixo))
    if nomePotion == nil or nomePotion == "" then
        nomePotion = "Potion " .. prefixo
    end

    local okCura = pcall(function()
        chat:enviarMensagem("/" .. prefixo .. " +" .. curaReal)
    end)

    if not okCura then
        CWNA_mostrarAvisoInventario(controleOrigem, "Nao foi possivel usar esta potion.")
        return
    end

    pcall(function()
        local marcadorCor = "[" .. string.char(194, 167) .. "K"
        local corItem = codigoCorRankChatLoja(item.RankItem)
        chat:enviarMensagem("<" .. nomeJogador .. "> " .. marcadorCor .. "1]utilizou 1x " .. marcadorCor .. corItem .. "]" .. nomePotion .. marcadorCor .. "1] e restaurou " .. tostring(curaReal) .. " de " .. prefixo)
    end)

    item.quantidade = quantidade - 1
    if fixNumeroInventario(item.quantidade) <= 0 then
        local okLimpeza = pcall(function()
            CWNA_removerItemInventarioSeQuantidadeZero(item)
        end)

        if not okLimpeza then
            pcall(function()
                prepararSlotVazioInventario(item, item.ordemInventario)
            end)
        end
    end
end

function CWNA_registrarDropPotionBoneco(drop, drag, ficha, controleOrigem)
    if drop == nil or drag == nil or ficha == nil then
        return
    end

    local uid = nil
    local ok = pcall(function()
        uid = drag:getData("cwnaInventarioUid")
    end)

    if not ok or uid == nil then
        return
    end

    local item = procurarItemInventarioPorUid(ficha, uid)

    if item == nil or tipoPotionDoItemInventario(item) == nil then
        return
    end

    drop:addAction("cwnaInventarioUid", function(uidDrop)
        CWNA_usarPotionArrastadaNoBoneco(ficha, uidDrop, controleOrigem)
    end)
end

function CWNA_mostrarAvisoInventario(controle, texto, duracao, corTexto, textoColorido)
    local ctrl = controle
    local raiz = controle
    local aviso = nil
    local label = nil

    while raiz ~= nil and raiz.parent ~= nil do
        raiz = raiz.parent
    end

    if raiz ~= nil and raiz.findControlByName ~= nil then
        aviso = raiz:findControlByName("avisoGlobalInventario")
        label = raiz:findControlByName("lblAvisoGlobalInventario")
    end

    while ctrl ~= nil and aviso == nil do
        if ctrl.findControlByName ~= nil then
            aviso = ctrl:findControlByName("avisoLojaInterno")
            label = ctrl:findControlByName("lblAvisoLojaInterno")

            if aviso == nil then
                aviso = ctrl:findControlByName("avisoSlotErradoInventario")
                label = ctrl:findControlByName("lblAvisoSlotErradoInventario")
            end
        end

        ctrl = ctrl.parent
    end

    if aviso == nil then
        return
    end

    if label ~= nil then
        label.text = texto or "Slot errado, confira o tipo do item"
        label.fontColor = corTexto or "#FFFFFF"
    end

    aviso.visible = true
    pcall(function() aviso:bringToFront() end)
    setTimeout(function()
        if aviso ~= nil then
            pcall(function() aviso:bringToFront() end)
        end
    end, 1)

    setTimeout(function()
        if aviso ~= nil then
            aviso.visible = false
        end
    end, duracao or 2600)
end

local function CWNA_marcarDropInvalidoVisual(controle, event)
    if event ~= nil then
        pcall(function() event.cursor = "noDrop" end)
        pcall(function() event.Cursor = "noDrop" end)
    end

    if controle ~= nil then
        pcall(function() controle.cursor = "noDrop" end)
        setTimeout(function()
            if controle ~= nil then
                pcall(function() controle.cursor = "default" end)
            end
        end, 50)
    end
end

function CWNA_removerItemInventarioSeQuantidadeZero(item)
    if item == nil or ehSlotVazioInventario(item) then
        return false
    end

    local textoQtd = tostring(item.quantidade or "")
    if textoQtd == "" then
        return false
    end

    if fixNumeroInventario(textoQtd) > 0 then
        return false
    end

    local ficha = NDB.getRoot(item)
    local ordem = tonumber(item.ordemInventario) or item.ordemInventario

    if ficha ~= nil and item.equipadoEm ~= nil and item.equipadoEm ~= "" then
        CWNA_desequiparSlotInventario(ficha, item.equipadoEm)
    end

    prepararSlotVazioInventario(item, ordem)
    return true
end

function CWNA_registrarDropSlotInventario(drop, drag, ficha, slotAlvo, controleOrigem, event)
    if drop == nil or drag == nil or ficha == nil or slotAlvo == nil then
        return
    end

    local infoEspecial = nil
    local okEspecial = pcall(function()
        infoEspecial = drag:getData("cwnaSlotEspecial")
    end)

    if okEspecial and infoEspecial ~= nil then
        local dadosEspecial = dadosDoSlotEspecialInventario(ficha, infoEspecial.slot)

        if dadosEspecial == nil then
            return
        end

        if infoEspecial.slot == slotAlvo then
            drop:addAction("cwnaSlotEspecial", function()
            end)
            return
        end

        CWNA_marcarDropInvalidoVisual(controleOrigem, event)
        drop:addAction("cwnaSlotEspecial", function()
            CWNA_mostrarAvisoInventario(controleOrigem, "Slot errado, confira o tipo do item")
        end)
        return
    end

    local uidLoja = nil
    local okLoja = pcall(function()
        uidLoja = drag:getData("cwnaLojaUid")
    end)

    if okLoja and uidLoja ~= nil then
        local itemLoja = procurarItemLojaPorUid(ficha, uidLoja)

        if itemLoja == nil then
            return
        end

        if slotDoItemInventario(itemLoja) ~= slotAlvo then
            CWNA_marcarDropInvalidoVisual(controleOrigem, event)
            drop:addAction("cwnaLojaUid", function()
                CWNA_mostrarAvisoInventario(controleOrigem, "Slot errado, confira o tipo do item")
            end)
            return
        end

        drop:addAction("cwnaLojaUid", function(uidDrop)
            CWNA_comprarItemLojaPorUid(ficha, uidDrop, controleOrigem)
        end)
        return
    end

    local uid = nil
    local tipoDragOrigem = "cwnaInventarioUid"
    local ok = pcall(function()
        uid = drag:getData("cwnaInventarioUid")
    end)

    if (not ok or uid == nil) then
        local info = nil
        ok = pcall(function()
            info = drag:getData("cwnaSlotEquipado")
        end)

        if ok and info ~= nil then
            uid = info.uid
            tipoDragOrigem = "cwnaSlotEquipado"
        end
    end

    if not ok or uid == nil then
        return
    end

    local item = procurarItemInventarioPorUid(ficha, uid)

    if item == nil then
        return
    end

    if slotDoItemInventario(item) ~= slotAlvo then
        CWNA_marcarDropInvalidoVisual(controleOrigem, event)
        drop:addAction(tipoDragOrigem, function()
            CWNA_mostrarAvisoInventario(controleOrigem, "Slot errado, confira o tipo do item")
        end)
        return
    end

    drop:addAction("cwnaInventarioUid", function(uidDrop)
        CWNA_dropItemInventario(ficha, slotAlvo, uidDrop, controleOrigem)
    end)
end

function CWNA_dragSlotInventario(ficha, slot, drag)
    if ficha == nil or slot == nil or drag == nil then
        return
    end

    local dados = dadosDoSlotEspecialInventario(ficha, slot)

    if dados ~= nil then
        drag:addData("cwnaSlotEspecial", {slot = slot})
        drag:addData("text", dados.nomeItem or "Item equipado")

        if dados.imagemestilo2 ~= nil and dados.imagemestilo2 ~= "" then
            drag:addData("url", dados.imagemestilo2)
            drag:addData("imageURL", dados.imagemestilo2)
            drag:addData("image", dados.imagemestilo2)
            drag:addData("text/uri-list", dados.imagemestilo2)
        end
    end
end


--------------------------------------------------
-- RANK / CLASSE
--------------------------------------------------

local RankDB = {
    ["E"]  = {hp = 6,  pp = 2,  atributos = 7},
    ["D"]  = {hp = 10, pp = 4,  atributos = 9},
    ["C"]  = {hp = 14, pp = 6,  atributos = 11},
    ["B"]  = {hp = 20, pp = 8,  atributos = 13},
    ["A"]  = {hp = 24, pp = 10, atributos = 15},
    ["S"]  = {hp = 30, pp = 15, atributos = 17},
    ["SS"] = {hp = 38, pp = 18, atributos = 25}
}

local ClassHP = {
    ["COLOSSO"] = 8,
    ["MONGE"] = 5,
    ["ESTANDARTE"] = 7,
    ["CAMPEÃO"] = 6,
    ["DANÇARINO"] = 5,
    ["SENTINELA"] = 4,
    ["LAMINAS"] = 4,
    ["ESTRATEGISTA"] = 3,
    ["FORJADO"] = 6,
    ["ASSASSINO"] = 4,
    ["ELEMENTARISTA"] = 4,
    ["ORACULO"] = 3
}

local function classeNormalizada(nomeClasse)
    if nomeClasse == "CAMPEAO" then
        return "CAMPEÃO"
    end

    if nomeClasse == "DANCARINO" then
        return "DANÇARINO"
    end

    return nomeClasse
end


--------------------------------------------------
-- XP / LEVEL
--------------------------------------------------

local function xpNecessarioParaNivel(nivel)
    local xp = 0
    for i = 2, nivel do
        xp = xp + (i * 5)
    end
    return xp
end

local function calcularNivel(xp)
    local nivel = 1
    for i = 2, 20 do
        if xp >= xpNecessarioParaNivel(i) then
            nivel = i
        else
            break
        end
    end
    return nivel
end

function atualizarNivel(sheet)
    if not sheet then return end

    sheet.NivelPersonagem = calcularNivel(n(sheet.XP))

    atualizarBarraXP(sheet)

    recalcularDefesa(sheet)
end

function atualizarBarraXP(sheet)
    if not sheet then return end

    local xpAtual = n(sheet.XP)
    local nivel = calcularNivel(xpAtual)

    local xpProximoNivel = xpNecessarioParaNivel(nivel + 1)

    -- Se estiver no nÃ­vel mÃ¡ximo
    if nivel >= 20 then
        xpProximoNivel = xpAtual
    end

    sheet.XPBarra = xpAtual
    sheet.XPBarraMax = xpProximoNivel
    sheet.XPTexto = xpAtual .. "/" .. xpProximoNivel
end

function onClasseOuRankChange(sheet)
    recalcularDefesa(sheet)
end


--------------------------------------------------
-- PERÃCIAS
--------------------------------------------------

PERICIAS_FORCA = {
    "BracoDeFerro","Correr","DanoCurtoAlcance","DanoLongoAlcance",
    "EmpurrarObstaculo","Escalar"
}

PERICIAS_DES = {
    "AcertoDistancia","AcertoCurtoAlcance","DesarmarArmadilha",
    "Esquivar","Furtividade","Iniciativa","MontariaDirecao","Roubo"
}

PERICIAS_INT = {
    "AcertoMagico","IdentificarCriatura","Investigacao","LerManuscrito",
    "Medicina","PrepararEstrategia","Profissao","ResistenciaMental"
}

PERICIAS_SAB = {
    "DetectarMagia","DanoMagico","Historia","Natureza",
    "PerceberMentira","Percepcao","Religiao","Sobrevivencia"
}

PERICIAS_CAR = {
    "Atuar","Discurso","Intimidar","Mentir","Seducao"
}

PERICIAS_CON = {
    "ResistenciaCansaco","ResistirVeneno","SegurarFolego","SuporteFrioCalor"
}


--------------------------------------------------
-- FUNÃ‡Ã•ES BASE
--------------------------------------------------

local function custoPericia(nivel)
    return (nivel * (nivel + 1)) / 2
end

local function gastoTotal(sheet, lista)
    local total = 0
    for _, nome in ipairs(lista) do
        total = total + custoPericia(n(sheet[nome .. "1"]))
    end
    return total
end

local function modDisponivel(sheet, baseMod, lista)
    return n(baseMod) - gastoTotal(sheet, lista)
end

function onHBChange()
    recalcularDefesa(self.sheet)
end
--------------------------------------------------
-- DEFESA PRINCIPAL
--------------------------------------------------

function recalcularDefesa(sheet)
    if not sheet then return end

    local ca, rd, hp, pp, dano, cura = 0, 0, 0, 0, 0, 0

    for _, slot in ipairs(slots) do
        ca = ca + n(sheet["Ca" .. slot])
        rd = rd + n(sheet["Rd" .. slot])
        hp = hp + n(sheet["Hp" .. slot])
        pp = pp + n(sheet["Pp" .. slot])
        dano = dano + n(sheet["Dano" .. slot])
        cura = cura + n(sheet["Cura" .. slot])
    end

    local function calcularProf(level)
    if level >= 17 then return 6 end
    if level >= 13 then return 5 end
    if level >= 9 then return 4 end
    if level >= 5 then return 3 end
    return 2
    end

    local level = n(sheet.NivelPersonagem)
    local prof = calcularProf(level)
    sheet.Prof = prof
    local skinEquipada = skinEquipadaInventario(sheet)

    local bonusAcertoCurto = 0
    local bonusAcertoLongo = 0
    local bonusAcertoMagico = 0
    bonusResistenciaMental = 0

    local function temHB(hb)
        return sheet.HB1 == hb
            or sheet.HB2 == hb
            or sheet.HB3 == hb
            or sheet.HB4 == hb
    end

    if temHB("GOLPE_PESADO") then
        bonusAcertoCurto = bonusAcertoCurto - 1
        bonusAcertoLongo = bonusAcertoLongo - 1
        bonusAcertoMagico = bonusAcertoMagico - 1
    end
    if temHB("PELE_MISTICA") then
    bonusResistenciaMental = bonusResistenciaMental + 1
    end

    --------------------------------------------------
    -- ATRIBUTOS
    --------------------------------------------------

    sheet.ForcaTotal = n(sheet.ForcaValor) + n(sheet.ForcaAdd) + n(skinEquipada and skinEquipada.bonusForca)
    sheet.ForcaMod = sheet.ForcaTotal * 2

    sheet.DestrezaTotal = n(sheet.DestrezaValor) + n(sheet.DestrezaAdd) + n(skinEquipada and skinEquipada.bonusDestreza)
    sheet.DestrezaMod = sheet.DestrezaTotal * 2

    sheet.ConstituicaoTotal = n(sheet.ConstituicaoValor) + n(sheet.ConstituicaoAdd) + n(skinEquipada and skinEquipada.bonusConstituicao)
    sheet.ConstituicaoMod = sheet.ConstituicaoTotal * 2

    sheet.InteligenciaTotal = n(sheet.InteligenciaValor) + n(sheet.InteligenciaAdd) + n(skinEquipada and skinEquipada.bonusInteligencia)
    sheet.InteligenciaMod = sheet.InteligenciaTotal * 2

    sheet.SabedoriaTotal = n(sheet.SabedoriaValor) + n(sheet.SabedoriaAdd) + n(skinEquipada and skinEquipada.bonusSabedoria)
    sheet.SabedoriaMod = sheet.SabedoriaTotal * 2

    sheet.CarismaTotal = n(sheet.CarismaValor) + n(sheet.CarismaAdd) + n(skinEquipada and skinEquipada.bonusCarisma)
    sheet.CarismaMod = sheet.CarismaTotal * 2

    --------------------------------------------------
    -- MODS USÃVEIS
    --------------------------------------------------

    sheet.ForcaModUsavel = modDisponivel(sheet, sheet.ForcaMod, PERICIAS_FORCA)
    sheet.DestrezaModUsavel = modDisponivel(sheet, sheet.DestrezaMod, PERICIAS_DES)
    sheet.InteligenciaModUsavel = modDisponivel(sheet, sheet.InteligenciaMod, PERICIAS_INT)
    sheet.SabedoriaModUsavel = modDisponivel(sheet, sheet.SabedoriaMod, PERICIAS_SAB)
    sheet.CarismaModUsavel = modDisponivel(sheet, sheet.CarismaMod, PERICIAS_CAR)
    sheet.ConstituicaoModUsavel = modDisponivel(sheet, sheet.ConstituicaoMod, PERICIAS_CON)

    --------------------------------------------------
    -- PERÃCIAS
    --------------------------------------------------

    local pericias = {
    "BracoDeFerro","Correr","DanoCurtoAlcance","DanoLongoAlcance",
    "EmpurrarObstaculo","Escalar","AcertoDistancia","AcertoCurtoAlcance",
    "DesarmarArmadilha","Esquivar","Furtividade","Iniciativa",
    "MontariaDirecao","Roubo","AcertoMagico","IdentificarCriatura",
    "Investigacao","LerManuscrito","Medicina","PrepararEstrategia",
    "Profissao","ResistenciaMental","DetectarMagia","DanoMagico",
    "Historia","Natureza","PerceberMentira","Percepcao",
    "Religiao","Sobrevivencia","Atuar","Discurso",
    "Intimidar","Mentir","Seducao","ResistenciaCansaco",
    "ResistirVeneno","SegurarFolego","SuporteFrioCalor"
}

for _, nome in ipairs(pericias) do
    local total = n(sheet[nome .. "1"]) + n(sheet[nome .. "2"])

    local ativo = sheet[nome .. "_ativo"]
    if ativo == 1 or ativo == true or ativo == "true" then
        total = total + prof
    end

    -- bÃ´nus por HB
    if nome == "AcertoCurtoAlcance" then
        total = total + bonusAcertoCurto

    elseif nome == "AcertoDistancia" then
        total = total + bonusAcertoLongo

    elseif nome == "AcertoMagico" then
        total = total + bonusAcertoMagico

    elseif nome == "ResistenciaMental" then
        total = total + bonusResistenciaMental
    end

    -- penalidade por exaustão
    total = total + n(sheet.Exaustao)

    -- salva resultado final
    sheet[nome .. "Total"] = total
end

    --------------------------------------------------
    -- ATRIBUTO PRINCIPAL
    --------------------------------------------------

    local atributoPrincipal = sheet.AtributoPrincipal
    local valorPrincipal = 0

    if atributoPrincipal == "FOR" then
        valorPrincipal = n(sheet.ForcaTotal)
    elseif atributoPrincipal == "DES" then
        valorPrincipal = n(sheet.DestrezaTotal)
    elseif atributoPrincipal == "CON" then
        valorPrincipal = n(sheet.ConstituicaoTotal)
    elseif atributoPrincipal == "INT" then
        valorPrincipal = n(sheet.InteligenciaTotal)
    elseif atributoPrincipal == "SAB" then
        valorPrincipal = n(sheet.SabedoriaTotal)
    elseif atributoPrincipal == "CAR" then
        valorPrincipal = n(sheet.CarismaTotal)
    end

    --------------------------------------------------
    -- BASES
    --------------------------------------------------

    local rank = RankDB and RankDB[sheet.Rank] or {hp = 0, pp = 0, atributos = 0}
    local classe = classeNormalizada(sheet.Classe)
    local classBonus = ClassHP and ClassHP[classe] or 0
    local AtributosRank = rank.atributos
    local AtributosNivel = 0

    if level >= 4 then AtributosNivel = AtributosNivel + 3 end
    if level >= 6 then AtributosNivel = AtributosNivel + 3 end
    if level >= 8 then AtributosNivel = AtributosNivel + 3 end
    if level >= 12 then AtributosNivel = AtributosNivel + 3 end
    if level >= 14 then AtributosNivel = AtributosNivel + 3 end
    if level >= 16 then AtributosNivel = AtributosNivel + 3 end
    if level >= 18 then AtributosNivel = AtributosNivel + 3 end
    local bonusPP = 0
    local bonusRD = 0
    local BonusAtributo = 0

    local function temHB(hb)
        return sheet.HB1 == hb
            or sheet.HB2 == hb
            or sheet.HB3 == hb
            or sheet.HB4 == hb
    end

    local bonusHP = 0
    local bonusCA = 0
    

    if temHB("ROBUSTO") then
        bonusHP = bonusHP + (level * 3)
    end
        if temHB("RECUPERACAO_ARCANA") then
        bonusPP = bonusPP + math.min(level, 10)
    end
    
    if temHB("OSSOS_DENSOS") then
        bonusRD = bonusRD + 3
    end

    if temHB("PELE_ENDURECIDA") then
        bonusCA = bonusCA + 1
    end

    if temHB("APRIMORAMENTO_DE_ATRIBUTO") then
        BonusAtributo = BonusAtributo + 3
    end

    

    --------------------------------------------------
    -- RESULTADOS FINAIS
    --------------------------------------------------

    sheet.CaPersonagem = ca + math.floor(valorPrincipal / 2) + 8 + bonusCA + n(skinEquipada and skinEquipada.bonusCA)
    sheet.RdPersonagem = rd + bonusRD + n(skinEquipada and skinEquipada.bonusRD)

    sheet.HpPersonagem =
        hp +
        rank.hp +
        (classBonus * level) +
        (sheet.ConstituicaoTotal * level) +
        bonusHP +
        n(skinEquipada and skinEquipada.bonusHP)

    sheet.PpPersonagem =
        pp +
        rank.pp +
        (level * 2) +
        bonusPP +
        n(skinEquipada and skinEquipada.bonusPP)

    local gastoAtributos =
    n(sheet.ForcaValor) +
    n(sheet.DestrezaValor) +
    n(sheet.ConstituicaoValor) +
    n(sheet.InteligenciaValor) +
    n(sheet.SabedoriaValor) +
    n(sheet.CarismaValor)

    sheet.PontosRestantes =
    (AtributosRank + AtributosNivel + BonusAtributo)
    - gastoAtributos

    sheet.DanoPersonagem = dano
    sheet.CuraPersonagem = cura
end


--------------------------------------------------
-- INIT
--------------------------------------------------

function onInit()
    if self and self.sheet then
        recalcularDefesa(self.sheet)
    end
end

]]></script>

<event name="onChange"><![CDATA[
    recalcularDefesa(self.sheet)
]]></event>

</dataLink>





