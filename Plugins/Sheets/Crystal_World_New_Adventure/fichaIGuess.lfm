                        CWNA_confirmarSenhaLoja(self)
                    end
                ]]></event>
            </edit>
            <button text="OK" left="44" top="78" width="58" height="24">
                <event name="onClick"><![CDATA[
                    CWNA_confirmarSenhaLoja(self)
                ]]></event>
            </button>
            <button text="Cancelar" left="112" top="78" width="70" height="24">
                <event name="onClick"><![CDATA[
                    local edt = self:findControlByName("edtSenhaLoja")
                    if edt ~= nil then edt.text = "" end
                    local senhaFrame = self:findControlByName("frameSenhaLoja")
                    if senhaFrame ~= nil then senhaFrame.visible = false end
                ]]></event>
            </button>
        </rectangle>
    </frame>

