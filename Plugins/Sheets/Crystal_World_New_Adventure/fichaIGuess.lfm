    <rectangle left="678" top="1016" width="34" height="22" color="#00000000">
        <edit field="CustoPPAtaque1" align="client" type="number" transparent="true" fontColor="#FFFFFF" fontStyle="bold" fontSize="10" horzTextAlign="center"/>
    </rectangle>
    <dataLink field="CustoPPAtaque1" defaultValue="0"/>

    <rectangle left="728" top="1016" width="34" height="22" color="#00000000">
        <edit field="CustoPPAtaque2" align="client" type="number" transparent="true" fontColor="#FFFFFF" fontStyle="bold" fontSize="10" horzTextAlign="center"/>
    </rectangle>
    <dataLink field="CustoPPAtaque2" defaultValue="0"/>

	<imageCheckBox name="CURTO"
		left="577" top="985" width="28" height="55"
		checkedImage=""
		uncheckedImage="">

		<event name="onClick">

		local mesa = Firecast.getMesaDe(sheet);
		if not CWNA_gastarPPAtaque(sheet, "CustoPPAtaque1", "Ataque Curto Alcance", self) then
			return
		end;

		local acerto = tonumber(sheet.AcertoCurtoAlcanceTotal) or 0;
        local prof = tonumber(sheet.Prof) or 0;
		local r1 = Firecast.interpretarRolagem("1d20+" .. acerto .. "+" .. prof);

		if mesa then
			mesa.activeChat:rolarDados(r1, "Acerto Curto Alcance");
		end;

		if sheet.DanoMonstro1 and sheet.DanoMonstro1 ~= "" then
			local danoBase = tonumber(sheet.DanoCurtoAlcanceTotal) or 0;
			local prof = tonumber(sheet.Prof) or 0;

			local r2 = Firecast.interpretarRolagem(
				sheet.DanoMonstro1 .. "+" .. danoBase .. "+" .. prof
			);

			if mesa then
				mesa.activeChat:rolarDados(r2, "Dano Curto Alcance");
			end;
		end;

		</event>

	</imageCheckBox>

