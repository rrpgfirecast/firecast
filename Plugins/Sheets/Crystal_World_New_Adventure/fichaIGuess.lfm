    <button name="btnComprarDetalheLoja" text="" left="642" top="486" width="162" height="50" opacity="0" cursor="handPoint">
        <event name="onClick"><![CDATA[
            if tostring(sheet.TempCompraLojaUid or "") == "" then
                return
