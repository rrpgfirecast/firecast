<button text="🔒" left="359" top="571" width="22" height="22">
    <event name="onClick"><![CDATA[

        Dialogs.inputQuery(
            "Senha",
            "senha ADM:",
            "",

            function(senha)

                if senha == nil then
                    return
                end


                if senha ~= "151289" then
                    showMessage("Senha incorreta!")
                    return
                end


                local ouroEdit = self:findControlByName("edtNovoOuro")
                local prataEdit = self:findControlByName("edtNovaPrata")
                local painel = self:findControlByName("PainelEditarDinheiro")


                ouroEdit.text = tostring(sheet.OuroPersonagem or 0)
                prataEdit.text = tostring(sheet.PrataPersonagem or 0)


                painel.visible = true


            end
        )


    ]]></event>
</button>

<rectangle name="PainelEditarDinheiro"
    left="400"
    top="300"
    width="220"
    height="180"
    color="#111111"
    visible="false">


    <!-- BORDA SUPERIOR -->
    <rectangle
        left="0"
        top="0"
        width="220"
        height="30"
        color="#3A3A3A">

        <label
            left="0"
            top="5"
            width="220"
            height="20"
            text="GERENCIAR MOEDAS"
            fontColor="white"
            horzTextAlign="center"/>

    </rectangle>



    <!-- LINHA DIVISORIA -->
    <rectangle
        left="10"
        top="35"
        width="200"
        height="2"
        color="#C8A000"/>




    <!-- OURO -->

    <label
        left="20"
        top="55"
        width="80"
        height="20"
        text="🪙 Ouro:"
        fontColor="#FFD700"/>


    <edit
        name="edtNovoOuro"
        left="105"
        top="52"
        width="90"
        height="25"
        type="number"
        horzTextAlign="center"
        fontColor="white"/>




    <!-- PRATA -->

    <label
        left="20"
        top="90"
        width="80"
        height="20"
        text="⚪ Prata:"
        fontColor="#C0C0C0"/>


    <edit
        name="edtNovaPrata"
        left="105"
        top="87"
        width="90"
        height="25"
        type="number"
        horzTextAlign="center"
        fontColor="white"/>




    <!-- CADEADO -->

    <button
        name="btnPermitirEdicaoDinheiro"
        text="🔒"
        left="165"
        top="120"
        width="30"
        height="25">


        <event name="onClick"><![CDATA[


            local ouro = self:findControlByName("edtOuro")
            local prata = self:findControlByName("edtPrata")
            local botao = self:findControlByName("btnPermitirEdicaoDinheiro")



            if ouro == nil or prata == nil then

                showMessage("Erro: campos Ouro/Prata não encontrados.")
                return

            end




            if tostring(sheet.PermitirEditarDinheiro or "true") == "true" then


                sheet.PermitirEditarDinheiro = "false"


                ouro.enabled = false
                prata.enabled = false


                botao.text = "🔒"



            else


                sheet.PermitirEditarDinheiro = "true"


                ouro.enabled = true
                prata.enabled = true


                botao.text = "🔓"



            end



        ]]></event>


    </button>





    <!-- BOTAO CONFIRMAR -->

    <button
        name="btnConfirmarDinheiro"
        text="CONFIRMAR"
        left="55"
        top="150"
        width="110"
        height="22">


        <event name="onClick"><![CDATA[


            local ouroEdit = self:findControlByName("edtNovoOuro")
            local prataEdit = self:findControlByName("edtNovaPrata")


            local ouro = tonumber(ouroEdit.text)
            local prata = tonumber(prataEdit.text)



            if ouro == nil or prata == nil then

                showMessage("Digite valores válidos.")
                return

            end



            if ouro < 0 then ouro = 0 end
            if prata < 0 then prata = 0 end


            if ouro > 99999 then ouro = 99999 end
            if prata > 99999 then prata = 99999 end



            sheet.OuroPersonagem = ouro
            sheet.PrataPersonagem = prata



            local painel = self:findControlByName("PainelEditarDinheiro")

            painel.visible = false



        ]]></event>


    </button>



</rectangle>

<dataLink field="PermitirEditarDinheiro" defaultValue="true">
    <event name="onChange"><![CDATA[
        local ouro = self:findControlByName("edtOuro")
        local prata = self:findControlByName("edtPrata")
        local botao = self:findControlByName("btnPermitirEdicaoDinheiro")
        local liberado = tostring(self.sheet.PermitirEditarDinheiro or "true") == "true"

        if ouro ~= nil then
            ouro.enabled = liberado
        end

        if prata ~= nil then
            prata.enabled = liberado
        end

        if botao ~= nil then
            botao.text = liberado and "🔓" or "🔒"
        end
    ]]></event>
</dataLink>

<button name="btnShopInventario" text="SHOP" left="812" top="571" width="58" height="22">
    <event name="onClick"><![CDATA[
        local frame = self:findControlByName("frameLojaInventario")

        if frame ~= nil then
            frame.visible = not frame.visible
            sheet.LojaAberta = frame.visible and "true" or "false"
            local btnSkins = self:findControlByName("btnConfigSkins")
            if btnSkins ~= nil then
                btnSkins.visible = not frame.visible
                btnSkins.enabled = not frame.visible
            end
            if frame.visible then
                sheet.LojaItensPorPagina = 24
                CWNA_mudarPaginaLoja(sheet, 0)
                pcall(function() frame:bringToFront() end)
            else
                sheet.LojaDestravada = "false"
            end
        end
    ]]></event>
</button>

<frame name="frameLojaInventario" left="10" top="7" width="858" height="567" visible="false">
    <image align="client" url="Frames/Loja.png" style="stretch" animate="true" showProgress="false"/>

    <button text="x" left="812" top="12" width="26" height="24">
        <event name="onClick"><![CDATA[
            local frame = self:findControlByName("frameLojaInventario")
            if frame ~= nil then frame.visible = false end
            sheet.LojaAberta = "false"
            sheet.LojaDestravada = "false"
            local btnSkins = self:findControlByName("btnConfigSkins")
            if btnSkins ~= nil then
                btnSkins.visible = true
                btnSkins.enabled = true
            end
        ]]></event>
    </button>

    <button name="btnCadeadoLoja" text="🔒" left="778" top="12" width="28" height="24">
        <event name="onClick"><![CDATA[
            if tostring(sheet.LojaDestravada or "") == "true" then
                sheet.LojaDestravada = "false"
                CWNA_atualizarCardsLoja(sheet)
                local painel = self:findControlByName("frameEditorLoja")
                if painel ~= nil then painel.visible = false end
                self.text = "🔒"
                return
            end

            sheet.TempCompraLojaUid = ""
            sheet.TempCompraLojaNome = ""
            sheet.TempCompraLojaRank = ""
            sheet.TempCompraLojaImagem = ""
            sheet.TempCompraLojaDescricao = ""
            sheet.TempCompraLojaAtributos = ""
            sheet.TempCompraLojaPreco = ""
            sheet.TempCompraLojaCorRank = "#FFFFFF"
            sheet.TempCompraLojaConfirmTexto = ""
            sheet.TempCompraLojaQuantidade = 1
            sheet.TempCompraLojaPermiteQuantidade = "false"
            local senhaFrame = self:findControlByName("frameSenhaLoja")
            if senhaFrame ~= nil then
                senhaFrame.visible = true
                pcall(function() senhaFrame:bringToFront() end)
                local edt = self:findControlByName("edtSenhaLoja")
                if edt ~= nil then pcall(function() edt:setFocus() end) end
            end
        ]]></event>
    </button>

