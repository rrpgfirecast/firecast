        <button name="btnConfigSkins" left="844" top="18" width="34" height="30" text="⚙">
            <event name="onClick"><![CDATA[
                if tostring(sheet.LojaAberta or "") == "true" then
                    return
                end

                local frame = self:findControlByName("frameAdminSkins")

                if frame == nil and self.parent ~= nil then
                    frame = self.parent:findControlByName("frameAdminSkins")
                end

                if frame == nil then return end

                if frame.visible then
                    frame.visible = false
                    return
                end

                Dialogs.inputQuery(
                    "Senha",
                    "Senha ADM:",
                    "",
                    function(senha)
                        if senha == nil then
                            return
                        end

                        if senha ~= "151289" then
                            showMessage("Senha incorreta!")
                            return
                        end

                        CWNA_recalcularVisualSkinInventario(sheet, self)
                        CWNA_atualizarCardsSkinInventario(sheet)
                        frame.visible = true
                        pcall(function() frame:bringToFront() end)
                    end)
            ]]></event>
        </button>

        <button name="btnAbrirSkinsJogador" left="465" top="50" width="38" height="36" text="" opacity="0" cursor="handPoint">
            <event name="onClick"><![CDATA[
                local frame = self:findControlByName("frameSkinsJogador")

                if frame == nil and self.parent ~= nil then
                    frame = self.parent:findControlByName("frameSkinsJogador")
                end

                if frame ~= nil then
                    CWNA_recalcularVisualSkinInventario(sheet, self)
                    CWNA_atualizarCardsSkinInventario(sheet)
                    frame.visible = not frame.visible
                    if frame.visible then
                        pcall(function() frame:bringToFront() end)
                    end
                end
            ]]></event>
        </button>

