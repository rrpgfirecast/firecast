<?xml version="1.0" encoding="UTF-8"?>
<form name="templateMagias2" height="78" width="78"
      margins="{top=3, bottom=3, right=3, left=3}">

<style>
comboBox{
    fontFamily: Cambria;
    transparent: true;
    fontColor: #c74d14;
}
edit{
    fontFamily: Cambria;
    transparent: true;
    fontColor: white;
}
label, button{
    fontFamily: Cambria;
    fontColor: white;
    fontStyle: bold;
}
</style>

<script>
<![CDATA[
local slotsPorTipo = {
    capacete = "Capacete",
    peitoral = "Peitoral",
    escudo = "Escudo",
    bota = "Bota",
    calca = "Calca",
    ["calça"] = "Calca",
    arma = "Arma"
}

local imagensPadrao = {
    Capacete = "/Frames/Capacete.png",
    Peitoral = "/Frames/Peitoral.png",
    Escudo = "/Frames/Escudo.png",
    Bota = "/Frames/Bota.png",
    Calca = "/Frames/Calca.png",
    Arma = "/Frames/Arma.png"
}

local atributos = {
    {campoItem = "hp", prefixoSlot = "Hp"},
    {campoItem = "pp", prefixoSlot = "Pp"},
    {campoItem = "ca", prefixoSlot = "Ca"},
    {campoItem = "rd", prefixoSlot = "Rd"},
    {campoItem = "dano", prefixoSlot = "Dano"},
    {campoItem = "cura", prefixoSlot = "Cura"}
}

local function limparTexto(valor)
    return string.lower(tostring(valor or "")):gsub("^%s*(.-)%s*$", "%1")
end

local function slotDoItem(item)
    return slotsPorTipo[limparTexto(item.tipoItem)]
end

local function valorAtributo(valor)
    return tonumber(valor) or 0
end

local function limparSlot(ficha, slot)
    if ficha == nil or slot == nil then
        return
    end

    ficha["Imagem" .. slot] = imagensPadrao[slot] or ""
    ficha["ItemEquipado" .. slot] = ""

    for _, atributo in ipairs(atributos) do
        ficha[atributo.prefixoSlot .. slot] = 0
    end
end

local function desmarcarItemAnterior(itemAtual, slot)
    local lista = NDB.getParent(itemAtual)

    if lista == nil then
        return
    end

    local handleAtual = NDB.getNodeHandle(itemAtual)

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if NDB.getNodeHandle(item) ~= handleAtual and item.equipadoEm == slot then
            item.equipadoEm = ""
        end
    end
end

local function equiparItem(item)
    local ficha = NDB.getRoot(item)
    local slot = slotDoItem(item)

    if ficha == nil then
        showMessage("Nao encontrei a ficha para equipar este item.")
        return
    end

    if slot == nil then
        showMessage("Escolha um tipo valido: Capacete, Peitoral, Escudo, Bota, Calca ou Arma.")
        return
    end

    if item.equipadoEm ~= nil and item.equipadoEm ~= "" and item.equipadoEm ~= slot then
        limparSlot(ficha, item.equipadoEm)
    end

    desmarcarItemAnterior(item, slot)

    ficha["Imagem" .. slot] = item.imagemestilo2 or imagensPadrao[slot]
    ficha["ItemEquipado" .. slot] = item.nomeItem or ""

    for _, atributo in ipairs(atributos) do
        ficha[atributo.prefixoSlot .. slot] = valorAtributo(item[atributo.campoItem])
    end

    item.equipadoEm = slot
end

local function apagarItem(item)
    local ficha = NDB.getRoot(item)

    if ficha ~= nil and item.equipadoEm ~= nil and item.equipadoEm ~= "" then
        limparSlot(ficha, item.equipadoEm)
    end

    NDB.deleteNode(item)
end
]]>
</script>

<rectangle align="client" color="#202020"
           xradius="5" yradius="5" cornerType="round">

    <!-- ITEM -->
    <image left="0" top="0" width="78" height="78"
           field="imagemestilo2"
           style="autoFit"
           animate="true"/>

    <dataLink field="imagemestilo2"
              defaultValue="https://blob.firecast.com.br/blobs/HHEWWGHO_4452746/itens.png"/>

    <!-- BOTÃO INVISÍVEL EDITAR -->
    <button left="0" top="0" width="78" height="78"
            opacity="0">

        <event name="onClick">
            local pop = self:findControlByName("popEditor");
            if pop ~= nil then
                pop:setNodeObject(self.sheet);
                pop:showPopupEx("center");
            end;
        </event>
    </button>

    <!-- EXCLUIR -->
    <button text="x"
            width="17" height="17"
            left="54" top="2"
            onClick="apagarItem(sheet)"/>

    <!-- QUANTIDADE -->
    <layout height="18" top="2" left="4" width="80">

        <label field="quantidade"
               width="25"
               horzTextAlign="center"
               left="-5"
               fontSize="11"
               fontColor="#FFFF00"/>

        <dataLink field="quantidade" defaultValue="0"/>

    </layout>

    <!-- POPUP EDITOR 400x600 -->
    <popup name="popEditor"
           width="400"
           height="600"
           backOpacity="0"
           drawContainer="false">

        <!-- FUNDO (IMAGEM FIXA 400x600) -->
        <image left="0" top="0"
               width="400" height="600"
               src="https://blob.firecast.com.br/blobs/FJSUDTWB_4453149/JANELINHA.png"/>

        <!-- CONTEÚDO POR CIMA (SEM ALTERAR LÓGICA) -->
        <rectangle align="client" color="#00000000">

			<!-- NOME -->
			<edit field="nomeItem"
				left="32" top="62"
				width="330" height="33"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<!-- TIPO -->
			<comboBox field="tipoItem"
				left="30" top="128"
				width="335" height="30"
				items="{'Capacete', 'Peitoral', 'Escudo', 'Bota', 'Calca', 'Arma'}"
				values="{'Capacete', 'Peitoral', 'Escudo', 'Bota', 'Calca', 'Arma'}"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>
			<dataLink field="tipoItem" defaultValue="Capacete"/>

			<!-- IMAGEM EDITÁVEL -->
			<image field="imagemestilo2"
				left="82" top="186"
				width="226" height="226"
				style="autoFit"
				editable="true"/>

			<button text="EQUIPAR"
				left="136" top="420"
				width="128" height="28"
				fontColor="#c74d14"
				onClick="equiparItem(sheet); self.popEditor:close(false, true);"/>

			<!-- ATRIBUTOS -->

			<edit field="hp"
				left="36" top="456"
				width="80"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="pp"
				left="153" top="456"
				width="80"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="ca"
				left="273" top="456"
				width="80"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="rd"
				left="35" top="522"
				width="68"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="dano"
				left="125" top="522"
				width="143"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="cura"
				left="289" top="522"
				width="68"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

		</rectangle>

    </popup>

</rectangle>
</form>
