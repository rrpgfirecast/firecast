<?xml version="1.0" encoding="UTF-8"?>
<form name="templateMagias" height="250" width="407" margins="{top=5, bottom=5, right=5, left=5}">  
<style>
comboBox{
	fontFamily: Cambria;
	transparent: true;
	fontColor: #cdcdcd;
}
edit{
	fontFamily: Cambria;
	transparent: false;
	fontColor: white;
}
label, button{
	fontFamily: Cambria;
	fontColor: white;
	fontStyle: bold;
}
</style>
	
    <rectangle align="client" xradius="5" yradius="5" cornerType="round" color="#202020">
		

		<image 	left="0"  top="0"   height="250" width="407" field="imagemestilo" editable="true" style="autoFit" animate="true"/>
		<dataLink field="imagemestilo" defaultValue="https://blob.firecast.com.br/blobs/CAABLLTL_4455444/6a39a0483cc024f401831a63.jpg"/>
		<edit horzTextAlign="center" width="30" height="30" left="5" top="5" field="Nvmagia" fontStyle="bold" type="number" min="0" max="99" fontColor="#e6ab0c" fontSize="15"/>
		<layout height="30" top="5" left="119" width="282.5">
					
			<button text="ðŸž­" width='30' onClick="NDB.deleteNode(sheet); contador = contador + 1;" align="right" margins="{left=2}"/>
			<edit field="nomeMagia" horzTextAlign="center" height="20" width="200" left="-10" />

		</layout>

		<button text="DescriÃ§Ã£o" top="215" left="26" width="355" height="25" name="labDesc">
			<event name="onClick">
			local pop = self:findControlByName("popMagia");
			if pop ~= nil then
			pop:setNodeObject(self.sheet);
			pop:showPopupEx("center");
			else
			showMessage("Ops, bug... Nao encontrei o popup para exibir");
			end;
			</event>
		</button>

		<popup name="popMagia" width="730" height="430" backOpacity="0" drawContainer="false">
			<rectangle align="client"  color="#000000" xradius= "10" yradius="10">
				<image field="imagemMagia" align="client" style="autofit" margins="{right=20, left=20}" opacity="0.1" animate="true"/>

				<dataLink defaultValue="DescriÃ§Ã£o." field="descriMagia" />
				<richEdit left="11" top="11" width="700" height="400" field="SkilsNOTAS" backgroundColor="#696969" defaultFontColor="white"/>
			</rectangle>
		</popup>
	</rectangle>
</form>


