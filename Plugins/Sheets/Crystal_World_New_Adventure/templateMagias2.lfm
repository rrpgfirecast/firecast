<?xml version="1.0" encoding="UTF-8"?>
<form name="templateMagias2" height="78" width="78"
      margins="{top=3, bottom=3, right=3, left=3}">

<style>
comboBox{
    fontFamily: Cambria;
    transparent: true;
    fontColor: #c74d14;
}
edit{
    fontFamily: Cambria;
    transparent: true;
    fontColor: white;
}
label, button{
    fontFamily: Cambria;
    fontColor: white;
    fontStyle: bold;
}
</style>




<script>
<![CDATA[
local slotsPorTipo = {
    capacete = "Capacete",
    peitoral = "Peitoral",
    escudo = "Escudo",
    bota = "Bota",
    calca = "Calca",
    ["calça"] = "Calca",
    arma = "Arma"
}

local tiposPotion = {
    ["potion hp"] = "HP",
    ["potion pp"] = "PP"
}

local imagensPadrao = {
    Capacete = "/Frames/Capacete.png",
    Peitoral = "/Frames/Peitoral.png",
    Escudo = "/Frames/Escudo.png",
    Bota = "/Frames/Bota.png",
    Calca = "/Frames/Calca.png",
    Arma = "/Frames/Arma.png"
}

local atributos = {
    {campoItem = "hp", prefixoSlot = "Hp"},
    {campoItem = "pp", prefixoSlot = "Pp"},
    {campoItem = "ca", prefixoSlot = "Ca"},
    {campoItem = "rd", prefixoSlot = "Rd"},
    {campoItem = "dano", prefixoSlot = "Dano"},
    {campoItem = "cura", prefixoSlot = "Cura"}
}

local function limparTexto(valor)
    return string.lower(tostring(valor or "")):gsub("^%s*(.-)%s*$", "%1")
end

local function slotDoItem(item)
    return slotsPorTipo[limparTexto(item.tipoItem)]
end

local function tipoPotionDoItem(item)
    return tiposPotion[limparTexto(item.tipoItem)]
end

local function valorAtributo(valor)
    return tonumber(valor) or 0
end

local function limparSlot(ficha, slot)
    if ficha == nil or slot == nil then
        return
    end

    ficha["Imagem" .. slot] = imagensPadrao[slot] or ""
    ficha["ItemEquipado" .. slot] = ""

    for _, atributo in ipairs(atributos) do
        ficha[atributo.prefixoSlot .. slot] = 0
    end
end

local function desmarcarItemAnterior(itemAtual, slot)
    local lista = NDB.getParent(itemAtual)

    if lista == nil then
        return
    end

    local handleAtual = NDB.getNodeHandle(itemAtual)

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if NDB.getNodeHandle(item) ~= handleAtual and item.equipadoEm == slot then
            item.equipadoEm = ""
        end
    end
end

local function desequiparItem(item)
    local ficha = NDB.getRoot(item)
    local slot = item.equipadoEm

    if ficha == nil or slot == nil or slot == "" then
        return
    end

    -- limpa imagem e nome
    ficha["Imagem" .. slot] = imagensPadrao[slot] or ""
    ficha["ItemEquipado" .. slot] = ""

    -- zera atributos
    for _, atributo in ipairs(atributos) do
        ficha[atributo.prefixoSlot .. slot] = 0
    end

    item.equipadoEm = ""
end


local function equiparItem(item)
    if item == nil then return end

    -- SE JÁ ESTIVER EQUIPADO → DESEQUIPA
    if item.equipadoEm ~= nil and item.equipadoEm ~= "" then
        desequiparItem(item)
        return
    end

    local ficha = NDB.getRoot(item)
    local slot = slotDoItem(item)

    if ficha == nil then
        showMessage("Nao encontrei a ficha para equipar este item.")
        return
    end

    if slot == nil then
        showMessage("Escolha um tipo valido: Capacete, Peitoral, Escudo, Bota, Calca ou Arma.")
        return
    end

    desmarcarItemAnterior(item, slot)
	limparSlot(ficha, slot)

    ficha["Imagem" .. slot] = item.imagemestilo2 or imagensPadrao[slot]
    ficha["ItemEquipado" .. slot] = item.nomeItem or ""

   local function fix(v)
    if v == nil then return 0 end

    local s = tostring(v)
    s = s:gsub("%s+", "")
    s = s:gsub(",", ".")

    return tonumber(s) or 0
end

for _, atributo in ipairs(atributos) do
    ficha[atributo.prefixoSlot .. slot] = fix(item[atributo.campoItem])
end

    item.equipadoEm = slot
end

local function consumirQuantidade(item)
    local quantidade = tonumber(item.quantidade) or 0

    if quantidade <= 0 then
        showMessage("Este item nao tem quantidade disponivel.")
        return false
    end

    item.quantidade = quantidade - 1
    return true
end

local function usarPotion(item)

    local ficha = NDB.getRoot(item)
    if not ficha then
        showMessage("Nao encontrei a ficha.")
        return
    end

    local tipoPotion = tipoPotionDoItem(item)
    if not tipoPotion then return end

    local mesa = rrpg.getMesaDe(sheet)
    local jogador = mesa.me
    local chat = mesa.chat

    if not jogador or not chat then
        showMessage("Jogador ou chat nao disponivel.")
        return
    end

    -- =========================
    -- DEFINE BARRA CORRETA
    -- =========================
    local indexBarra
    local valorBase
    local prefixo

    if tipoPotion == "HP" then
        indexBarra = 1
        valorBase = valorAtributo(item.cura)
        prefixo = "HP"

    elseif tipoPotion == "PP" then
        indexBarra = 2
        valorBase = valorAtributo(item.pp)
        prefixo = "PP"

    else
        return
    end

    -- =========================
    -- LEITURA DA BARRA (ATUAL)
    -- =========================
    local atual, maximo, percent = jogador:getBarValue(indexBarra)

    if atual == nil or maximo == nil then
        showMessage("Barra nao disponivel ou invisivel.")
        return
    end

    -- =========================
    -- CHEIO
    -- =========================
    if atual >= maximo then
        if prefixo == "HP" then
            showMessage("SEU HP ESTA CHEIO")
        else
            showMessage("SEUS PP ESTAO COMPLETOS")
        end
        return
    end

    -- =========================
    -- CALCULO REAL (sem overflow)
    -- =========================
    local falta = maximo - atual
    local curaReal = math.min(valorBase, falta)

    if curaReal <= 0 then return end

    -- =========================
    -- CONSUMO
    -- =========================
    if not consumirQuantidade(item) then return end

    -- =========================
    -- CHAT
    -- =========================
    local msg = "/" .. prefixo .. " +" .. curaReal
    pcall(function()
        chat:enviarMensagem(msg)
    end)

end



local coresRank = {
    E  = "#808080", -- cinza
    D  = "#00FF00", -- verde
    C  = "#00BFFF", -- azul
    B  = "#8000FF", -- roxo
    A  = "#d6b10e", -- laranja
    S  = "#FF0000", -- vermelho
    SS = "#FF0000"
}

local function atualizarAcoesItem(form)
    if form == nil or form.sheet == nil then
        return
    end

    local item = form.sheet
    local ehEquipavel = slotDoItem(item) ~= nil
    local ehPotion = tipoPotionDoItem(item) ~= nil

    local btnEquipar = form:findControlByName("btnEquiparItem")
    local btnUsar = form:findControlByName("btnUsarPotion")
    local retAcao = form:findControlByName("retAcaoItem")
    local retFundo = form:findControlByName("retFundoItem")

    
    local txtEquipped = form:findControlByName("txtEquipped")

    local equipado = item.equipadoEm ~= nil and item.equipadoEm ~= ""

    local corRank = coresRank[item.RankItem] or "#808080"

    if btnEquipar ~= nil then
        btnEquipar.visible = ehEquipavel

        if equipado then
            btnEquipar.text = "D"
        else
            btnEquipar.text = "E"
        end
    end

    if btnUsar ~= nil then
        btnUsar.visible = ehPotion
    end

    if retAcao ~= nil then
        retAcao.visible = ehEquipavel or ehPotion
    end

    if retFundo ~= nil then
        retFundo.strokeSize = 1

        if equipado then
            retFundo.color = "#00000000"
            
        else
            retFundo.color = "#202020"
            retFundo.strokeColor = corRank
        end
    end

    -- =========================
    -- EQUIPPED TEXT RENDER
    -- =========================
    if txtEquipped ~= nil then
        txtEquipped.visible = equipado

        if equipado then
            txtEquipped.text = "EQUIPPED"
            txtEquipped.fontColor = corRank

            -- POSIÇÃO EDITÁVEL (AJUSTE AQUI)
            txtEquipped.left = txtEquipped.left or 10
            txtEquipped.top = txtEquipped.top or 2
        end
    end
end

local function apagarItem(item)
    local ficha = NDB.getRoot(item)

    if ficha ~= nil and item.equipadoEm ~= nil and item.equipadoEm ~= "" then
        local slot = item.equipadoEm

        -- limpa atributos da ficha
        limparSlot(ficha, slot)

        -- força sincronização visual da ficha (slots)
        local campos = {
            "Imagem"..slot,
            "ItemEquipado"..slot
        }

        for _, campo in ipairs(campos) do
            ficha[campo] = ficha[campo] -- força refresh no Firecast
        end
    end

    item.equipadoEm = ""

    NDB.deleteNode(item)
end
]]>
</script>

<rectangle align="client" strokeColor="#4e98c9" strokeSize="1" color="#202020"
           xradius="5" yradius="5" cornerType="round"
           name="retFundoItem">

    <!-- ITEM -->
    <image left="2" top="2" width="74" height="74"
           field="imagemestilo2"
           style="autoFit"
           animate="true"/>

    <dataLink field="imagemestilo2"
              defaultValue="https://blob.firecast.com.br/blobs/HHEWWGHO_4452746/itens.png"/>

    <!-- BOTÃO INVISÍVEL EDITAR -->
    <button left="0" top="0" width="78" height="78"
            opacity="0">

        <event name="onClick">
            local pop = self:findControlByName("popEditor");
            if pop ~= nil then
                pop:setNodeObject(self.sheet);
                pop:showPopupEx("center");
            end;
        </event>
    </button>

    <!-- EXCLUIR -->
    <button text="x"
            width="17" height="17"
            left="59" top="2"
            onClick="apagarItem(sheet)"/>

    <!-- QUANTIDADE -->
    <layout height="18" top="2" left="4" width="80">

        <label field="quantidade"
               width="25"
               horzTextAlign="center"
               left="-5"
               fontSize="14"
               fontColor="#FFFF00"/>

        <dataLink field="quantidade" defaultValue="1"/>

    </layout>

   
    <rectangle name="retAcaoItem"
               left="22" top="57"
               width="15" height="15"
               color="#00000000"
               visible="false"/>

    <button name="btnEquiparItem"
        text="E"
        left="58" top="58"
        width="18" height="18"
        fontSize="10"
        visible="true"
        onClick="equiparItem(sheet); atualizarAcoesItem(self.parent);"/>

<button name="btnUsarPotion"
        text="U"
        left="58" top="58"
        width="18" height="18"
        fontSize="10"
        visible="false"
        onClick="usarPotion(sheet); atualizarAcoesItem(self);"/>

    <dataLink fields="{'tipoItem','equipadoEm','quantidade','hp','pp','ca','rd','dano','cura'}">
        <event name="onChange"><![CDATA[
            atualizarAcoesItem(self)
        ]]></event>
    </dataLink>

    <!-- POPUP EDITOR 400x600 -->
    <popup name="popEditor"
           width="400"
           height="600"
           backOpacity="0"
           drawContainer="false">

        <!-- FUNDO (IMAGEM FIXA 400x600) -->
        <image left="0" top="0"
               width="400" height="600"
               src="https://blob.firecast.com.br/blobs/FJSUDTWB_4453149/JANELINHA.png"/>

        <!-- CONTEÚDO POR CIMA (SEM ALTERAR LÓGICA) -->
        <rectangle align="client" color="#00000000">

			<!-- NOME -->
			<edit field="nomeItem"
				left="32" top="62"
				width="330" height="33"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

            <label text="QTD" left="32" top="169" width="30" fontColor="#c74d14" fontStyle="bold"/>
             <edit field="quantidade"
				left="30" top="184"
				width="30" height="30"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

            <label text="RNK" left="332" top="169" width="30" fontColor="#c74d14" fontStyle="bold"/>
            <comboBox field="RankItem"
				left="333" top="184"
				width="30" height="30"
				items="{'E', 'D', 'C', 'B', 'A', 'S', 'SS',}"
				values="{'E', 'D', 'C', 'B', 'A', 'S', 'SS'}"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"
                fontStyle="bold"/>
			<dataLink field="RankItem" defaultValue="E"/>

			<!-- TIPO -->
			<comboBox field="tipoItem"
				left="30" top="128"
				width="335" height="30"
				items="{'CAPACETE', 'PEITORAL', 'ESCUDO', 'BOTA', 'CALCA', 'ARMA', 'POTION HP', 'POTION PP', 'OUTROS'}"
				values="{'CAPACETE', 'PEITORAL', 'ESCUDO', 'BOTA', 'CALCA', 'ARMA', 'POTION HP', 'POTION PP'}"
                horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"
                fontStyle="bold"/>
			<dataLink field="tipoItem" defaultValue="OUTROS"/>

			<!-- IMAGEM EDITÁVEL -->
			<image field="imagemestilo2"
				left="82" top="186"
				width="226" height="226"
				style="autoFit"
				editable="true"/>

			<!-- ATRIBUTOS -->

			<edit field="hp"
				left="36" top="456"
				width="80"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="pp"
				left="153" top="456"
				width="80"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="ca"
				left="273" top="456"
				width="80"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="rd"
				left="35" top="522"
				width="68"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="dano"
				left="125" top="522"
				width="143"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

			<edit field="cura"
				left="289" top="522"
				width="68"
				horzTextAlign="center"
				vertTextAlign="center"
				fontColor="#c74d14"/>

		</rectangle>

    </popup>

</rectangle>
</form>
