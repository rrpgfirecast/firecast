								<dataLink field="hpact">
                <event name="onChange">                    
                        if (sheet.hpact >= 20) then
                                self.hp20full.opacity = "1";
								else
								self.hp20full.opacity = "0";
								
                        end;
						if (sheet.hpact >= 10) and not (sheet.hpact > 19) then
                                self.hp20half.opacity = "1";
								else
								self.hp20half.opacity = "0";
								
                        end;
						if (sheet.hpact >= 1) and not (sheet.hpact > 9) then
                                self.hp20red.opacity = "1";
								else
								self.hp20red.opacity = "0";
								
                        end;
						if (sheet.hpact == 0) then
                                self.hp20empty.opacity = "1";
								else
								self.hp20empty.opacity = "0";
								
                        end;
						
						if (sheet.hpact >= 40) then
