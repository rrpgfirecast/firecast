			<layout align="client">

            <edit name="edtSegredo"
                  field="SegredoMestre"
                  width="1900"
				  height="1000"
                  readOnly="true"/>

            <button name="btnAcaoShown" opacity="0" left="200" text="Show" width="120">
					
					<event name="onClick">
                        self.edtSegredo.height = "1";
                </event>
				</button>
				
				<button name="btnAcaoHide" opacity="1" left="400" text="Hide" width="120">
					
					<event name="onClick">
                        self.edtSegredo.height = "1000";
                </event>
				</button>

        </layout>
