							<dataLink field="close" defaultValue="0"/>
							
						<label name="closeresult" top="607" left="1295" width="70" height="40" horzTextAlign="center" fontSize="28" fontStyle="bold" fontColor="#dde809" field="closeresult" fontFamily="Minecraft"/>
							<dataLink field="closeresult"/>
							
				<dataLink field="close">
                <event name="onChange">                    
                        if (sheet.close >= 0) then
                                self.closeresult.text = "-";	
								
                        end;
						if (sheet.close >= 2) then
                                self.closeresult.text = "1";	
								
                        end;
						if (sheet.close >= 5) then
                                self.closeresult.text = "1d2";	
								
                        end;
						if (sheet.close >= 8) then
                                self.closeresult.text = "1d3";	
								
                        end;
						if (sheet.close >= 12) then
                                self.closeresult.text = "1d4";	
								
                        end;
						if (sheet.close >= 15) then
                                self.closeresult.text = "1d6";	
								
                        end;
						if (sheet.close >= 20) then
                                self.closeresult.text = "2d4";	
								
                        end;
						if (sheet.close >= 25) then
                                self.closeresult.text = "2d5";	
								
                        end;
						if (sheet.close >= 30) then
                                self.closeresult.text = "2d6";	
								
                        end;
						if (sheet.close >= 45) then
                                self.closeresult.text = "2d7";	
								
                        end;
						if (sheet.close >= 60) then
                                self.closeresult.text = "4d4";	
								
                        end;
						if (sheet.close >= 75) then
                                self.closeresult.text = "4d5";	
								
                        end;
						if (sheet.close >= 100) then
                                self.closeresult.text = "4d6";	
								
                        end;
						
                </event>
        </dataLink>	
