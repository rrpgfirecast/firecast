				<tab name="abamestre" title="Mestre">

										<!--MESTRE Nivel e Talz-->
						<label text="Nivels" top="100" left="300" fontSize="50" fontStyle="bold" width="200" />
						
						<edit top="150" left="300" width="65" height="40" horzTextAlign="trailing" fontSize="34" type="number" max="99" fontStyle="bold" fontColor="yellow" field="nvl" fontFamily="Minecraft"/>
							<dataLink field="nvl"/>
							
						<edit top="200" left="300" width="125" height="44" horzTextAlign="trailing" fontSize="32" type="number" fontColor="yellow" field="xp" fontFamily="Minecraft"/>
