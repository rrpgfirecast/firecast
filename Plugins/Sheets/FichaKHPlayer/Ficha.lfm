                <tab title="Habilidades">
				<scrollBox align="client" height="850">
				<image top="0" left="0" width="1790" height="900" src="/images/HabilidadesEditavel.png"/>


        <button left="850" top="100" height="35" cursor="handPoint" opacity="0" text="Nova Habilidade" width="110">
               <event name="onClick">
			   self.rclHabilidades:append();
			   </event>
			   
			</button>
			
		<image left="850" top="95" width="110" height="40" field="NewHab" src="/frames/new.png"/>

		<image left="1050" top="55" width="300" height="80" field="ApBar" src="/frames/Apmax.png"/>

		<edit field="apact" name="apact" top="76" left="1120" width="110" height="44" horzTextAlign="trailing" transparent="true" fontSize="38" fontColor="yellow" fontFamily="Minecraft"/>
			<dataLink field="apact" defaultValue="0"/>
			
		<label name="apmax" top="76" left="1265" width="110" height="46" fontSize="40" fontColor="yellow" field="apmax" fontFamily="Minecraft"/>
			<dataLink field="apmax" defaultValue="2"/>
			<dataLink fields="{'apmaxEdit', 'EquipmentBonusMaxAp'}">
                <event name="onChange">
                        local mod = math.floor(((sheet.apmaxEdit)));
                      
                        if (mod >= 0) then
                                mod = "" .. mod;
								
                        end;                       

                        sheet.apmax = mod;
						
						sheet.apmax = (tonumber(sheet.EquipmentBonusMaxAp) or 0)+
						(tonumber(sheet.apmaxEdit) or 0);
                </event>
        </dataLink>
		

			

        <recordList name="rclHabilidades" minQt="1" field="firmhabilidades" templateForm="frmHabil"
                    left="775" top="140" width="860" height="700" selectable="true">
					
					<event name="onSelect">
					local node = self.rclHabilidades.selectedNode;  
                          self.boxDetalhesDaHabil.node = node;                       
                          self.boxDetalhesDaHabil.visible = (node ~= nil);
					</event>
					</recordList>
					
					 <dataScopeBox name="boxDetalhesDaHabil" visible="false" left="30" top="100" width="900" height="800">      

                                <textEditor name="habDesc" field="habDesc" fontColor="white" top="580" left="40" width="670" height="160" fontSize="18" transparent="true" fontFamily="KHMenu"/>
								<dataLink field="habDesc" defaultValue="Descrição"/>

								
                                <edit name="habLvl" field="habLvl" fontColor="yellow" top="458" left="72" horzTextAlign="center" width="60" height="40" transparent="true" fontSize="36" fontFamily="Minecraft"/>
								<dataLink field="habLvl" defaultValue="-"/>
								
								<comboBox name="habObt" field="habObt" left="182" top="458" width="170" height="40" horzTextAlign="center" fontColor="yellow" transparent="true" fontSize="34" fontFamily="Minecraft"
								items="{'Weapon', 'Equip', 'Level Up', 'Quest', 'Unique', 'N/A'}"
								values="{'W', 'E', 'L', 'Q', 'U', 'N'}"/>
								<dataLink field="habObt" defaultValue="N"/>

								
								<comboBox name="habBon" field="habBon" left="400" top="458" width="170" height="40" horzTextAlign="center" fontColor="yellow" transparent="true" fontSize="32" fontFamily="Minecraft"
								items="{'STR', 'WIL', 'MAG', 'Percept.', 'DEX', 'EVA', 'DEF', 'RES', 'Fire', 'Blizzard', 'Thunder', 'Water', 'Earth', 'Aero', 
								'Dark', 'Light', 'Arcana', 'Null', 'Close', 'Ranged', 'M.Action', 'B.Action', 'S.Action', 'Move', 'Health', 'Mana', 'Drive', 'N/A'}"
								values="{'STR', 'WIL', 'MAG', 'PERC', 'DEX', 'EVA', 'DEF', 'RES', 'FIRE', 'BLIZ', 'THUN', 'WATE', 'EART', 'AERO',
								'DARK', 'LIGH', 'ARCA', 'NULL', 'CLOS', 'RANG', 'MACT', 'BACT', 'SACT', 'MOVE', 'HP', 'MP', 'DP', 'N'}"/>
								<dataLink field="habBon" defaultValue="N"/>


                                <edit name="habBonNum" field="habBonNum" fontColor="green" type="number" top="458" left="605" horzTextAlign="center" width="60" height="40" transparent="true" fontSize="36" fontFamily="Minecraft"/>
								<dataLink field="habBonNum" defaultValue="-"/>
								
								<edit name="habDice" field="habDice" fontColor="white" top="514" left="170" width="484" height="44" transparent="true" fontSize="36" fontFamily="Minecraft"/>
								<dataLink field="habDice" defaultValue="N/A"/>

        </dataScopeBox>
				
														<!--AtributosNormais-->
				
						<edit top="202" left="60" width="110" height="44" horzTextAlign="center" fontSize="36" type="number" fontColor="white" transparent="true" field="ATRstr" fontFamily="Minecraft"/>
							<dataLink field="ATRstr" defaultValue="1"/>
							
						<label top="202" left="160" width="110" height="44" horzTextAlign="center" fontSize="36" fontStyle="bold" fontColor="yellow" field="ATRstrresult" fontFamily="Minecraft"/>
							<dataLink field="ATRstrresult"/>
							<dataLink field="ATRstr">
							<event name="onChange">
						 local mod = math.floor(((sheet.ATRstr or 10) / 2) - 5);
                      

                        if (mod >= 0) then
                                mod = "+" .. mod;
                        end;                       

                        sheet.ATRstrresult = mod;
                </event>
        </dataLink>
		
						<edit top="202" left="280" width="110" height="44" horzTextAlign="center" fontSize="36" type="number" fontColor="white" transparent="true" field="ATRdex" fontFamily="Minecraft"/>
							<dataLink field="ATRdex" defaultValue="1"/>
							
						<label top="202" left="390" width="110" height="44" horzTextAlign="center" fontSize="36" fontStyle="bold" fontColor="yellow" field="ATRdexresult" fontFamily="Minecraft"/>
							<dataLink field="ATRdexresult"/>
							<dataLink field="ATRdex">
							<event name="onChange">
						 local mod = math.floor(((sheet.ATRdex or 10) / 2) - 5);
                      

                        if (mod >= 0) then
