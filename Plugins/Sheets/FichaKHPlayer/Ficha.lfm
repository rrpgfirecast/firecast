<?xml version="1.0" encoding="UTF-8"?>

<form formType="sheetTemplate" dataType="br.com.meusite.kingdomheartsficha" 
      title="Ficha Kingdom Hearts" name="frmkh2">
        <tabControl name="taball" left="0" top="1" align="client">
                <tab title="Frente">
					<scrollBox align="client" height="850">
						<image top="0" left="10" width="1800" height="910" src="/images/FrenteEditavel.png">
						<!--Nome-->
						<edit top="44" left="180" width="400" height="50" fontSize="34" fontStyle="bold" transparent="true" field="nome" fontFamily="Minecraft"/>
							<dataLink field="nome" defaultValue="Name"/>
							
						<!--Idade-->
						<edit top="150" left="172" width="80" height="40" fontSize="26" transparent="true" field="age" fontFamily="Minecraft"/>	

						<!--Altura-->
						<edit top="195" left="172" width="80" height="40" fontSize="26" type="number" transparent="true" field="height" fontFamily="Minecraft"/>
							<label text="cm" top="195" left="242" width="200" height="40" fontSize="26" fontStyle="bold" fontFamily="Minecraft"/>
						
						<!--Peso-->
						<edit top="240" left="172" width="80" height="40" fontSize="26" transparent="true" type="float" field="weight" fontFamily="Minecraft"/>
							<label text="kg" top="240" left="251" width="200" height="40" fontSize="26" fontStyle="bold" fontFamily="Minecraft"/>
							
						<!--Genero-->
						<comboBox items="{'Male', 'Female', '???'}" top="285" left="172" width="110" height="40" fontSize="26" transparent="true" field="gender" fontFamily="Minecraft"
						values="{'M', 'F', 'N'}" value="N"/> 
						
						<!--Origin-->
						<textEditor top="380" left="23" width="270" height="120" fontSize="20" transparent="true" field="origin" fontFamily="Minecraft"/>
						
						<!--Nivel e Talz-->
						<label name="nvl" top="162" left="454" width="65" height="40" horzTextAlign="trailing" fontSize="34" fontStyle="bold" fontColor="yellow" field="nvl" fontFamily="Minecraft"/>
							<dataLink field="nvl" defaultValue="1"/>
							
						<label name="xp" top="245" left="400" width="125" height="44" horzTextAlign="trailing" fontSize="32" fontColor="yellow" field="xp" fontFamily="Minecraft"/>
							<dataLink field="xp"/>
							
						<label name="nxtlvl" top="325" left="320" width="205" height="44" horzTextAlign="trailing" fontSize="34" fontStyle="bold" fontColor="orange" field="nxtlvl" fontFamily="Minecraft"/>
							<dataLink field="nxtlvl"/>
							
				<dataLink field="nvl">
                <event name="onChange">
                        local mod = math.floor(((sheet.nvl + 1) * 25));
                      
                        if (sheet.nvl >= 11) then
                                mod = math.floor(((sheet.nvl) * 50));
								
                        end;
						
						if (sheet.nvl >= 25) then
                                mod = math.floor(((sheet.nvl) * 75));
								
						end;
						
						if (sheet.nvl >= 50) then
                                mod = math.floor(((sheet.nvl) * 100));
								
						end;

                        sheet.nxtlvl = mod;
                </event>
        </dataLink>
		
				<dataLink field="xp">
                <event name="onChange">
                        if (sheet.xp >= sheet.nxtlvl) then
                                sheet.xp = (tonumber(sheet.xp)) - sheet.nxtlvl;
                                sheet.nvl = (tonumber(sheet.nvl)) + 1;

                        end;
                </event>
        </dataLink>
		
						<!--Classe-->
						<label text="Class" top="509" left="82" width="310" height="44" horzTextAlign="center" fontSize="34" fontColor="white" fontFamily="Minecraft"/>
							
						<edit name="classename" top="550" left="102" width="300" height="44" horzTextAlign="center" fontSize="32" fontColor="yellow" transparent="true" field="classename" fontFamily="Minecraft"/>
							<dataLink field="classename"/>
							
						<!--Munny-->
						<edit top="549" left="655" width="185" height="42" horzTextAlign="trailing" fontSize="32" type="float" fontStyle="italic" fontColor="orange" transparent="true" field="munny" fontFamily="Minecraft"/>
							<dataLink field="munny" defaultValue="0"/>
						
						<!--Specialization-->
						<layout left="72" top="627" width="900" height="900">  
					<imageCheckBox width="380" height="100" field="spec"
                               checkedImage="/images/SpecON.png"
                               uncheckedImage="/images/SpecOFF1.png"/>
        </layout>
		<dataLink field="spec">
                <event name="onChange">
                        if sheet["spec"] == true then
						
						self.spectext.text = "Specialization";
						self.spectext.fontColor = "green";
						self.specname.visible = true;
						else
						
						self.spectext.text = "Locked";
						self.spectext.fontColor = "red";
						self.specname.visible = false;
						sheet["specname"] = "";

						end
                </event>
        </dataLink>
						<label name="spectext" top="612" left="64" width="340" height="44" horzTextAlign="center" fontSize="34" fontColor="red" field="spectext" fontFamily="Minecraft"/>
						<dataLink field="spectext" defaultValue="Locked"/>

						<edit name="specname" visible="false" top="658" left="100" width="320" height="44" horzTextAlign="center" fontSize="32" fontColor="#52ff4d" transparent="true" field="specname" fontFamily="Minecraft"/>
							<dataLink field="specname"/>
							
						<!--Heart Core-->
						<layout left="487" top="627" width="1000" height="1000">  
                <imageCheckBox width="440" height="100" field="hearm"
                               checkedImage="/images/HeartON.png"
                               uncheckedImage="/images/HeartOFF.png"/>
        </layout>
		<dataLink field="hearm">
                <event name="onChange">
                        if sheet["hearm"] == true then
						
						self.heart.text = "Heart Core";
						self.heart.fontColor = "#FFD700";
						self.hhcore.visible = true;
						else
						
						self.heart.text = "Locked";
						self.heart.fontColor = "red";
						self.hhcore.visible = false;
						sheet["hhcore"] = "";

						end
                </event>
        </dataLink>
						<label name="heart" top="612" left="435" width="410" height="44" horzTextAlign="center" fontSize="32" fontStyle="bold" fontColor="red" field="heart" fontFamily="Minecraft"/>
						<dataLink field="heart" defaultValue="Locked"/>
						
						<edit name="hhcore" visible="false" top="657" left="532" width="340" height="44" horzTextAlign="center" fontSize="34" fontColor="yellow" transparent="true" field="hhcore" fontFamily="Minecraft"/>
							<dataLink field="hhcore"/>
							
						<!--HP STAT-->
						<label top="274" left="624" width="65" height="40" horzTextAlign="trailing" fontSize="24" fontStyle="bold" fontColor="#5cf529" field="hpmax" fontFamily="Minecraft"/>
							<dataLink field="hpmax"/>
							
						<edit name="hpact" top="274" left="573" width="60" height="40" horzTextAlign="trailing" fontSize="22" type="number" fontColor="#5cf529" transparent="true" field="hpact" fontFamily="Minecraft"/>
							<dataLink field="hpact" defaultValue="20"/>
							
				<dataLink field="hpmax">
                <event name="onChange">
                        if (sheet.hpmax == 20) then
                              self.hpact.max = "20";

                        end;
						if (sheet.hpmax == 40) then
                              self.hpact.max = "40";

                        end;
						if (sheet.hpmax == 60) then
