<?xml version="1.0" encoding="UTF-8"?>
<popupForm name="frmPokemonInventarioPopup"
           width="620"
           height="520"
           theme="dark"
           placement="center"
           cancelable="true"
           resizable="false">

    <style>
        rectangle.inventoryPopupRoot {
            color: #070A10;
            strokeColor: #7CFFB2;
            strokeSize: 1;
            xradius: 6;
            yradius: 6;
        }

        rectangle.inventoryPopupHeader {
            color: #090D15;
            strokeColor: #7CFFB2;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        rectangle.inventoryPopupPanel {
            color: #0B0F16;
            strokeColor: #263042;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        rectangle.itemImageFrame {
            color: #071019;
            strokeColor: #7CFFB2;
            strokeSize: 1;
            xradius: 6;
            yradius: 6;
        }

        rectangle.statChip {
            color: #111824;
            strokeColor: #2A3343;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
        }

        label.popupTitle {
            fontColor: #7CFFB2;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 16;
            vertTextAlign: center;
        }

        label.popupHint {
            fontColor: #8FA7BD;
            fontSize: 9;
            vertTextAlign: center;
        }

        label.bigPlaceholder {
            fontColor: #7CFFB2;
            fontSize: 36;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.smallLabel {
            fontColor: #9EB7D0;
            fontSize: 9;
            fontStyle: bold;
            vertTextAlign: center;
        }

        label.statText {
            fontColor: #D8E7FF;
            fontSize: 10;
            fontStyle: bold;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        edit.lineEdit {
            transparent: true;
            fontColor: #F4F8FF;
            fontSize: 11;
        }

        edit.nameEdit {
            transparent: true;
            fontColor: #FFFFFF;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 15;
        }

        edit.centerEdit {
            transparent: true;
            fontColor: #F4F8FF;
            fontSize: 11;
            horzTextAlign: center;
        }

        textEditor.longText {
            fontColor: #EAF2FF;
            fontSize: 10;
        }

        rectangle.btnUse {
            color: #7CFFB2;
            strokeColor: #7CFFB2;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        rectangle.btnDark {
            color: #111824;
            strokeColor: #2A3343;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        rectangle.btnDelete {
            color: #151010;
            strokeColor: #FF5A5A;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        label.btnUseText {
            fontColor: #091015;
            fontStyle: bold;
            fontSize: 10;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.btnText {
            fontColor: #D8F2FF;
            fontStyle: bold;
            fontSize: 10;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.btnDeleteText {
            fontColor: #FFBDBD;
            fontStyle: bold;
            fontSize: 10;
            horzTextAlign: center;
            vertTextAlign: center;
        }
    </style>

    <script><![CDATA[
        local PokemonTextMode = require("PokemonTextMode.lua");

        local function trim(value)
            if value == nil then return nil; end;
            return tostring(value):match("^%s*(.-)%s*$");
        end;

        local function parseNumber(value)
            local text = trim(value) or "0";
            text = string.gsub(text, ",", ".");
            text = string.match(text, "[-]?%d+%.?%d*") or "0";
            return tonumber(text) or 0;
        end;

        local function formatNumber(value)
            if math.floor(value) == value then
                return tostring(value);
            end;

            local text = string.format("%.2f", value);
            text = string.gsub(text, "%.?0+$", "");
            return text;
        end;

        local function normalize(value)
            local normalized = string.lower(tostring(value or ""));

            normalized = string.gsub(normalized, "á", "a");
            normalized = string.gsub(normalized, "à", "a");
            normalized = string.gsub(normalized, "â", "a");
            normalized = string.gsub(normalized, "ã", "a");
            normalized = string.gsub(normalized, "é", "e");
            normalized = string.gsub(normalized, "ê", "e");
            normalized = string.gsub(normalized, "í", "i");
            normalized = string.gsub(normalized, "ó", "o");
            normalized = string.gsub(normalized, "ô", "o");
            normalized = string.gsub(normalized, "õ", "o");
            normalized = string.gsub(normalized, "ú", "u");
            normalized = string.gsub(normalized, "ç", "c");

            return normalized;
        end;

        local function parentOf(node)
            local ok, parent;

            if ndb ~= nil and ndb.getParent ~= nil then
                ok, parent = pcall(ndb.getParent, node);
                if ok then return parent; end;
            end;

            if NDB ~= nil and NDB.getParent ~= nil then
                ok, parent = pcall(NDB.getParent, node);
                if ok then return parent; end;
            end;

            return nil;
        end;

        local function rootSheet()
            local current = sheet;
            local last = sheet;

            for i = 1, 8 do
                if current == nil then break; end;

                if current.nomePokemon ~= nil or
                   current.vidaBase ~= nil or
                   current.typeSelectionOrder ~= nil then
                    return current;
                end;

                last = current;
                local parent = parentOf(current);
                if parent == nil or parent == current then break; end;
                current = parent;
            end;

            return last;
        end;

        local function getChildNodesSafe(node)
            if node == nil or ndb == nil or ndb.getChildNodes == nil then
                return {};
            end;

            local ok, children = pcall(ndb.getChildNodes, node);
            if ok and children ~= nil then return children; end;
            return {};
        end;

        local function getNodeNameSafe(node)
            if node == nil or ndb == nil or ndb.getNodeName == nil then
                return nil;
            end;

            local ok, name = pcall(ndb.getNodeName, node);
            if ok then return name; end;
            return nil;
        end;

        local function refreshInventorySummary(root)
            root = root or rootSheet();
            if root == nil then return; end;

            local itemCount = 0;
            local totalWeight = 0;

            for _, node in ipairs(getChildNodesSafe(root)) do
                local nodeName = getNodeNameSafe(node);
                local isInventoryItem = (nodeName == "inventarioItens") or
                                        node.peso ~= nil or
                                        node.pesoTotal ~= nil or
                                        node.imagemItem ~= nil;

                if isInventoryItem then
                    itemCount = itemCount + 1;

                    local total = parseNumber(node.pesoTotal);
                    if total == 0 then
                        total = parseNumber(node.quantidade) * parseNumber(node.peso);
                    end;

                    totalWeight = totalWeight + total;
                end;
            end;

            root.inventarioResumo = "Itens: " .. tostring(itemCount) ..
                                    "    Peso total: " .. formatNumber(totalWeight) ..
                                    "    Botão direito: detalhes";
        end;

        local function categoryVisuals()
            local category = normalize(sheet ~= nil and sheet.categoria or "");

            if category == "consumivel" or category == "consumível" then
                return "🧪", "#7CFFB2";
            elseif category == "equipamento" then
                return "🛡", "#00BFFF";
            elseif category == "ferramenta" then
                return "⚙", "#FFD700";
            elseif category == "material" then
                return "", "#9FB4C5";
            elseif category == "item-chave" or category == "item chave" or category == "chave" then
                return "🔑", "#FF9A3D";
            elseif category == "comida" then
                return "🍖", "#7CFFB2";
            elseif category == "medicinal" then
                return "✚", "#39FF14";
            elseif category == "documento" then
                return "📜", "#8FA7BD";
            elseif category == "raro" or category == "especial" then
                return "✦", "#8A5CFF";
            end;

            return "", "#7CFFB2";
        end;

        function self:ensureDefaults()
            if sheet == nil then return; end;

            sheet.nome = sheet.nome or "Novo item";
            sheet.quantidade = sheet.quantidade or "1";
            sheet.peso = sheet.peso or "0";
            sheet.pesoTotal = sheet.pesoTotal or "0";
            sheet.categoria = sheet.categoria or "Misc";
            sheet.descricaoCurta = sheet.descricaoCurta or "Item sem descrição curta";
            sheet.efeito = sheet.efeito or "";
            sheet.descricao = sheet.descricao or "";
            sheet.observacoes = sheet.observacoes or "";
            self:refreshTotal();
            self:refreshVisual();
        end;

        function self:refreshTotal()
            if sheet == nil then return; end;

            local quantidade = formatNumber(parseNumber(sheet.quantidade));
            local peso = formatNumber(parseNumber(sheet.peso));
            local total = formatNumber(parseNumber(sheet.quantidade) * parseNumber(sheet.peso));

            sheet.pesoTotal = total;
            sheet.qtdChip = "Qtd " .. quantidade;
            sheet.pesoChip = "Peso " .. peso;
            sheet.totalChip = "Total " .. total;
            refreshInventorySummary();
        end;

        function self:refreshVisual()
            if sheet == nil then return; end;

            local icon, accent = categoryVisuals();
            sheet.categoriaIcone = icon;

            local category = trim(sheet.categoria) or "Misc";
            local short = trim(sheet.descricaoCurta);
            if short == nil or short == "" then
                sheet.itemResumo = category;
            else
                sheet.itemResumo = category .. " · " .. short;
            end;

            if self.rectInventoryPopupRoot ~= nil then
                self.rectInventoryPopupRoot.strokeColor = accent;
            end;
            if self.rectInventoryPopupHeader ~= nil then
                self.rectInventoryPopupHeader.strokeColor = accent;
            end;
            if self.rectItemImageFrame ~= nil then
                self.rectItemImageFrame.strokeColor = accent;
            end;
            if self.lblPopupTitle ~= nil then
                self.lblPopupTitle.fontColor = accent;
            end;
            if self.rectPopupUse ~= nil then
                self.rectPopupUse.color = accent;
                self.rectPopupUse.strokeColor = accent;
            end;
        end;

        function self:useOne()
            if sheet == nil then return; end;

            local quantidade = parseNumber(sheet.quantidade);
            if quantidade > 0 then
                quantidade = quantidade - 1;
            end;

            sheet.quantidade = formatNumber(quantidade);
            self:refreshTotal();
        end;

        function self:openPresetPopup()
            if sheet == nil then return; end;

            local popup = gui.newPopupForm("frmPokemonInventarioPresetPopup");
            if popup ~= nil then
                popup:setNodeObject(sheet);
                popup:show();
            end;
        end;

        function self:deleteSelf()
            if sheet == nil then return; end;

            local root = rootSheet();
            if NDB ~= nil and NDB.deleteNode ~= nil then
                NDB.deleteNode(sheet);
            elseif ndb ~= nil and ndb.deleteNode ~= nil then
                ndb.deleteNode(sheet);
            end;

            refreshInventorySummary(root);
            PokemonTextMode.refresh(root);
            self:close();
        end;
    ]]></script>

    <event name="onScopeNodeChanged">
        self:ensureDefaults();
    </event>

    <event name="onNodeReady">
        self:ensureDefaults();
    </event>

    <dataLink fields="{'quantidade','peso'}">
        <event name="onChange">
            self:refreshTotal();
            PokemonTextMode.refresh(sheet);
        </event>
    </dataLink>

    <dataLink fields="{'categoria','descricaoCurta','nome','efeito','descricao','observacoes'}">
        <event name="onChange">
            self:refreshVisual();
            PokemonTextMode.refresh(sheet);
        </event>
    </dataLink>

    <rectangle align="client" name="rectInventoryPopupRoot" class="inventoryPopupRoot" padding="{left=10, top=10, right=10, bottom=10}">
        <rectangle name="rectInventoryPopupHeader" align="top" height="54" class="inventoryPopupHeader" padding="{left=10, top=5, right=10, bottom=5}" margins="{bottom=8}">
            <layout align="client">
                <label name="lblPopupTitle" align="top" height="26" text="ITEM // DETALHES" class="popupTitle" />
                <rectangle align="right" width="92" class="btnDark" hitTest="true" margins="{left=8, top=6, bottom=6}">
                    <event name="onClick">self:openPresetPopup();</event>
                    <label align="client" text="Presets" class="btnText" />
                </rectangle>
                <label align="client" text="Imagem, uso, descrição e anotações do item" class="popupHint" />
            </layout>
        </rectangle>

        <layout align="top" height="204" margins="{bottom=8}">
            <rectangle name="rectItemImageFrame" align="left" width="190" class="itemImageFrame" padding="{left=8, top=8, right=8, bottom=8}" margins="{right=10}">
                <image align="client" field="imagemItem" editable="true" style="autoFit" />
            </rectangle>

            <rectangle align="client" class="inventoryPopupPanel" padding="{left=10, top=8, right=10, bottom=8}">
                <layout align="top" height="36" margins="{bottom=6}">
                    <edit align="client" field="nome" class="nameEdit" />
                    <rectangle align="bottom" height="1" color="#7CFFB2" />
                </layout>

                <layout align="top" height="32" margins="{bottom=6}">
                    <label align="left" width="72" text="Categoria" class="smallLabel" fontColor="#7CFFB2" />
                    <layout align="client">
                        <edit align="client" field="categoria" class="lineEdit" />
                        <rectangle align="bottom" height="1" color="#7CFFB2" />
                    </layout>
                </layout>

                <layout align="top" height="32" margins="{bottom=8}">
                    <label align="left" width="72" text="Resumo" class="smallLabel" fontColor="#7CFFB2" />
                    <layout align="client">
                        <edit align="client" field="descricaoCurta" class="lineEdit" />
                        <rectangle align="bottom" height="1" color="#7CFFB2" />
                    </layout>
                </layout>

                <layout align="top" height="32" margins="{bottom=8}">
                    <rectangle align="left" width="86" class="statChip" margins="{right=6}">
                        <label align="client" field="qtdChip" text="Qtd 1" class="statText" />
                    </rectangle>
                    <rectangle align="left" width="96" class="statChip" margins="{right=6}">
                        <label align="client" field="pesoChip" text="Peso 0" class="statText" />
                    </rectangle>
                    <rectangle align="left" width="106" class="statChip">
                        <label align="client" field="totalChip" text="Total 0" class="statText" />
                    </rectangle>
                </layout>

                <layout align="client">
                    <label align="left" width="42" text="Qtd." class="smallLabel" fontColor="#8FA7BD" />
                    <layout align="left" width="72" margins="{right=10}">
                        <edit align="client" field="quantidade" class="centerEdit" />
                        <rectangle align="bottom" height="1" color="#8FA7BD" />
                    </layout>
                    <label align="left" width="42" text="Peso" class="smallLabel" fontColor="#8FA7BD" />
                    <layout align="left" width="72">
                        <edit align="client" field="peso" class="centerEdit" />
                        <rectangle align="bottom" height="1" color="#8FA7BD" />
                    </layout>
                </layout>
            </rectangle>
        </layout>

        <layout align="client" margins="{bottom=8}">
            <rectangle align="left" width="288" class="inventoryPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{right=8}">
                <label align="top" height="16" text="Efeito / uso rápido" class="smallLabel" fontColor="#FFD700" />
                <textEditor align="client" field="efeito" class="longText" />
            </rectangle>

            <layout align="client">
                <rectangle align="top" height="104" class="inventoryPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{bottom=8}">
                    <label align="top" height="16" text="Descrição detalhada" class="smallLabel" fontColor="#7CFFB2" />
                    <textEditor align="client" field="descricao" class="longText" />
                </rectangle>

                <rectangle align="client" class="inventoryPopupPanel" padding="{left=10, top=8, right=10, bottom=8}">
                    <label align="top" height="16" text="Observações" class="smallLabel" fontColor="#8FA7BD" />
                    <textEditor align="client" field="observacoes" class="longText" />
                </rectangle>
            </layout>
        </layout>

        <layout align="bottom" height="32">
            <rectangle name="rectPopupUse" align="left" width="110" class="btnUse" hitTest="true" margins="{right=8}">
                <event name="onClick">self:useOne();</event>
                <label align="client" text="USAR 1" class="btnUseText" />
            </rectangle>

            <rectangle align="left" width="92" class="btnDelete" hitTest="true">
                <event name="onClick">self:deleteSelf();</event>
                <label align="client" text="APAGAR" class="btnDeleteText" />
            </rectangle>

            <layout align="client" />

            <rectangle align="right" width="112" class="btnDark" hitTest="true">
                <event name="onClick">self:close();</event>
                <label align="client" text="Fechar" class="btnText" />
            </rectangle>
        </layout>
    </rectangle>
</popupForm>
