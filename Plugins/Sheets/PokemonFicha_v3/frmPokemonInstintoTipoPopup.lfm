<?xml version="1.0" encoding="UTF-8"?>
<popupForm name="frmPokemonInstintoTipoPopup"
           width="660"
           height="570"
           theme="dark"
           placement="center"
           cancelable="true"
           resizable="false">

    <style>
        rectangle.instinctPopupRoot {
            color: #070A10;
            strokeColor: #9E4DFF;
            strokeSize: 1;
            xradius: 6;
            yradius: 6;
        }

        rectangle.instinctPopupHeader {
            color: #090D15;
            strokeColor: #9E4DFF;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        rectangle.instinctPopupPanel {
            color: #0B0F16;
            strokeColor: #263042;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        rectangle.typeBadge {
            color: #111824;
            strokeColor: #9E4DFF;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
        }

        label.popupTitle {
            fontColor: #9E4DFF;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 16;
            vertTextAlign: center;
        }

        label.popupHint {
            fontColor: #8FA7BD;
            fontSize: 9;
            vertTextAlign: center;
        }

        label.typeBadgeText {
            fontColor: #9E4DFF;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 10;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.smallLabel {
            fontColor: #9EB7D0;
            fontSize: 9;
            fontStyle: bold;
            vertTextAlign: center;
        }

        edit.lineEdit {
            transparent: true;
            fontColor: #F4F8FF;
            fontSize: 11;
        }

        edit.nameEdit {
            transparent: true;
            fontColor: #FFFFFF;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 15;
        }

        textEditor.longText {
            fontColor: #EAF2FF;
            fontSize: 10;
        }

        rectangle.actionBtn {
            color: #9E4DFF;
            strokeColor: #9E4DFF;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        rectangle.btnDark {
            color: #111824;
            strokeColor: #2A3343;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        rectangle.btnDelete {
            color: #151010;
            strokeColor: #FF5A5A;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        label.actionText {
            fontColor: #091015;
            fontStyle: bold;
            fontSize: 10;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.btnText {
            fontColor: #D8F2FF;
            fontStyle: bold;
            fontSize: 10;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.btnDeleteText {
            fontColor: #FFBDBD;
            fontStyle: bold;
            fontSize: 10;
            horzTextAlign: center;
            vertTextAlign: center;
        }
    </style>

    <script><![CDATA[
        local PokemonChat = require("PokemonChat.lua");
        local PokemonEnergy = require("PokemonEnergy.lua");
        local PokemonTextMode = require("PokemonTextMode.lua");

        local function roomChat(root)
            local room = nil;

            if root ~= nil then
                room = Firecast.getRoomOf(root);
            end;

            if room == nil and sheet ~= nil then
                room = Firecast.getRoomOf(sheet);
            end;

            if room ~= nil then
                return room.chat;
            end;
            return nil;
        end;

        local function trim(value)
            if value == nil then return nil; end;
            return tostring(value):match("^%s*(.-)%s*$");
        end;

        local function normalize(value)
            local normalized = string.lower(tostring(value or ""));

            normalized = string.gsub(normalized, "á", "a");
            normalized = string.gsub(normalized, "à", "a");
            normalized = string.gsub(normalized, "â", "a");
            normalized = string.gsub(normalized, "ã", "a");
            normalized = string.gsub(normalized, "é", "e");
            normalized = string.gsub(normalized, "ê", "e");
            normalized = string.gsub(normalized, "í", "i");
            normalized = string.gsub(normalized, "ó", "o");
            normalized = string.gsub(normalized, "ô", "o");
            normalized = string.gsub(normalized, "õ", "o");
            normalized = string.gsub(normalized, "ú", "u");
            normalized = string.gsub(normalized, "ç", "c");

            return normalized;
        end;

        local function normalizeFormula(value)
            local formula = trim(value);

            if formula == nil or formula == "" then
                return nil;
            end;

            if string.match(formula, "[%d]*[dD]%d+") == nil then
                if string.sub(formula, 1, 1) == "-" then
                    formula = "1d20 " .. formula;
                else
                    formula = "1d20 + " .. formula;
                end;
            end;

            return formula;
        end;

        local function typeVisuals()
            local tipo = normalize(sheet ~= nil and sheet.tipo or "");

            if tipo == "fogo" then return "▲ FOGO", "#FF6A3D";
            elseif tipo == "agua" then return "◆ ÁGUA", "#3DA5FF";
            elseif tipo == "planta" or tipo == "grama" then return "♣ PLANTA", "#39FF14";
            elseif tipo == "eletrico" then return "✦ ELÉTRICO", "#FFD700";
            elseif tipo == "gelo" then return "◇ GELO", "#7DEBFF";
            elseif tipo == "lutador" or tipo == "luta" then return "▲ LUTADOR", "#C84A3D";
            elseif tipo == "venenoso" or tipo == "veneno" then return "● VENENO", "#B56DFF";
            elseif tipo == "terrestre" or tipo == "terra" then return "◆ TERRA", "#C8964A";
            elseif tipo == "voador" then return "◇ VOADOR", "#9BBEFF";
            elseif tipo == "psiquico" then return "● PSÍQUICO", "#FF66CC";
            elseif tipo == "inseto" then return "♣ INSETO", "#B8E24A";
            elseif tipo == "pedra" then return "◆ PEDRA", "#B8A06A";
            elseif tipo == "fantasma" then return "○ FANTASMA", "#8A5CFF";
            elseif tipo == "dragao" then return "✦ DRAGÃO", "#6D7CFF";
            elseif tipo == "sombrio" or tipo == "noturno" then return "● SOMBRIO", "#9E4DFF";
            elseif tipo == "aco" then return "■ AÇO", "#8FA7BD";
            elseif tipo == "fada" then return "✦ FADA", "#FF9AD5";
            elseif tipo == "normal" then return "● NORMAL", "#C7CDD7";
            end;

            return "TIPO NÃO DEFINIDO", "#9E4DFF";
        end;

        function self:ensureDefaults()
            if sheet == nil then return; end;

            sheet.nome = sheet.nome or "Novo instinto";
            sheet.tipo = sheet.tipo or "";
            sheet.categoria = sheet.categoria or "";
            sheet.tags = sheet.tags or "";
            sheet.fonte = sheet.fonte or "";
            sheet.acao = sheet.acao or "";
            sheet.custo = sheet.custo or "";
            sheet.custoPE = sheet.custoPE or "";
            sheet.bonus = sheet.bonus or "";
            sheet.teste = sheet.teste or "";
            sheet.formula = sheet.formula or "1d20";
            sheet.resumoCurto = sheet.resumoCurto or "";
            sheet.descricao = sheet.descricao or "";
            sheet.usoNarrativo = sheet.usoNarrativo or "";

            self:refreshVisual();
        end;

        function self:refreshVisual()
            if sheet == nil then return; end;

            local badge, accent = typeVisuals();
            sheet.instinctPopupBadge = badge;

            if self.rectInstinctPopupRoot ~= nil then self.rectInstinctPopupRoot.strokeColor = accent; end;
            if self.rectInstinctPopupHeader ~= nil then self.rectInstinctPopupHeader.strokeColor = accent; end;
            if self.lblInstinctPopupTitle ~= nil then self.lblInstinctPopupTitle.fontColor = accent; end;
            if self.rectInstinctPopupBadge ~= nil then self.rectInstinctPopupBadge.strokeColor = accent; end;
            if self.lblInstinctPopupBadge ~= nil then self.lblInstinctPopupBadge.fontColor = accent; end;
            if self.rectInstinctPopupAction ~= nil then
                self.rectInstinctPopupAction.color = accent;
                self.rectInstinctPopupAction.strokeColor = accent;
            end;
            if self.rectInstinctPopupHit ~= nil then
                self.rectInstinctPopupHit.color = "#164E72";
                self.rectInstinctPopupHit.strokeColor = accent;
            end;
        end;

        function self:openAccuracyPopup()
            if sheet == nil then return; end;

            local root = PokemonEnergy.rootSheet(sheet);
            if root == nil then return; end;

            local _, accent = typeVisuals();
            root.attrBrutoOrigem = "ACERTAR // " .. (sheet.nome or "Golpe Interpretativo");
            root.attrBrutoTitulo = "🎯 ACERTAR // " .. (sheet.nome or "Golpe Interpretativo");
            root.attrBrutoCor = accent;

            local popup = gui.newPopupForm("frmPokemonAtributoBrutoPopup");
            if popup ~= nil then
                popup:setNodeObject(root);
                popup:show();
            end;
        end;

        function self:openDamagePopup()
            if sheet == nil then return; end;

            local popup = gui.newPopupForm("frmPokemonDanoRolagemPopup");
            if popup ~= nil then
                popup:setNodeObject(sheet);
                popup:show();
            end;
        end;

        function self:testSelf()
            self:openDamagePopup();
        end;

        function self:openPresetPopup()
            if sheet == nil then return; end;

            local popup = gui.newPopupForm("frmPokemonInstintoPresetPopup");
            if popup ~= nil then
                popup:setNodeObject(sheet);
                popup:show();
            end;
        end;

        function self:deleteSelf()
            if sheet == nil then return; end;
            local root = PokemonEnergy.rootSheet(sheet);

            if NDB ~= nil and NDB.deleteNode ~= nil then
                NDB.deleteNode(sheet);
            elseif ndb ~= nil and ndb.deleteNode ~= nil then
                ndb.deleteNode(sheet);
            end;

            PokemonTextMode.refresh(root);
            self:close();
        end;
    ]]></script>

    <event name="onScopeNodeChanged">
        self:ensureDefaults();
    </event>

    <event name="onNodeReady">
        self:ensureDefaults();
    </event>

    <dataLink fields="{'nome','fonte','tipo','categoria','tags','acao','custo','custoPE','bonus','teste','formula','resumoCurto','descricao','usoNarrativo'}">
        <event name="onChange">
            self:refreshVisual();
            PokemonTextMode.refresh(sheet);
        </event>
    </dataLink>

    <rectangle name="rectInstinctPopupRoot" align="client" class="instinctPopupRoot" padding="{left=10, top=10, right=10, bottom=10}">
        <rectangle name="rectInstinctPopupHeader" align="top" height="62" class="instinctPopupHeader" padding="{left=10, top=6, right=10, bottom=6}" margins="{bottom=8}">
            <layout align="top" height="28">
                <label name="lblInstinctPopupTitle" align="client" text="INSTINTO DE TIPO // DETALHES" class="popupTitle" />
                <rectangle align="right" width="92" class="btnDark" hitTest="true" margins="{left=8}">
                    <event name="onClick">self:openPresetPopup();</event>
                    <label align="client" text="Presets" class="btnText" />
                </rectangle>
                <rectangle name="rectInstinctPopupBadge" align="right" width="162" class="typeBadge" margins="{left=8}">
                    <label name="lblInstinctPopupBadge" align="client" field="instinctPopupBadge" text="TIPO NÃO DEFINIDO" class="typeBadgeText" />
                </rectangle>
            </layout>
            <label align="client" text="Talentos, passivas e truques ligados ao tipo do Pokémon." class="popupHint" />
        </rectangle>

        <rectangle align="top" height="92" class="instinctPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{bottom=8}">
            <layout align="top" height="34" margins="{bottom=8}">
                <label align="left" width="70" text="Nome" class="smallLabel" fontColor="#9E4DFF" />
                <layout align="client" margins="{right=10}">
                    <edit align="client" field="nome" class="nameEdit" />
                    <rectangle align="bottom" height="1" color="#9E4DFF" />
                </layout>
                <label align="left" width="48" text="Fonte" class="smallLabel" fontColor="#8FA7BD" />
                <layout align="right" width="140">
                    <edit align="client" field="fonte" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#8FA7BD" />
                </layout>
            </layout>

            <layout align="client">
                <label align="left" width="70" text="Tipo" class="smallLabel" fontColor="#9E4DFF" />
                <layout align="left" width="120" margins="{right=10}">
                    <edit align="client" field="tipo" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#9E4DFF" />
                </layout>
                <label align="left" width="76" text="Categoria" class="smallLabel" fontColor="#9E4DFF" />
                <layout align="left" width="130" margins="{right=10}">
                    <edit align="client" field="categoria" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#9E4DFF" />
                </layout>
                <label align="left" width="42" text="Tags" class="smallLabel" fontColor="#8FA7BD" />
                <layout align="client">
                    <edit align="client" field="tags" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#8FA7BD" />
                </layout>
            </layout>
        </rectangle>

        <rectangle align="top" height="88" class="instinctPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{bottom=8}">
            <layout align="top" height="32" margins="{bottom=8}">
                <label align="left" width="52" text="Ação" class="smallLabel" fontColor="#FFD700" />
                <layout align="left" width="104" margins="{right=10}">
                    <edit align="client" field="acao" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#FFD700" />
                </layout>
                <label align="left" width="48" text="Custo" class="smallLabel" fontColor="#FFD700" />
                <layout align="left" width="82" margins="{right=10}">
                    <edit align="client" field="custo" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#FFD700" />
                </layout>
                <label align="left" width="64" text="Custo PE" class="smallLabel" fontColor="#FF5A5A" />
                <layout align="left" width="68" margins="{right=10}">
                    <edit align="client" field="custoPE" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#FF5A5A" />
                </layout>
                <label align="left" width="52" text="Bônus" class="smallLabel" fontColor="#FFD700" />
                <layout align="client">
                    <edit align="client" field="bonus" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#FFD700" />
                </layout>
            </layout>

            <layout align="client">
                <label align="left" width="102" text="Teste sugerido" class="smallLabel" fontColor="#FFD700" />
                <layout align="left" width="180" margins="{right=10}">
                    <edit align="client" field="teste" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#FFD700" />
                </layout>
                <label align="left" width="58" text="Fórmula" class="smallLabel" fontColor="#FFD700" />
                <layout align="client">
                    <edit align="client" field="formula" class="lineEdit" />
                    <rectangle align="bottom" height="1" color="#FFD700" />
                </layout>
            </layout>
        </rectangle>

        <rectangle align="top" height="74" class="instinctPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{bottom=8}">
            <label align="top" height="16" text="Resumo curto do selo" class="smallLabel" fontColor="#7CFFB2" />
            <textEditor align="client" field="resumoCurto" class="longText" />
        </rectangle>

        <layout align="client" margins="{bottom=8}">
            <rectangle align="left" width="314" class="instinctPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{right=8}">
                <label align="top" height="16" text="Descrição completa" class="smallLabel" fontColor="#7CFFB2" />
                <textEditor align="client" field="descricao" class="longText" />
            </rectangle>

            <rectangle align="client" class="instinctPopupPanel" padding="{left=10, top=8, right=10, bottom=8}">
                <label align="top" height="16" text="Uso narrativo" class="smallLabel" fontColor="#FF66CC" />
                <textEditor align="client" field="usoNarrativo" class="longText" />
            </rectangle>
        </layout>

        <layout align="bottom" height="32">
            <rectangle name="rectInstinctPopupHit" align="left" width="124" class="actionBtn" color="#164E72" strokeColor="#5ED7FF" hitTest="true" margins="{right=8}">
                <event name="onClick">self:openAccuracyPopup();</event>
                <label align="client" text="🎯 ACERTAR" class="actionText" />
            </rectangle>

            <rectangle name="rectInstinctPopupAction" align="left" width="124" class="actionBtn" hitTest="true" margins="{right=8}">
                <event name="onClick">self:testSelf();</event>
                <label align="client" text="💥 DANO" class="actionText" />
            </rectangle>

            <rectangle align="left" width="92" class="btnDelete" hitTest="true">
                <event name="onClick">self:deleteSelf();</event>
                <label align="client" text="APAGAR" class="btnDeleteText" />
            </rectangle>

            <layout align="client" />

            <rectangle align="right" width="112" class="btnDark" hitTest="true">
                <event name="onClick">self:close();</event>
                <label align="client" text="Fechar" class="btnText" />
            </rectangle>
        </layout>
    </rectangle>
</popupForm>
