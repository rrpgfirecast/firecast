        local function previewText(value, fallback)
            local text = trim(value);
            if text == nil or text == "" then
                return fallback;
            end;

            return text;
        end;

        local function slotText(icon, name)
            local text = trim(name);
            if text == nil or text == "" then
                return "＋";
            end;

            local slotIcon = trim(icon) or "";
            if slotIcon == "" then
                return text;
            end;

            return slotIcon .. " " .. text;
        end;

        function self:refreshNarrativePanels()
            if sheet == nil then return; end;

            sheet.evolucaoVisual = previewText(sheet.evolucaoPokemon, "Sem evolução registrada.");
            sheet.notasCampoPreview = previewText(sheet.descricaoPokemon, "Notas de campo não registradas.");

            sheet.personalidadeSlot1 = slotText(previewText(sheet.personalidadeNaturalIcone, "😼"), sheet.personalidadeNatural);
            sheet.personalidadeSlot2 = slotText(previewText(sheet.personalidadeNatural2Icone, "🧠"), sheet.personalidadeNatural2);

            sheet.habilidadeNaturalSlot1 = slotText(previewText(sheet.habilidadeNaturalIcone, "🎭"), sheet.habilidadeNaturalNome);
            sheet.habilidadeNaturalSlot2 = slotText(previewText(sheet.habilidadeNatural2Icone, "👣"), sheet.habilidadeNatural2Nome);
            sheet.habilidadeNaturalSlot3 = slotText(previewText(sheet.habilidadeNatural3Icone, "🌒"), sheet.habilidadeNatural3Nome);

            sheet.resumoComportamentalPreview = previewText(
                sheet.resumoComportamental,
                previewText(sheet.descricaoNatural, "Resumo comportamental não registrado.")
            );
        end;

