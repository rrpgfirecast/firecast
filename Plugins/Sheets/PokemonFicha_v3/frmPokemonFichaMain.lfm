    <script><![CDATA[
        local rrpg = require("rrpg.lua");
        local PokemonChat = require("PokemonChat.lua");
        local PokemonLuckMonitor = require("PokemonLuckMonitor.lua");
        local PokemonTokenSync = require("PokemonTokenSync.lua");
        local PokemonAttributeAdjustments = require("PokemonAttributeAdjustments.lua");
        local PokemonTextMode = require("PokemonTextMode.lua");
        local PokemonSheetBackup = require("PokemonSheetBackup.lua");
        local dialogs = require("dialogs.lua");

        local function roomChat()
            if sheet == nil then return nil; end;
            local room = Firecast.getRoomOf(sheet);
            if room ~= nil then
                return room.chat;
            end;
            return nil;
        end;

        local function parseNumber(value)
            return tonumber(value) or 0;
        end;

        local function trim(value)
            if value == nil then return nil; end;
            return tostring(value):match("^%s*(.-)%s*$");
        end;

        local function parseFirecastHudNumber(value)
            local text = trim(value);
            if text == nil or text == "" then return 0; end;

            text = string.gsub(text, ",", ".");

            local numberText = string.match(text, "[-+]?%d+%.?%d*");
            local number = tonumber(numberText);

            if number == nil then return 0; end;
            if number < 0 then number = 0; end;

            return math.floor(number);
        end;

        local function formatFirecastDistance(value)
            local text = trim(value);
            if text == nil or text == "" then return "0m"; end;

            local normalized = string.gsub(text, ",", ".");
            local numberText = string.match(normalized, "[-+]?%d+%.?%d*");

            if numberText ~= nil then
                local number = tonumber(numberText);

                if number ~= nil then
                    if number == math.floor(number) then
                        return tostring(math.floor(number)) .. "m";
                    else
                        local compact = tostring(number):gsub("0+$", ""):gsub("%.$", "");
                        return compact .. "m";
                    end;
                end;
            end;

            return text;
        end;

        local function firecastCharacterOfCurrentSheet()
            if sheet == nil then return nil; end;

            if rrpg ~= nil and rrpg.getPersonagemDe ~= nil then
                local ok, personagem = pcall(rrpg.getPersonagemDe, sheet);
                if ok then return personagem; end;
            end;

            if Firecast ~= nil and Firecast.getCharacterOf ~= nil then
                local ok, personagem = pcall(Firecast.getCharacterOf, sheet);
                if ok then return personagem; end;
            end;

            return nil;
        end;

        local function hasDice(formula)
            if formula == nil then return false; end;
            return string.match(formula, "[%d]*[dD]%d+") ~= nil;
        end;

        local rollAttributeSources = {
            vida={base="vidaBase", mod="vidaMod"},
            poder={base="poderBase", mod="poderMod"},
            forca={base="forcaBase", mod="forcaMod"},
            resistencia={base="resistenciaBase", mod="resistenciaMod"},
            defesa={base="defesaBase", mod="defesaMod"},
            velocidade={base="velocidadeBase", mod="velocidadeMod"},
            precisao={value="precisaoValor"},
            protecao={value="protecaoValor"},
            efeito={value="efeitoValor"},
            tenacidade={value="tenacidadeValor"},
            astucia={value="astuciaValor"},
            fisico={value="fisicoValor"},
            mental={value="mentalValor"},
            natural={value="naturalValor"},
            social={value="socialValor"},
            tecnico={value="tecnicoValor"}
        };

        local rollAttributeAliases = {
            vida="vida", vid="vida", vi="vida",
            poder="poder", pod="poder", po="poder",
            forca="forca", forc="forca", ["for"]="forca", fo="forca",
            resistencia="resistencia", res="resistencia",
            defesa="defesa", def="defesa", de="defesa",
            velocidade="velocidade", vel="velocidade",
            precisao="precisao", pre="precisao",
            protecao="protecao", prot="protecao", pro="protecao",
            efeito="efeito", efe="efeito",
            tenacidade="tenacidade", ten="tenacidade",
            astucia="astucia", ast="astucia",
            fisico="fisico", fis="fisico",
            mental="mental", men="mental",
            natural="natural", nat="natural",
            social="social", soc="social",
            tecnico="tecnico", tec="tecnico"
        };

        local function normalizeRollToken(token)
            local normalized = string.lower(tostring(token or ""));

            normalized = string.gsub(normalized, "á", "a");
            normalized = string.gsub(normalized, "à", "a");
            normalized = string.gsub(normalized, "â", "a");
            normalized = string.gsub(normalized, "ã", "a");
            normalized = string.gsub(normalized, "é", "e");
            normalized = string.gsub(normalized, "ê", "e");
            normalized = string.gsub(normalized, "í", "i");
            normalized = string.gsub(normalized, "ó", "o");
            normalized = string.gsub(normalized, "ô", "o");
            normalized = string.gsub(normalized, "õ", "o");
            normalized = string.gsub(normalized, "ú", "u");
            normalized = string.gsub(normalized, "ç", "c");

            return normalized;
        end;

        local function isRollTokenChar(char)
            local byte = string.byte(char);

            return (byte >= 48 and byte <= 57) or
                   (byte >= 65 and byte <= 90) or
                   (byte >= 97 and byte <= 122) or
                   byte == 95 or
                   byte >= 128;
        end;

        local function cleanRollExpression(value)
            local cleaned = trim(value);
            if cleaned == nil or cleaned == "" then
                return "0";
            end;

            cleaned = string.gsub(cleaned, "[%(%)]", "");
            cleaned = trim(cleaned);

            if cleaned == nil or cleaned == "" then
                return "0";
            end;

            return cleaned;
        end;

        local function rollFieldExpression(fieldName)
            if sheet == nil then return "0"; end;

            local value = cleanRollExpression(sheet[fieldName]);
            if value == nil or value == "" then
                return "0";
            end;

            return value;
        end;

        local function joinRollTerms(left, right)
            local first = cleanRollExpression(left);
            local second = cleanRollExpression(right);

            if first == "0" then
                return second;
            end;

            if second == "0" then
                return first;
            end;

            if string.match(second, "^[%+%-]") then
                return first .. " " .. second;
            end;

            return first .. " + " .. second;
        end;

        local function rollAttributeExpression(key)
            local source = rollAttributeSources[key];
            if source == nil then return "0"; end;

            local expression;

            if source.value ~= nil then
                expression = rollFieldExpression(source.value);
            else
                expression = joinRollTerms(rollFieldExpression(source.base), rollFieldExpression(source.mod));
            end;

            return PokemonAttributeAdjustments.expressionFor(sheet, key, expression);
        end;

        local function resolveRollToken(token)
            local key = rollAttributeAliases[normalizeRollToken(token)];

            if key ~= nil then
                return rollAttributeExpression(key);
            end;

            return token;
        end;

        function self:resolveRollAttributes(formula)
            if formula == nil or sheet == nil then return formula; end;

            local text = tostring(formula);
            local parts = {};
            local token = "";

            for i = 1, string.len(text) do
                local char = string.sub(text, i, i);

                if isRollTokenChar(char) then
                    token = token .. char;
                else
                    if token ~= "" then
                        table.insert(parts, resolveRollToken(token));
                        token = "";
                    end;

                    table.insert(parts, char);
                end;
            end;

            if token ~= "" then
                table.insert(parts, resolveRollToken(token));
            end;

            return table.concat(parts);
        end;

        function self:normalizeFormula(formula)
            local normalized = trim(self:resolveRollAttributes(formula));

            if normalized == nil or normalized == "" then
                return nil;
            end;

            if not hasDice(normalized) then
                if string.sub(normalized, 1, 1) == "-" then
                    normalized = "1d20 " .. normalized;
                else
                    normalized = "1d20 + " .. normalized;
                end;
            end;

            return normalized;
        end;

        function self:updateConsoleLast(title, rawFormula, result, normalizedFormula)
            if sheet == nil then return; end;

            local rollTitle = trim(title) or "Rolagem";
            local raw = trim(rawFormula) or trim(normalizedFormula) or "";
            local resultText = "rolando...";

            if result ~= nil then
                resultText = tostring(result);
            end;

            sheet.ultimaRolagemConsoleTitulo = rollTitle;
            sheet.ultimaRolagemConsoleRawFormula = raw;
            sheet.ultimaRolagemConsoleFormula = trim(normalizedFormula) or raw;
            sheet.ultimaRolagemConsole = "Última: " .. rollTitle .. " -> " .. resultText;
        end;

        function self:rerollConsoleLast()
            if sheet == nil then return; end;

            local formula = trim(sheet.ultimaRolagemConsoleRawFormula) or trim(sheet.ultimaRolagemConsoleFormula);
            if formula == nil or formula == "" then
                return;
            end;

            if trim(sheet.ultimaRolagemConsoleTitulo) == "🧿 SAI ZIKA" or
               formula == "20d4 + 20d6 + 20d8 + 20d10 + 20d12 + 20d20" then
                self:rollSaiZika();
                return;
            end;

            self:rollFormula(formula, trim(sheet.ultimaRolagemConsoleTitulo) or "Última rolagem");
        end;

        local function sendPlainChatMessage(message)
            local chat = roomChat();
            if chat == nil then return; end;

            if chat.asyncSendStd ~= nil then
                local ok = pcall(function()
                    chat:asyncSendStd(message);
                end);

                if ok then
                    return;
                end;
            end;

            if chat.enviarMensagem ~= nil then
                chat:enviarMensagem(message);
            end;
        end;

        function self:rollSaiZika()
            local total = select(2, PokemonLuckMonitor.rollSaiZika(sheet));

            if sheet ~= nil then
                sheet.ultimaRolagemConsoleTitulo = "🧿 SAI ZIKA";
                sheet.ultimaRolagemConsoleRawFormula = "20d4 + 20d6 + 20d8 + 20d10 + 20d12 + 20d20";
                sheet.ultimaRolagemConsoleFormula = sheet.ultimaRolagemConsoleRawFormula;
                sheet.ultimaRolagemConsole = "Última: 🧿 SAI ZIKA -> " .. tostring(total or 0);
            end;

            self:openAzarNaSortePopup();
        end;

        function self:refreshAzarNaSorte()
            PokemonLuckMonitor.refresh(sheet);
        end;

        function self:openAzarNaSortePopup()
            if sheet == nil then return; end;

            PokemonLuckMonitor.refresh(sheet);
            local popup = gui.newPopupForm("frmPokemonAzarNaSortePopup");
            if popup ~= nil then
                popup:setNodeObject(sheet);
                popup:show();
            end;
        end;

        function self:cycleAzarPerfil()
            PokemonLuckMonitor.cycleProfile(sheet);
        end;

        function self:resetAzarSessao()
            dialogs.confirmOkCancel("Resetar estatísticas da sessão atual?\nA sorte será perdoada. O azar, não.", function(confirmed)
                if confirmed then
                    PokemonLuckMonitor.resetCurrent(sheet);
                end;
            end);
        end;

        function self:archiveAzarSessao()
            dialogs.confirmOkCancel("Arquivar sessão atual e iniciar uma nova contagem?", function(confirmed)
                if confirmed then
                    PokemonLuckMonitor.archiveCurrent(sheet);
                end;
            end);
        end;

        function self:selectUtilityTab(tabName)
            local selected = tabName or self._utilityTab or "azar";
            local tabs = {
                azar = {
                    panel=self.pnlUtilityAzar,
                    button=self.btnUtilityAzar,
                    label=self.lblUtilityAzar,
                    accent="#C7CDD7",
                    activeColor="#222936"
                },
                texto = {
                    panel=self.pnlUtilityTexto,
                    button=self.btnUtilityTexto,
                    label=self.lblUtilityTexto,
                    accent="#40D8FF",
                    activeColor="#102A35"
                },
                backup = {
                    panel=self.pnlUtilityBackup,
                    button=self.btnUtilityBackup,
                    label=self.lblUtilityBackup,
                    accent="#7CFFB2",
                    activeColor="#122C22"
                },
                config = {
                    panel=self.pnlUtilityConfig,
                    button=self.btnUtilityConfig,
                    label=self.lblUtilityConfig,
                    accent="#FF9AD5",
                    activeColor="#301626"
                }
            };

            if tabs[selected] == nil then selected = "azar"; end;
            self._utilityTab = selected;

            for name, config in pairs(tabs) do
                local active = name == selected;

                if config.panel ~= nil then
                    config.panel.visible = active;
                end;

                if config.button ~= nil then
                    config.button.color = active and config.activeColor or "#10141C";
                    config.button.strokeColor = config.accent;
                    config.button.strokeSize = active and 2 or 1;
                end;

                if config.label ~= nil then
                    config.label.fontColor = active and "#FFFFFF" or config.accent;
                end;
            end;

            if selected == "azar" then
                self:refreshAzarNaSorte();
            elseif selected == "config" then
                self:refreshAdvancedSettings();
            end;
        end;

        function self:refreshModoTexto()
            if sheet == nil then return; end;
            PokemonTextMode.refresh(sheet);
        end;

        local function collectRecordListNames(recordList)
            local names = {};
            if recordList == nil or recordList.getChildren == nil then
                return "";
            end;

            local ok, forms = pcall(function()
                return recordList:getChildren();
            end);

            if not ok or forms == nil then
                return "";
            end;

            for _, form in ipairs(forms) do
                local node = nil;

                if form ~= nil and form.getNodeObject ~= nil then
                    local nodeOk, result = pcall(function()
                        return form:getNodeObject();
                    end);

                    if nodeOk then node = result; end;
                end;

                if node == nil and form ~= nil and form.getNode ~= nil then
                    local nodeOk, result = pcall(function()
                        return form:getNode();
                    end);

                    if nodeOk then node = result; end;
                end;

                local name = trim(node ~= nil and node.nome or nil);
                if name ~= nil and name ~= "" then
                    table.insert(names, name);
                end;
            end;

            return table.concat(names, "\n");
        end;

        function self:syncModoTextoListNames()
            if sheet == nil then return; end;

            sheet.modoTextoInventarioNomes = collectRecordListNames(self.rclInventarioItens);
            sheet.modoTextoGolpesPrincipaisNomes = collectRecordListNames(self.rclHabPrincipais);
            sheet.modoTextoGolpesInterpretativosNomes = collectRecordListNames(self.rclHabInterpretativas);
        end;

        function self:gerarModoTextoAgora()
            if sheet == nil then return; end;
            self:syncModoTextoListNames();
            PokemonTextMode.refresh(sheet, true);
        end;

        function self:gerarBackupFichaAgora()
            if sheet == nil or self.txtBackupFicha == nil then return; end;

            if self.lblBackupFichaStatus ~= nil then
                self.lblBackupFichaStatus.text = "Gerando backup nativo...";
            end;

            local xml, err = PokemonSheetBackup.exportXML(sheet);
            if xml == nil then
                self.txtBackupFicha.text = "Falha ao gerar backup:\n" .. tostring(err or "erro desconhecido");
                if self.lblBackupFichaStatus ~= nil then
                    self.lblBackupFichaStatus.text = "Falha ao gerar backup.";
                end;
                return;
            end;

            self.txtBackupFicha.text = xml;
            if self.lblBackupFichaStatus ~= nil then
                self.lblBackupFichaStatus.text = "Backup XML sem Modo Texto e Azar na Sorte. Selecione tudo para enviar.";
            end;
        end;

        function self:addCustomRollShortcut()
            if self.rclRolagensCustomizadas == nil then return; end;

            local node = self.rclRolagensCustomizadas:append();
            if node == nil then return; end;

            node.icone = node.icone or "🎯";
            node.nome = node.nome or "Rolagem rápida";
            node.formula = node.formula or "1d20";
            node.categoria = node.categoria or "Custom";
            node.cor = node.cor or "#FFD700";
            node.custoPE = node.custoPE or "";

            local popup = gui.newPopupForm("frmPokemonRolagemPopup");
            if popup ~= nil then
                popup:setNodeObject(node);
                popup:show();
            end;
        end;

        local function formatInventoryNumber(value)
            if math.floor(value) == value then
                return tostring(value);
            end;

            local text = string.format("%.2f", value);
            text = string.gsub(text, "%.?0+$", "");
            return text;
        end;

        local function getNodeNameSafe(node)
            if node == nil or ndb == nil or ndb.getNodeName == nil then
                return nil;
            end;

            local ok, name = pcall(ndb.getNodeName, node);
            if ok then return name; end;
            return nil;
        end;

        local function getChildNodesSafe(node)
            if node == nil or ndb == nil or ndb.getChildNodes == nil then
                return {};
            end;

            local ok, children = pcall(ndb.getChildNodes, node);
            if ok and children ~= nil then
                return children;
            end;

            return {};
        end;

        function self:refreshInventorySummary()
            if sheet == nil then return; end;

            local itemCount = 0;
            local totalWeight = 0;

            for _, node in ipairs(getChildNodesSafe(sheet)) do
                local nodeName = getNodeNameSafe(node);
                local isInventoryItem = (nodeName == "inventarioItens") or
                                        node.peso ~= nil or
                                        node.pesoTotal ~= nil or
                                        node.imagemItem ~= nil;

                if isInventoryItem then
                    itemCount = itemCount + 1;

                    local total = parseNumber(node.pesoTotal);
                    if total == 0 then
                        total = parseNumber(node.quantidade) * parseNumber(node.peso);
                    end;

                    totalWeight = totalWeight + total;
                end;
            end;

            sheet.inventarioResumo = "Itens: " .. tostring(itemCount) ..
                                     "    Peso total: " .. formatInventoryNumber(totalWeight) ..
                                     "    Botão direito: detalhes";
        end;

        function self:addInventoryItem()
            if self.rclInventarioItens == nil then return; end;

            local node = self.rclInventarioItens:append();
