        local function defaultAttrInfo()
            return "Info: botão direito rola o dado escolhido + valor do atributo.";
        end;

        local function setAttrTitle(text, selected)
            if self.lblAttrMatrixTitle ~= nil then
                self.lblAttrMatrixTitle.text = "// MATRIZ DE ATRIBUTOS";
            end;

            if self.lblAttrMatrixInfo ~= nil then
                if text == nil or text == "" or text == "MATRIZ DE ATRIBUTOS" then
                    self.lblAttrMatrixInfo.text = defaultAttrInfo();
                elseif selected then
                    self.lblAttrMatrixInfo.text = "Selecionado: " .. text;
                else
                    self.lblAttrMatrixInfo.text = "Info: " .. text;
                end;
            end;
        end;

        function self:updateAttrRollTotals()
            if sheet == nil then return; end;

            for key, cfg in pairs(attrCoreRollLabels) do
                local label = self[cfg.label];
                if label ~= nil then
                    label.text = rollAttributeExpression(key);
                end;
            end;

            self:refreshAttributeAdjustments();
        end;

        function self:refreshAttributeAdjustments()
            if sheet == nil then return; end;

            local activeCount = PokemonAttributeAdjustments.activeCount(sheet);

            if self.lblAttrAdjustButton ~= nil then
                if activeCount > 0 then
                    self.lblAttrAdjustButton.text = "± MODIFICADORES · " .. tostring(activeCount);
                    self.lblAttrAdjustButton.fontColor = "#7CFFB2";
                else
                    self.lblAttrAdjustButton.text = "± MODIFICADORES";
                    self.lblAttrAdjustButton.fontColor = "#D8F2FF";
                end;
            end;

            for key, labelName in pairs(attrAdjustmentLabels) do
                local label = self[labelName];

                if label ~= nil then
                    local badge = PokemonAttributeAdjustments.badgeFor(sheet, key);
                    label.text = badge;

                    if string.sub(badge or "", 1, 1) == "-" then
                        label.fontColor = "#FF7A4F";
                    elseif badge ~= nil and badge ~= "" then
                        label.fontColor = "#7CFFB2";
                    else
                        label.fontColor = "#4C5A6B";
                    end;
                end;
            end;
        end;

        function self:openAttributeAdjustmentsPopup()
            if sheet == nil then return; end;

            local popup = gui.newPopupForm("frmPokemonAjustesAtributosPopup");

            if popup ~= nil then
                popup:setNodeObject(sheet);
                popup:show();
            end;
        end;

        function self:setResourceButtonHover(rectName, color, active)
            local rect = self[rectName];
            if rect == nil then return; end;

            rect.strokeColor = color;
            if active then
                rect.strokeSize = 3;
            else
                rect.strokeSize = 1;
            end;
        end;

        function self:openManualLink()
            gui.openInBrowser("https://docs.google.com/document/d/1StpvB6HrFUdfUmhGPTqA28OeY7ygnOZiyRPwQok_Zzk/edit?tab=t.0");
        end;

        function self:openStreamLink()
            gui.openInBrowser("https://www.twitch.tv/eri_plays");
        end;

        function self:openContextoAoVivoPopup()
            if sheet == nil then return; end;

            local popup = gui.newPopupForm("frmPokemonContextoAoVivoPopup");

            if popup ~= nil then
                popup:setNodeObject(sheet);
                popup:show();
            end;
        end;

        local function paintAttrRect(key, active)
            local cfg = attrConfigs[key];
            if cfg == nil then return; end;

            local rect = self[cfg.rect];
            if rect == nil then return; end;

            if active then
                rect.strokeColor = cfg.active;
                rect.strokeSize = 2;
                rect.color = "#111824";
            else
                rect.strokeColor = "#2A3343";
                rect.strokeSize = 1;
                rect.color = "#0D111A";
            end;
        end;

        function self:getAttrDie(key)
            local cfg = attrConfigs[key];
            if cfg == nil or sheet == nil then return "D20"; end;

            local current = string.upper(trim(sheet[cfg.dieField]) or "D20");

            for _, die in ipairs(attrDiceOptions) do
                if current == die then
                    return die;
                end;
            end;

            return "D20";
        end;

        function self:updateAttrDiceState()
            for key, cfg in pairs(attrConfigs) do
                local die = self:getAttrDie(key);
                local label = self[cfg.dieLabel];
                local rect = self[cfg.dieRect];

                if label ~= nil then
                    label.text = die;
                    label.fontColor = cfg.active;
                end;

                if rect ~= nil then
                    rect.strokeColor = cfg.active;
                end;
            end;
        end;

        function self:cycleAttrDie(key)
            local cfg = attrConfigs[key];
            if cfg == nil or sheet == nil then return; end;

            local current = self:getAttrDie(key);
            local index = 1;

            for i, die in ipairs(attrDiceOptions) do
                if current == die then
                    index = i;
                    break;
                end;
            end;

            local nextIndex = index + 1;
            if nextIndex > #attrDiceOptions then
                nextIndex = 1;
            end;

            sheet[cfg.dieField] = attrDiceOptions[nextIndex];
            self:updateAttrDiceState();
        end;

        function self:rollAttrDie(key)
            local cfg = attrConfigs[key];
            if cfg == nil then return; end;

            local die = self:getAttrDie(key);
            local formula = joinRollTerms("1" .. string.lower(die), rollAttributeExpression(key));
            local source = rollAttributeSources[key];
            local breakdown = {
                adjustments=PokemonAttributeAdjustments.detailsFor(sheet, key)
            };

            if source ~= nil and source.value ~= nil then
                breakdown.value = rollFieldExpression(source.value);
            elseif source ~= nil then
                breakdown.mod = rollFieldExpression(source.mod);
                breakdown.base = rollFieldExpression(source.base);
            end;

            self:rollFormula(formula, (cfg.name or key) .. " " .. die, {
                accentColor = cfg.active,
                attributeDetailsEnabled = self:isAttributeChatDetailsEnabled(),
                attributeBreakdown = breakdown
            });
        end;

        function self:rollGeneralActionTest(key, cfg)
            if cfg == nil or cfg.rollAttr == nil then return; end;

            local attrCfg = attrConfigs[cfg.rollAttr];
            if attrCfg == nil then return; end;

            local die = self:getAttrDie(cfg.rollAttr);
            local formula = joinRollTerms("1" .. string.lower(die), rollAttributeExpression(cfg.rollAttr));

            self:rollFormula(formula, cfg.name .. " · " .. attrCfg.name .. " " .. die, {
                accentColor = cfg.color
            });
        end;

        function self:handleAttrMouseDown(key, event)
            if event ~= nil and event.button == "right" then
                self:rollAttrDie(key);
            end;
        end;

        function self:updateAttrMatrixState()
            for key, _ in pairs(attrConfigs) do
                paintAttrRect(key, key == self._selectedAttrKey);
            end;

            local selected = attrConfigs[self._selectedAttrKey];
            if selected ~= nil then
                setAttrTitle(selected.desc, true);
            else
                setAttrTitle("MATRIZ DE ATRIBUTOS");
            end;
        end;

        function self:hoverAttr(key)
            if self._selectedAttrKey ~= nil then return; end;

            local cfg = attrConfigs[key];
            if cfg == nil then return; end;

            paintAttrRect(key, true);
            setAttrTitle(cfg.desc);
        end;

        function self:leaveAttr(key)
            if self._selectedAttrKey ~= nil then return; end;

            paintAttrRect(key, false);
            setAttrTitle("MATRIZ DE ATRIBUTOS");
        end;

        function self:toggleAttrSelection(key)
            if self._selectedAttrKey == key then
                self._selectedAttrKey = nil;
            else
                self._selectedAttrKey = key;
            end;

            self:updateAttrMatrixState();
        end;

        local function paintGeneralAction(key, active)
            local cfg = generalActionConfigs[key];
            if cfg == nil then return; end;

            local card = self[cfg.card];
            if card ~= nil then
                if active then
                    card.strokeColor = cfg.color;
                    card.strokeSize = 2;
                    card.color = "#111824";
                else
                    card.strokeColor = "#2A3343";
                    card.strokeSize = 1;
                    card.color = "#0B0F16";
                end;
            end;

            local stripe = self[cfg.stripe];
            if stripe ~= nil then
                stripe.color = cfg.color;
            end;
        end;

        function self:hoverGeneralAction(key)
            paintGeneralAction(key, true);
        end;

        function self:leaveGeneralAction(key)
            paintGeneralAction(key, false);
        end;

        local function generalActionCostValue(cfg)
            if cfg == nil then return 0; end;
            return parseFirecastHudNumber(cfg.cost);
        end;

        local function pokemonActionName()
            if sheet == nil then return "Pokémon"; end;

            local name = trim(sheet.nomePokemon) or trim(sheet.apelidoPokemon);
            if name == nil or name == "" then
                return "Pokémon";
            end;

            return name;
        end;

        function self:sendGeneralActionChatMessage(cfg, peAntes, peDepois, peMaximo)
            if cfg == nil then return; end;

            local cost = generalActionCostValue(cfg);
            local peText = tostring(peDepois);

            if peMaximo > 0 then
                peText = peText .. "/" .. tostring(peMaximo);
            end;

            local lines = {};
            table.insert(lines, "[§K1]● " .. cfg.icon .. " " .. cfg.name .. " — AÇÃO REALIZADA ●[§K1]");
            table.insert(lines, "[§K7]" .. pokemonActionName() .. "[§K1]  [§K14]PE:[§K1] " .. peText .. " [§K7](-" .. tostring(cost) .. ")[§K1]");

            if cfg.rollAttr ~= nil then
                table.insert(lines, "[§K7]" .. cfg.meta .. " · teste automático preparado.[§K1]");
            else
                table.insert(lines, "[§K7]" .. cfg.meta .. " · " .. cfg.effect .. "[§K1]");
            end;

            sendPlainChatMessage(table.concat(lines, "\n"));
        end;

        function self:executeGeneralAction(key)
            if sheet == nil then return; end;

            local cfg = generalActionConfigs[key];
            if cfg == nil then return; end;

            local cost = generalActionCostValue(cfg);
            local peMaximo = parseFirecastHudNumber(sheet.peMaximo);
            local peAtualTexto = trim(sheet.peAtual);
            local peAtual = parseFirecastHudNumber(sheet.peAtual);

            if (peAtualTexto == nil or peAtualTexto == "") and peMaximo > 0 then
                peAtual = peMaximo;
            end;

            if cost > 0 and peAtual < cost then
                dialogs.alert("Pontos de Energia insuficientes para " .. cfg.name .. ".\n\nAtual: " .. tostring(peAtual) .. " PE\nCusto: " .. tostring(cost) .. " PE");
                return;
            end;

            local peDepois = peAtual - cost;
            if peDepois < 0 then peDepois = 0; end;

            sheet.peAtual = tostring(peDepois);
            self:syncFirecastStatusHud();
            self:sendGeneralActionChatMessage(cfg, peAtual, peDepois, peMaximo);
            self:rollGeneralActionTest(key, cfg);
        end;

        function self:requestExecuteGeneralAction(key)
            local cfg = generalActionConfigs[key];
            if cfg == nil then return; end;

            local cost = generalActionCostValue(cfg);
            local extra = "";

            if cfg.rollAttr ~= nil then
                extra = "\nTambém será rolado o teste de " .. (attrConfigs[cfg.rollAttr].name or cfg.teste) .. ".";
            end;

            dialogs.confirmYesNo("Executar " .. cfg.name .. "?\n\nCusto: " .. tostring(cost) .. " PE." .. extra, function(confirmed)
                if confirmed then
                    self:executeGeneralAction(key);
                end;
            end);
        end;

        function self:handleGeneralActionMouseDown(key, event)
            if event ~= nil and event.button == "right" then
                self:openGeneralActionPopup(key);
            else
                self:requestExecuteGeneralAction(key);
            end;
        end;

        function self:openGeneralActionPopup(key)
            local cfg = generalActionConfigs[key];
            if cfg == nil then return; end;

            local popup = gui.newPopupForm("frmPokemonAcaoGeralPopup");
            if popup == nil then return; end;

            popup._generalActionMain = self;
            popup._generalActionKey = key;

            if popup.rectActionPopupRoot ~= nil then
                popup.rectActionPopupRoot.strokeColor = cfg.color;
            end;
            if popup.rectActionPopupHeader ~= nil then
                popup.rectActionPopupHeader.strokeColor = cfg.color;
            end;
            if popup.rectActionPopupStripe ~= nil then
                popup.rectActionPopupStripe.color = cfg.color;
            end;
            if popup.lblActionPopupIcon ~= nil then
                popup.lblActionPopupIcon.text = cfg.icon;
                popup.lblActionPopupIcon.fontColor = cfg.color;
            end;
            if popup.lblActionPopupTitle ~= nil then
                popup.lblActionPopupTitle.text = cfg.name;
                popup.lblActionPopupTitle.fontColor = cfg.color;
            end;
            if popup.lblActionPopupCost ~= nil then
                popup.lblActionPopupCost.text = cfg.cost;
            end;
            if popup.lblActionPopupTipo ~= nil then
                popup.lblActionPopupTipo.text = "Tipo: " .. cfg.tipo;
            end;
            if popup.lblActionPopupAcao ~= nil then
                popup.lblActionPopupAcao.text = "Ação: " .. cfg.acao;
            end;
            if popup.lblActionPopupTeste ~= nil then
                popup.lblActionPopupTeste.text = "Teste: " .. cfg.teste;
            end;
            if popup.lblActionPopupDetalhe ~= nil then
                popup.lblActionPopupDetalhe.text = cfg.detalhe;
            end;
            if popup.lblActionPopupCusto ~= nil then
                popup.lblActionPopupCusto.text = "Custo: " .. cfg.cost .. ".";
            end;
            if popup.lblActionPopupDescricao ~= nil then
                popup.lblActionPopupDescricao.text = cfg.descricao;
            end;
            if popup.lblActionPopupUso ~= nil then
                popup.lblActionPopupUso.text = "Uso em cena: " .. cfg.uso;
            end;
            if popup.rectActionPopupExecute ~= nil then
                popup.rectActionPopupExecute.strokeColor = cfg.color;
            end;
            if popup.lblActionPopupExecute ~= nil then
                popup.lblActionPopupExecute.fontColor = cfg.color;
            end;

            popup:show();
        end;

        function self:ensureDefaults()
            -- Desativado de propósito.
            -- A inicialização automática estava criando campos cedo demais no NodeDatabase
            -- e disparando o erro "NodeDatabase is still loading" na primeira abertura.
        end;    ]]></script>

    <event name="onScopeNodeChanged">
        self._allowAutoWrites = false;
        self._firecastHudSyncReady = false;
        self._firecastHudArmGeneration = (self._firecastHudArmGeneration or 0) + 1;
        self._firecastHudSyncInFlight = false;
        self._firecastHudSyncPending = false;
        self._firecastHudLastSync = nil;
        self:updateThemeBySex();
        self:rebuildTypeTextFromOrder();
        self:updateTypeMarkers();
        self:updateProfilePhotoStyle();
        self:updateAttrMatrixState();
        self:updateAttrDiceState();
        self:updateAttrRollTotals();
        self:refreshInventorySummary();
        self:refreshNarrativePanels();
        self:refreshAzarNaSorte();
        self:refreshModoTexto();
        self:refreshAdvancedSettings();
        self:selectUtilityTab(self._utilityTab or "azar");
    </event>

    <event name="onNodeReady">
        self._firecastHudSyncReady = false;
        self._allowAutoWrites = true;
        self:refreshDerivedFields();
        self:updateThemeBySex();
        self:rebuildTypeTextFromOrder();
        self:updateTypeMarkers();
        self:updateProfilePhotoStyle();
        self:updateAttrMatrixState();
        self:updateAttrDiceState();
        self:updateAttrRollTotals();
        self:refreshInventorySummary();
        self:refreshNarrativePanels();
        self:refreshAzarNaSorte();
        self:refreshModoTexto();
        self:refreshAdvancedSettings();
        self:scheduleFirecastStatusHudArm();
        self:selectUtilityTab(self._utilityTab or "azar");
    </event>

    <dataLink field="sexoPokemon">
        <event name="onChange">
            self:updateThemeBySex();
            self:refreshModoTexto();
        </event>
    </dataLink>

    <dataLink fields="{'typeNormalOn','typeFireOn','typeWaterOn','typeGrassOn','typeElectricOn','typeIceOn','typeFightingOn','typePoisonOn','typeGroundOn','typeFlyingOn','typePsychicOn','typeBugOn','typeRockOn','typeGhostOn','typeDragonOn','typeDarkOn','typeSteelOn','typeFairyOn','typeSelectionOrder'}">
