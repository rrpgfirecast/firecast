            node.nome = node.nome or "Novo item";
            node.quantidade = node.quantidade or "1";
            node.peso = node.peso or "0";
            node.pesoTotal = node.pesoTotal or "0";
            node.categoria = node.categoria or "Misc";
            node.descricaoCurta = node.descricaoCurta or "Item sem descrição curta";
            node.efeito = node.efeito or "";
            node.descricao = node.descricao or "";
            node.observacoes = node.observacoes or "";

            self:refreshInventorySummary();
            self:refreshModoTexto();

            local popup = gui.newPopupForm("frmPokemonInventarioPopup");
            if popup ~= nil then
                popup:setNodeObject(node);
                popup:show();
            end;
        end;

