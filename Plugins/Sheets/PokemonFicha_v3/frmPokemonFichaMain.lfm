    <dataLink fields="{'vidaBase', 'vidaMod', 'poderBase', 'poderMod', 'forcaBase', 'forcaMod', 'resistenciaBase', 'resistenciaMod', 'defesaBase', 'defesaMod', 'velocidadeBase', 'velocidadeMod', 'precisaoValor', 'protecaoValor', 'efeitoValor', 'tenacidadeValor', 'astuciaValor', 'fisicoValor', 'mentalValor', 'naturalValor', 'socialValor', 'tecnicoValor', 'ajustesAtributosCache', 'ajustesRefreshTick'}">
