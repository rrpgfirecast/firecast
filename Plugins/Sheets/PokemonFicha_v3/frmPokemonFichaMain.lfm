            precisao={rect="rectAttrPrecisao", name="Precisão", active="#FFD700", desc="Precisão: acerto de golpes, disparos e ações que exigem mira.", dieField="attrDiePrecisao", dieRect="rectAttrDiePrecisao", dieLabel="lblAttrDiePrecisao"},
            protecao={rect="rectAttrProtecao", name="Proteção", active="#FFD700", desc="Proteção: esquiva, bloqueio e defesa ativa contra ameaças.", dieField="attrDieProtecao", dieRect="rectAttrDieProtecao", dieLabel="lblAttrDieProtecao"},
