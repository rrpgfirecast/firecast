                                <label align="top" height="28" field="azarDetalheD6" text="D6    Rolados: 0    1: 0    Max: 0" fontColor="#D8E7FF" fontFamily="Consolas" fontSize="10" vertTextAlign="center" />
                                <label align="top" height="28" field="azarDetalheD8" text="D8    Rolados: 0    1: 0    Max: 0" fontColor="#D8E7FF" fontFamily="Consolas" fontSize="10" vertTextAlign="center" />
                                <label align="client" text="D10 / D20 / D100 completos no popup." fontColor="#8FA7BD" fontSize="9" vertTextAlign="center" />
                            </rectangle>

                            <rectangle align="right" width="218" color="#0B0F16" strokeColor="#263042" strokeSize="1" xradius="5" yradius="5" padding="{left=8, top=8, right=8, bottom=8}">
                                <label align="top" height="26" text="CONTROLE" fontColor="#C7CDD7" fontFamily="Consolas" fontStyle="bold" fontSize="10" vertTextAlign="center" />
                                <rectangle align="top" height="34" class="btnAddDark" hitTest="true" strokeColor="#C7CDD7" margins="{bottom=8}">
                                    <event name="onClick">self:rollSaiZika();</event>
                                    <label align="client" text="🧿 SAI ZIKA" class="btnAddEmoji" />
                                </rectangle>
                                <rectangle align="top" height="34" class="btnAddDark" hitTest="true" strokeColor="#FF5A5A" margins="{bottom=8}">
                                    <event name="onClick">self:resetAzarSessao();</event>
                                    <label align="client" text="↻ Resetar sessão" class="btnAddEmoji" />
                                </rectangle>
                                <rectangle align="top" height="34" class="btnAddDark" hitTest="true" strokeColor="#7CFFB2">
                                    <event name="onClick">self:archiveAzarSessao();</event>
                                    <label align="client" text="📦 Arquivar sessão" class="btnAddEmoji" />
                                </rectangle>
                                <label align="client" text="Conta D4, D6, D8, D10, D20 e D100." fontColor="#8FA7BD" fontSize="8" horzTextAlign="center" vertTextAlign="center" wordWrap="true" />
                            </rectangle>
                        </layout>
                    </rectangle>

                    <rectangle name="pnlUtilityTexto" align="client" visible="false" color="#080B11" strokeColor="#40D8FF" strokeSize="1" xradius="5" yradius="5" padding="{left=8, top=8, right=8, bottom=8}">
                        <rectangle align="top" height="54" color="#090D15" strokeColor="#40D8FF" strokeSize="1" xradius="4" yradius="4" padding="{left=8, top=5, right=6, bottom=5}" margins="{bottom=8}">
                            <layout align="top" height="24">
                                <label align="left" width="250" text="// MODO TEXTO" class="colTitle" fontColor="#40D8FF" horzTextAlign="leading" />
                                <label align="client" field="modoTextoAtualizado" text="Modo Texto atualizado pela ficha." fontColor="#8FA7BD" fontSize="8" horzTextAlign="trailing" vertTextAlign="center" />
                                <rectangle align="right" width="110" class="btnAddDark" hitTest="true" strokeColor="#40D8FF" margins="{left=8}">
                                    <event name="onClick">self:gerarModoTextoAgora();</event>
                                    <label align="client" text="↻ Atualizar" class="btnAddEmoji" />
                                </rectangle>
                            </layout>
                            <label align="client" text="Resumo exportável da ficha. Campo editável em texto simples." fontColor="#D8E7FF" fontSize="9" vertTextAlign="center" />
                        </rectangle>
                        <rectangle align="client" color="#0B0F16" strokeColor="#263042" strokeSize="1" xradius="5" yradius="5" padding="{left=10, top=8, right=10, bottom=8}">
                            <textEditor align="client" field="modoTextoTexto" class="longText" />
                        </rectangle>
                    </rectangle>

                    <rectangle name="pnlUtilityBackup" align="client" visible="false" color="#080B11" strokeColor="#7CFFB2" strokeSize="1" xradius="5" yradius="5" padding="{left=8, top=8, right=8, bottom=8}">
                        <rectangle align="top" height="54" color="#090D15" strokeColor="#7CFFB2" strokeSize="1" xradius="4" yradius="4" padding="{left=8, top=5, right=6, bottom=5}" margins="{bottom=8}">
                            <layout align="top" height="24">
                                <label align="left" width="250" text="// BACKUP DA FICHA" class="colTitle" fontColor="#7CFFB2" horzTextAlign="leading" />
                                <label name="lblBackupFichaStatus" align="client" text="Gere o XML completo para diagnóstico ou cópia de segurança." fontColor="#8FA7BD" fontSize="8" horzTextAlign="trailing" vertTextAlign="center" />
                                <rectangle align="right" width="132" class="btnAddDark" hitTest="true" strokeColor="#7CFFB2" margins="{left=8}">
                                    <event name="onClick">self:gerarBackupFichaAgora();</event>
                                    <label align="client" text="💾 Gerar backup" class="btnAddEmoji" />
                                </rectangle>
                            </layout>
                            <label align="client" text="Exportação NDB da ficha sem o Modo Texto derivado nem o histórico de Azar na Sorte." fontColor="#D8E7FF" fontSize="9" vertTextAlign="center" />
                        </rectangle>
                        <rectangle align="client" color="#0B0F16" strokeColor="#263042" strokeSize="1" xradius="5" yradius="5" padding="{left=10, top=8, right=10, bottom=8}">
                            <textEditor name="txtBackupFicha" align="client" class="longText" text="Clique em Gerar backup para carregar o XML completo da ficha." />
                        </rectangle>
                    </rectangle>

                    <rectangle name="pnlUtilityConfig" align="client" visible="false" color="#080B11" strokeColor="#FF9AD5" strokeSize="1" xradius="5" yradius="5" padding="{left=8, top=8, right=8, bottom=8}">
                        <rectangle align="top" height="54" color="#090D15" strokeColor="#FF9AD5" strokeSize="1" xradius="4" yradius="4" padding="{left=8, top=5, right=8, bottom=5}" margins="{bottom=8}">
                            <label align="top" height="24" text="// CONFIGURAÇÕES AVANÇADAS" class="colTitle" fontColor="#FF9AD5" horzTextAlign="leading" />
                            <label align="client" text="CONTROLES LOCAIS / INTEGRAÇÃO FIRECAST" fontColor="#8FA7BD" fontSize="8" vertTextAlign="center" />
                        </rectangle>

                        <rectangle align="top" height="112" color="#0B0F16" strokeColor="#394559" strokeSize="1" xradius="5" yradius="5" padding="{left=14, top=12, right=12, bottom=12}" margins="{bottom=8}">
                            <layout align="left" width="760" margins="{right=16}">
                                <label align="top" height="28" text="ENTRADA SILENCIOSA" fontColor="#F4F8FF" fontFamily="Consolas" fontStyle="bold" fontSize="12" vertTextAlign="center" />
                                <label name="lblFirecastAutoSyncStatus" align="client" text="Abrir a ficha não envia barras. Alterações reais continuam sincronizando." fontColor="#BDEFD0" fontSize="10" vertTextAlign="center" wordWrap="true" />
                            </layout>
                            <rectangle name="btnFirecastAutoSync" align="right" width="230" color="#153624" strokeColor="#7CFFB2" strokeSize="2" xradius="5" yradius="5" hitTest="true">
                                <event name="onClick">self:toggleFirecastSilentOpen();</event>
                                <label name="lblFirecastAutoSync" align="client" text="● LIGADA" fontColor="#7CFFB2" fontFamily="Consolas" fontStyle="bold" fontSize="14" horzTextAlign="center" vertTextAlign="center" />
                            </rectangle>
                        </rectangle>

                        <rectangle align="top" height="112" color="#0B0F16" strokeColor="#394559" strokeSize="1" xradius="5" yradius="5" padding="{left=14, top=12, right=12, bottom=12}">
                            <layout align="left" width="760" margins="{right=16}">
                                <label align="top" height="28" text="DETALHES DE ATRIBUTO NO CHAT" fontColor="#F4F8FF" fontFamily="Consolas" fontStyle="bold" fontSize="12" vertTextAlign="center" />
                                <label name="lblAttributeChatDetailsStatus" align="client" text="Rolagens da Matriz mostram MOD, BASE e ajustes nomeados no chat." fontColor="#BDEFD0" fontSize="10" vertTextAlign="center" wordWrap="true" />
                            </layout>
                            <rectangle name="btnAttributeChatDetails" align="right" width="230" color="#153624" strokeColor="#7CFFB2" strokeSize="2" xradius="5" yradius="5" hitTest="true">
                                <event name="onClick">self:toggleAttributeChatDetails();</event>
                                <label name="lblAttributeChatDetails" align="client" text="● LIGADO" fontColor="#7CFFB2" fontFamily="Consolas" fontStyle="bold" fontSize="14" horzTextAlign="center" vertTextAlign="center" />
                            </rectangle>
                        </rectangle>
                    </rectangle>
                </rectangle>

            </layout>
        </scrollBox>
    </rectangle>
</form>


