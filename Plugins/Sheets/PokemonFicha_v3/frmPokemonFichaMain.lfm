                                    <event name="onMouseEnter"><![CDATA[self:setResourceButtonHover("rectContextButton", "#40D8FF", true);]]></event>
                                    <event name="onMouseLeave"><![CDATA[self:setResourceButtonHover("rectContextButton", "#007FA8", false);]]></event>
                                    <event name="onClick">self:openContextoAoVivoPopup();</event>
