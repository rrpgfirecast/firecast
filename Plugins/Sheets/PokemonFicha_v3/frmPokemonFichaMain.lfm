        function self:rollFormula(formula, label, rollContext)
            local rawFormula = trim(formula);
            local normalized = self:normalizeFormula(formula);

            if normalized == nil then
                return;
            end;

            rollContext = rollContext or {};
            rollContext.title = rollContext.title or label or "Rolagem";
            rollContext.rawFormula = rollContext.rawFormula or rawFormula;
            rollContext.formula = rollContext.formula or normalized;

            self:updateConsoleLast(rollContext.title, rollContext.rawFormula, nil, normalized);

            local chat = roomChat();

            if chat ~= nil then
                rollContext.pokemonName = rollContext.pokemonName or ((sheet ~= nil and (sheet.nomePokemon or sheet.apelidoPokemon)) or nil);

                PokemonChat.roll(chat, normalized, {
                    title = rollContext.title,
                    rawFormula = rollContext.rawFormula,
                    formula = rollContext.formula,
                    ownerSheet = sheet,
                    pokemonName = rollContext.pokemonName,
                    accentColor = rollContext.accentColor,
                    attributeDetailsEnabled = rollContext.attributeDetailsEnabled,
                    attributeBreakdown = rollContext.attributeBreakdown,
                    onResult = function(resultNumber, rollObject)
                        self:updateConsoleLast(rollContext.title, rollContext.rawFormula, resultNumber, normalized);
                    end
                });
            end;
        end;

        function self:rollField(fieldName, label)
            if sheet == nil then return; end;
            self:rollFormula(sheet[fieldName], label);
        end;

        function self:applyDamageToDefense()
            if sheet == nil then return; end;

            dialogs.inputQuery("DANO", "Informe o dano recebido:", "", function(value)
                local damage = parseFirecastHudNumber(value);

                if damage <= 0 then
                    dialogs.alert("Informe um valor de dano maior que zero.");
                    return;
                end;

                local defenseTotal = parseNumber(sheet.defesaBase) + parseNumber(sheet.defesaMod);
                if defenseTotal < 0 then defenseTotal = 0; end;

                local actualDamage = damage - defenseTotal;
                if actualDamage < 0 then actualDamage = 0; end;

                local pvMaximo = parseFirecastHudNumber(sheet.pvMaximo);
                local pvAtualTexto = trim(sheet.pvAtual);
                local pvAntes = parseFirecastHudNumber(sheet.pvAtual);

                if (pvAtualTexto == nil or pvAtualTexto == "") and pvMaximo > 0 then
                    pvAntes = pvMaximo;
                end;

                local pvDepois = pvAntes - actualDamage;
                if pvDepois < 0 then pvDepois = 0; end;

                sheet.pvAtual = tostring(pvDepois);

                dialogs.showMessage(
                    "Dano aplicado.\n\n" ..
                    "Dano bruto: " .. tostring(damage) .. "\n" ..
                    "Defesa total: " .. tostring(defenseTotal) .. "\n" ..
                    "Dano na Vida: " .. tostring(actualDamage) .. "\n" ..
                    "Pontos de Vida: " .. tostring(pvAntes) .. " -> " .. tostring(pvDepois)
                );
            end, nil, false);
        end;

        local function firecastHudState()
            if sheet == nil then return; end;

            local pvAtualTexto = trim(sheet.pvAtual);
            local peAtualTexto = trim(sheet.peAtual);
            local pvAtual = parseFirecastHudNumber(sheet.pvAtual);
            local pvMaximo = parseFirecastHudNumber(sheet.pvMaximo);
            local peAtual = parseFirecastHudNumber(sheet.peAtual);
            local peMaximo = parseFirecastHudNumber(sheet.peMaximo);
            local xpAtual = parseFirecastHudNumber(sheet.experienciaPokemon);
            local xpMaximo = parseFirecastHudNumber(sheet.experienciaMaximoPokemon);

            if pvMaximo <= 0 then pvMaximo = pvAtual; end;
            if peMaximo <= 0 then peMaximo = peAtual; end;
            if xpMaximo <= 0 then xpMaximo = 100; end;
            if xpAtual > xpMaximo then xpMaximo = xpAtual; end;
            if (pvAtualTexto == nil or pvAtualTexto == "") and pvMaximo > 0 then pvAtual = pvMaximo; end;
            if (peAtualTexto == nil or peAtualTexto == "") and peMaximo > 0 then peAtual = peMaximo; end;

            local deslocamentoTexto = "🚶 Deslocamento: " .. formatFirecastDistance(sheet.deslocamentoValor);
            local syncKey = table.concat({
                tostring(pvAtual),
                tostring(pvMaximo),
                tostring(peAtual),
                tostring(peMaximo),
                tostring(xpAtual),
                tostring(xpMaximo),
                deslocamentoTexto
            }, "|");

            return {
                pvAtual=pvAtual,
                pvMaximo=pvMaximo,
                peAtual=peAtual,
                peMaximo=peMaximo,
                xpAtual=xpAtual,
                xpMaximo=xpMaximo,
                deslocamentoTexto=deslocamentoTexto,
                syncKey=syncKey
            };
        end;

        function self:isFirecastSilentOpenEnabled()
            if sheet == nil then return false; end;
            local value = sheet.firecastSilentOpenEnabled;

            -- Fichas existentes entram silenciosamente por padrão.
            if value == nil or value == "" then return true; end;
            return value == true or value == 1 or value == "1" or value == "true";
        end;

        function self:isAttributeChatDetailsEnabled()
            if sheet == nil then return false; end;
            local value = sheet.attributeChatDetailsEnabled;

            -- Fichas existentes recebem o novo detalhamento por padrão.
            if value == nil or value == "" then return true; end;
            return value == true or value == 1 or value == "1" or value == "true";
        end;
        function self:refreshAdvancedSettings()
            local enabled = self:isFirecastSilentOpenEnabled();
            local chatDetailsEnabled = self:isAttributeChatDetailsEnabled();

            if self.btnFirecastAutoSync ~= nil then
                self.btnFirecastAutoSync.color = enabled and "#153624" or "#351719";
                self.btnFirecastAutoSync.strokeColor = enabled and "#7CFFB2" or "#FF5A5A";
                self.btnFirecastAutoSync.strokeSize = enabled and 2 or 1;
            end;

            if self.lblFirecastAutoSync ~= nil then
                self.lblFirecastAutoSync.text = enabled and "● LIGADA" or "○ DESLIGADA";
                self.lblFirecastAutoSync.fontColor = enabled and "#7CFFB2" or "#FF8A8A";
            end;

            if self.lblFirecastAutoSyncStatus ~= nil then
                if enabled then
                    self.lblFirecastAutoSyncStatus.text = "Abrir a ficha não envia barras. Alterações reais continuam sincronizando.";
                    self.lblFirecastAutoSyncStatus.fontColor = "#BDEFD0";
                else
                    self.lblFirecastAutoSyncStatus.text = "Entrada silenciosa desativada. As barras serão enviadas após o carregamento.";
                    self.lblFirecastAutoSyncStatus.fontColor = "#C7CDD7";
                end;
            end;
            if self.btnAttributeChatDetails ~= nil then
                self.btnAttributeChatDetails.color = chatDetailsEnabled and "#153624" or "#351719";
                self.btnAttributeChatDetails.strokeColor = chatDetailsEnabled and "#7CFFB2" or "#FF5A5A";
                self.btnAttributeChatDetails.strokeSize = chatDetailsEnabled and 2 or 1;
            end;

            if self.lblAttributeChatDetails ~= nil then
                self.lblAttributeChatDetails.text = chatDetailsEnabled and "● LIGADO" or "○ DESLIGADO";
                self.lblAttributeChatDetails.fontColor = chatDetailsEnabled and "#7CFFB2" or "#FF8A8A";
            end;

            if self.lblAttributeChatDetailsStatus ~= nil then
                if chatDetailsEnabled then
                    self.lblAttributeChatDetailsStatus.text = "Rolagens da Matriz mostram MOD, BASE e ajustes nomeados no chat.";
                    self.lblAttributeChatDetailsStatus.fontColor = "#BDEFD0";
                else
                    self.lblAttributeChatDetailsStatus.text = "Rolagens da Matriz usam o formato compacto original.";
                    self.lblAttributeChatDetailsStatus.fontColor = "#C7CDD7";
                end;
            end;
        end;

        function self:toggleFirecastSilentOpen()
            if sheet == nil then return; end;
            sheet.firecastSilentOpenEnabled = not self:isFirecastSilentOpenEnabled();
            self:refreshAdvancedSettings();
        end;

        function self:toggleAttributeChatDetails()
            if sheet == nil then return; end;
            sheet.attributeChatDetailsEnabled = not self:isAttributeChatDetailsEnabled();
            self:refreshAdvancedSettings();
        end;
        function self:armFirecastStatusHudSync()
            local state = firecastHudState();
            self._firecastHudLastSync = state ~= nil and state.syncKey or nil;
            self._firecastHudSyncReady = true;
        end;

        function self:scheduleFirecastStatusHudArm()
            self._firecastHudSyncReady = false;
            self._firecastHudArmGeneration = (self._firecastHudArmGeneration or 0) + 1;
            local generation = self._firecastHudArmGeneration;

            setTimeout(function()
                if self._firecastHudArmGeneration ~= generation then return; end;
                if sheet == nil then return; end;

                if self:isFirecastSilentOpenEnabled() then
                    self:armFirecastStatusHudSync();
                else
                    self._firecastHudSyncReady = true;
                    self._firecastHudLastSync = nil;
                    self:syncFirecastStatusHud(true);
                end;
            end, 500);
        end;

        function self:syncFirecastStatusHud(force)
            if sheet == nil then return; end;

            local state = firecastHudState();
            if state == nil then return; end;

            if force ~= true and self._firecastHudSyncReady ~= true then
                self._firecastHudLastSync = state.syncKey;
                return;
            end;

            if force ~= true and self._firecastHudLastSync == state.syncKey then return; end;

            if self._firecastHudSyncInFlight == true then
                self._firecastHudSyncPending = true;
                return;
            end;

            local personagem = firecastCharacterOfCurrentSheet();
            if personagem == nil or personagem.asyncUpdate == nil then return; end;

            self._firecastHudSyncInFlight = true;
            self._firecastHudLastSync = state.syncKey;

            local ok = pcall(function()
                personagem:asyncUpdate({
                    bar0Val = state.pvAtual,
                    bar0Max = state.pvMaximo,
                    bar1Val = state.peAtual,
                    bar1Max = state.peMaximo,
                    bar2Val = state.xpAtual,
                    bar2Max = state.xpMaximo,
                    edtLine0 = state.deslocamentoTexto
                });
            end);

            if not ok then
                self._firecastHudLastSync = nil;
            end;

            PokemonTokenSync.syncTokenBars(sheet, false);

            setTimeout(function()
                self._firecastHudSyncInFlight = false;

                if self._firecastHudSyncPending == true then
                    self._firecastHudSyncPending = false;
                    self:syncFirecastStatusHud();
                end;
            end, 350);
        end;

        local function applyDerivedFieldIfAuto(fieldName, autoFieldName, newValue)
            if sheet == nil then return; end;

            local newText = tostring(newValue or "");
            local currentText = trim(sheet[fieldName]);
            local lastAutoText = trim(sheet[autoFieldName]);

            if currentText == nil or currentText == "" or
               (lastAutoText ~= nil and lastAutoText ~= "" and currentText == lastAutoText) then
                sheet[fieldName] = newText;
            end;

            sheet[autoFieldName] = newText;
        end;

        function self:refreshDerivedFields()
            if sheet == nil then return; end;
            if self._allowAutoWrites ~= true then return; end;

            local vidaTotal = parseNumber(sheet.vidaBase) + parseNumber(sheet.vidaMod);
            local energiaTotal = parseNumber(sheet.poderBase) + parseNumber(sheet.poderMod);
            local velocidadeTotal = parseNumber(sheet.velocidadeBase) + parseNumber(sheet.velocidadeMod);
            local deslocamentoBase = 5 + math.floor(velocidadeTotal / 2);

            applyDerivedFieldIfAuto("pvMaximo", "pvMaximoAuto", vidaTotal);
            applyDerivedFieldIfAuto("peMaximo", "peMaximoAuto", energiaTotal);
            applyDerivedFieldIfAuto("deslocamentoValor", "deslocamentoAuto", tostring(deslocamentoBase) .. " metros");

            self:syncFirecastStatusHud();
        end;

        function self:updateThemeBySex()
            if sheet == nil then return; end;

            local sexo = sheet.sexoPokemon or "Macho";
            local sexoColor;

            if sexo == "Fêmea" then
                self.rectRoot.color = "#160B14";
                sheet.sexoEmoji = "♀";
                sexoColor = "#FF66CC";
            elseif sexo == "Neutro" then
                self.rectRoot.color = "#0F1012";
                sheet.sexoEmoji = "◌";
                sexoColor = "#8C9AB5";
            else
                self.rectRoot.color = "#0A0D12";
                sheet.sexoEmoji = "♂";
                sexoColor = "#00BFFF";
            end;

            if self.rectSexoButton ~= nil then
                self.rectSexoButton.strokeColor = sexoColor;
            end;

            if self.updateTypeMarkers ~= nil then
                self:updateTypeMarkers();
            end;
        end;

        function self:toggleSexo()
            if sheet == nil then return; end;

            if sheet.sexoPokemon == "Macho" then
                sheet.sexoPokemon = "Fêmea";
            elseif sheet.sexoPokemon == "Fêmea" then
                sheet.sexoPokemon = "Neutro";
            else
                sheet.sexoPokemon = "Macho";
            end;

            self:updateThemeBySex();
        end;

        local typeConfigs = {
            {key="Normal", field="typeNormalOn", rect="rectTypeNormal", active="#CFCFD4", display="Normal", emoji="⚪"},
            {key="Fire", field="typeFireOn", rect="rectTypeFire", active="#FF7B39", display="Fogo", emoji="🔥"},
            {key="Water", field="typeWaterOn", rect="rectTypeWater", active="#4DB8FF", display="Água", emoji="💧"},
            {key="Grass", field="typeGrassOn", rect="rectTypeGrass", active="#6DDB6D", display="Grama", emoji="🌿"},
            {key="Electric", field="typeElectricOn", rect="rectTypeElectric", active="#FFD84D", display="Elétrico", emoji="⚡"},
            {key="Ice", field="typeIceOn", rect="rectTypeIce", active="#9EE7FF", display="Gelo", emoji="❄"},
            {key="Fighting", field="typeFightingOn", rect="rectTypeFighting", active="#D96C52", display="Lutador", emoji="👊"},
            {key="Poison", field="typePoisonOn", rect="rectTypePoison", active="#B56DFF", display="Veneno", emoji="☠"},
            {key="Ground", field="typeGroundOn", rect="rectTypeGround", active="#C89A58", display="Terra", emoji="⛰"},
            {key="Flying", field="typeFlyingOn", rect="rectTypeFlying", active="#BFD8FF", display="Voador", emoji="🕊"},
            {key="Psychic", field="typePsychicOn", rect="rectTypePsychic", active="#FF79C8", display="Psíquico", emoji="🔮"},
            {key="Bug", field="typeBugOn", rect="rectTypeBug", active="#B7E051", display="Inseto", emoji="🐛"},
            {key="Rock", field="typeRockOn", rect="rectTypeRock", active="#B8A27B", display="Pedra", emoji="🪨"},
            {key="Ghost", field="typeGhostOn", rect="rectTypeGhost", active="#8B7CFF", display="Fantasma", emoji="👻"},
            {key="Dragon", field="typeDragonOn", rect="rectTypeDragon", active="#7B8CFF", display="Dragão", emoji="🐉"},
            {key="Dark", field="typeDarkOn", rect="rectTypeDark", active="#9E4DFF", display="Sombrio", emoji="🌑"},
            {key="Steel", field="typeSteelOn", rect="rectTypeSteel", active="#9FB4C5", display="Aço", emoji="⚙"},
            {key="Fairy", field="typeFairyOn", rect="rectTypeFairy", active="#FFB6E6", display="Fada", emoji="✨"}
        };

        local function isTypeOn(value)
            return (value == true) or (value == 1) or (value == "1") or (value == "true");
        end;

        local function splitTypeOrder(raw)
            local result = {};
            local source = trim(raw) or "";

            for token in string.gmatch(source, "[^|]+") do
                local cleaned = trim(token);
                if cleaned ~= nil and cleaned ~= "" then
                    table.insert(result, cleaned);
                end;
            end;

            return result;
        end;

        local function findTypeConfigByField(fieldName)
            for _, cfg in ipairs(typeConfigs) do
                if cfg.field == fieldName then
                    return cfg;
                end;
            end;
            return nil;
        end;

        local function findTypeConfigByKey(typeKey)
            for _, cfg in ipairs(typeConfigs) do
                if cfg.key == typeKey then
                    return cfg;
                end;
            end;
            return nil;
        end;

        local function selectedTypeConfigs()
            local selected = {};
            if sheet == nil then return selected; end;

            local order = splitTypeOrder(sheet.typeSelectionOrder);
            for _, typeKey in ipairs(order) do
                local cfg = findTypeConfigByKey(typeKey);
                if cfg ~= nil and isTypeOn(sheet[cfg.field]) then
                    table.insert(selected, cfg);
                end;
            end;

            return selected;
        end;

        local function paintTypeBadge(rectName, labelName, cfg, emptyText)
            local rect = self[rectName];
            local label = self[labelName];

            if cfg ~= nil then
                if rect ~= nil then
                    rect.strokeColor = cfg.active;
                    rect.color = "#151D2A";
                end;
                if label ~= nil then
                    label.text = cfg.emoji .. " " .. cfg.display;
                    label.fontColor = "#F4F8FF";
                end;
            else
                if rect ~= nil then
                    rect.strokeColor = "#2A3343";
                    rect.color = "#0B1018";
                end;
                if label ~= nil then
                    label.text = emptyText;
                    label.fontColor = "#8FA7BD";
                end;
            end;
        end;

        function self:openTypePopup()
            if sheet == nil then return; end;

            local popup = gui.newPopupForm("frmPokemonTiposPopup");
            if popup ~= nil then
                popup:setNodeObject(sheet);
                popup:show();
            end;
        end;

        function self:rebuildTypeTextFromOrder()
            if sheet == nil then return; end;

            local order = splitTypeOrder(sheet.typeSelectionOrder);
            local displayParts = {};

            for _, typeKey in ipairs(order) do
                local cfg = findTypeConfigByKey(typeKey);
                if cfg ~= nil then
                    table.insert(displayParts, cfg.display);
                end;
            end;

            sheet.tipoPokemon = table.concat(displayParts, " | ");
        end;

        function self:toggleType(fieldName)
            if sheet == nil then return; end;

            local cfg = findTypeConfigByField(fieldName);
            if cfg == nil then return; end;

            local order = splitTypeOrder(sheet.typeSelectionOrder);
            local v = sheet[fieldName];
            local isOn = isTypeOn(v);

            if isOn then
                sheet[fieldName] = nil;

                local newOrder = {};
                for _, typeKey in ipairs(order) do
                    if typeKey ~= cfg.key then
                        table.insert(newOrder, typeKey);
                    end;
                end;
                order = newOrder;
            else
                sheet[fieldName] = "1";

                local alreadyThere = false;
                for _, typeKey in ipairs(order) do
                    if typeKey == cfg.key then
                        alreadyThere = true;
                        break;
                    end;
                end;

                if not alreadyThere then
                    table.insert(order, cfg.key);
                end;
            end;

            sheet.typeSelectionOrder = table.concat(order, " | ");
            self:rebuildTypeTextFromOrder();
            self:updateTypeMarkers();
        end;

        function self:updateTypeMarkers()
            if sheet == nil then return; end;

            for _, cfg in ipairs(typeConfigs) do
                local rect = self[cfg.rect];
                if rect ~= nil then
                    local isOn = isTypeOn(sheet[cfg.field]);

                    if isOn then
                        rect.strokeColor = cfg.active;
                        rect.strokeSize = 2;
                        rect.color = "#18222D";
                    else
                        rect.strokeColor = "#2A3343";
                        rect.strokeSize = 1;
                        rect.color = "#0B1016";
                    end;
                end;
            end;

            local selected = selectedTypeConfigs();
            local primary = selected[1];

            paintTypeBadge("rectTypeBadgePrimary", "lblTypeBadgePrimary", primary, "Sem tipo");
            paintTypeBadge("rectTypeBadgeSecondary", "lblTypeBadgeSecondary", selected[2], "＋ Tipo");

            local accent = "#00BFFF";
            if primary ~= nil then
                accent = primary.active;
            end;

            if self.rectProfilePhotoCard ~= nil then
                self.rectProfilePhotoCard.strokeColor = accent;
            end;

            if self.lblProfilePhotoTitle ~= nil then
                self.lblProfilePhotoTitle.fontColor = accent;
            end;

            if self.rectProfilePhotoTitleButton ~= nil then
                self.rectProfilePhotoTitleButton.strokeColor = accent;
            end;

            if self.rectVisualTypeBadge ~= nil then
                self.rectVisualTypeBadge.strokeColor = accent;
            end;

            if self.lblVisualTypeBadge ~= nil then
                if primary ~= nil then
                    self.lblVisualTypeBadge.text = primary.emoji .. " " .. primary.display;
                    self.lblVisualTypeBadge.fontColor = "#F4F8FF";
                else
                    self.lblVisualTypeBadge.text = "Tipo não definido";
                    self.lblVisualTypeBadge.fontColor = "#8FA7BD";
                end;
            end;
        end;

        local profilePhotoStyles = {
            {id="autoFit"},
            {id="proportional"},
            {id="originalSize"},
            {id="stretch"}
        };

        local function profilePhotoStyleIndex(value)
            local style = tostring(value or "autoFit");
            for i, cfg in ipairs(profilePhotoStyles) do
                if cfg.id == style then
                    return i;
                end;
            end;
            return 1;
        end;

        function self:updateProfilePhotoStyle()
            local style = "autoFit";

            if sheet ~= nil then
                style = tostring(sheet.perfilVisualImageStyle or "autoFit");
            end;

            if self.imgProfileVisual ~= nil then
                self.imgProfileVisual.style = profilePhotoStyles[profilePhotoStyleIndex(style)].id;
                self.imgProfileVisual.center = true;
            end;
        end;

        function self:cycleProfilePhotoStyle()
            if sheet == nil then return; end;

            local currentIndex = profilePhotoStyleIndex(sheet.perfilVisualImageStyle);
            local nextIndex = currentIndex + 1;
            if nextIndex > #profilePhotoStyles then
                nextIndex = 1;
            end;

            sheet.perfilVisualImageStyle = profilePhotoStyles[nextIndex].id;
            self:updateProfilePhotoStyle();
        end;

        function self:openProfileVisualPopup()
            if sheet == nil then return; end;

            local popup = gui.newPopupForm("frmPokemonPerfilVisualPopup");
            if popup ~= nil then
                popup:setNodeObject(sheet);
                popup:show();
            end;
        end;

        local attrConfigs = {
            vida={rect="rectAttrVida", name="Vida", active="#00BFFF", desc="Vida: vitalidade, fôlego e capacidade de continuar lutando.", dieField="attrDieVida", dieRect="rectAttrDieVida", dieLabel="lblAttrDieVida"},
            poder={rect="rectAttrPoder", name="Poder", active="#00BFFF", desc="Poder: energia especial, técnicas e força não física.", dieField="attrDiePoder", dieRect="rectAttrDiePoder", dieLabel="lblAttrDiePoder"},
