            astucia={rect="rectAttrAstucia", name="Astúcia", active="#39FF14", desc="Astúcia: leitura, truques, percepção e oportunismo.", dieField="attrDieAstucia", dieRect="rectAttrDieAstucia", dieLabel="lblAttrDieAstucia"},
            fisico={rect="rectAttrFisico", name="Físico", active="#39FF14", desc="Físico: corpo, atletismo, força prática e esforço bruto.", dieField="attrDieFisico", dieRect="rectAttrDieFisico", dieLabel="lblAttrDieFisico"},
            mental={rect="rectAttrMental", name="Mental", active="#39FF14", desc="Mental: foco, memória, raciocínio e força de vontade.", dieField="attrDieMental", dieRect="rectAttrDieMental", dieLabel="lblAttrDieMental"},
            natural={rect="rectAttrNatural", name="Natural", active="#39FF14", desc="Natural: instinto, ambiente, criaturas e sobrevivência.", dieField="attrDieNatural", dieRect="rectAttrDieNatural", dieLabel="lblAttrDieNatural"},
            social={rect="rectAttrSocial", name="Social", active="#39FF14", desc="Social: presença, influência, empatia e blefe.", dieField="attrDieSocial", dieRect="rectAttrDieSocial", dieLabel="lblAttrDieSocial"},
