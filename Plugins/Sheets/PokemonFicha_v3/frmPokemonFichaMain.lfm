                        </rectangle>

                        <rectangle align="client" class="hudPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{right=8}">
                            <label align="top" height="16" text="BIOSTATUS" class="hudBlockTitle" fontColor="#00BFFF" />

                            <layout align="top" height="58" margins="{top=2, bottom=6}">
                                <rectangle align="left" width="64" class="hudStatCard" padding="{left=6, top=4, right=6, bottom=4}" margins="{right=6}">
                                    <label align="top" height="14" text="Nível" class="hudStatTitle" fontColor="#FFAE4D" />
                                    <edit align="client" field="nivelPokemon" class="hudCompactCenter" fontSize="15" />
                                    <rectangle align="bottom" height="1" color="#FFAE4D" />
                                </rectangle>

                                <rectangle align="left" width="100" class="hudStatCard" padding="{left=6, top=4, right=6, bottom=4}" margins="{right=6}">
                                    <label align="top" height="14" text="Experiência" class="hudStatTitle" fontColor="#FFAE4D" />
                                    <edit align="client" field="experienciaPokemon" class="hudCompactCenter" fontSize="13" />
                                    <rectangle align="bottom" height="1" color="#FFAE4D" />
                                </rectangle>

                                <rectangle align="client" class="hudStatCard" padding="{left=8, top=4, right=8, bottom=4}" margins="{right=6}">
                                    <label align="top" height="14" text="Condição" class="hudStatTitle" fontColor="#FF66CC" />
                                    <edit align="client" field="condicaoValor" class="hudCompactField" fontSize="13" />
                                    <rectangle align="bottom" height="1" color="#FF66CC" />
                                </rectangle>

                                <rectangle align="right" width="82" class="hudStatCard" padding="{left=6, top=4, right=6, bottom=4}" margins="{right=6}">
                                    <label align="top" height="14" text="Altura" class="hudStatTitle" fontColor="#7CFFB2" />
                                    <edit align="client" field="alturaPokemon" class="hudCompactCenter" fontSize="12" />
