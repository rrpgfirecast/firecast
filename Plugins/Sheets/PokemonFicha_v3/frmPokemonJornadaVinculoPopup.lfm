<?xml version="1.0" encoding="UTF-8"?>
<popupForm name="frmPokemonJornadaVinculoPopup"
           width="720"
           height="590"
           theme="dark"
           placement="center"
           cancelable="true"
           resizable="false">

    <style>
        rectangle.bondPopupRoot {
            color: #070A10;
            strokeColor: #FF9AD5;
            strokeSize: 1;
            xradius: 6;
            yradius: 6;
        }

        rectangle.bondPopupHeader {
            color: #090D15;
            strokeColor: #FF9AD5;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        rectangle.bondPopupPanel {
            color: #0B0F16;
            strokeColor: #263042;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        rectangle.bondImageLarge {
            color: #071019;
            strokeColor: #FF9AD5;
            strokeSize: 1;
            xradius: 6;
            yradius: 6;
        }

        rectangle.btnDark {
            color: #111824;
            strokeColor: #2A3343;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        rectangle.btnDelete {
            color: #151010;
            strokeColor: #FF5A5A;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        label.popupTitle {
            fontColor: #FF9AD5;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 17;
            vertTextAlign: center;
        }

        label.smallLabel {
            fontColor: #FF9AD5;
            fontSize: 9;
            fontStyle: bold;
            vertTextAlign: center;
        }

        edit.lineEdit {
            transparent: true;
            fontColor: #F4F8FF;
            fontSize: 11;
        }

        edit.nameEdit {
            transparent: true;
            fontColor: #FFFFFF;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 15;
        }

        textEditor.longText {
            fontColor: #EAF2FF;
            fontSize: 10;
        }

        label.btnText {
            fontColor: #D8F2FF;
            fontStyle: bold;
            fontSize: 10;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.btnDeleteText {
            fontColor: #FFBDBD;
            fontStyle: bold;
            fontSize: 10;
            horzTextAlign: center;
            vertTextAlign: center;
        }
    </style>

    <script><![CDATA[
        local PokemonTextMode = require("PokemonTextMode.lua");

        function self:deleteSelf()
            if sheet == nil then return; end;
            local root = PokemonTextMode.rootSheet(sheet);

            if NDB ~= nil and NDB.deleteNode ~= nil then
                NDB.deleteNode(sheet);
            elseif ndb ~= nil and ndb.deleteNode ~= nil then
                ndb.deleteNode(sheet);
            end;

            PokemonTextMode.refresh(root);
            self:close();
        end;
    ]]></script>

    <dataLink fields="{'nomeVinculo','tipoRelacao','estadoRelacao','nivelVinculo','nivelTensao','ultimaInteracao','historicoVinculo','segredoPendencia','notasVinculo'}">
        <event name="onChange">
            PokemonTextMode.refresh(sheet);
        </event>
    </dataLink>

    <rectangle align="client" class="bondPopupRoot" padding="{left=10, top=10, right=10, bottom=10}">
        <rectangle align="top" height="54" class="bondPopupHeader" padding="{left=10, top=6, right=10, bottom=6}" margins="{bottom=8}">
            <label align="client" text="VÍNCULO // DETALHES" class="popupTitle" />
        </rectangle>

        <layout align="top" height="190" margins="{bottom=8}">
            <rectangle align="left" width="178" class="bondImageLarge" padding="{left=8, top=8, right=8, bottom=8}" margins="{right=10}">
                <image align="client" field="imagemVinculo" editable="true" style="autoFit" />
            </rectangle>

            <rectangle align="client" class="bondPopupPanel" padding="{left=10, top=8, right=10, bottom=8}">
                <layout align="top" height="34" margins="{bottom=6}">
                    <edit align="client" field="nomeVinculo" class="nameEdit" />
                    <rectangle align="bottom" height="1" color="#FF9AD5" />
                </layout>

                <layout align="top" height="32" margins="{bottom=6}">
                    <label align="left" width="72" text="Tipo" class="smallLabel" />
                    <layout align="left" width="172" margins="{right=10}">
                        <edit align="client" field="tipoRelacao" class="lineEdit" />
                        <rectangle align="bottom" height="1" color="#FF9AD5" />
                    </layout>
                    <label align="left" width="66" text="Estado" class="smallLabel" fontColor="#FFD700" />
                    <layout align="client">
                        <edit align="client" field="estadoRelacao" class="lineEdit" />
                        <rectangle align="bottom" height="1" color="#FFD700" />
                    </layout>
                </layout>

                <layout align="top" height="32" margins="{bottom=6}">
                    <label align="left" width="72" text="Vínculo" class="smallLabel" />
                    <layout align="left" width="70" margins="{right=12}">
                        <edit align="client" field="nivelVinculo" class="lineEdit" horzTextAlign="center" />
                        <rectangle align="bottom" height="1" color="#FF9AD5" />
                    </layout>
                    <label align="left" width="62" text="Tensão" class="smallLabel" fontColor="#FF5A5A" />
                    <layout align="left" width="70" margins="{right=12}">
                        <edit align="client" field="nivelTensao" class="lineEdit" horzTextAlign="center" />
                        <rectangle align="bottom" height="1" color="#FF5A5A" />
                    </layout>
                    <label align="client" text="Use 0 a 5" fontColor="#8FA7BD" fontSize="8" vertTextAlign="center" />
                </layout>

                <label align="top" height="16" text="Última interação" class="smallLabel" fontColor="#7DEBFF" />
                <textEditor align="client" field="ultimaInteracao" class="longText" />
            </rectangle>
        </layout>

        <layout align="client" margins="{bottom=8}">
            <rectangle align="left" width="340" class="bondPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{right=8}">
                <label align="top" height="18" text="Histórico do vínculo" class="smallLabel" />
                <textEditor align="client" field="historicoVinculo" class="longText" />
            </rectangle>

            <layout align="client">
                <rectangle align="top" height="112" class="bondPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{bottom=8}">
                    <label align="top" height="18" text="Segredo / pendência" class="smallLabel" fontColor="#8A5CFF" />
                    <textEditor align="client" field="segredoPendencia" class="longText" />
                </rectangle>

                <rectangle align="client" class="bondPopupPanel" padding="{left=10, top=8, right=10, bottom=8}">
                    <label align="top" height="18" text="Notas do vínculo" class="smallLabel" fontColor="#8FA7BD" />
                    <textEditor align="client" field="notasVinculo" class="longText" />
                </rectangle>
            </layout>
        </layout>

        <layout align="bottom" height="32">
            <rectangle align="left" width="92" class="btnDelete" hitTest="true">
                <event name="onClick">self:deleteSelf();</event>
                <label align="client" text="APAGAR" class="btnDeleteText" />
            </rectangle>
            <layout align="client" />
            <rectangle align="right" width="112" class="btnDark" hitTest="true">
                <event name="onClick">self:close();</event>
                <label align="client" text="Fechar" class="btnText" />
            </rectangle>
        </layout>
    </rectangle>
</popupForm>
