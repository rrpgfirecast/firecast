                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#9FB4C5" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("pedrasEvolutivasRaras");</event>
                        <label align="top" height="20" text="PEDRAS EVOLUTIVAS RARAS" class="itemPresetName" fontColor="#9FB4C5" margins="{left=8}" />
                        <label align="client" text="Lua, Sol, Luz, Anoitecer e Amanhecer." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#9FB4C5" hitTest="true" margins="{bottom=10}">
                        <event name="onClick">self:applyItem("pedrasPreciosas");</event>
                        <label align="top" height="20" text="PEDRAS PRECIOSAS" class="itemPresetName" fontColor="#9FB4C5" margins="{left=8}" />
                        <label align="client" text="Ouro, Pérola, Diamante, Rubi e afins." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>

                    <label align="top" height="22" text="COMIDA / SUPORTE" class="sectionTitle" fontColor="#7CFFB2" />

                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#7CFFB2" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("comidaHumana");</event>
                        <label align="top" height="20" text="COMIDA HUMANA" class="itemPresetName" fontColor="#7CFFB2" margins="{left=8}" />
                        <label align="client" text="Uma porção comum de comida humana." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#7CFFB2" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("racaoPokemon");</event>
                        <label align="top" height="20" text="RAÇÃO POKÉMON" class="itemPresetName" fontColor="#7CFFB2" margins="{left=8}" />
                        <label align="client" text="Uma porção comum para Pokémon." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#FF6A3D" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("pokeblocoVermelho");</event>
                        <label align="top" height="20" text="POKÉBLOCO VERMELHO" class="itemPresetName" fontColor="#FF6A3D" margins="{left=8}" />
                        <label align="client" text="+1d4 Técnico em torneios." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#3DA5FF" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("pokeblocoAzul");</event>
                        <label align="top" height="20" text="POKÉBLOCO AZUL" class="itemPresetName" fontColor="#3DA5FF" margins="{left=8}" />
                        <label align="client" text="+1d4 Astúcia em torneios." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#FF9AD5" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("pokeblocoRosa");</event>
                        <label align="top" height="20" text="POKÉBLOCO ROSA" class="itemPresetName" fontColor="#FF9AD5" margins="{left=8}" />
                        <label align="client" text="+1d4 Social em torneios." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#39FF14" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("pokeblocoVerde");</event>
                        <label align="top" height="20" text="POKÉBLOCO VERDE" class="itemPresetName" fontColor="#39FF14" margins="{left=8}" />
                        <label align="client" text="+1d4 Mental em torneios." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#FFD700" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("pokeblocoAmarelo");</event>
                        <label align="top" height="20" text="POKÉBLOCO AMARELO" class="itemPresetName" fontColor="#FFD700" margins="{left=8}" />
                        <label align="client" text="+1d4 Físico em torneios." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#8A5CFF" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("pokeblocoMulticor");</event>
                        <label align="top" height="20" text="POKÉBLOCO MULTICOR" class="itemPresetName" fontColor="#8A5CFF" margins="{left=8}" />
                        <label align="client" text="+1d4 Natural em torneios." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#00BFFF" hitTest="true" margins="{bottom=6}">
                        <event name="onClick">self:applyItem("pokebola");</event>
                        <label align="top" height="20" text="POKÉBOLA" class="itemPresetName" fontColor="#00BFFF" margins="{left=8}" />
                        <label align="client" text="Ajuda recuperação no repouso." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                    <rectangle align="top" height="42" class="itemPresetButton" strokeColor="#8A5CFF" hitTest="true">
                        <event name="onClick">self:applyItem("centroSaude");</event>
                        <label align="top" height="20" text="CENTRO DE SAÚDE" class="itemPresetName" fontColor="#8A5CFF" margins="{left=8}" />
                        <label align="client" text="Serviço utilitário de recuperação." class="itemPresetDesc" margins="{left=8}" />
                    </rectangle>
                </rectangle>
            </layout>
        </scrollBox>

        <layout align="bottom" height="32">
            <layout align="client" />
            <rectangle align="right" width="112" class="btnDark" hitTest="true">
                <event name="onClick">self:close();</event>
                <label align="client" text="Fechar" class="btnText" />
            </rectangle>
        </layout>
    </rectangle>
</popupForm>
