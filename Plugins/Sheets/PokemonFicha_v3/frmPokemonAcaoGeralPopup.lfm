<?xml version="1.0" encoding="UTF-8"?>
<popupForm name="frmPokemonAcaoGeralPopup"
           width="470"
           height="430"
           theme="dark"
           placement="center"
           cancelable="true"
           resizable="false">

    <style>
        rectangle.actionPopupRoot {
            color: #070A10;
            strokeColor: #8A5CFF;
            strokeSize: 1;
            xradius: 6;
            yradius: 6;
        }

        rectangle.actionPopupHeader {
            color: #090D15;
            strokeColor: #8A5CFF;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        rectangle.actionPopupPanel {
            color: #0B0F16;
            strokeColor: #263042;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        label.actionPopupIcon {
            fontColor: #8A5CFF;
            fontSize: 28;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.actionPopupTitle {
            fontColor: #8A5CFF;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 18;
            vertTextAlign: center;
        }

        label.actionPopupSubtitle {
            fontColor: #8FA7BD;
            fontSize: 9;
            vertTextAlign: center;
        }

        label.actionPopupCost {
            fontColor: #FFFFFF;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 12;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.actionPopupLine {
            fontColor: #D8E7FF;
            fontSize: 10;
            vertTextAlign: center;
        }

        label.actionPopupBody {
            fontColor: #F4F8FF;
            fontSize: 10;
            vertTextAlign: leading;
        }

        label.actionPopupUse {
            fontColor: #BFD2E8;
            fontSize: 10;
            vertTextAlign: leading;
        }

        rectangle.actionPopupButton {
            color: #111824;
            strokeColor: #2A3343;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        label.actionPopupButtonText {
            fontColor: #D8F2FF;
            fontSize: 10;
            fontStyle: bold;
            horzTextAlign: center;
            vertTextAlign: center;
        }
    </style>

    <rectangle name="rectActionPopupRoot" align="client" class="actionPopupRoot" padding="{left=10, top=10, right=10, bottom=10}">
        <rectangle name="rectActionPopupHeader" align="top" height="70" class="actionPopupHeader" padding="{left=0, top=0, right=10, bottom=0}" margins="{bottom=8}">
            <rectangle name="rectActionPopupStripe" align="left" width="6" color="#8A5CFF" />
            <label name="lblActionPopupIcon" align="left" width="54" text="*" class="actionPopupIcon" />
            <layout align="client" padding="{top=7, bottom=7}">
                <label name="lblActionPopupTitle" align="top" height="30" text="AÇÃO" class="actionPopupTitle" />
                <label align="client" text="Manual de ação geral" class="actionPopupSubtitle" />
            </layout>
            <rectangle align="right" width="58" class="actionPopupPanel" padding="{left=4, top=4, right=4, bottom=4}" margins="{left=8, top=14, bottom=14}">
                <label name="lblActionPopupCost" align="client" text="0 PE" class="actionPopupCost" />
            </rectangle>
        </rectangle>

        <rectangle align="top" height="128" class="actionPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{bottom=8}">
            <label name="lblActionPopupTipo" align="top" height="20" text="Tipo: --" class="actionPopupLine" />
            <label name="lblActionPopupAcao" align="top" height="20" text="Ação: --" class="actionPopupLine" />
            <label name="lblActionPopupTeste" align="top" height="20" text="Teste: --" class="actionPopupLine" />
            <label name="lblActionPopupDetalhe" align="top" height="20" text="--" class="actionPopupLine" />
            <label name="lblActionPopupCusto" align="client" text="Custo: --" class="actionPopupLine" />
        </rectangle>

        <rectangle align="client" class="actionPopupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{bottom=8}">
            <scrollBox align="client">
                <layout align="top" height="164">
                    <label name="lblActionPopupDescricao" align="top" height="76" text="Descrição." class="actionPopupBody" wordWrap="true" margins="{bottom=10}" />
                    <label name="lblActionPopupUso" align="top" height="76" text="Uso em cena." class="actionPopupUse" wordWrap="true" />
                </layout>
            </scrollBox>
        </rectangle>

        <layout align="bottom" height="30">
            <layout align="client" />
            <rectangle name="rectActionPopupExecute" align="right" width="128" class="actionPopupButton" hitTest="true" margins="{right=8}">
                <event name="onClick"><![CDATA[
                    if self._generalActionMain ~= nil and self._generalActionKey ~= nil then
                        self._generalActionMain:requestExecuteGeneralAction(self._generalActionKey);
                    end;
                ]]></event>
                <label name="lblActionPopupExecute" align="client" text="Executar" class="actionPopupButtonText" />
            </rectangle>
            <rectangle align="right" width="112" class="actionPopupButton" hitTest="true">
                <event name="onClick">self:close();</event>
                <label align="client" text="Fechar" class="actionPopupButtonText" />
            </rectangle>
        </layout>
    </rectangle>
</popupForm>
