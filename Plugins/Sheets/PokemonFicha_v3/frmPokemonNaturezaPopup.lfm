<?xml version="1.0" encoding="UTF-8"?>
<popupForm name="frmPokemonNaturezaPopup"
           width="620"
           height="560"
           theme="dark"
           placement="center"
           cancelable="true"
           resizable="false">

    <style>
        rectangle.popupRoot {
            color: #070A10;
            strokeColor: #39FF14;
            strokeSize: 1;
            xradius: 6;
            yradius: 6;
        }

        rectangle.popupHeader {
            color: #090D15;
            strokeColor: #39FF14;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        rectangle.popupPanel {
            color: #0B0F16;
            strokeColor: #263042;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        rectangle.slotPanel {
            color: #0D111A;
            strokeColor: #2A3343;
            strokeSize: 1;
            xradius: 5;
            yradius: 5;
        }

        label.popupTitle {
            fontColor: #39FF14;
            fontFamily: Consolas;
            fontStyle: bold;
            fontSize: 16;
            horzTextAlign: center;
            vertTextAlign: center;
        }

        label.sectionTitle {
            fontColor: #9EB7D0;
            fontSize: 10;
            fontStyle: bold;
            vertTextAlign: center;
        }

        label.smallLabel {
            fontColor: #9EB7D0;
            fontSize: 8;
            fontStyle: bold;
            vertTextAlign: center;
        }

        edit.lineEdit {
            transparent: true;
            fontColor: #F4F8FF;
            fontSize: 11;
        }

        edit.iconEdit {
            transparent: true;
            fontColor: #F4F8FF;
            fontSize: 14;
            horzTextAlign: center;
        }

        textEditor.longText {
            fontColor: #EAF2FF;
            fontSize: 10;
        }

        rectangle.btnDark {
            color: #111824;
            strokeColor: #2A3343;
            strokeSize: 1;
            xradius: 4;
            yradius: 4;
            cursor: handPoint;
        }

        label.btnText {
            fontColor: #D8F2FF;
            fontSize: 10;
            fontStyle: bold;
            horzTextAlign: center;
            vertTextAlign: center;
        }
    </style>

    <rectangle align="client" class="popupRoot" padding="{left=10, top=10, right=10, bottom=10}">
        <rectangle align="top" height="42" class="popupHeader" margins="{bottom=8}">
            <label align="client" text="NATUREZA // INSTINTOS" class="popupTitle" />
        </rectangle>

        <scrollBox align="client" margins="{bottom=8}">
            <layout align="top" height="664">
                <rectangle align="top" height="118" class="popupPanel" padding="{left=10, top=8, right=10, bottom=8}" margins="{bottom=8}">
                    <label align="top" height="18" text="RESUMO COMPORTAMENTAL" class="sectionTitle" fontColor="#39FF14" />
                    <textEditor align="client" field="resumoComportamental" class="longText" />
                </rectangle>

                <label align="top" height="18" text="PERSONALIDADE" class="sectionTitle" fontColor="#FF66CC" margins="{bottom=4}" />

                <layout align="top" height="158" margins="{bottom=8}">
                    <rectangle align="left" width="292" class="slotPanel" padding="{left=8, top=8, right=8, bottom=8}" margins="{right=8}">
                        <layout align="top" height="30" margins="{bottom=6}">
                            <layout align="left" width="42" margins="{right=8}">
                                <edit align="client" field="personalidadeNaturalIcone" class="iconEdit" />
                                <rectangle align="bottom" height="1" color="#FF66CC" />
                            </layout>
                            <layout align="client">
                                <edit align="client" field="personalidadeNatural" class="lineEdit" />
                                <rectangle align="bottom" height="1" color="#FF66CC" />
                            </layout>
                        </layout>
                        <label align="top" height="14" text="Descrição" class="smallLabel" fontColor="#FF66CC" />
                        <textEditor align="client" field="descricaoNatural" class="longText" />
                    </rectangle>

                    <rectangle align="client" class="slotPanel" padding="{left=8, top=8, right=8, bottom=8}">
                        <layout align="top" height="30" margins="{bottom=6}">
                            <layout align="left" width="42" margins="{right=8}">
                                <edit align="client" field="personalidadeNatural2Icone" class="iconEdit" />
                                <rectangle align="bottom" height="1" color="#8A5CFF" />
                            </layout>
                            <layout align="client">
                                <edit align="client" field="personalidadeNatural2" class="lineEdit" />
                                <rectangle align="bottom" height="1" color="#8A5CFF" />
                            </layout>
                        </layout>
                        <label align="top" height="14" text="Descrição" class="smallLabel" fontColor="#8A5CFF" />
                        <textEditor align="client" field="descricaoNatural2" class="longText" />
                    </rectangle>
                </layout>

                <label align="top" height="18" text="EFEITOS DE PERSONALIDADE" class="sectionTitle" fontColor="#8FA7BD" margins="{bottom=4}" />
                <layout align="top" height="84" margins="{bottom=8}">
                    <rectangle align="left" width="292" class="slotPanel" padding="{left=8, top=8, right=8, bottom=8}" margins="{right=8}">
                        <textEditor align="client" field="efeitoPersonalidadeNatural" class="longText" />
                    </rectangle>
                    <rectangle align="client" class="slotPanel" padding="{left=8, top=8, right=8, bottom=8}">
                        <textEditor align="client" field="efeitoPersonalidadeNatural2" class="longText" />
                    </rectangle>
                </layout>

                <label align="top" height="18" text="HABILIDADES NATURAIS" class="sectionTitle" fontColor="#FFD700" margins="{bottom=4}" />

                <rectangle align="top" height="88" class="slotPanel" padding="{left=8, top=8, right=8, bottom=8}" margins="{bottom=6}">
                    <layout align="left" width="42" margins="{right=8}">
                        <edit align="client" field="habilidadeNaturalIcone" class="iconEdit" />
                        <rectangle align="bottom" height="1" color="#FFD700" />
                    </layout>
                    <layout align="left" width="150" margins="{right=8}">
                        <edit align="client" field="habilidadeNaturalNome" class="lineEdit" />
                        <rectangle align="bottom" height="1" color="#FFD700" />
                    </layout>
                    <textEditor align="client" field="habilidadeNaturalDescricao" class="longText" />
                </rectangle>

                <rectangle align="top" height="88" class="slotPanel" padding="{left=8, top=8, right=8, bottom=8}" margins="{bottom=6}">
                    <layout align="left" width="42" margins="{right=8}">
                        <edit align="client" field="habilidadeNatural2Icone" class="iconEdit" />
                        <rectangle align="bottom" height="1" color="#00BFFF" />
                    </layout>
                    <layout align="left" width="150" margins="{right=8}">
                        <edit align="client" field="habilidadeNatural2Nome" class="lineEdit" />
                        <rectangle align="bottom" height="1" color="#00BFFF" />
                    </layout>
                    <textEditor align="client" field="habilidadeNatural2Descricao" class="longText" />
                </rectangle>

                <rectangle align="top" height="88" class="slotPanel" padding="{left=8, top=8, right=8, bottom=8}">
                    <layout align="left" width="42" margins="{right=8}">
                        <edit align="client" field="habilidadeNatural3Icone" class="iconEdit" />
                        <rectangle align="bottom" height="1" color="#8A5CFF" />
                    </layout>
                    <layout align="left" width="150" margins="{right=8}">
                        <edit align="client" field="habilidadeNatural3Nome" class="lineEdit" />
                        <rectangle align="bottom" height="1" color="#8A5CFF" />
                    </layout>
                    <textEditor align="client" field="habilidadeNatural3Descricao" class="longText" />
                </rectangle>
            </layout>
        </scrollBox>

        <layout align="bottom" height="30">
            <layout align="client" />
            <rectangle align="right" width="112" class="btnDark" hitTest="true">
                <event name="onClick">self:close();</event>
                <label align="client" text="Fechar" class="btnText" />
            </rectangle>
        </layout>
    </rectangle>
</popupForm>
