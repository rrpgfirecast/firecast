<?xml version="1.0" encoding="UTF-8"?>
<form name="Creatures" align="client">    
    <scrollBox g="col" g-width="12" g-vert-tile="true">
        <button text="Nova Criatura" g="col" g-width="12" height="25" onClick="self.rclCreatures:append();" textTrimming="none"/>
        <gridRecordList name="rclCreatures" field="rclCreatures" templateForm="CreaturesCreature" g="col" g-width="12" g-cnt-line-spacing="5">
            <event name="onCompare">
                return Utils.compareStringPtBr(left.nome, right.nome);
            </event>
        </gridRecordList>
    </scrollBox>
</form>