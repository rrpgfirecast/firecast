<?xml version="1.0" encoding="UTF-8"?>
<group>
    <template name="Title">
		<label g="col" g-width="$(widthL or 3)" text="$(text)" horzTextAlign="center" height="25" fontSize="$(fontSize or 13)" textTrimming="none"/>
		<edit g="col" g-width="$(widthR or 9)" field="$(field)" height="25"/>
    </template>
    <template name="Title2">
		<label g="col" g-width="$(widthL or 3)" text="$(text)" horzTextAlign="center" height="25" fontSize="$(fontSize or 13)" textTrimming="none"/>
		<edit g="col" g-width="$(widthR or 4)" field="$(field)" height="25"/>
		<edit g="col" g-width="$(widthR2 or 5)" field="$(field)2" height="25"/>
    </template>
    <template name="Title3">
		<label g="col" g-width="$(widthL or 6)" text="$(text)" horzTextAlign="center" height="25" fontSize="$(fontSize or 13)" textTrimming="none"/>
		<edit g="col" g-width="$(widthR or 2)" field="$(field)" height="25"/>
		<edit g="col" g-width="$(widthR2 or 2)" field="$(field)2" height="25"/>
		<edit g="col" g-width="$(widthR3 or 2)" field="$(field)3" height="25"/>
    </template>
    <template name="TitleComboBox">
		<label g="col" g-width="$(widthL or 3)" text="$(text)" horzTextAlign="center" height="25" textTrimming="none"/>
		<comboBox g="col" g-width="$(widthR or 9)" field="$(field)" height="25" items="$(items)" values="$(values)" onChange="$(onChange)"/>
    </template>
	<template name="TitleEditor">
		<label g="col" g-width="12" height="25" text="$(text)" horzTextAlign="center" textTrimming="none"/>
        <textEditor g="col" g-width="12" g-min-height="100" g-vert-tile="true" field="$(field)"/>
	</template>
    <template name="ComboTitle">
		<comboBox g="col" g-width="$(widthL or 3)" field="$(field)" height="25" items="$(items)" values="$(values)" onChange="$(onChange)"/>
		<edit g="col" g-width="$(widthR or 9)" field="$(field2)" height="25"/>
    </template>

	<template name="SkillLabel">
		<label g="col" g-width="6" text="Perícia" horzTextAlign="center" height="25" fontSize="13" textTrimming="none"/>
		<label g="col" g-width="2" text="Esp" horzTextAlign="center" height="25" fontSize="13" textTrimming="none"/>
		<label g="col" g-width="2" text="Foco" horzTextAlign="center" height="25" fontSize="13" textTrimming="none"/>
		<label g="col" g-width="2" text="NA" horzTextAlign="center" height="25" fontSize="13" textTrimming="none"/>
	</template>

