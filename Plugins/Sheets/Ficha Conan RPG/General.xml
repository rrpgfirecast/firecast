<?xml version="1.0" encoding="UTF-8"?>
<form name="General" align="client">    
	<scrollBox align="client" g-cnt-line-spacing="5">
		<!-- Title region -->
		<rectangle g="col" g-width="12" g-width-lg="4" color="black" strokeColor="white" strokeSize="1" g-min-height="60" padding="{left=5,right=5,top=5,bottom=5}">
			<Title text="NOME" field="nome"/>
			<Title2 text="EXPERIÊNCIA" field="xp"/>
		</rectangle>
		<rectangle g="col" g-width="12" g-width-lg="4" color="black" strokeColor="white" strokeSize="1" g-min-height="60" padding="{left=5,right=5,top=5,bottom=5}">
			<Title text="RENOME" field="renome"/>
			<Title2 text="PONTOS DE FORTUNA" field="fortuna"/>
		</rectangle>
		<rectangle g="col" g-width="12" g-width-lg="4" color="black" strokeColor="white" strokeSize="1" g-min-height="60" padding="{left=5,right=5,top=5,bottom=5}">
			<Title text="POSIÇÃO" field="posicao"/>
		</rectangle>

		<layout g="col" g-width="12" g-width-lg="6" g-auto-height="true" g-cnt-line-spacing="5">
			<rectangle g="col" g-width="12" g-width-lg="6" color="black" strokeColor="white" strokeSize="1" g-min-height="210" padding="{left=5,right=5,top=5,bottom=5}">
				<label g="col" g-width="12" text="PROTEÇÃO DE ARMADURA" horzTextAlign="center" height="25" fontSize="13" textTrimming="none"/>
				<Title text="CABEÇA (1-2)" field="protCabeca"/>
				<Title text="BRAÇO D (3-5)" field="protBracoD"/>
				<Title text="BRAÇO E (6-8)" field="protBracoE"/>
				<Title text="TORSO (9-14)" field="protTorso"/>
				<Title text="PERNA D (15-17)" field="protPernaD"/>
				<Title text="PERNA E (18-20)" field="protPernaE"/>
				<Title text="QUALIDADE ARMADURA" field="qualidades"/>
			</rectangle>

			<rectangle g="col" g-width="12" g-width-lg="6" color="black" strokeColor="white" strokeSize="1" g-min-height="210" padding="{left=5,right=5,top=5,bottom=5}">
				<Title text="CORAGEM" field="coragem"/>
				<label g="col" g-width="12" text="FÍSICO" horzTextAlign="center" height="25" fontSize="13" textTrimming="none"/>
				<Title2 text="Vigor" field="vigor"/>
				<Title2 text="Ferimentos" field="ferimentos"/>
				<label g="col" g-width="12" text="MENTAL" horzTextAlign="center" height="25" fontSize="13" textTrimming="none"/>
				<Title2 text="Determinação" field="determinacao"/>
				<Title2 text="Trauma" field="trauma"/>
			</rectangle>

			<rectangle g="col" g-width="12" color="black" strokeColor="white" strokeSize="1" padding="{left=5,right=5,top=5,bottom=5}" g-auto-height="true" g-min-height="415">
				<image align="client" field="avatar" editable="true" style="proportional" >
					<event name="OnStartDrag">
					    drag:addData("imageURL", sheet.avatar)
					</event>
				</image>
			</rectangle>
		</layout>

		<layout g="col" g-width="12" g-width-lg="6" g-auto-height="true">
			<rectangle g="col" g-width="12" color="black" strokeColor="white" strokeSize="1" g-min-height="210"  g-auto-height="true" padding="{left=5,right=5,top=5,bottom=5}">
				<label g="col" g-width="12" text="ATRIBUTOS E PERÍCIAS" horzTextAlign="center" height="25" fontSize="13" textTrimming="none"/>
				<layout g="col" g-width="12" g-width-lg="6" g-auto-height="true">
					<Title text="AGILIDADE" field="agilidade"/>
					<SkillLabel/>
					<Title3 text="Acrobatismo" field="acrobatismo"/>
					<Title3 text="Combater" field="combater"/>
					<Title3 text="Furtividade" field="furtividade"/>

					<Title text="ATENÇÃO" field="atencao"/>
					<SkillLabel/>
					<Title3 text="Discernimento" field="discernimento"/>
					<Title3 text="Ladinagem" field="ladinagem"/>
					<Title3 text="Observar" field="observar"/>
					<Title3 text="Sobrevivência" field="sobrevivencia"/>

					<Title text="MÚSCULO" field="musculo"/>
					<SkillLabel/>
					<Title3 text="Atletismo" field="atletismo"/>
					<Title3 text="Resistência" field="resistencia"/>

					<Title text="COORDENAÇÃO" field="coordenacao"/>
					<SkillLabel/>
					<Title3 text="Aparar" field="aparar"/>
					<Title3 text="Pontaria" field="pontaria"/>
					<Title3 text="Velejar" field="velejar"/>
				</layout>
				<layout g="col" g-width="12" g-width-lg="6" g-auto-height="true">
					<Title text="INTELIGÊNCIA" field="inteligencia"/>
					<SkillLabel/>
					<Title3 text="Alquimia" field="alquimia"/>
					<Title3 text="Curar" field="curar"/>
					<Title3 text="Guerra" field="guerra"/>
					<Title3 text="Linguística" field="linguistica"/>
					<Title3 text="Manufatura" field="manufatura"/>
					<Title3 text="Saber" field="saber"/>

					<Title text="PERSONALIDADE" field="personalidade"/>
					<SkillLabel/>
					<Title3 text="Aconselhar" field="aconselhar"/>
					<Title3 text="Comandar" field="comandar"/>
					<Title3 text="Domar Animais" field="domarAnimais"/>
					<Title3 text="Persuasão" field="persuasao"/>
					<Title3 text="Sociedade" field="sociedade"/>

					<Title text="VONTADE" field="vontade"/>
					<SkillLabel/>
					<Title3 text="Disciplina" field="disciplina"/>
					<Title3 text="Feitiçaria" field="feiticaria"/>
				</layout>
			</rectangle>
		</layout>

	</scrollBox>
</form>