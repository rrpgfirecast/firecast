<?xml version="1.0" encoding="UTF-8"?>
<form name="FeatsFeat" g="col" g-width="12" g-width-lg="4" height="85">
	<script> 
		<![CDATA[			
		local function askForDelete()
			Dialogs.confirmYesNo("Deseja realmente apagar esse talento?",
								 function (confirmado)
									if confirmado then
										NDB.deleteNode(sheet)
									end
								 end)
		end
		]]>	
	</script>

    <import file="Templates.xml"/>

	<rectangle g="col" g-width="12"  color="black" strokeColor="white" strokeSize="1" g-min-height="85" padding="{left=5,right=5,top=5,bottom=5}">
		<ComboTitle field="tipo" field2="nome" items="{'TERRA NATAL', 'CASTA', 'LINHAGEM', 'EDUCAÇÃO', 'NATUREZA', 'ARQUÉTIPO', 'OUTRO'}" values="{'tn', 'c', 'l', 'e', 'n', 'a', 'o'}"/>
		<Title text="Efeito" field="efeito"/>

		<Title text="Perícia" field="pericia" widthL="2" widthR="3"/>
		<Title text="Grad." field="grad" widthL="2" widthR="3"/>
		<button g="col" g-width="2" height="25" text="🗑️" onClick="askForDelete()" hint="Apagar" textTrimming="none"/>
	</rectangle>
</form>