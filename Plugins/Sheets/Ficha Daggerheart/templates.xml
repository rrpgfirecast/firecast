    <template name="Weapon">
    	<rectangle g="col" g-width="6" g-width-lg="3" color="#17130F" strokeColor="#5E4930" strokeSize="1" g-min-height="300" padding="{left=8,right=8,top=8,bottom=8}" cornerType="round" xradius="6" yradius="6">
			<button g="col" g-width="12" text="$(text)" horzTextAlign="center" vertTextAlign="center" height="28" fontSize="11" fontStyle="bold" hint="Rolar dano">
				<event name="onClick">
					local profChecks = {
					    sheet.profCheck1,
					    sheet.profCheck2,
					    sheet.profCheck3,
					    sheet.profCheck4,
					    sheet.profCheck5,
					    sheet.profCheck6
					}

					local profCount = 0
					for _, v in ipairs(profChecks) do
					    if v then
					        profCount = profCount + 1
					    end
					end

					local roll = sheet.$(field)Damage
					if roll == nil then return end

					if profCount > 1 then
						roll = roll:gsub("(%d*)d", function(num)
					        return profCount .. "d"
					    end, 1)
					end

					local rolagem = Firecast.interpretarRolagem(roll)
					if not rolagem.possuiAlgumDado then return end
					local mesa = Firecast.getMesaDe(sheet)
					mesa.activeChat:rolarDados(rolagem, "Dano " .. (sheet.$(field)Type or "Físico") .. " de " .. (sheet.$(field)Name or "Arma"))
				</event>
			</button>
		<!-- 	
			if (prof ~= nil) and (prof ~= "") and (prof == "true") then			
		-->	
			<label g="col" g-width="3" text="PROF" horzTextAlign="center" vertTextAlign="center" height="25" fontSize="10" fontColor="#C8B78E" fontStyle="bold"/>
			<checkBox g="col" g-width="1" field="profCheck1" height="25"/>
			<checkBox g="col" g-width="1" field="profCheck2" height="25"/>
			<checkBox g="col" g-width="1" field="profCheck3" height="25"/>
			<checkBox g="col" g-width="1" field="profCheck4" height="25"/>
			<checkBox g="col" g-width="1" field="profCheck5" height="25"/>
			<checkBox g="col" g-width="1" field="profCheck6" height="25"/>
			<label g="col" g-width="3"/>
			
		<!-- 							
			else			
		-->		

			<layout g="col" g-width="12" height="25"/>
		<!-- 							
			end			
		-->		

			<Title text="NAME" field="$(field)Name"/>
			<Title text="TRAIT" field="$(field)Trait" widthL="3" widthR="3"/>
			<Title text="RANGE" field="$(field)Range" widthL="3" widthR="3"/>
			<Title text="DAMAGE" field="$(field)Damage" widthL="3" widthR="3"/>
			<Title text="TYPE" field="$(field)Type" widthL="3" widthR="3"/>
			<Title text="BURDEN" field="$(field)Burden"/>
			<label g="col" g-width="12" text="FEATURE" horzTextAlign="center" vertTextAlign="center" height="24" fontSize="10" fontColor="#CDAA57" fontStyle="bold"/>
			<textEditor g="col" g-width="12" g-vert-tile="true" g-min-height="96" field="$(field)Feature" fontColor="#FFF7E8"/>

		</rectangle>
    </template>

    <template name="InventorySlot">
		<rectangle g="col" g-width="6" height="26" color="#181512" strokeColor="#3A3329" strokeSize="1">
			<edit align="client" field="$(field)item" transparent="true" fontColor="#FFF7E8"/>
		</rectangle>
		<rectangle g="col" g-width="5" height="26" color="#181512" strokeColor="#3A3329" strokeSize="1">
			<edit align="client" field="$(field)diceroll" transparent="true" fontColor="#FFF7E8"/>
		</rectangle>
        <button g="col" g-width="1" text="R" class="btnSlot" margins="{top=2}" hint="Rolar item">
            <event name="onClick">
				local roll = sheet.$(field)diceroll
				if roll == nil then return end
				local nomeItem = sheet.$(field)item
				if nomeItem == nil then return end

                local mesa = Firecast.getMesaDe(sheet);
                local meuJogador = mesa.meuJogador
                local meuNick = meuJogador.nick

				local rolagem = Firecast.interpretarRolagem(roll)
				if not rolagem.possuiAlgumDado then return end
                local msg = "[Item] ".. meuNick .."[§R][§K2] usou: [§K1][§B]" .. (sheet.$(field)item or "")
                mesa.activeChat:enviarMensagem(msg)
				mesa.activeChat:rolarDados(rolagem)
            </event>
        </button>
    </template>	
</group>
