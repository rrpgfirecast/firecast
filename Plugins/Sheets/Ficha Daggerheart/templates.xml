	<template name="ShowButton">
		<button g="col" g-width="12" g-width-lg="2" text="CHAT" class="btnSlot" margins="{left=2,right=2,top=2,bottom=2}" hint="Enviar carta para o chat">
			<event name="onClick">
				if sheet.$(field)URL == nil then return end
				local mesaDoPersonagem = Firecast.getMesaDe(sheet);
				local meuJogador = mesaDoPersonagem.meuJogador
				local meuNick = meuJogador.nick
									
				local msg = "[Carta] ".. meuNick .."[§R][§K2] destacou a Carta:"
				msg = msg .. "\n****\n### [§K1][§B]".. (sheet.$(field)Nome or "") .."[§B]\n###### [§I".. (sheet.$(field)URL or "") .."]\n****"
				mesaDoPersonagem.activeChat:enviarMensagem(msg)
			</event>
		</button>
	</template>

