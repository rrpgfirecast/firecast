<?xml version="1.0" encoding="UTF-8"?>
<form name="Description" align="client" margins="{top=1}">
	<scrollBox align="client" g-cnt-line-spacing="8" padding="{left=2,right=2,top=2,bottom=8}">
		<label g="col" g-width="12" text="CHARACTER INFORMATION" height="24" horzTextAlign="center" vertTextAlign="center" fontSize="13" fontStyle="bold" fontColor="#CDAA57"/>

		<rectangle g="col" g-width="12" color="#17130F" strokeColor="#5E4930" strokeSize="1" g-auto-height="true" g-min-height="124" padding="{left=10,right=10,top=10,bottom=10}" cornerType="round" xradius="6" yradius="6">
			<layout g="col" g-width="12" g-width-lg="3" g-min-height="104">
				<label g="col" g-width="3" height="26" text="SIZE" horzTextAlign="center" vertTextAlign="center" fontSize="10" fontColor="#C8B78E" fontStyle="bold"/>
				<comboBox g="col" g-width="5" height="26" field="tamanho" fontColor="#FFF7E8" items="{'Minusculo', 'Diminuto', 'Miudo', 'Pequeno', 'Medio', 'Grande', 'Enorme', 'Imenso', 'Colossal'}" values="{'-4','-3','-2','-1','0','1','2','3','4'}" horzTextAlign="center"/>
				<checkBox g="col" g-width="4" height="26" field="quadruped" text="Quadruped"/>
				<Title text="HEIGHT" field="altura"/>
				<Title text="WEIGHT" field="peso"/>
				<Title text="AGE" field="idade"/>
			</layout>
			<layout g="col" g-width="12" g-width-lg="3" g-min-height="104">
				<Title text="SEX" field="sexo"/>
				<Title text="EYES" field="aparenciaOlhos"/>
				<Title text="SKIN" field="pele"/>
				<Title text="HAIR" field="cabelo"/>
			</layout>
			<layout g="col" g-width="12" g-width-lg="3" g-min-height="104">
				<Title text="PLANE" field="plano"/>
				<Title text="REGION" field="regiao"/>
				<Title text="KINGDOM" field="reino"/>
				<Title text="OTHER" field="aparenciaOutros"/>
			</layout>
			<layout g="col" g-width="12" g-width-lg="3" g-min-height="104">
				<label g="col" g-width="12" text="QUICK NOTES" horzTextAlign="center" vertTextAlign="center" height="24" fontSize="11" fontStyle="bold" fontColor="#CDAA57"/>
				<textEditor g="col" g-width="12" g-vert-tile="true" g-min-height="78" field="anotacoes1" fontColor="#FFF7E8"/>
			</layout>
		</rectangle>

		<rectangle g="col" g-width="12" g-width-lg="4" g-vert-tile="true" color="#161B18" strokeColor="#577154" strokeSize="1" g-min-height="300" padding="{left=10,right=10,top=10,bottom=10}" cornerType="round" xradius="6" yradius="6">
			<label g="col" g-width="12" height="26" text="APPEARANCE" horzTextAlign="center" vertTextAlign="center" fontSize="12" fontStyle="bold" fontColor="#D3C36E"/>
			<textEditor g="col" g-width="12" g-vert-tile="true" field="aparencia" fontColor="#FFF7E8"/>
		</rectangle>

		<rectangle g="col" g-width="12" g-width-lg="4" g-vert-tile="true" color="#151419" strokeColor="#564C76" strokeSize="1" g-min-height="300" padding="{left=10,right=10,top=10,bottom=10}" cornerType="round" xradius="6" yradius="6">
			<label g="col" g-width="12" height="26" text="PERSONALITY" horzTextAlign="center" vertTextAlign="center" fontSize="12" fontStyle="bold" fontColor="#C5B7EA"/>
			<textEditor g="col" g-width="12" g-vert-tile="true" field="personalidade" fontColor="#FFF7E8"/>
		</rectangle>

		<rectangle g="col" g-width="12" g-width-lg="4" g-vert-tile="true" color="#17130F" strokeColor="#5E4930" strokeSize="1" g-min-height="300" padding="{left=10,right=10,top=10,bottom=10}" cornerType="round" xradius="6" yradius="6">
			<label g="col" g-width="12" height="26" text="NOTES" horzTextAlign="center" vertTextAlign="center" fontSize="12" fontStyle="bold" fontColor="#CDAA57"/>
			<textEditor g="col" g-width="6" g-vert-tile="true" field="anotacoes2" fontColor="#FFF7E8"/>
			<textEditor g="col" g-width="6" g-vert-tile="true" field="anotacoes3" fontColor="#FFF7E8"/>
		</rectangle>

		<rectangle g="col" g-width="12" g-width-lg="8" g-vert-tile="true" color="#141414" strokeColor="#3A3329" strokeSize="1" g-min-height="700" padding="{left=10,right=10,top=10,bottom=10}" cornerType="round" xradius="6" yradius="6">
			<label g="col" g-width="12" height="26" text="BACKGROUND" horzTextAlign="center" vertTextAlign="center" fontSize="12" fontStyle="bold" fontColor="#CDAA57"/>
			<richEdit g="col" g-width="12" g-vert-tile="true" field="background" backgroundColor="#171512" defaultFontSize="12" defaultFontColor="#FFF7E8"/>
		</rectangle>

		<rectangle g="col" g-width="12" g-width-lg="4" g-vert-tile="true" color="#141414" strokeColor="#3A3329" strokeSize="1" g-min-height="700" padding="{left=10,right=10,top=10,bottom=10}" cornerType="round" xradius="6" yradius="6">
			<label g="col" g-width="12" height="26" text="CAMPAIGN NOTES" horzTextAlign="center" vertTextAlign="center" fontSize="12" fontStyle="bold" fontColor="#CDAA57"/>
			<textEditor g="col" g-width="6" g-vert-tile="true" field="anotacoes4" fontColor="#FFF7E8"/>
			<textEditor g="col" g-width="6" g-vert-tile="true" field="anotacoes5" fontColor="#FFF7E8"/>
			<textEditor g="col" g-width="6" g-vert-tile="true" field="anotacoes6" fontColor="#FFF7E8"/>
			<textEditor g="col" g-width="6" g-vert-tile="true" field="anotacoes7" fontColor="#FFF7E8"/>
			<textEditor g="col" g-width="6" g-vert-tile="true" field="anotacoes8" fontColor="#FFF7E8"/>
			<textEditor g="col" g-width="6" g-vert-tile="true" field="anotacoes9" fontColor="#FFF7E8"/>
		</rectangle>
	</scrollBox>
</form>
