		<rectangle g="col" g-width="12" g-width-lg="4" color="#161B18" strokeColor="#577154" strokeSize="1" g-min-height="380" padding="{left=10,right=10,top=10,bottom=10}" cornerType="round" xradius="6" yradius="6">
			<label g="col" g-width="12" text="HOPE" horzTextAlign="center" vertTextAlign="center" height="24" fontSize="14" fontStyle="bold" fontColor="#D3C36E"/>
			<label g="col" g-width="3"/>
			<imageCheckBox g="col" g-width="1" uncheckedImage="images/losangooff.png" checkedImage="images/losango.png" field="hopeCheck1" height="30"/>
			<imageCheckBox g="col" g-width="1" uncheckedImage="images/losangooff.png" checkedImage="images/losango.png" field="hopeCheck2" height="30"/>
			<imageCheckBox g="col" g-width="1" uncheckedImage="images/losangooff.png" checkedImage="images/losango.png" field="hopeCheck3" height="30"/>
			<imageCheckBox g="col" g-width="1" uncheckedImage="images/losangooff.png" checkedImage="images/losango.png" field="hopeCheck4" height="30"/>
			<imageCheckBox g="col" g-width="1" uncheckedImage="images/losangooff.png" checkedImage="images/losango.png" field="hopeCheck5" height="30"/>
			<imageCheckBox g="col" g-width="1" uncheckedImage="images/losangooff.png" checkedImage="images/losango.png" field="hopeCheck6" height="30"/>
			<label g="col" g-width="3"/>

			<label g="col" g-width="12" text="Hope Feature" horzTextAlign="center" vertTextAlign="center" height="22" fontSize="10" fontStyle="bold" fontColor="#BFD2B7"/>
			<textEditor g="col" g-width="12" g-min-height="88" field="hopeFeature" horzTextAlign="center" fontColor="#FFF7E8"/>

			<label g="col" g-width="12" text="EXPERIENCES" horzTextAlign="center" vertTextAlign="center" height="26" fontSize="12" fontStyle="bold" fontColor="#D3C36E"/>
