			<imageCheckBox uncheckedImage="images/hpoff.png" checkedImage="images/hp.png" g="col" g-width="1" height="28" field="hpCheck10"/>
			<imageCheckBox uncheckedImage="images/hpoff.png" checkedImage="images/hp.png" g="col" g-width="1" height="28" field="hpCheck11"/>
			<imageCheckBox uncheckedImage="images/hpoff.png" checkedImage="images/hp.png" g="col" g-width="1" height="28" field="hpCheck12"/>

			<label g="col" g-width="12"/>
			<label g="col" g-width="5"/>
			<Title text="MAX STRESS" field="maxStress" widthL="1" widthR="1"/>
			<label g="col" g-width="5"/>
			<label g="col" g-width="12"/>
			<imageCheckBox uncheckedImage="images/stressoff.png" checkedImage="images/stress.png" g="col" g-width="1" height="28" field="stressCheck1"/>
			<imageCheckBox uncheckedImage="images/stressoff.png" checkedImage="images/stress.png" g="col" g-width="1" height="28" field="stressCheck2"/>
			<imageCheckBox uncheckedImage="images/stressoff.png" checkedImage="images/stress.png" g="col" g-width="1" height="28" field="stressCheck3"/>
			<imageCheckBox uncheckedImage="images/stressoff.png" checkedImage="images/stress.png" g="col" g-width="1" height="28" field="stressCheck4"/>
			<imageCheckBox uncheckedImage="images/stressoff.png" checkedImage="images/stress.png" g="col" g-width="1" height="28" field="stressCheck5"/>
			<imageCheckBox uncheckedImage="images/stressoff.png" checkedImage="images/stress.png" g="col" g-width="1" height="28" field="stressCheck6"/>
			<imageCheckBox uncheckedImage="images/stressoff.png" checkedImage="images/stress.png" g="col" g-width="1" height="28" field="stressCheck7"/>
			<imageCheckBox uncheckedImage="images/stressoff.png" checkedImage="images/stress.png" g="col" g-width="1" height="28" field="stressCheck8"/>
			<imageCheckBox uncheckedImage="images/stressoff.png" checkedImage="images/stress.png" g="col" g-width="1" height="28" field="stressCheck9"/>
