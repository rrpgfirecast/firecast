			<label g="col" g-width="3" text="Bonus" horzTextAlign="center" vertTextAlign="center" height="18" fontSize="10" fontStyle="bold" fontColor="#BFD2B7"/>
			<Experience field="exp1"/>
			<Experience field="exp2"/>
			<Experience field="exp3"/>
			<Experience field="exp4"/>
			<Experience field="exp5"/>
		</rectangle>

		<rectangle g="col" g-width="12" g-width-lg="4" color="#151419" strokeColor="#564C76" strokeSize="1" g-min-height="380" padding="{left=10,right=10,top=10,bottom=10}" cornerType="round" xradius="6" yradius="6">
			<label g="col" g-width="12" text="DEFENSE" horzTextAlign="center" vertTextAlign="center" height="34" fontSize="12" fontStyle="bold" fontColor="#C5B7EA"/>
			<label g="col" g-width="2"/>
			<Title text="EVASION" field="evasion" widthL="1" widthR="2"/>
			<label g="col" g-width="2"/>
			<Title text="ARMOR" field="armor" widthL="1" widthR="2"/>
			<label g="col" g-width="2"/>
			<label g="col" g-width="12"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck1"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck2"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck3"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck4"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck5"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck6"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck7"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck8"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck9"/>
