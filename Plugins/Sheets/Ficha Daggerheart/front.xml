			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck11"/>
			<imageCheckBox uncheckedImage="images/shieldoff.png" checkedImage="images/shield.png" g="col" g-width="1" height="28" field="armorCheck12"/>
			
			<label g="col" g-width="12"/>

			<label g="col" g-width="12" text="DAMAGE &amp; HEALTH" horzTextAlign="center" vertTextAlign="center" height="36" fontSize="14" fontStyle="bold" fontColor="#C5B7EA"/>
			<label g="col" g-width="3" text="Minor" horzTextAlign="center" vertTextAlign="center" height="26" fontSize="12" fontStyle="bold" fontColor="#C2BDD4"/>
			<rectangle g="col" g-width="2" height="26" color="#181512" strokeColor="#3A3329" strokeSize="1" cornerType="round" xradius="4" yradius="4">
				<edit align="client" field="damage1" transparent="true" horzTextAlign="center" fontColor="#FFF7E8"/>
			</rectangle>
			<label g="col" g-width="2" text="Major" horzTextAlign="center" vertTextAlign="center" height="26" fontSize="12" fontStyle="bold" fontColor="#C2BDD4"/>
			<rectangle g="col" g-width="2" height="26" color="#181512" strokeColor="#3A3329" strokeSize="1" cornerType="round" xradius="4" yradius="4">
				<edit align="client" field="damage2" transparent="true" horzTextAlign="center" fontColor="#FFF7E8"/>
			</rectangle>
			<label g="col" g-width="3" text="Severe" horzTextAlign="center" vertTextAlign="center" height="26" fontSize="12" fontStyle="bold" fontColor="#C2BDD4"/>

			<label g="col" g-width="12"/>
			<label g="col" g-width="5"/>
			<Title text="MAX HP" field="maxHp" widthL="1" widthR="1"/>
			<label g="col" g-width="5"/>
			<label g="col" g-width="12"/>
			<imageCheckBox uncheckedImage="images/hpoff.png" checkedImage="images/hp.png" g="col" g-width="1" height="28" field="hpCheck1"/>
			<imageCheckBox uncheckedImage="images/hpoff.png" checkedImage="images/hp.png" g="col" g-width="1" height="28" field="hpCheck2"/>
			<imageCheckBox uncheckedImage="images/hpoff.png" checkedImage="images/hp.png" g="col" g-width="1" height="28" field="hpCheck3"/>
