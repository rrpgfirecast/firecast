		</rectangle>
		
		<rectangle g="col" g-width="12" g-width-lg="4" color="#17130F" strokeColor="#6E5531" strokeSize="1" padding="{left=10,right=10,top=10,bottom=10}" g-min-height="380" g-auto-height="true" cornerType="round" xradius="6" yradius="6">
			<label g="col" g-width="12" text="CLASS FEATURE" horzTextAlign="center" vertTextAlign="center" height="26" fontSize="14" fontStyle="bold" fontColor="#CDAA57"/>
			<textEditor g="col" g-width="12" g-min-height="320" field="classFeature" horzTextAlign="center" fontColor="#FFF7E8"/>
		</rectangle>

		<label g="col" g-width="12" text="PROGRESS" height="26" horzTextAlign="center" vertTextAlign="center" fontSize="16" fontStyle="bold" fontColor="#CDAA57"/>
		<tabControl g="col" g-width="12" height="480">
			<tab title="Tier 2">
				<scrollBox align="client" g-cnt-line-spacing="6" padding="{left=8,right=8,top=8,bottom=8}">
					<rectangle g="col" g-width="12" color="#141414" strokeColor="#5E4930" strokeSize="1" padding="{left=10,right=10,top=10,bottom=10}" g-auto-height="true">
						<label g="col" g-width="12" text="TIER 2: LEVELS 2-4" horzTextAlign="center" height="26" fontStyle="bold" fontColor="#CDAA57"/>
						<label g="col" g-width="12" text="At level 2, gain an additional Experience at +2 and gain a +1 bonus to your Proficiency." horzTextAlign="center" height="40" wordWrap="true"/>
						<label g="col" g-width="12" text="Choose two options from the list below and mark them." horzTextAlign="center" height="30" wordWrap="true"/>
						<label g="col" g-width="3"/>
						<rectangle g="col" g-width="6" color="#141414" strokeColor="#5E4930" strokeSize="1" padding="{left=10,right=10,top=10,bottom=10}" g-auto-height="true">
							<checkBox g="col" g-width="1" height="24" field="unCharacterTrait1"/>
							<checkBox g="col" g-width="1" height="24" field="unCharacterTrait2"/>
							<checkBox g="col" g-width="10" field="unCharacterTrait3" text="Gain a +1 bonus to two unmarked character traits and mark them." height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" height="24" field="extraHPslot1"/>
							<checkBox g="col" g-width="10" field="extraHPslot2" text="Permanently gain one Hit Point slot." height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" height="24" field="extraSressSlot1"/>
							<checkBox g="col" g-width="10" field="extraSressSlot2" text="Permanently gain one Stress slot." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="expBonus1" text="Permanently gain a +1 bonus to two Experiences." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="extraDomainCard1" text="Choose an additional domain card of your level or lower from a domain you have access to (up to level 4)." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="extraEvasion1" text="Permanently gain a +1 bonus to your Evasion." height="24" wordWrap="true"/>
						</rectangle>
						<label g="col" g-width="3"/>
						<label g="col" g-width="12" text="Update your level, adjust damage thresholds, and take an additional domain card of your level or lower every time you level up." horzTextAlign="center" height="50" wordWrap="true" fontColor="#BEB39B"/>
					</rectangle>
				</scrollBox>
			</tab>
			<tab title="Tier 3">
				<scrollBox align="client" g-cnt-line-spacing="6" padding="{left=8,right=8,top=8,bottom=8}">
					<rectangle g="col" g-width="12" color="#141414" strokeColor="#5E4930" strokeSize="1" padding="{left=10,right=10,top=10,bottom=10}" g-auto-height="true">
						<label g="col" g-width="12" text="TIER 3: LEVELS 5-7" horzTextAlign="center" height="26" fontStyle="bold" fontColor="#CDAA57"/>
						<label g="col" g-width="12" text="At level 5, gain an additional Experience at +2, clear all marks on character traits, then gain a +1 bonus to your Proficiency." horzTextAlign="center" height="46" wordWrap="true"/>
						<label g="col" g-width="12" text="Choose two options from this list or from a previous tier." horzTextAlign="center" height="30" wordWrap="true"/>
						<label g="col" g-width="3"/>
						<rectangle g="col" g-width="6" color="#141414" strokeColor="#5E4930" strokeSize="1" padding="{left=10,right=10,top=10,bottom=10}" g-auto-height="true">
							<checkBox g="col" g-width="1" height="24" field="unCharacterTrait4"/>
							<checkBox g="col" g-width="1" height="24" field="unCharacterTrait5"/>
							<checkBox g="col" g-width="10" field="unCharacterTrait6" text="Gain a +1 bonus to two unmarked character traits and mark them." height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" field="extraHPslot3"/>
							<checkBox g="col" g-width="10" field="extraHPslot4" text="Permanently gain one Hit Point slot." height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" height="24" field="extraSressSlot3"/>
							<checkBox g="col" g-width="10" field="extraSressSlot4" text="Permanently gain one Stress slot." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="expBonus2" text="Permanently gain a +1 bonus to two Experiences." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="extraDomainCard2" text="Choose an additional domain card of your level or lower from a domain you have access to (up to level 7)." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="extraEvasion2" text="Permanently gain a +1 bonus to your Evasion." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="upgradedClass1" text="Take an upgraded subclass card. Cross out the multiclass option." height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" height="24" field="extraProficiency1Part1"/>
							<checkBox g="col" g-width="10" field="extraProficiency1Part2" text="Increase your Proficiency by +1. You must spend two points in this option, to gain it's benefit" height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" height="48" field="multiClass1Part1"/>
							<checkBox g="col" g-width="10" field="multiClass1Part2" text="Multiclass: Choose an additional class. You must spend two points in this option, to gain it's benefit.\nCross out the upgraded subclass option." height="48" wordWrap="true"/>
						</rectangle>
						<label g="col" g-width="3"/>
						<label g="col" g-width="12" text="Update your level, adjust damage thresholds, and take an additional domain card of your level or lower every time you level up." horzTextAlign="center" height="50" wordWrap="true" fontColor="#BEB39B"/>
					</rectangle>
				</scrollBox>
			</tab>
			<tab title="Tier 4">
				<scrollBox align="client" g-cnt-line-spacing="6" padding="{left=8,right=8,top=8,bottom=8}">
					<rectangle g="col" g-width="12" color="#141414" strokeColor="#5E4930" strokeSize="1" padding="{left=10,right=10,top=10,bottom=10}" g-auto-height="true">
						<label g="col" g-width="12" text="TIER 4: LEVELS 8-10" horzTextAlign="center" height="26" fontStyle="bold" fontColor="#CDAA57"/>
						<label g="col" g-width="12" text="At level 8, gain an additional Experience at +2, clear all marks on character traits, then gain a +1 bonus to your Proficiency." horzTextAlign="center" height="46" wordWrap="true"/>
						<label g="col" g-width="12" text="Choose two options from this list or from a previous tier." horzTextAlign="center" height="30" wordWrap="true"/>
						<label g="col" g-width="3"/>
						<rectangle g="col" g-width="6" color="#141414" strokeColor="#5E4930" strokeSize="1" padding="{left=10,right=10,top=10,bottom=10}" g-auto-height="true">
							<checkBox g="col" g-width="1" height="24" field="unCharacterTrait7"/>
							<checkBox g="col" g-width="1" height="24" field="unCharacterTrait8"/>
							<checkBox g="col" g-width="10" field="unCharacterTrait9" text="Gain a +1 bonus to two unmarked character traits and mark them." height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" field="extraHPslot5"/>
							<checkBox g="col" g-width="10" field="extraHPslot6" text="Permanently gain one Hit Point slot." height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" height="24" field="extraSressSlot5"/>
							<checkBox g="col" g-width="10" field="extraSressSlot6" text="Permanently gain one Stress slot." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="expBonus3" text="Permanently gain a +1 bonus to two Experiences." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="extraDomainCard3" text="Choose an additional domain card of your level or lower from a domain you have access to (up to level 7)." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="extraEvasion3" text="Permanently gain a +1 bonus to your Evasion." height="24" wordWrap="true"/>
							<label g="col" g-width="2" height="24"/>
							<checkBox g="col" g-width="10" field="upgradedClass2" text="Take an upgraded subclass card. Cross out the multiclass option." height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" height="24" field="extraProficiency2Part1"/>
							<checkBox g="col" g-width="10" field="extraProficiency2Part2" text="Increase your Proficiency by +1. You must spend two points in this option, to gain it's benefit" height="24" wordWrap="true"/>
							<label g="col" g-width="1" height="24"/>
							<checkBox g="col" g-width="1" height="48" field="multiClass2Part1"/>
							<checkBox g="col" g-width="10" field="multiClass2Part2" text="Multiclass: Choose an additional class. You must spend two points in this option, to gain it's benefit.\nCross out the upgraded subclass option." height="48" wordWrap="true"/>
						</rectangle>
						<label g="col" g-width="3"/>
						<label g="col" g-width="12" text="Update your level, adjust damage thresholds, and take an additional domain card of your level or lower every time you level up." horzTextAlign="center" height="50" wordWrap="true" fontColor="#BEB39B"/>
