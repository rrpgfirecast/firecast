		<rectangle g="col" g-width="6" g-width-lg="2" color="#17130F" strokeColor="#5E4930" strokeSize="1" g-min-height="112" padding="{left=8,right=8,top=8,bottom=8}" cornerType="round" xradius="6" yradius="6">
			<Attribute text="STRENGTH" field="strength" text1="Lift" text2="Smash" text3="Grapple"/>
