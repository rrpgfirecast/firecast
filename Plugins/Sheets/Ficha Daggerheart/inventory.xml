<?xml version="1.0" encoding="UTF-8"?>
<form name="Inventory" align="client">

    <scrollBox align="client" g-cnt-line-spacing="5">
    	<Weapon text="PRIMARY WEAPON" field="primWeap" prof="true"/>
    	<Weapon text="SECONDARY WEAPON" field="secWeap" prof="false"/>
    	<Weapon text="INVENTORY WEAPON" field="invWeap1" prof="false"/>
    	<Weapon text="INVENTORY WEAPON" field="invWeap2" prof="false"/>

		<rectangle g="col" g-width="6" g-width-lg="3" color="black" strokeColor="white" strokeSize="1" g-min-height="210" padding="{left=5,right=5,top=5,bottom=5}">
			<label g="col" g-width="12" text="ACTIVE ARMOR" horzTextAlign="center" vertTextAlign="center" height="25"/>

			<Title text="NAME" field="armorName"/>
			<Title text="THRESHOLDS" field="armorThresholds" widthL="3" widthR="3"/>
			<Title text="SCORE" field="armorScore" widthL="3" widthR="3"/>
			<label g="col" g-width="12" text="FEATURE" horzTextAlign="center" vertTextAlign="center" height="25"/>
			<textEditor g="col" g-width="12" g-vert-tile="true" g-min-height="75" field="armorFeature"/>
			
		</rectangle>
		<rectangle g="col" g-width="6" g-width-lg="3" color="black" strokeColor="white" strokeSize="1" g-min-height="210" padding="{left=5,right=5,top=5,bottom=5}">
			<label g="col" g-width="12" text="GOLD" horzTextAlign="center" vertTextAlign="center" height="25"/>

			<label g="col" g-width="2" text="Handfuls" horzTextAlign="center" vertTextAlign="center" height="50"/>
			<imageCheckBox uncheckedImage="images/coinsoff.png" checkedImage="images/coins.png" g="col" g-width="1" field="handfulCheck1"/>
			<imageCheckBox uncheckedImage="images/coinsoff.png" checkedImage="images/coins.png" g="col" g-width="1" field="handfulCheck2"/>
			<imageCheckBox uncheckedImage="images/coinsoff.png" checkedImage="images/coins.png" g="col" g-width="1" field="handfulCheck3"/>
			<imageCheckBox uncheckedImage="images/coinsoff.png" checkedImage="images/coins.png" g="col" g-width="1" field="handfulCheck4"/>
			<imageCheckBox uncheckedImage="images/coinsoff.png" checkedImage="images/coins.png" g="col" g-width="1" field="handfulCheck5"/>
			<imageCheckBox uncheckedImage="images/coinsoff.png" checkedImage="images/coins.png" g="col" g-width="1" field="handfulCheck6"/>
			<imageCheckBox uncheckedImage="images/coinsoff.png" checkedImage="images/coins.png" g="col" g-width="1" field="handfulCheck7"/>
			<imageCheckBox uncheckedImage="images/coinsoff.png" checkedImage="images/coins.png" g="col" g-width="1" field="handfulCheck8"/>
			<imageCheckBox uncheckedImage="images/coinsoff.png" checkedImage="images/coins.png" g="col" g-width="1" field="handfulCheck9"/>

			<label g="col" g-width="2" text="Bags" horzTextAlign="center" vertTextAlign="center" height="50"/>
			<imageCheckBox uncheckedImage="images/bagoff.png" checkedImage="images/bag.png" g="col" g-width="1" field="bagsCheck1"/>
			<imageCheckBox uncheckedImage="images/bagoff.png" checkedImage="images/bag.png" g="col" g-width="1" field="bagsCheck2"/>
			<imageCheckBox uncheckedImage="images/bagoff.png" checkedImage="images/bag.png" g="col" g-width="1" field="bagsCheck3"/>
			<imageCheckBox uncheckedImage="images/bagoff.png" checkedImage="images/bag.png" g="col" g-width="1" field="bagsCheck4"/>
			<imageCheckBox uncheckedImage="images/bagoff.png" checkedImage="images/bag.png" g="col" g-width="1" field="bagsCheck5"/>
			<imageCheckBox uncheckedImage="images/bagoff.png" checkedImage="images/bag.png" g="col" g-width="1" field="bagsCheck6"/>
			<imageCheckBox uncheckedImage="images/bagoff.png" checkedImage="images/bag.png" g="col" g-width="1" field="bagsCheck7"/>
			<imageCheckBox uncheckedImage="images/bagoff.png" checkedImage="images/bag.png" g="col" g-width="1" field="bagsCheck8"/>
			<imageCheckBox uncheckedImage="images/bagoff.png" checkedImage="images/bag.png" g="col" g-width="1" field="bagsCheck9"/>
			
			<label g="col" g-width="2" text="Chest" horzTextAlign="center" vertTextAlign="center" height="50"/>
			<imageCheckBox g="col" g-width="1" uncheckedImage="images/chestoff.png" checkedImage="images/chest.png" field="chestCheck1"/>
		</rectangle>

		<rectangle g="col" g-width="6" g-width-lg="3" color="black" strokeColor="white" strokeSize="1" g-min-height="210" padding="{left=5,right=5,top=5,bottom=5}">
			<label g="col" g-width="6" text="ITEM" horzTextAlign="center" vertTextAlign="center" height="25"/>
			<label g="col" g-width="6" text="ROLL" horzTextAlign="center" vertTextAlign="center" height="25"/>
			<InventorySlot field="slot1"/>
			<InventorySlot field="slot2"/>
			<InventorySlot field="slot3"/>
			<InventorySlot field="slot4"/>
			<InventorySlot field="slot5"/>
			<InventorySlot field="slot6"/>
			<InventorySlot field="slot7"/>
		</rectangle>

		<rectangle g="col" g-width="6" g-width-lg="3" color="black" strokeColor="white" strokeSize="1" g-min-height="210" padding="{left=5,right=5,top=5,bottom=5}">
			<label g="col" g-width="6" text="ITEM" horzTextAlign="center" vertTextAlign="center" height="25"/>
			<label g="col" g-width="6" text="ROLL" horzTextAlign="center" vertTextAlign="center" height="25"/>
			<InventorySlot field="slot8"/>
			<InventorySlot field="slot9"/>
			<InventorySlot field="slot10"/>
			<InventorySlot field="slot11"/>
			<InventorySlot field="slot12"/>
			<InventorySlot field="slot13"/>
			<InventorySlot field="slot14"/>
		</rectangle>

        <richEdit g="col" g-width="12" g-vert-tile="true" field="inventory" backgroundColor="#333333" defaultFontSize="12" defaultFontColor="white"/>
	</scrollBox>
</form>