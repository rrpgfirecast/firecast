<?xml version="1.0" encoding="UTF-8"?>
<form name="frmHabilidadeItem" height="40" margins="{top=2, bottom=2}">
    <script>
        <![CDATA[
        local function entrarEdicao()
            self.layoutView.visible = false;
            self.layoutEdit.visible = true;
            self.height = 240; -- Aumentei a altura pra caber a descrição na tela mais estreita
        end;

        local function salvarEdicao()
            self.layoutView.visible = true;
            self.layoutEdit.visible = false;
            self.height = 40; 
        end;

        local function enviarDescricao()
            local mesa = Firecast.getMesaDe(sheet);
            if not mesa then return end;
            
            local nome = tostring(sheet.nomeHabilidade or "Nova Habilidade");
            local origem = tostring(sheet.origemHabilidade or "Não informada");
            local desc = tostring(sheet.descricaoHabilidade or "Sem descrição.");
            
            local mensagem = "[§K3]Habilidade:[§K1] " .. nome .. "\n" ..
                             "[§K3]Origem/Tipo:[§K1] " .. origem .. "\n" ..
                             "[§K3]Descrição:[§K1] \n" .. desc;
                             
            mesa.chat:enviarMensagem(mensagem);
        end;
        ]]>
    </script>

    <layout name="layoutView" align="top" height="40" visible="true">
        <rectangle align="client" color="#f0f0f0" strokeColor="#cccccc" strokeSize="1" xradius="5" yradius="5"/>
        
        <label left="5" top="10" width="150" height="20" field="nomeHabilidade" fontColor="black" fontStyle="bold" text="Nova Hab..."/>
        <label left="160" top="10" width="125" height="20" field="origemHabilidade" fontColor="gray" fontStyle="italic"/>

        <button left="295" top="5" width="32" height="30" text="💬" hint="Enviar para o Chat" onClick="enviarDescricao()"/>
        <button left="330" top="5" width="32" height="30" text="✏️" hint="Editar" onClick="entrarEdicao()"/>
    </layout>

    <layout name="layoutEdit" align="top" height="240" visible="false">
        <rectangle align="client" color="#a32424" xradius="10" yradius="10"/> 
        
        <label left="5" top="10" width="50" height="20" text="Nome:" fontColor="#ffd700" fontStyle="bold"/>
        <edit left="55" top="10" width="120" height="20" field="nomeHabilidade"/>
        
        <label left="185" top="10" width="55" height="20" text="Origem:" fontColor="#ffd700" fontStyle="bold"/>
        <edit left="240" top="10" width="115" height="20" field="origemHabilidade" textPrompt="Ex: Raça"/>

        <label left="5" top="40" width="100" height="20" text="Descrição:" fontColor="#ffd700" fontStyle="bold"/>
        <textEditor left="5" top="60" width="350" height="130" field="descricaoHabilidade"/>

        <button left="190" top="200" width="75" height="30" text="Excluir" fontColor="red" onClick="NDB.deleteNode(sheet)"/>
        <button left="275" top="200" width="80" height="30" text="Salvar" onClick="salvarEdicao()"/>
    </layout>
</form>