<?xml version="1.0" encoding="UTF-8"?>
<form name="frmzipe1_svg" align="client" theme="light" margins="{top=1}">
    <style>#frmzipe1_svg path {color: black; strokeColor: black; mode: stretch;} &#xD;
#frmzipe1_svg label {fontColor: black; textTrimming: none; wordWrap: false; autoSize: true;}</style>
    <script>
        <![CDATA[
        local atualizarDefesa;
        local atualizarPericias;

        -- 1. ATRIBUTOS
        local function atualizarAtributos()
            if sheet == nil then return end
            local atributos = {
                {base="For", mod="ModFor"}, {base="Des", mod="ModDes"}, {base="Con", mod="ModCon"},
                {base="Int", mod="ModInt"}, {base="Sab", mod="ModSab"}, {base="Car", mod="ModCar"}
            }
            for i=1, #atributos do
                local at = atributos[i]
                local valorBase = tonumber(sheet[at.base]) or 10 
                local modificador = math.floor((valorBase - 10) / 2)
                sheet[at.mod] = modificador
            end
            
            atualizarDefesa()
        end

        -- 2. DEFESA (E a regra da Armadura Pesada)
        atualizarDefesa = function()
            if sheet == nil then return end
            
            local bonusArmadura = tonumber(sheet.B_Arm1) or 0
            local bonusEscudo = tonumber(sheet.B_Esc2) or 0
            local penArmadura = math.abs(tonumber(sheet.Pa) or 0)
            local penEscudo = math.abs(tonumber(sheet.Pe) or 0)
            
            sheet.B_Arm = bonusArmadura
            sheet.B_Esc = bonusEscudo
            sheet.PArmTotal = penArmadura + penEscudo
            
            local atributoDefesa = sheet.SeleAtribDefe or "Des"
            local modDefesa = 0
            
            if atributoDefesa == "For" then modDefesa = tonumber(sheet.ModFor) or 0
            elseif atributoDefesa == "Des" then modDefesa = tonumber(sheet.ModDes) or 0
            elseif atributoDefesa == "Con" then modDefesa = tonumber(sheet.ModCon) or 0
            elseif atributoDefesa == "Int" then modDefesa = tonumber(sheet.ModInt) or 0
            elseif atributoDefesa == "Sab" then modDefesa = tonumber(sheet.ModSab) or 0
            elseif atributoDefesa == "Car" then modDefesa = tonumber(sheet.ModCar) or 0
            end
            
            if not sheet.arm_pesa then
                modDefesa = 0
            end
            
            sheet.ModAtribDefe = modDefesa
            
            local base = 10
            local outrosCA = tonumber(sheet.Outros_B_CA) or 0
            
            sheet.CA = base + modDefesa + bonusArmadura + bonusEscudo + outrosCA
            
            atualizarPericias()
        end

        -- 3. PERÍCIAS (Com a penalidade puxada da Defesa)
        atualizarPericias = function()
            if sheet == nil then return end

            local nivel = tonumber(sheet.Lv) or 1
            local metadeNivel = math.floor(nivel / 2)
            local bonusTreino = 2
            if nivel >= 7 and nivel <= 14 then bonusTreino = 4
            elseif nivel >= 15 then bonusTreino = 6 end

            local pericias = {
                {id="Acro", atrib="ModDes"}, {id="Ades", atrib="ModCar"}, {id="Atle", atrib="ModFor"},
                {id="Atua", atrib="ModCar"}, {id="Cava", atrib="ModDes"}, {id="Conh", atrib="ModInt"},
                {id="Cura", atrib="ModSab"}, {id="Dipl", atrib="ModCar"}, {id="Enga", atrib="ModCar"},
                {id="Fort", atrib="ModCon"}, {id="Furt", atrib="ModDes"}, {id="Guer", atrib="ModInt"},
                {id="Inic", atrib="ModDes"}, {id="Inti", atrib="ModCar"}, {id="Intu", atrib="ModSab"},
                {id="Inve", atrib="ModInt"}, {id="Joga", atrib="ModCar"}, {id="Ladi", atrib="ModDes"},
                {id="Luta", atrib="ModFor"}, {id="Mist", atrib="ModInt"}, {id="Nobr", atrib="ModCar"},
                {id="Ofi1", atrib="ModInt"}, {id="Ofi2", atrib="ModInt"}, {id="Perc", atrib="ModSab"},
                {id="Pilo", atrib="ModDes"}, {id="Pont", atrib="ModDes"}, {id="Refl", atrib="ModDes"},
                {id="Reli", atrib="ModSab"}, {id="Sobr", atrib="ModSab"}, {id="Vont", atrib="ModSab"}
            }

            local penArmadura = tonumber(sheet.PArmTotal) or 0

            for i=1, #pericias do
                local p = pericias[i]
                sheet["nv" .. p.id] = metadeNivel
                local modAtrib = tonumber(sheet[p.atrib]) or 0
                sheet["atrib" .. p.id] = string.sub(p.atrib, 4)
                
                local treino = 0
                if sheet["checkTrei" .. p.id] then treino = bonusTreino end
                sheet["trei" .. p.id] = treino
                
                local outros = tonumber(sheet["outr" .. p.id]) or 0
                
                local penalidadeFinal = 0
                if p.id == "Acro" or p.id == "Furt" or p.id == "Ladi" or p.id == "Pilo" then
                    penalidadeFinal = -penArmadura 
                end
                
                sheet["total" .. p.id] = metadeNivel + modAtrib + treino + outros + penalidadeFinal
            end
        end
        -- 4. Rolar Atributo
        local function rolarAtributo(atributo, nomeEmoji, isResistencia)
            local mesa = Firecast.getMesaDe(sheet);
            if not mesa then return end;

            -- Pega o modificador (Ex: sheet.ModFor)
            local mod = tonumber(sheet["Mod" .. atributo]) or 0
            
            -- Pega a metade do nível para as resistências
            local nivel = tonumber(sheet.Lv) or 1
            local metadeNivel = math.floor(nivel / 2)

            local bonusTotal = mod
            local tipoRolagem = "Teste de " .. atributo

            -- Se for resistência, soma a metade do nível
            if isResistencia then
                bonusTotal = mod + metadeNivel
                tipoRolagem = "Resistência de " .. atributo
            end

            -- Rola no chat!
            mesa.chat:rolarDados("1d20 + " .. bonusTotal, nomeEmoji .. " " .. tipoRolagem);
        end
        -- 5. Form do Atributo
        local function pedirRolagemAtributo(atributo, nomeEmoji)
            local opcoes = {
                "Teste de Habilidade",
                "Teste de Resistência"
            }
            
            Dialogs.choose("O que você deseja rolar para " .. atributo .. "?", opcoes,
                function(selecionado, indice, texto)
                    -- O "selecionado" verifica se o jogador realmente clicou em algo ou se só fechou a janela
                    if selecionado then
                        if indice == 1 then
                            -- Selecionou a primeira opção: Teste normal
                            rolarAtributo(atributo, nomeEmoji, false)
                        elseif indice == 2 then
                            -- Selecionou a segunda opção: Resistência
                            rolarAtributo(atributo, nomeEmoji, true)
                        end
                    end
                end
            )
        end
        -- 6. Form da Perícia
        local function rolarPericia(nomePericia, valorTotal)
            local mesa = Firecast.getMesaDe(sheet);
            if not mesa then return end;

            -- Garante que o valor é um número (se estiver vazio, rola +0)
            local bonus = tonumber(valorTotal) or 0
            
            -- Rola direto no chat!
            mesa.chat:rolarDados("1d20 + " .. bonus, "🎲 Teste de " .. nomePericia);
        end
        ]]>
    </script>
