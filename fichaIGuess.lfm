<script><![CDATA[

--------------------------------------------------
-- UTILS
--------------------------------------------------

local slots = {"Capacete", "Peitoral", "Escudo", "Bota", "Calca", "Arma"}

local function n(v)
    if v == nil then return 0 end
    local s = tostring(v):gsub(",", ".")
    return tonumber(s) or 0
end

local function CWNA_mostrarAvisoPerfil(controle, texto)
    local ctrl = controle
    local aviso = nil
    local label = nil

    while ctrl ~= nil and aviso == nil do
        if ctrl.findControlByName ~= nil then
            aviso = ctrl:findControlByName("avisoPerfilFicha")
            label = ctrl:findControlByName("lblAvisoPerfilFicha")
        end

        ctrl = ctrl.parent
    end

    if aviso == nil then
        showMessage(texto or "")
        return
    end

    if label ~= nil then
        label.text = texto or ""
    end

    aviso.visible = true

    setTimeout(function()
        if aviso ~= nil then
            aviso.visible = false
        end
    end, 2600)
end

local function CWNA_gastarPPAtaque(sheet, campoCustoPP, nomeAtaque, controleOrigem)
    local custo = math.max(0, n(sheet[campoCustoPP]))

    if custo <= 0 then
        return true
    end

    local mesa = Firecast.getMesaDe(sheet)

    if mesa == nil then
        return false
    end

    local jogador = mesa.me
    local chat = mesa.activeChat or mesa.chat

    if jogador == nil or chat == nil then
        CWNA_mostrarAvisoPerfil(controleOrigem, "Jogador ou chat nao disponivel.")
        return false
    end

    local ppAtual = nil
    pcall(function()
        ppAtual = jogador:getBarValue(2)
    end)

    if ppAtual == nil then
        CWNA_mostrarAvisoPerfil(controleOrigem, "Barra de PP nao disponivel.")
        return false
    end

    if ppAtual < custo then
        CWNA_mostrarAvisoPerfil(controleOrigem, "PP insuficiente para usar " .. nomeAtaque .. ".")
        return false
    end

    pcall(function()
        chat:enviarMensagem("/PP -" .. custo)
    end)

    return true
end

local slotsPorTipoInventario = {
    capacete = "Capacete",
    peitoral = "Peitoral",
    escudo = "Escudo",
    bota = "Bota",
    calca = "Calca",
    ["calÃƒÂ§a"] = "Calca",
    arma = "Arma"
}

local tiposPotionInventario = {
    ["potion hp"] = "HP",
    ["potion pp"] = "PP"
}

local imagensPadraoInventario = {
    Capacete = "/Frames/Capacete.png",
    Peitoral = "/Frames/Peitoral.png",
    Escudo = "/Frames/Escudo.png",
    Bota = "/Frames/Bota.png",
    Calca = "/Frames/Calca.png",
    Arma = "/Frames/Arma.png"
}

local partesBonecoInventario = {
    Capacete = "capacete",
    Peitoral = "peitoral",
    Bota = "bota",
    Calca = "calca"
}

local catalogoVisualEquipamentosInventario = {
    ["rank e"] = {rank = "e"},
    ["rank d"] = {rank = "d"},
    ["rank c"] = {rank = "c"},
    ["rank b"] = {rank = "b"},
    ["rank a"] = {rank = "a"},
    ["rank s"] = {rank = "s"},
    ["rank ss"] = {rank = "s"},

    ["capacete de pano velho"] = {rank = "e", partes = {Capacete = "capacete_e"}},
    ["camisa esfarrapada"] = {rank = "e", partes = {Peitoral = "peitoral_e"}},
    ["calÃƒÂ§as rasgadas"] = {rank = "e", partes = {Calca = "calca_e"}},
    ["sandÃƒÂ¡lias de couro gastas"] = {rank = "e", partes = {Bota = "bota_e"}},

    ["chapÃƒÂ©u de viagem"] = {rank = "d", partes = {Capacete = "capacete_d"}},
    ["tÃƒÂºnica reforÃƒÂ§ada"] = {rank = "d", partes = {Peitoral = "peitoral_d"}},
    ["calÃƒÂ§as de lona"] = {rank = "d", partes = {Calca = "calca_d"}},
    ["botas de algodÃƒÂ£o grosso"] = {rank = "d", partes = {Bota = "bota_d"}},

    ["elmo de couro enrijecido"] = {rank = "c", partes = {Capacete = "capacete_c"}},
    ["peitoral de couro curtido"] = {rank = "c", partes = {Peitoral = "peitoral_c"}},
    ["perneiras de couro com fivelas"] = {rank = "c", partes = {Calca = "calca_c"}},
    ["botas altas de couro"] = {rank = "c", partes = {Bota = "bota_c"}},

    ["elmo de cobre com narigueira"] = {rank = "b", partes = {Capacete = "capacete_b"}},
    ["peitoral de escamas de cobre"] = {rank = "b", partes = {Peitoral = "peitoral_b"}},
    ["grevas de cobre leves"] = {rank = "b", partes = {Calca = "calca_b"}},
    ["botas de cobre reforÃƒÂ§adas"] = {rank = "b", partes = {Bota = "bota_b"}}
}

local atributosInventario = {
    {campoItem = "hp", prefixoSlot = "Hp"},
    {campoItem = "pp", prefixoSlot = "Pp"},
    {campoItem = "ca", prefixoSlot = "Ca"},
    {campoItem = "rd", prefixoSlot = "Rd"},
    {campoItem = "dano", prefixoSlot = "Dano"},
    {campoItem = "cura", prefixoSlot = "Cura"}
}

local function limparTextoInventario(valor)
    return string.lower(tostring(valor or "")):gsub("^%s*(.-)%s*$", "%1")
end

local function slotDoItemInventario(item)
    return slotsPorTipoInventario[limparTextoInventario(item and item.tipoItem)]
end

local function tipoPotionDoItemInventario(item)
    return tiposPotionInventario[limparTextoInventario(item and item.tipoItem)]
end

local function rotuloTipoItemInventario(item)
    local tipo = limparTextoInventario(item and item.tipoItem)

    if tipo == "" then
        return "outros"
    end

    return tipo
end

local function chaveNomeItemInventario(item)
    local nome = limparTextoInventario(item and item.nomeItem)
    nome = nome:gsub("[_%-%:]+", " ")
    nome = nome:gsub("%s+", " ")

    return nome
end

local function visualDoItemInventario(item)
    local nome = chaveNomeItemInventario(item)
    local entrada = catalogoVisualEquipamentosInventario[nome]

    if entrada ~= nil then
        return entrada
    end

    local rankNoNome = nome:match("rank%s+(%a+)")

    if rankNoNome ~= nil then
        return catalogoVisualEquipamentosInventario["rank " .. rankNoNome]
    end

    return nil
end

local function imagemBaseBonecoInventario(slot)
    local parte = partesBonecoInventario[slot]

    if parte == nil then
        return nil
    end

    return "/Frames/equipes/" .. parte .. "_base.png"
end

local function imagemEquipamentoBonecoInventario(item, slot)
    local parte = partesBonecoInventario[slot]
    local entrada = visualDoItemInventario(item)

    if parte == nil or entrada == nil then
        return imagemBaseBonecoInventario(slot)
    end

    local nomeArquivo = nil

    if entrada.partes ~= nil then
        nomeArquivo = entrada.partes[slot]
    end

    if nomeArquivo == nil and entrada.rank ~= nil then
        nomeArquivo = parte .. "_" .. entrada.rank
    end

    if nomeArquivo == nil or entrada.rank == nil then
        return imagemBaseBonecoInventario(slot)
    end

    return "/Frames/equipes/" .. entrada.rank .. "/" .. nomeArquivo .. ".png"
end

local function fixNumeroInventario(v)
    if v == nil then return 0 end

    local s = tostring(v)
    s = s:gsub("%s+", "")
    s = s:gsub(",", ".")

    return tonumber(s) or 0
end

local function uidInventarioItem(item)
    if item == nil then
        return nil
    end

    if item.uidInventario == nil or item.uidInventario == "" then
        item.uidInventario = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
    end

    return item.uidInventario
end

local function procurarItemInventarioPorUid(ficha, uid)
    if ficha == nil or uid == nil then
        return nil
    end

    local lista = ficha.magias2

    if lista == nil then
        return nil
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if item.uidInventario == uid then
            return item
        end
    end

    return nil
end

local function ehSlotVazioInventario(item)
    return item ~= nil and tostring(item.slotVazio or "") == "true"
end

local function contarItensReaisInventario(lista)
    local total = 0

    if lista == nil then
        return total
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if not ehSlotVazioInventario(item) then
            total = total + 1
        end
    end

    return total
end

local function contarNosInventario(lista)
    local total = 0

    if lista == nil then
        return total
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        total = total + 1
    end

    return total
end

local function prepararSlotVazioInventario(slot, ordem)
    if slot == nil then
        return
    end

    slot.slotVazio = "true"
    slot.ordemInventario = ordem
    slot.uidInventario = "slot_" .. tostring(ordem)
    slot.nomeItem = ""
    slot.tipoItem = ""
    slot.RankItem = ""
    slot.imagemestilo2 = ""
    slot.equipadoEm = ""
    slot.quantidade = ""
end

function CWNA_inicializarSlotsInventario(ficha, listaControle)
    if ficha == nil then
        return
    end

    local lista = ficha.magias2

    if lista == nil and listaControle ~= nil then
        lista = listaControle.node
    end

    if lista == nil then
        lista = NDB.createChildNode(ficha, "magias2")
    end

    if lista == nil then
        return
    end

    local totalNos = contarNosInventario(lista)

    if totalNos >= 60 then
        ficha.SlotsInventarioCriados = "true"
        return
    end

    if ficha.SlotsInventarioCriados == "true" then
        return
    end

    local usados = {}

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        local ordem = tonumber(item.ordemInventario)

        if ordem ~= nil and ordem >= 1 and ordem <= 60 then
            usados[ordem] = true
        end
    end

    for i = 1, 60 do
        if totalNos >= 60 then
            break
        end

        if usados[i] ~= true then
            local slot = nil

            if listaControle ~= nil and listaControle.append ~= nil then
                slot = listaControle:append()
            end

            if slot == nil then
                slot = NDB.createChildNode(lista, "item")
            end

            if slot ~= nil then
                prepararSlotVazioInventario(slot, i)
                usados[i] = true
                totalNos = totalNos + 1
            end
        end
    end

    ficha.SlotsInventarioCriados = "true"
end

function CWNA_garantirSlotsInventario(ficha, listaControle)
    if ficha == nil and listaControle == nil then
        return
    end

    local lista = ficha and ficha.magias2 or nil

    if lista == nil and listaControle ~= nil then
        lista = listaControle.node
    end

    if lista == nil then
        return
    end

    local totalNos = 0
    local slotsVazios = {}

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        totalNos = totalNos + 1

        if ehSlotVazioInventario(item) then
            table.insert(slotsVazios, item)
        end
    end

    if totalNos > 60 then
        table.sort(slotsVazios, function(a, b)
            local ordemA = tonumber(a.ordemInventario) or 999999
            local ordemB = tonumber(b.ordemInventario) or 999999

            if ordemA ~= ordemB then
                return ordemA > ordemB
            end

            return tostring(a.uidInventario or "") > tostring(b.uidInventario or "")
        end)

        for _, slot in ipairs(slotsVazios) do
            if totalNos <= 60 then
                break
            end

            NDB.deleteNode(slot)
            totalNos = totalNos - 1
        end
    end

    local usados = {}
    local livres = {}

    for i = 1, 60 do
        livres[i] = true
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if item.uidInventario == nil or item.uidInventario == "" then
            item.uidInventario = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
        end

        local ordem = tonumber(item.ordemInventario)

        if ordem ~= nil and ordem >= 1 and ordem <= 60 and usados[ordem] == nil then
            usados[ordem] = item
            livres[ordem] = nil
        end
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        local ordem = tonumber(item.ordemInventario)

        if ordem == nil or ordem < 1 or ordem > 60 or usados[ordem] ~= item then
            for i = 1, 60 do
                if livres[i] then
                    item.ordemInventario = i
                    usados[i] = item
                    livres[i] = nil
                    break
                end
            end
        end
    end

    for i = 1, 60 do
        if usados[i] == nil then
            if totalNos >= 60 then
                return
            end

            local slot = nil

            if listaControle ~= nil and listaControle.append ~= nil then
                slot = listaControle:append()
            end

            if slot == nil then
                return
            end

            slot.slotVazio = "true"
            slot.ordemInventario = i
            slot.uidInventario = "slot_" .. tostring(i)
            slot.nomeItem = ""
            slot.tipoItem = ""
            slot.RankItem = ""
            slot.imagemestilo2 = ""
            slot.equipadoEm = ""
            slot.quantidade = ""
            usados[i] = slot
            totalNos = totalNos + 1
        end
    end
end

function CWNA_repopularSlotsInventario(ficha, listaControle)
    if ficha == nil and listaControle == nil then
        return
    end

    local lista = ficha and ficha.magias2 or nil

    if lista == nil and listaControle ~= nil then
        lista = listaControle.node
    end

    if lista == nil then
        return
    end

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if ehSlotVazioInventario(item) then
            NDB.deleteNode(item)
        end
    end

    CWNA_garantirSlotsInventario(ficha, listaControle)

    if listaControle ~= nil and listaControle.sort ~= nil then
        listaControle:sort()
    end
end

local function procurarPrimeiroSlotVazioInventario(lista)
    if lista == nil then
        return nil
    end

    local melhor = nil
    local melhorOrdem = 999999

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if ehSlotVazioInventario(item) then
            local ordem = tonumber(item.ordemInventario) or 999999

            if ordem < melhorOrdem then
                melhor = item
                melhorOrdem = ordem
            end
        end
    end

    return melhor
end

local function limparSlotInventario(ficha, slot)
    if ficha == nil or slot == nil then
        return
    end

    ficha["Imagem" .. slot] = imagensPadraoInventario[slot] or ""
    ficha["ItemEquipado" .. slot] = ""
    ficha["ItemEquipadoHandle" .. slot] = nil
    ficha["ItemEquipadoUid" .. slot] = nil

    if partesBonecoInventario[slot] ~= nil then
        ficha["Boneco" .. slot] = imagemBaseBonecoInventario(slot)
    end

    for _, atributo in ipairs(atributosInventario) do
        ficha[atributo.prefixoSlot .. slot] = 0
    end
end

local function desmarcarItemAnteriorInventario(itemAtual, slot)
    local lista = NDB.getParent(itemAtual)

    if lista == nil then
        return
    end

    local handleAtual = NDB.getNodeHandle(itemAtual)

    for _, item in ipairs(NDB.getChildNodes(lista)) do
        if NDB.getNodeHandle(item) ~= handleAtual and item.equipadoEm == slot then
            item.equipadoEm = ""
        end
    end
end

function CWNA_desequiparSlotInventario(ficha, slot)
    if ficha == nil or slot == nil or slot == "" then
        return
    end

    local handle = ficha["ItemEquipadoHandle" .. slot]

    if handle ~= nil then
        local ok, item = pcall(function() return NDB.openNode(handle) end)

        if ok and item ~= nil then
            item.equipadoEm = ""
        end
    end

    limparSlotInventario(ficha, slot)
    recalcularDefesa(ficha)
end

function CWNA_equiparItemInventario(ficha, item, slotAlvo)
    if ficha == nil or item == nil then
        return
    end

    local slotItem = slotDoItemInventario(item)

    if slotItem == nil then
        showMessage("Este item nao pode ser equipado.")
        return
    end

    if slotAlvo ~= nil and slotItem ~= slotAlvo then
        return
    end

    if item.equipadoEm ~= nil and item.equipadoEm ~= "" and item.equipadoEm ~= slotItem then
        limparSlotInventario(ficha, item.equipadoEm)
    end

    desmarcarItemAnteriorInventario(item, slotItem)
    limparSlotInventario(ficha, slotItem)

    ficha["Imagem" .. slotItem] = item.imagemestilo2 or imagensPadraoInventario[slotItem]
    ficha["ItemEquipado" .. slotItem] = item.nomeItem or ""
    ficha["ItemEquipadoHandle" .. slotItem] = NDB.getNodeHandle(item)
    ficha["ItemEquipadoUid" .. slotItem] = uidInventarioItem(item)

    if partesBonecoInventario[slotItem] ~= nil then
        ficha["Boneco" .. slotItem] = imagemEquipamentoBonecoInventario(item, slotItem)
    end

    for _, atributo in ipairs(atributosInventario) do
        ficha[atributo.prefixoSlot .. slotItem] = fixNumeroInventario(item[atributo.campoItem])
    end

    item.equipadoEm = slotItem
    recalcularDefesa(ficha)
end

function CWNA_dropItemInventario(ficha, slotAlvo, uid)
    if uid == nil then
        return
    end

    local item = procurarItemInventarioPorUid(ficha, uid)

    if item ~= nil then
        CWNA_equiparItemInventario(ficha, item, slotAlvo)
    end
end

function CWNA_usarPotionArrastadaNoBoneco(ficha, uid, controleOrigem)
    if ficha == nil or uid == nil then
        return
    end

    local item = procurarItemInventarioPorUid(ficha, uid)

    if item == nil then
        return
    end

    local tipoPotion = tipoPotionDoItemInventario(item)

    if tipoPotion == nil then
        CWNA_mostrarAvisoInventario(controleOrigem, "Solte aqui apenas potion HP ou PP")
        return
    end

    local mesa = rrpg.getMesaDe(ficha)
    local jogador = mesa and mesa.me or nil
    local chat = mesa and mesa.chat or nil

    if jogador == nil or chat == nil then
        showMessage("Jogador ou chat nao disponivel.")
        return
    end

    local indexBarra = nil
    local valorBase = 0
    local prefixo = nil

    if tipoPotion == "HP" then
        indexBarra = 1
        valorBase = fixNumeroInventario(item.cura)
        prefixo = "HP"
    elseif tipoPotion == "PP" then
        indexBarra = 2
        valorBase = fixNumeroInventario(item.pp)
        prefixo = "PP"
    else
        return
    end

    local atual, maximo = jogador:getBarValue(indexBarra)

    if atual == nil or maximo == nil then
        showMessage("Barra nao disponivel ou invisivel.")
        return
    end

    if atual >= maximo then
        if prefixo == "HP" then
            showMessage("SEU HP ESTA CHEIO")
        else
            showMessage("SEUS PP ESTAO COMPLETOS")
        end

        return
    end

    local curaReal = math.min(valorBase, maximo - atual)

    if curaReal <= 0 then
        return
    end

    local quantidade = tonumber(item.quantidade) or 0

    if quantidade <= 0 then
        showMessage("Este item nao tem quantidade disponivel.")
        return
    end

    item.quantidade = quantidade - 1

    local nomeJogador = "Jogador"
    pcall(function()
        nomeJogador = tostring(jogador.nick or jogador.nickname or jogador.nome or jogador.name or jogador.login or "Jogador")
    end)

    local nomePotion = tostring(item.nomeItem or item.tipoItem or ("Potion " .. prefixo))
    if nomePotion == nil or nomePotion == "" then
        nomePotion = "Potion " .. prefixo
    end

    pcall(function()
        chat:enviarMensagem("/" .. prefixo .. " +" .. curaReal)
    end)

    pcall(function()
        chat:enviarMensagem("O Jogador " .. nomeJogador .. " utilizou 1x " .. nomePotion .. " e restaurou " .. curaReal .. " de " .. prefixo)
    end)
end

function CWNA_registrarDropPotionBoneco(drop, drag, ficha, controleOrigem)
    if drop == nil or drag == nil or ficha == nil then
        return
    end

    local uid = nil
    local ok = pcall(function()
        uid = drag:getData("cwnaInventarioUid")
    end)

    if not ok or uid == nil then
        return
    end

    local item = procurarItemInventarioPorUid(ficha, uid)

    if item == nil or tipoPotionDoItemInventario(item) == nil then
        return
    end

    drop:addAction("cwnaInventarioUid", function(uidDrop)
        CWNA_usarPotionArrastadaNoBoneco(ficha, uidDrop, controleOrigem)
    end)
end

function CWNA_mostrarAvisoInventario(controle, texto)
    local ctrl = controle
    local aviso = nil
    local label = nil

    while ctrl ~= nil and aviso == nil do
        if ctrl.findControlByName ~= nil then
            aviso = ctrl:findControlByName("avisoSlotErradoInventario")
            label = ctrl:findControlByName("lblAvisoSlotErradoInventario")
        end

        ctrl = ctrl.parent
    end

    if aviso == nil then
        return
    end

    if label ~= nil then
        label.text = texto or "Slot errado, confira o tipo do item"
    end

    aviso.visible = true

    setTimeout(function()
        if aviso ~= nil then
            aviso.visible = false
        end
    end, 2600)
end

function CWNA_registrarDropSlotInventario(drop, drag, ficha, slotAlvo, controleOrigem)
    if drop == nil or drag == nil or ficha == nil or slotAlvo == nil then
        return
    end

    local uid = nil
    local ok = pcall(function()
        uid = drag:getData("cwnaInventarioUid")
    end)

    if (not ok or uid == nil) then
        local info = nil
        ok = pcall(function()
            info = drag:getData("cwnaSlotEquipado")
        end)

        if ok and info ~= nil then
            uid = info.uid
        end
    end

    if not ok or uid == nil then
        return
    end

    local item = procurarItemInventarioPorUid(ficha, uid)

    if item == nil then
        return
    end

    if slotDoItemInventario(item) ~= slotAlvo then
        local mensagem = "Você não pode equipar " .. rotuloTipoItemInventario(item) .. " no slote de " .. slotAlvo

        drop:addAction("cwnaInventarioUid", function()
            CWNA_mostrarAvisoInventario(controleOrigem, mensagem)
        end)

        drop:addAction("cwnaSlotEquipado", function()
            CWNA_mostrarAvisoInventario(controleOrigem, mensagem)
        end)

        return
    end

    drop:addAction("cwnaInventarioUid", function(uidDrop)
        CWNA_dropItemInventario(ficha, slotAlvo, uidDrop)
    end)
end

function CWNA_dragSlotInventario(ficha, slot, drag)
    if ficha == nil or slot == nil or drag == nil then
        return
    end

    local uid = ficha["ItemEquipadoUid" .. slot]
    local handle = ficha["ItemEquipadoHandle" .. slot]

    if uid ~= nil then
        drag:addData("cwnaSlotEquipado", {slot = slot, uid = uid})
        drag:addData("text", ficha["ItemEquipado" .. slot] or "Item equipado")
    elseif handle ~= nil then
        drag:addData("cwnaSlotEquipado", {slot = slot, handle = handle})
        drag:addData("text", ficha["ItemEquipado" .. slot] or "Item equipado")
    end
end


--------------------------------------------------
-- RANK / CLASSE
--------------------------------------------------

local RankDB = {
    ["E"]  = {hp = 6,  pp = 2,  atributos = 7},
    ["D"]  = {hp = 10, pp = 4,  atributos = 9},
    ["C"]  = {hp = 14, pp = 6,  atributos = 11},
    ["B"]  = {hp = 20, pp = 8,  atributos = 13},
    ["A"]  = {hp = 24, pp = 10, atributos = 15},
    ["S"]  = {hp = 30, pp = 15, atributos = 17},
    ["SS"] = {hp = 38, pp = 18, atributos = 25}
}

local ClassHP = {
    ["COLOSSO"] = 8,
    ["MONGE"] = 5,
    ["ESTANDARTE"] = 7,
    ["CAMPEÃƒO"] = 6,
    ["DANÃ‡ARINO"] = 5,
    ["SENTINELA"] = 4,
    ["LAMINAS"] = 4,
    ["ESTRATEGISTA"] = 3,
    ["FORJADO"] = 6,
    ["ASSASSINO"] = 4,
    ["ELEMENTARISTA"] = 4,
    ["ORACULO"] = 3
}


--------------------------------------------------
-- XP / LEVEL
--------------------------------------------------

local function xpNecessarioParaNivel(nivel)
    local xp = 0
    for i = 2, nivel do
        xp = xp + (i * 5)
    end
    return xp
end

local function calcularNivel(xp)
    local nivel = 1
    for i = 2, 20 do
        if xp >= xpNecessarioParaNivel(i) then
            nivel = i
        else
            break
        end
    end
    return nivel
end

function atualizarNivel(sheet)
    if not sheet then return end

    sheet.NivelPersonagem = calcularNivel(n(sheet.XP))

    atualizarBarraXP(sheet)

    recalcularDefesa(sheet)
end

function atualizarBarraXP(sheet)
    if not sheet then return end

    local xpAtual = n(sheet.XP)
    local nivel = calcularNivel(xpAtual)

    local xpProximoNivel = xpNecessarioParaNivel(nivel + 1)

    -- Se estiver no nÃ­vel mÃ¡ximo
    if nivel >= 20 then
        xpProximoNivel = xpAtual
    end

    sheet.XPBarra = xpAtual
    sheet.XPBarraMax = xpProximoNivel
    sheet.XPTexto = xpAtual .. "/" .. xpProximoNivel
end

function onClasseOuRankChange(sheet)
    recalcularDefesa(sheet)
end


--------------------------------------------------
-- PERÃCIAS
--------------------------------------------------

PERICIAS_FORCA = {
    "BracoDeFerro","Correr","DanoCurtoAlcance","DanoLongoAlcance",
    "EmpurrarObstaculo","Escalar"
}

PERICIAS_DES = {
    "AcertoDistancia","AcertoCurtoAlcance","DesarmarArmadilha",
    "Esquivar","Furtividade","Iniciativa","MontariaDirecao","Roubo"
}

PERICIAS_INT = {
    "AcertoMagico","IdentificarCriatura","Investigacao","LerManuscrito",
    "Medicina","PrepararEstrategia","Profissao","ResistenciaMental"
}

PERICIAS_SAB = {
    "DetectarMagia","DanoMagico","Historia","Natureza",
    "PerceberMentira","Percepcao","Religiao","Sobrevivencia"
}

PERICIAS_CAR = {
    "Atuar","Discurso","Intimidar","Mentir","Seducao"
}

PERICIAS_CON = {
    "ResistenciaCansaco","ResistirVeneno","SegurarFolego","SuporteFrioCalor"
}


--------------------------------------------------
-- FUNÃ‡Ã•ES BASE
--------------------------------------------------

local function custoPericia(nivel)
    return (nivel * (nivel + 1)) / 2
end

local function gastoTotal(sheet, lista)
    local total = 0
    for _, nome in ipairs(lista) do
        total = total + custoPericia(n(sheet[nome .. "1"]))
    end
    return total
end

local function modDisponivel(sheet, baseMod, lista)
    return n(baseMod) - gastoTotal(sheet, lista)
end

function onHBChange()
    recalcularDefesa(self.sheet)
end
--------------------------------------------------
-- DEFESA PRINCIPAL
--------------------------------------------------

function recalcularDefesa(sheet)
    if not sheet then return end

    local ca, rd, hp, pp, dano, cura = 0, 0, 0, 0, 0, 0

    for _, slot in ipairs(slots) do
        ca = ca + n(sheet["Ca" .. slot])
        rd = rd + n(sheet["Rd" .. slot])
        hp = hp + n(sheet["Hp" .. slot])
        pp = pp + n(sheet["Pp" .. slot])
        dano = dano + n(sheet["Dano" .. slot])
        cura = cura + n(sheet["Cura" .. slot])
    end

    local function calcularProf(level)
    if level >= 17 then return 6 end
    if level >= 13 then return 5 end
    if level >= 9 then return 4 end
    if level >= 5 then return 3 end
    return 2
    end

    local level = n(sheet.NivelPersonagem)
    local prof = calcularProf(level)
    sheet.Prof = prof

    local bonusAcertoCurto = 0
    local bonusAcertoLongo = 0
    local bonusAcertoMagico = 0
    bonusResistenciaMental = 0

    local function temHB(hb)
        return sheet.HB1 == hb
            or sheet.HB2 == hb
            or sheet.HB3 == hb
            or sheet.HB4 == hb
    end

    if temHB("GOLPE_PESADO") then
        bonusAcertoCurto = bonusAcertoCurto - 1
        bonusAcertoLongo = bonusAcertoLongo - 1
        bonusAcertoMagico = bonusAcertoMagico - 1
    end
    if temHB("PELE_MISTICA") then
    bonusResistenciaMental = bonusResistenciaMental + 1
    end

    --------------------------------------------------
    -- ATRIBUTOS
    --------------------------------------------------

    sheet.ForcaTotal = n(sheet.ForcaValor) + n(sheet.ForcaAdd)
    sheet.ForcaMod = sheet.ForcaTotal * 2

    sheet.DestrezaTotal = n(sheet.DestrezaValor) + n(sheet.DestrezaAdd)
    sheet.DestrezaMod = sheet.DestrezaTotal * 2

    sheet.ConstituicaoTotal = n(sheet.ConstituicaoValor) + n(sheet.ConstituicaoAdd)
    sheet.ConstituicaoMod = sheet.ConstituicaoTotal * 2

    sheet.InteligenciaTotal = n(sheet.InteligenciaValor) + n(sheet.InteligenciaAdd)
    sheet.InteligenciaMod = sheet.InteligenciaTotal * 2

    sheet.SabedoriaTotal = n(sheet.SabedoriaValor) + n(sheet.SabedoriaAdd)
    sheet.SabedoriaMod = sheet.SabedoriaTotal * 2

    sheet.CarismaTotal = n(sheet.CarismaValor) + n(sheet.CarismaAdd)
    sheet.CarismaMod = sheet.CarismaTotal * 2

    --------------------------------------------------
    -- MODS USÃVEIS
    --------------------------------------------------

    sheet.ForcaModUsavel = modDisponivel(sheet, sheet.ForcaMod, PERICIAS_FORCA)
    sheet.DestrezaModUsavel = modDisponivel(sheet, sheet.DestrezaMod, PERICIAS_DES)
    sheet.InteligenciaModUsavel = modDisponivel(sheet, sheet.InteligenciaMod, PERICIAS_INT)
    sheet.SabedoriaModUsavel = modDisponivel(sheet, sheet.SabedoriaMod, PERICIAS_SAB)
    sheet.CarismaModUsavel = modDisponivel(sheet, sheet.CarismaMod, PERICIAS_CAR)
    sheet.ConstituicaoModUsavel = modDisponivel(sheet, sheet.ConstituicaoMod, PERICIAS_CON)

    --------------------------------------------------
    -- PERÃCIAS
    --------------------------------------------------

    local pericias = {
    "BracoDeFerro","Correr","DanoCurtoAlcance","DanoLongoAlcance",
    "EmpurrarObstaculo","Escalar","AcertoDistancia","AcertoCurtoAlcance",
    "DesarmarArmadilha","Esquivar","Furtividade","Iniciativa",
    "MontariaDirecao","Roubo","AcertoMagico","IdentificarCriatura",
    "Investigacao","LerManuscrito","Medicina","PrepararEstrategia",
    "Profissao","ResistenciaMental","DetectarMagia","DanoMagico",
    "Historia","Natureza","PerceberMentira","Percepcao",
    "Religiao","Sobrevivencia","Atuar","Discurso",
    "Intimidar","Mentir","Seducao","ResistenciaCansaco",
    "ResistirVeneno","SegurarFolego","SuporteFrioCalor"
}

for _, nome in ipairs(pericias) do
    local total = n(sheet[nome .. "1"]) + n(sheet[nome .. "2"])

    local ativo = sheet[nome .. "_ativo"]
    if ativo == 1 or ativo == true or ativo == "true" then
        total = total + prof
    end

    -- bÃ´nus por HB
    if nome == "AcertoCurtoAlcance" then
        total = total + bonusAcertoCurto

    elseif nome == "AcertoDistancia" then
        total = total + bonusAcertoLongo

    elseif nome == "AcertoMagico" then
        total = total + bonusAcertoMagico

    elseif nome == "ResistenciaMental" then
        total = total + bonusResistenciaMental
    end

    -- penalidade por exaustão
    total = total + n(sheet.Exaustao)

    -- salva resultado final
    sheet[nome .. "Total"] = total
end

    --------------------------------------------------
    -- ATRIBUTO PRINCIPAL
    --------------------------------------------------

    local atributoPrincipal = sheet.AtributoPrincipal
    local valorPrincipal = 0

    if atributoPrincipal == "FOR" then
        valorPrincipal = n(sheet.ForcaTotal)
    elseif atributoPrincipal == "DES" then
        valorPrincipal = n(sheet.DestrezaTotal)
    elseif atributoPrincipal == "CON" then
        valorPrincipal = n(sheet.ConstituicaoTotal)
    elseif atributoPrincipal == "INT" then
        valorPrincipal = n(sheet.InteligenciaTotal)
    elseif atributoPrincipal == "SAB" then
        valorPrincipal = n(sheet.SabedoriaTotal)
    elseif atributoPrincipal == "CAR" then
        valorPrincipal = n(sheet.CarismaTotal)
    end

    --------------------------------------------------
    -- BASES
    --------------------------------------------------

    local rank = RankDB and RankDB[sheet.Rank] or {hp = 0, pp = 0, atributos = 0}
    local classBonus = ClassHP and ClassHP[sheet.Classe] or 0
    local AtributosRank = rank.atributos
    local AtributosNivel = 0

    if level >= 4 then AtributosNivel = AtributosNivel + 3 end
    if level >= 6 then AtributosNivel = AtributosNivel + 3 end
    if level >= 8 then AtributosNivel = AtributosNivel + 3 end
    if level >= 12 then AtributosNivel = AtributosNivel + 3 end
    if level >= 14 then AtributosNivel = AtributosNivel + 3 end
    if level >= 16 then AtributosNivel = AtributosNivel + 3 end
    if level >= 18 then AtributosNivel = AtributosNivel + 3 end
    local bonusPP = 0
    local bonusRD = 0
    local BonusAtributo = 0

    local function temHB(hb)
        return sheet.HB1 == hb
            or sheet.HB2 == hb
            or sheet.HB3 == hb
            or sheet.HB4 == hb
    end

    local bonusHP = 0
    local bonusCA = 0
    

    if temHB("ROBUSTO") then
        bonusHP = bonusHP + (level * 3)
    end
        if temHB("RECUPERACAO_ARCANA") then
        bonusPP = bonusPP + math.min(level, 10)
    end
    
    if temHB("OSSOS_DENSOS") then
        bonusRD = bonusRD + 3
    end

    if temHB("PELE_ENDURECIDA") then
        bonusCA = bonusCA + 1
    end

    if temHB("APRIMORAMENTO_DE_ATRIBUTO") then
        BonusAtributo = BonusAtributo + 3
    end

    

    --------------------------------------------------
    -- RESULTADOS FINAIS
    --------------------------------------------------

    sheet.CaPersonagem = ca + math.floor(valorPrincipal / 2) + 8 + bonusCA
    sheet.RdPersonagem = rd + bonusRD

    sheet.HpPersonagem =
        hp +
        rank.hp +
        (classBonus * level) +
        (sheet.ConstituicaoTotal * level) +
        bonusHP

    sheet.PpPersonagem =
        pp +
        rank.pp +
        (level * 2) +
    bonusPP

    local gastoAtributos =
    n(sheet.ForcaValor) +
    n(sheet.DestrezaValor) +
    n(sheet.ConstituicaoValor) +
    n(sheet.InteligenciaValor) +
    n(sheet.SabedoriaValor) +
    n(sheet.CarismaValor)

    sheet.PontosRestantes =
    (AtributosRank + AtributosNivel + BonusAtributo)
    - gastoAtributos

    sheet.DanoPersonagem = dano
    sheet.CuraPersonagem = cura
end


--------------------------------------------------
-- INIT
--------------------------------------------------

function onInit()
    if self and self.sheet then
        recalcularDefesa(self.sheet)
    end
end

]]></script>

<event name="onChange"><![CDATA[
    recalcularDefesa(self.sheet)
]]></event>

</dataLink>





