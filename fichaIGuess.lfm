<button text="✚" top="520" left="20" width="22" height="22" name="labDesc">

    <event name="onClick">
        local frame=self:findControlByName("popAtributos");
        if frame then frame.visible=not frame.visible; if frame.visible then 
        frame.left=15; frame.top=510; end;
        else showMessage("Ops, bug... Nao encontrei o frame"); end;
    </event>

</button>







