                CWNA_dragSlotInventario(sheet, "Bota", drag)
            ]]></event>
            <event name="onStartDrop"><![CDATA[
                CWNA_registrarDropSlotInventario(drop, drag, sheet, "Bota", self)
            ]]></event>
            <image field="ImagemBota"
                   left="0" top="0"
                   width="84" height="88"
                   style="stretch"
                   hitTest="true">
                <event name="onStartDrag"><![CDATA[
                    CWNA_dragSlotInventario(sheet, "Bota", drag)
                ]]></event>
                <event name="onStartDrop"><![CDATA[
                    CWNA_registrarDropSlotInventario(drop, drag, sheet, "Bota", self)
                ]]></event>
            </image>
        </rectangle>

        <!-- ÃREA LISTA -->
        <rectangle align="client" color="#00000000" hitTest="true">
            <event name="onStartDrop"><![CDATA[
                drop:addAction("cwnaSlotEquipado", function(info)
                    if info ~= nil then
                        CWNA_desequiparSlotInventario(sheet, info.slot)
                    end
                end)

                if x >= 148 and x <= 386 and y >= 68 and y <= 518 then
                    CWNA_registrarDropPotionBoneco(drop, drag, sheet, self)
                end
            ]]></event>

            <!-- BARRA SUPERIOR -->
            <rectangle left="20" top="566" width="855" height="30" color="#00000000">

                <button left="100" top="4" width="30" text="✚">
                    <event name="onClick"><![CDATA[
                        local lista = self.rclMagias2
                        if lista == nil then return end

                        local node = self.sheet and self.sheet.magias2 or lista.node

                        if contarItensReaisInventario(node) >= 60 then
                            showMessage("Limite mÃ¡ximo de 60 itens.")
                            return
                        end

                        local novoItem = procurarPrimeiroSlotVazioInventario(node)

                        if novoItem == nil then
                            CWNA_inicializarSlotsInventario(self.sheet, lista)
                            node = self.sheet and self.sheet.magias2 or lista.node
                            novoItem = procurarPrimeiroSlotVazioInventario(node)
                        end

                        if novoItem == nil then
                            showMessage("Nenhum slot vazio disponÃ­vel.")
                            return
                        end

                        novoItem.slotVazio = nil
                        novoItem.uidInventario = tostring(os.time()) .. "_" .. tostring(math.random(100000, 999999))
                        novoItem.imagemestilo2 = "https://blob.firecast.com.br/blobs/HHEWWGHO_4452746/itens.png"
                        novoItem.quantidade = 1

                        lista:sort()

                        -- ATUALIZA STATUS DA FICHA
                        recalcularDefesa(self.sheet)
                    ]]></event>
                </button>

                <label left="20" top="6"
                       text="ADICIONAR"
                       fontStyle="bold"
                       fontFamily="Constantia"/>

                
            </rectangle>

            <!-- LISTA -->
            <recordList align="client"
                        layout="horizontalTiles"
                        name="rclMagias2"
                        field="magias2"
                        templateForm="templateMagias2"
                        margins="{left = 25, right = 13, top = 602, bottom = 15}">

                <event name="onCompare"><![CDATA[
                    local ordemA = tonumber(nodeA.ordemInventario) or 999999
                    local ordemB = tonumber(nodeB.ordemInventario) or 999999

                    if ordemA > ordemB then
                        return 1;
                    elseif ordemA < ordemB then
                        return -1;
                    else
                        local uidA = tostring(nodeA.uidInventario or "")
                        local uidB = tostring(nodeB.uidInventario or "")

                        if uidA > uidB then
                            return 1;
                        elseif uidA < uidB then
                            return -1;
                        else
                            return 0;
                        end;
                    end;
                ]]></event>

            </recordList>

            <rectangle name="avisoSlotErradoInventario"
                       left="100" top="203"
