<rectangle left="230" top="571" width="44" height="22" color="#131313">

    <edit
    name="edtOuro"
    field="OuroPersonagem"
    align="client"
    horzTextAlign="center"
    type="number"
    max="99999"
    fontColor="white"
    enabled="false"/>

    <dataLink field="OuroPersonagem" defaultValue="0"/>

</rectangle>


<rectangle left="314" top="571" width="44" height="22" color="#131313">

    <edit
    name="edtPrata"
    field="PrataPersonagem"
    align="client"
    horzTextAlign="center"
    type="number"
    max="99999"
    fontColor="white"
    enabled="false"/>

    <dataLink field="PrataPersonagem" defaultValue="0"/>

</rectangle>


<button text="🔒" left="359" top="571" width="22" height="22">
    <event name="onClick"><![CDATA[

        Dialogs.inputQuery(
            "Senha",
            "senha ADM:",
            "",

            function(senha)

                if senha == nil then
                    return
                end


                if senha ~= "151289" then
                    showMessage("Senha incorreta!")
                    return
                end


                local ouroEdit = self:findControlByName("edtNovoOuro")
                local prataEdit = self:findControlByName("edtNovaPrata")
                local painel = self:findControlByName("PainelEditarDinheiro")


                ouroEdit.text = tostring(sheet.OuroPersonagem or 0)
                prataEdit.text = tostring(sheet.PrataPersonagem or 0)


                painel.visible = true


            end
        )


    ]]></event>
</button>

<rectangle name="PainelEditarDinheiro"
    left="400"
    top="300"
    width="220"
    height="180"
    color="#111111"
    visible="false">


    <!-- BORDA SUPERIOR -->
    <rectangle
        left="0"
        top="0"
        width="220"
        height="30"
        color="#3A3A3A">

        <label
            left="0"
            top="5"
            width="220"
            height="20"
            text="GERENCIAR MOEDAS"
            fontColor="white"
            horzTextAlign="center"/>

    </rectangle>



    <!-- LINHA DIVISORIA -->
    <rectangle
        left="10"
        top="35"
        width="200"
        height="2"
        color="#C8A000"/>




    <!-- OURO -->

    <label
        left="20"
        top="55"
        width="80"
        height="20"
        text="🪙 Ouro:"
        fontColor="#FFD700"/>


    <edit
        name="edtNovoOuro"
        left="105"
        top="52"
        width="90"
        height="25"
        type="number"
        horzTextAlign="center"
        fontColor="white"/>




    <!-- PRATA -->

    <label
        left="20"
        top="90"
        width="80"
        height="20"
        text="⚪ Prata:"
        fontColor="#C0C0C0"/>


    <edit
        name="edtNovaPrata"
        left="105"
        top="87"
        width="90"
        height="25"
        type="number"
        horzTextAlign="center"
        fontColor="white"/>




    <!-- CADEADO -->

    <button
        name="btnPermitirEdicaoDinheiro"
        text="🔒"
        left="165"
        top="120"
        width="30"
        height="25">


        <event name="onClick"><![CDATA[


            local ouro = self:findControlByName("edtOuro")
            local prata = self:findControlByName("edtPrata")
            local botao = self:findControlByName("btnPermitirEdicaoDinheiro")



            if ouro == nil or prata == nil then

                showMessage("Erro: campos Ouro/Prata não encontrados.")
                return

            end




            if tostring(sheet.PermitirEditarDinheiro or "true") == "true" then


                sheet.PermitirEditarDinheiro = "false"


                ouro.enabled = false
                prata.enabled = false


                botao.text = "🔒"



            else


                sheet.PermitirEditarDinheiro = "true"


                ouro.enabled = true
                prata.enabled = true


                botao.text = "🔓"



            end



        ]]></event>


    </button>





    <!-- BOTAO CONFIRMAR -->

    <button
        name="btnConfirmarDinheiro"
        text="CONFIRMAR"
        left="55"
        top="150"
        width="110"
        height="22">


        <event name="onClick"><![CDATA[


            local ouroEdit = self:findControlByName("edtNovoOuro")
            local prataEdit = self:findControlByName("edtNovaPrata")


            local ouro = tonumber(ouroEdit.text)
            local prata = tonumber(prataEdit.text)



            if ouro == nil or prata == nil then

                showMessage("Digite valores vÃ¡lidos.")
                return

            end



            if ouro < 0 then ouro = 0 end
            if prata < 0 then prata = 0 end


            if ouro > 99999 then ouro = 99999 end
            if prata > 99999 then prata = 99999 end



            sheet.OuroPersonagem = ouro
            sheet.PrataPersonagem = prata



            local painel = self:findControlByName("PainelEditarDinheiro")

            painel.visible = false



        ]]></event>


    </button>



</rectangle>

<dataLink field="PermitirEditarDinheiro" defaultValue="true">
    <event name="onChange"><![CDATA[
        local ouro = self:findControlByName("edtOuro")
        local prata = self:findControlByName("edtPrata")
        local botao = self:findControlByName("btnPermitirEdicaoDinheiro")
        local liberado = tostring(self.sheet.PermitirEditarDinheiro or "true") == "true"

        if ouro ~= nil then
            ouro.enabled = liberado
        end

        if prata ~= nil then
            prata.enabled = liberado
        end

        if botao ~= nil then
            botao.text = liberado and "🔓" or "🔒"
        end
    ]]></event>
</dataLink>
        

    </layout>

</tab>

                <tab title="              SKILLS              .">
                    <image width="895" height="1158"
                    url="Frames/SKILLS.png"/>

                    <rectangle align="top" height="30" xradius="5" yradius="5" cornerType="round" color="#21212100" margins="{left=20, right=20}">
									
									<button left="225" top="28" text="✚" width="30" onClick='self.rclMagias:append();'/>
								</rectangle>
								
								<recordList align="client" layout="horizontalTiles" name="rclMagias" field="magias" templateForm="templateMagias" 
								onSelect="self.rclMagias:sort();" onItemAdded="self.rclMagias:sort();" onItemRemoved="self.rclMagias:sort();" margins="{left = 30, right = -20, top = 35, bottom = 30}">
									<event name="onCompare">
									<![CDATA[               
										if(nodeA.elemMagia == nodeB.elemMagia) then
										
											if (nodeA.lvlMagia or 0) > (nodeB.lvlMagia or 0) then
													return 1;
											elseif (nodeA.lvlMagia or 0) < (nodeB.lvlMagia or 0) then
													return -1;
											else   
													return Utils.compareStringPtBr(nodeA.nomeMagia, nodeB.nomeMagia);
											end;
										
										elseif(nodeA.elemMagia == "Water" and 
										(nodeB.elemMagia == "Air" or nodeB.elemMagia == "Fire" or nodeB.elemMagia == "Earth" or nodeB.elemMagia == "Void" or nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Air" and 
										(nodeB.elemMagia == "Fire" or nodeB.elemMagia == "Earth" or nodeB.elemMagia == "Void" or nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Fire" and 
										(nodeB.elemMagia == "Earth" or nodeB.elemMagia == "Void" or nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Earth" and 
										(nodeB.elemMagia == "Void" or nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Void" and 
										(nodeB.elemMagia == "Universal")) then
											return -1;
										elseif(nodeA.elemMagia == "Universal" and 
										(nodeB.elemMagia == "Water" or nodeB.elemMagia == "Air" or nodeB.elemMagia == "Fire" or nodeB.elemMagia == "Earth" or nodeB.elemMagia == "Void")) then
											return 1;
										elseif(nodeA.elemMagia == "Void" and 
										(nodeB.elemMagia == "Water" or nodeB.elemMagia == "Air" or nodeB.elemMagia == "Fire" or nodeB.elemMagia == "Earth")) then
											return 1;
										elseif(nodeA.elemMagia == "Earth" and 
										(nodeB.elemMagia == "Water" or nodeB.elemMagia == "Air" or nodeB.elemMagia == "Fire")) then
											return 1;
										elseif(nodeA.elemMagia == "Fire" and 
										(nodeB.elemMagia == "Water" or nodeB.elemMagia == "Air")) then
											return 1;
										elseif(nodeA.elemMagia == "Air" and 
										(nodeB.elemMagia == "Water")) then
											return 1;
										end;
									]]>
									</event>
								</recordList>
                </tab>

                <tab title="            DIÁRIO            .">
                    <image width="895" height="1158"
                    url="Frames/fundo_branco.png"/>
                    <richEdit align="client" field="background2" backgroundColor="#272727" defaultFontColor="white" margins="{left=15, top=20, right=15, bottom=20}"/>
                </tab>

                <tab title="          ANOTAÇÕES          .">
                    <image width="895" height="1158"
                    url="Frames/fundo_branco.png"/>
